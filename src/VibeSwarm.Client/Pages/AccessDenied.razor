@page "/access-denied"
@attribute [AllowAnonymous]

<PageTitle>Access Denied - VibeSwarm</PageTitle>

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <Card Title="Access Denied" Icon="shield-lock" Class="shadow border-warning" HeaderClass="bg-warning text-dark">
                <p class="lead">You don't have permission to access this resource.</p>

                <p class="text-muted">
                    This could happen because:
                </p>
                <ul class="text-muted">
                    <li>You're not logged in</li>
                    <li>Your session has expired</li>
                    <li>You don't have the required permissions</li>
                </ul>

                <div class="mt-4">
                    <AuthorizeView>
                        <Authorized>
                            <p>You are currently logged in as <strong>@context.User.Identity?.Name</strong>.</p>
                            <ActionButton Icon="house" Text="Go to Home Page" Style="ActionButton.ButtonStyle.Primary"
                                          OnClick="@(() => NavigationManager.NavigateTo("/"))" />
                        </Authorized>
                        <NotAuthorized>
                            <p>Please log in to continue.</p>
                            <ActionButton Icon="box-arrow-in-right" Text="Log In" Style="ActionButton.ButtonStyle.Primary"
                                          OnClick="@(() => NavigationManager.NavigateTo($"/login?returnUrl={Uri.EscapeDataString(ReturnUrl ?? "/")}", forceLoad: true))" />
                        </NotAuthorized>
                    </AuthorizeView>
                </div>
            </Card>
        </div>
    </div>
</div>

@code {
    [SupplyParameterFromQuery]
    public string? ReturnUrl { get; set; }

    [Inject]
    private NavigationManager NavigationManager { get; set; } = default!;
}