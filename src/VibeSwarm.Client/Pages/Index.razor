@page "/"
@attribute [Authorize]
@inject IProviderService ProviderService
@inject ICommonProviderSetupService CommonProviderSetupService
@inject IProjectService ProjectService
@inject IVersionControlService VersionControlService
@inject HttpProviderService HttpProviderService
@inject NavigationManager NavigationManager
@inject IIdeaService IdeaService
@implements IAsyncDisposable
@using System.Threading
@using Microsoft.AspNetCore.SignalR.Client
@using VibeSwarm.Shared.Models

<PageHeader Title="Dashboard" Subtitle="Your distributed agent job management system" />

<div class="row g-3">
    @if (RunningDashboardJobs.Any())
    {
        <div class="col-12">
            <DashboardRunningJobsSection Items="@RunningDashboardJobs" />
        </div>
    }

    @if (IdeasStatus is not null &&
        (IdeasStatus.TotalUnprocessedIdeas > 0 || IdeasStatus.ProjectsCurrentlyProcessing > 0))
    {
        <div class="col-12">
            <section>
                <div class="d-flex flex-column flex-sm-row justify-content-between align-items-sm-center gap-2 mb-3">
                    <h5 class="mb-0 fw-semibold text-truncate">
                        <i class="bi bi-lightbulb me-2 opacity-75"></i>Ideas Processing
                    </h5>
                    <div class="d-flex flex-column flex-sm-row align-items-stretch align-items-sm-center gap-2 align-self-stretch align-self-sm-auto">
                        @if (IdeasStatus.ProjectsCurrentlyProcessing > 0)
                        {
                            <div class="d-flex flex-column flex-sm-row align-items-stretch align-items-sm-center gap-2">
                                <span class="badge bg-success-subtle text-success-emphasis d-inline-flex align-items-center justify-content-center justify-content-sm-start gap-1 text-wrap align-self-start align-self-sm-auto">
                                    <span class="spinner-border spinner-border-sm flex-shrink-0" style="width: 0.65rem; height: 0.65rem;" role="status"></span>
                                    @IdeasStatus.ProjectsCurrentlyProcessing project@(IdeasStatus.ProjectsCurrentlyProcessing != 1 ? "s" : "") processing
                                </span>
                                <button class="btn btn-sm btn-danger" @onclick="OnStopAllProcessing" disabled="@IsStoppingAll">
                                    @if (IsStoppingAll)
                                    {
                                        <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                                        <span>Stopping...</span>
                                    }
                                     else
                                     {
                                         <i class="bi bi-stop-fill me-1"></i>
                                         <span>Stop</span>
                                     }
                                 </button>
                             </div>
                         }
                         else if (IdeasStatus.TotalUnprocessedIdeas > 0 && !IsStartingAll)
                         {
                             <button class="btn btn-sm btn-success" @onclick="() => ShowStartAllModal = true">
                                 <i class="bi bi-play-fill me-1"></i>Start All Ideas
                                 <span class="badge bg-white text-success ms-1">@IdeasStatus.TotalUnprocessedIdeas</span>
                             </button>
                        }
                    </div>
                </div>

                @if (StartAllError is not null)
                {
                    <Alert Type="Alert.AlertType.Danger" Dismissible="true" OnDismiss="() => StartAllError = null">
                        @StartAllError
                    </Alert>
                }

                <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-2 g-lg-3">
                    @foreach (var project in IdeasStatus.Projects.Where(p => p.UnprocessedIdeas > 0 || p.IsProcessing))
                    {
                        <div class="col">
                            <div class="card border h-100">
                                <div class="card-body p-3 d-flex align-items-center gap-3">
                                    <div class="flex-grow-1 min-width-0">
                                        <div class="fw-medium text-truncate">@project.ProjectName</div>
                                        <small class="text-body-secondary">
                                            @project.UnprocessedIdeas idea@(project.UnprocessedIdeas != 1 ? "s" : "") remaining
                                        </small>
                                    </div>
                                    @if (project.IsProcessing)
                                    {
                                        <span class="badge bg-success-subtle text-success-emphasis flex-shrink-0">
                                            <span class="spinner-border spinner-border-sm" style="width: 0.5rem; height: 0.5rem;" role="status"></span>
                                            Running
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-body-secondary text-body-secondary flex-shrink-0">Queued</span>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </section>
        </div>
    }

    <div class="col-12">
        <DashboardJobAnalyticsSection />
    </div>

    <div class="col-12">
        <section>
            <div class="d-flex flex-column flex-sm-row justify-content-between align-items-sm-center gap-2 mb-3">
                <h5 class="mb-0 fw-semibold text-truncate">
                    <i class="bi bi-folder me-2 opacity-75"></i>Active Projects
                </h5>
                <div class="d-flex flex-wrap align-items-center gap-1 gap-sm-2">
                    <label for="dashboardProjectSort" class="small text-body-secondary mb-0">Sort by</label>
                    <InputSelect id="dashboardProjectSort" @bind-Value="SelectedProjectSort"
                                 class="form-select form-select-sm" style="width: auto; min-width: 9rem;">
                        <option value="@DashboardProjectSortOption.LastRan">Last ran</option>
                        <option value="@DashboardProjectSortOption.Name">Name</option>
                    </InputSelect>
                    <a href="/projects" class="btn btn-sm btn-secondary flex-shrink-0">View All</a>
                </div>
            </div>

            @if (IsLoading)
            {
                <LoadingSpinner />
            }
            else if (!SortedDashboardProjects.Any())
            {
                <EmptyState Icon="folder" Title="No projects yet"
                            Message="Create your first project to start running AI agent jobs.">
                    <a href="/projects" class="btn btn-sm btn-primary">
                        <i class="bi bi-plus-lg me-1"></i>Create Project
                    </a>
                </EmptyState>
            }
            else
            {
                <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-2 g-lg-3">
                    @foreach (var item in SortedDashboardProjects)
                    {
                        <div class="col">
                            <ProjectCard ProjectId="@item.Project.Id" Name="@item.Project.Name"
                                         Description="@item.Project.Description" WorkingPath="@item.Project.WorkingPath"
                                         GitHubRepository="@item.Project.GitHubRepository" CurrentBranch="@item.CurrentBranch"
                                         LatestJob="@item.LatestJob" CreatedAt="@item.Project.CreatedAt" />
                        </div>
                    }
                </div>
            }
        </section>
    </div>

    <div class="col-12">
        <section>
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="mb-0 fw-semibold text-truncate">
                    <i class="bi bi-cpu me-2 opacity-75"></i>Providers
                </h5>
                <a href="/providers" class="btn btn-sm btn-secondary flex-shrink-0">Manage</a>
            </div>

            @if (IsLoading)
            {
                <LoadingSpinner />
            }
            else if (!VisibleProviders.Any())
            {
                <EmptyState Icon="cpu" Title="@(HasConfiguredProviders ? "No active providers" : "No providers configured")"
                            Message="@(HasConfiguredProviders ? "Enable a provider to show it on the dashboard." : "Connect to AI coding agents like Claude Code CLI.")">
                    <a href="/providers" class="btn btn-sm btn-primary">
                        <i class="bi bi-plus-lg me-1"></i>@(HasConfiguredProviders ? "Manage Providers" : "Add Provider")
                    </a>
                </EmptyState>
            }
            else
            {
                <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-2 g-lg-3">
                    @foreach (var provider in VisibleProviders)
                    {
                        <div class="col">
                            <ProviderCard Name="@provider.Name" ProviderType="@provider.Type.ToString()"
                                          ConnectionMode="@provider.ConnectionMode.ToString()" IsEnabled="@provider.IsEnabled"
                                          CliVersion="@GetCliVersion(provider)" UsageSummary="@GetUsageSummary(provider.Id)" />
                        </div>
                    }
                </div>
            }
        </section>
    </div>
</div>

<ModalDialog @bind-IsVisible="ShowStartAllModal" Title="Start All Ideas" Icon="play-circle"
             Size="ModalDialog.ModalSize.Default" OnClose="() => ShowStartAllModal = false">
    <ChildContent>
        <p>
            Start processing ideas across <strong>@(IdeasStatus?.Projects.Count(p => p.UnprocessedIdeas > 0) ?? 0)</strong>
            project@(IdeasStatus?.Projects.Count(p => p.UnprocessedIdeas > 0) != 1 ? "s" : "")
            (<strong>@(IdeasStatus?.TotalUnprocessedIdeas ?? 0)</strong> total idea@(IdeasStatus?.TotalUnprocessedIdeas != 1 ? "s" : "")).
        </p>
        <p class="text-body-secondary small mb-0">
            Each idea will be converted to a job and queued for execution. You can stop processing at any time.
        </p>
        <div class="form-check mt-3">
            <input class="form-check-input" type="checkbox" id="dashboardAutoCommit" @bind="StartAllAutoCommit" />
            <label class="form-check-label" for="dashboardAutoCommit">
                <i class="bi bi-git me-1"></i>
                Auto-commit changes when jobs complete
            </label>
        </div>
    </ChildContent>
    <FooterContent>
        <button type="button" class="btn btn-secondary" @onclick="() => ShowStartAllModal = false" disabled="@IsStartingAll">
            Cancel
        </button>
        <button type="button" class="btn btn-success" @onclick="OnStartAllProcessing" disabled="@IsStartingAll">
            @if (IsStartingAll)
            {
                <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                <span>Starting...</span>
            }
            else
            {
                <i class="bi bi-play-fill me-1"></i>
                <span>Start Processing</span>
            }
        </button>
    </FooterContent>
</ModalDialog>

@code {
    private List<Provider> AllProviders { get; set; } = new();
    private List<DashboardProjectInfo> DashboardProjects { get; set; } = new();
    private List<DashboardRunningJobInfo> RunningDashboardJobs { get; set; } = new();
    private Dictionary<Guid, ProviderUsageSummary> UsageSummaries { get; set; } = new();
    private Dictionary<ProviderType, string> InstalledVersionsByType { get; set; } = new();
    private DashboardProjectSortOption SelectedProjectSort { get; set; } = DashboardProjectSortOption.LastRan;
    private bool IsLoading { get; set; } = true;
    private bool IsRefreshingDashboardData { get; set; }
    private bool PendingDashboardRefresh { get; set; }
    private HubConnection? HubConnection { get; set; }
    private CancellationTokenSource? SignalRCts { get; set; }
    private bool HasConfiguredProviders => AllProviders.Any();
    private IReadOnlyList<Provider> VisibleProviders => AllProviders
        .Where(provider => provider.IsEnabled)
        .ToList();
    private IReadOnlyList<DashboardProjectInfo> SortedDashboardProjects
        => DashboardProjectOrdering.Sort(DashboardProjects, SelectedProjectSort);

    private GlobalIdeasProcessingStatus? IdeasStatus { get; set; }
    private bool ShowStartAllModal { get; set; }
    private bool StartAllAutoCommit { get; set; }
    private bool IsStartingAll { get; set; }
    private bool IsStoppingAll { get; set; }
    private string? StartAllError { get; set; }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var providersTask = ProviderService.GetAllAsync();
            var usageTask = HttpProviderService.GetAllUsageSummariesAsync();
            var commonProviderStatusesTask = CommonProviderSetupService.GetStatusesAsync();
            var dashboardDataTask = LoadDashboardProjectsAsync();
            var ideasStatusTask = LoadIdeasStatusAsync();

            await Task.WhenAll(providersTask, usageTask, commonProviderStatusesTask, dashboardDataTask, ideasStatusTask);

            AllProviders = (await providersTask).ToList();
            UsageSummaries = await usageTask;
            InstalledVersionsByType = (await commonProviderStatusesTask)
                .Where(status => !string.IsNullOrWhiteSpace(status.InstalledVersion))
                .GroupBy(status => status.ProviderType)
                .ToDictionary(group => group.Key, group => group.First().InstalledVersion!);
        }
        finally
        {
            IsLoading = false;
        }
    }

    protected override Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _ = InitializeSignalRSafeAsync();
        }

        return Task.CompletedTask;
    }

    private string? GetCliVersion(Provider provider)
    {
        if (InstalledVersionsByType.TryGetValue(provider.Type, out var installedVersion))
        {
            return installedVersion;
        }

        return UsageSummaries.TryGetValue(provider.Id, out var summary) ? summary.CliVersion : null;
    }

    private ProviderUsageSummary? GetUsageSummary(Guid providerId)
    {
        return UsageSummaries.TryGetValue(providerId, out var summary) ? summary : null;
    }

    private async Task FetchBranchInfoAsync()
    {
        var branchTasks = DashboardProjects.Select(async item =>
        {
            try
            {
                if (Directory.Exists(item.Project.WorkingPath) &&
                    await VersionControlService.IsGitRepositoryAsync(item.Project.WorkingPath))
                {
                    item.CurrentBranch = await VersionControlService.GetCurrentBranchAsync(item.Project.WorkingPath);
                }
            }
            catch
            {
                // Silently ignore errors when fetching branch info
            }
        });

        await Task.WhenAll(branchTasks);
    }

    private async Task LoadDashboardProjectsAsync()
    {
        var projectsTask = ProjectService.GetRecentWithLatestJobAsync(10);
        var runningJobsTask = ProjectService.GetDashboardRunningJobsAsync();

        await Task.WhenAll(projectsTask, runningJobsTask);

        DashboardProjects = (await projectsTask).ToList();
        RunningDashboardJobs = (await runningJobsTask).ToList();

        await FetchBranchInfoAsync();
    }

    private async Task InitializeSignalRSafeAsync()
    {
        try
        {
            SignalRCts = new CancellationTokenSource();
            using var timeoutCts = new CancellationTokenSource(TimeSpan.FromSeconds(10));
            using var linkedCts = CancellationTokenSource.CreateLinkedTokenSource(SignalRCts.Token, timeoutCts.Token);

            await InitializeSignalRAsync(linkedCts.Token);
        }
        catch (OperationCanceledException)
        {
        }
        catch (Exception)
        {
        }
    }

    private async Task InitializeSignalRAsync(CancellationToken cancellationToken)
    {
        HubConnection = new HubConnectionBuilder()
            .WithUrl(NavigationManager.ToAbsoluteUri("/hubs/job"))
            .WithAutomaticReconnect([TimeSpan.Zero, TimeSpan.FromSeconds(2), TimeSpan.FromSeconds(5), TimeSpan.FromSeconds(10)])
            .Build();

        HubConnection.On<string, string>("JobStatusChanged", async (_, _) =>
        {
            await QueueDashboardRefreshAsync();
        });

        HubConnection.On<string, string>("JobCreated", async (_, _) =>
        {
            await QueueDashboardRefreshAsync();
        });

        HubConnection.On<string, string>("JobDeleted", async (_, _) =>
        {
            await QueueDashboardRefreshAsync();
        });

        HubConnection.On<string, bool, string?>("JobCompleted", async (_, _, _) =>
        {
            await QueueDashboardRefreshAsync();
        });

        HubConnection.On("JobListChanged", async () =>
        {
            await QueueDashboardRefreshAsync();
        });

        HubConnection.On<string, bool>("IdeasProcessingStateChanged", async (_, _) =>
        {
            await QueueDashboardRefreshAsync();
        });

        HubConnection.On<string, string, DateTime>("JobActivityUpdated", async (jobId, activity, timestamp) =>
        {
            if (!Guid.TryParse(jobId, out var parsedJobId))
            {
                return;
            }

            var runningJob = RunningDashboardJobs.FirstOrDefault(item => item.Job.Id == parsedJobId);
            if (runningJob is null)
            {
                return;
            }

            runningJob.Job.CurrentActivity = activity;
            await InvokeAsync(StateHasChanged);
        });

        HubConnection.Reconnected += async _ =>
        {
            if (HubConnection is null)
            {
                return;
            }

            await HubConnection.InvokeAsync("SubscribeToJobList");
            await QueueDashboardRefreshAsync();
        };

        await HubConnection.StartAsync(cancellationToken);
        await HubConnection.InvokeAsync("SubscribeToJobList");
    }

    private async Task QueueDashboardRefreshAsync()
    {
        await InvokeAsync(RefreshDashboardProjectsSafelyAsync);
    }

    private async Task RefreshDashboardProjectsSafelyAsync()
    {
        if (IsRefreshingDashboardData)
        {
            PendingDashboardRefresh = true;
            return;
        }

        do
        {
            PendingDashboardRefresh = false;
            IsRefreshingDashboardData = true;

            try
            {
                await Task.WhenAll(LoadDashboardProjectsAsync(), LoadIdeasStatusAsync());
                await InvokeAsync(StateHasChanged);
            }
            finally
            {
                IsRefreshingDashboardData = false;
            }
        }
        while (PendingDashboardRefresh);
    }

    private async Task LoadIdeasStatusAsync()
    {
        try
        {
            IdeasStatus = await IdeaService.GetGlobalProcessingStatusAsync();
        }
        catch
        {
            // Don't fail the dashboard if ideas status fails to load
        }
    }

    private async Task OnStartAllProcessing()
    {
        IsStartingAll = true;
        StartAllError = null;
		try
		{
			await IdeaService.StartAllProcessingAsync(new IdeaProcessingOptions
			{
				AutoCommitMode = StartAllAutoCommit ? AutoCommitMode.CommitOnly : AutoCommitMode.Off
			});
			ShowStartAllModal = false;
			StartAllAutoCommit = false;
			await LoadIdeasStatusAsync();
        }
        catch (Exception ex)
        {
            StartAllError = $"Failed to start processing: {ex.Message}";
        }
        finally
        {
            IsStartingAll = false;
        }
    }

    private async Task OnStopAllProcessing()
    {
        IsStoppingAll = true;
        StartAllError = null;
        try
        {
            await IdeaService.StopAllProcessingAsync();
            await LoadIdeasStatusAsync();
        }
        catch (Exception ex)
        {
            StartAllError = $"Failed to stop processing: {ex.Message}";
        }
        finally
        {
            IsStoppingAll = false;
        }
    }

    public async ValueTask DisposeAsync()
    {
        SignalRCts?.Cancel();
        SignalRCts?.Dispose();

        if (HubConnection is not null)
        {
            await HubConnection.DisposeAsync();
        }
    }
}
