@page "/inference"
@attribute [Authorize]
@inject IInferenceProviderService InferenceProviderService
@inject IInferenceService InferenceService
@inject NotificationService NotificationService

<PageHeader Title="Inference">
	<Actions>
		<ActionButton Icon="plus" Text="Add" Style="ActionButton.ButtonStyle.Primary" OnClick="ShowAddModal" />
	</Actions>
</PageHeader>

@if (_isLoading)
{
	<LoadingSpinner />
}
else if (!_providers.Any())
{
	<EmptyState Icon="hdd-network" Title="No inference providers"
				Message="Set up Ollama, Grok, or another inference provider for AI tasks like idea generation and commit messages." />
}
else
{
	<div class="list-group mb-4">
		@foreach (var provider in _providers)
		{
			var isHealthy = _healthStatus.GetValueOrDefault(provider.Id);
			var healthChecked = _healthChecked.Contains(provider.Id);
			<div class="list-group-item d-flex flex-column flex-md-row align-items-md-start gap-2 gap-md-3 p-3 hover-bg-tertiary">
				<div class="flex-grow-1 min-width-0">
					<div class="d-flex align-items-center gap-2 flex-wrap">
						<span class="fw-semibold">
							<i class="bi @GetProviderIcon(provider.ProviderType) me-1"></i>@provider.Name
						</span>
						<span class="badge bg-body-tertiary text-body-secondary">@provider.ProviderType</span>
						@if (isHealthy)
						{
							<span class="badge bg-success-subtle text-success-emphasis">
								<i class="bi bi-check-circle me-1"></i>Connected
							</span>
						}
						else if (healthChecked)
						{
							<span class="badge bg-danger-subtle text-danger-emphasis">
								<i class="bi bi-x-circle me-1"></i>Disconnected
							</span>
						}
						@if (!provider.IsEnabled)
						{
							<span class="badge bg-warning-subtle text-warning-emphasis">Disabled</span>
						}
					</div>
					<div class="small text-body-secondary mt-1 font-monospace text-truncate">@provider.Endpoint</div>
				</div>
				<div class="d-flex flex-wrap gap-2 flex-shrink-0 align-items-center">
					<ActionButton Icon="pencil" Text="Edit" Size="ActionButton.ButtonSize.Small" HideTextOnMobile="true"
								  OnClick="@(() => EditProvider(provider))" />
					<ActionButton Icon="trash" Text="Delete" Size="ActionButton.ButtonSize.Small"
								  Style="ActionButton.ButtonStyle.Danger" HideTextOnMobile="true"
								  OnClick="@(() => ShowDeleteConfirmation(provider))" />
				</div>
			</div>
		}
	</div>
}

@if (_providers.Any())
{
	<div class="card">
		<div class="card-body">
			<h6 class="fw-semibold mb-3">
				<i class="bi bi-chat-square-dots me-2"></i>Test Inference
			</h6>
			<div class="row g-3 mb-3">
				<div class="col-12 col-lg-3">
					<label for="testProvider" class="form-label">Provider</label>
					<select id="testProvider" class="form-select" value="@(_testProviderId?.ToString() ?? string.Empty)" @onchange="OnTestProviderChanged">
						@foreach (var provider in _providers.Where(p => p.IsEnabled))
						{
							<option value="@provider.Id">@provider.Name</option>
						}
					</select>
				</div>
				<div class="col-12 col-lg-4">
					<label for="testModel" class="form-label">Model</label>
					<select id="testModel" class="form-select" @bind="_selectedTestModelId" disabled="@(_isLoadingTestModels || !_testModels.Any())">
						<option value="">@(_isLoadingTestModels ? "Loading..." : "Use provider default model")</option>
						@foreach (var model in _testModels)
						{
							<option value="@model.ModelId">
								@(model.DisplayName ?? model.ModelId)
								@if (model.IsDefault)
								{
									@(" (Default)")
								}
							</option>
						}
					</select>
					<div class="form-text">@GetTestModelHelpText()</div>
				</div>
				<div class="col-12 col-lg-5">
					<label for="testPrompt" class="form-label">Prompt</label>
					<textarea id="testPrompt" class="form-control font-monospace" rows="3"
						@bind="_testPrompt" placeholder="Enter a test prompt..."></textarea>
				</div>
			</div>
			<button type="button" class="btn btn-primary"
				@onclick="TestGeneration"
				disabled="@(_isTesting || string.IsNullOrWhiteSpace(_testPrompt))">
				@if (_isTesting)
				{
					<span class="spinner-border spinner-border-sm me-1" role="status"></span>
					<span>Sending...</span>
				}
				else
				{
					<i class="bi bi-send me-1"></i>
					<span>Send</span>
				}
			</button>
			@if (_testResponse != null)
			{
				<hr />
				@if (_testResponse.Success)
				{
					<div class="d-flex flex-wrap gap-3 small text-body-secondary mb-2">
						@if (!string.IsNullOrEmpty(_testResponse.ModelUsed))
						{
							<span><i class="bi bi-cpu me-1"></i>@_testResponse.ModelUsed</span>
						}
						@if (_testResponse.DurationMs.HasValue)
						{
							<span><i class="bi bi-clock me-1"></i>@((_testResponse.DurationMs.Value / 1000.0).ToString("F2"))s</span>
						}
						@if (_testResponse.CompletionTokens.HasValue)
						{
							<span><i class="bi bi-hash me-1"></i>@_testResponse.CompletionTokens tokens</span>
						}
					</div>
					<pre class="p-3 rounded bg-body-secondary small mb-0 white-space-pre-wrap" style="word-break:break-word;">@_testResponse.Response</pre>
				}
				else
				{
					<Alert Type="Alert.AlertType.Danger" Message="@(_testResponse.Error ?? "An unknown error occurred.")" />
				}
			}
		</div>
	</div>
}

<InferenceProviderModal @bind-IsVisible="_showModal" EditProvider="@_editingProvider"
						OnSaved="HandleProviderSaved" OnCancelled="HandleModalCancelled" OnClosed="HandleModalClosed" />

<ConfirmationModal @bind-IsVisible="_showDeleteModal" Title="Delete Provider"
				   Message="@($"Are you sure you want to remove {_providerToDelete?.Name}?")" SubMessage="This action cannot be undone."
				   ConfirmText="Delete" ButtonClass="btn-danger" IsProcessing="_isDeleting" OnConfirm="ConfirmDelete"
				   OnCancel="CancelDelete" />

@code {
	private List<InferenceProvider> _providers = [];
	private Dictionary<Guid, bool> _healthStatus = new();
	private HashSet<Guid> _healthChecked = new();
	private bool _isLoading = true;

	// Modal state
	private bool _showModal;
	private InferenceProvider? _editingProvider;

	// Delete state
	private bool _showDeleteModal;
	private InferenceProvider? _providerToDelete;
	private bool _isDeleting;

	// Test inference state
	private Guid? _testProviderId;
	private List<InferenceModel> _testModels = [];
	private string _selectedTestModelId = string.Empty;
	private string _testPrompt = "Say hello in one sentence.";
	private bool _isTesting;
	private bool _isLoadingTestModels;
	private InferenceResponse? _testResponse;

	protected override async Task OnInitializedAsync()
	{
		await LoadProviders();
	}

	private async Task LoadProviders(Guid? preferredProviderId = null)
	{
		_isLoading = true;
		try
		{
			_providers = (await InferenceProviderService.GetAllAsync()).ToList();
			var enabledProviders = _providers
				.Where(p => p.IsEnabled)
				.ToList();
			if (preferredProviderId.HasValue && enabledProviders.Any(p => p.Id == preferredProviderId.Value))
			{
				_testProviderId = preferredProviderId.Value;
			}
			else if (!_testProviderId.HasValue || !enabledProviders.Any(p => p.Id == _testProviderId.Value))
			{
				_testProviderId = enabledProviders.FirstOrDefault()?.Id;
			}

			await LoadTestModelsAsync();

			foreach (var provider in _providers)
			{
				_ = CheckHealth(provider);
			}
		}
		catch (Exception ex)
		{
			NotificationService.ShowError($"Failed to load inference providers: {ex.Message}");
		}
		finally
		{
			_isLoading = false;
		}
	}

	private async Task CheckHealth(InferenceProvider provider)
	{
		try
		{
			var result = await InferenceService.CheckHealthAsync(provider.Endpoint, provider.ProviderType);
			_healthStatus[provider.Id] = result.IsAvailable;
			_healthChecked.Add(provider.Id);
			await InvokeAsync(StateHasChanged);
		}
		catch
		{
			_healthStatus[provider.Id] = false;
			_healthChecked.Add(provider.Id);
		}
	}

	// Modal handlers

	private void ShowAddModal()
	{
		_editingProvider = null;
		_showModal = true;
	}

	private void EditProvider(InferenceProvider provider)
	{
		_editingProvider = provider;
		_showModal = true;
	}

	private async Task HandleProviderSaved(Guid? newProviderId)
	{
		_showModal = false;
		_editingProvider = null;
		_healthStatus.Clear();
		_healthChecked.Clear();
		await LoadProviders(newProviderId);
	}

	private void HandleModalCancelled()
	{
		_showModal = false;
		_editingProvider = null;
	}

	private void HandleModalClosed()
	{
		_showModal = false;
		_editingProvider = null;
		StateHasChanged();
	}

	// Delete handlers

	private void ShowDeleteConfirmation(InferenceProvider provider)
	{
		_providerToDelete = provider;
		_showDeleteModal = true;
	}

	private void CancelDelete()
	{
		_showDeleteModal = false;
		_providerToDelete = null;
	}

	private async Task ConfirmDelete()
	{
		if (_providerToDelete == null) return;

		_isDeleting = true;
		try
		{
			await InferenceProviderService.DeleteAsync(_providerToDelete.Id);
			_providers.Remove(_providerToDelete);
			_healthStatus.Remove(_providerToDelete.Id);
			_healthChecked.Remove(_providerToDelete.Id);

			if (_testProviderId == _providerToDelete.Id)
			{
				_testProviderId = _providers.FirstOrDefault(p => p.IsEnabled)?.Id;
				_testResponse = null;
			}

			await LoadTestModelsAsync();

			NotificationService.ShowSuccess($"Provider \"{_providerToDelete.Name}\" removed.");
			_showDeleteModal = false;
			_providerToDelete = null;
		}
		catch (Exception ex)
		{
			NotificationService.ShowError($"Failed to delete provider: {ex.Message}");
		}
		finally
		{
			_isDeleting = false;
		}
	}

	// Test inference

	private async Task OnTestProviderChanged(ChangeEventArgs e)
	{
		_testProviderId = Guid.TryParse(e.Value?.ToString(), out var providerId)
			? providerId
			: null;
		_selectedTestModelId = string.Empty;
		_testResponse = null;
		await LoadTestModelsAsync();
	}

	private async Task LoadTestModelsAsync()
	{
		_testModels = [];
		if (!_testProviderId.HasValue)
		{
			_selectedTestModelId = string.Empty;
			return;
		}

		_isLoadingTestModels = true;
		try
		{
			_testModels = (await InferenceProviderService.GetModelsAsync(_testProviderId.Value))
				.Where(model => model.IsAvailable)
				.OrderByDescending(model => model.IsDefault)
				.ThenBy(model => model.DisplayName ?? model.ModelId)
				.ToList();
			if (!_testModels.Any(model => model.ModelId == _selectedTestModelId))
			{
				_selectedTestModelId = string.Empty;
			}
		}
		catch (Exception ex)
		{
			_selectedTestModelId = string.Empty;
			NotificationService.ShowError($"Failed to load inference models: {ex.Message}");
		}
		finally
		{
			_isLoadingTestModels = false;
		}
	}

	private async Task TestGeneration()
	{
		var provider = _providers.FirstOrDefault(p => p.Id == _testProviderId);
		if (provider == null || string.IsNullOrWhiteSpace(_testPrompt)) return;

		_isTesting = true;
		_testResponse = null;

		try
		{
			_testResponse = await InferenceService.GenerateAsync(new InferenceRequest
			{
				Prompt = _testPrompt.Trim(),
				Model = string.IsNullOrWhiteSpace(_selectedTestModelId) ? null : _selectedTestModelId,
				ProviderId = provider.Id,
				Endpoint = provider.Endpoint,
				ProviderType = provider.ProviderType
			});
		}
		catch (Exception ex)
		{
			_testResponse = new InferenceResponse { Success = false, Error = ex.Message };
		}
		finally
		{
			_isTesting = false;
		}
	}

	private string GetTestModelHelpText()
	{
		if (_isLoadingTestModels)
		{
			return "Loading models for the selected provider...";
		}

		if (_testModels.Count == 0)
		{
			return "No discovered models are available for this provider yet.";
		}

		var defaultModel = _testModels.FirstOrDefault(model => model.IsDefault);
		return defaultModel == null
			? "Choose a model to test with this provider."
			: $"Leave unselected to use {defaultModel.DisplayName ?? defaultModel.ModelId}.";
	}

	private static string GetProviderIcon(InferenceProviderType type) => type switch
	{
		InferenceProviderType.Grok => "bi-cloud",
		_ => "bi-hdd-network"
	};
}
