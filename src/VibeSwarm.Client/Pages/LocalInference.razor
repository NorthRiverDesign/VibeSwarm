@page "/inference"
@attribute [Authorize]
@inject IInferenceProviderService InferenceProviderService
@inject IInferenceService InferenceService
@inject NotificationService NotificationService
@inject IJSRuntime JSRuntime

<PageHeader Title="Inference">
	<Actions>
		<ActionButton Icon="plus" Text="Add" Style="ActionButton.ButtonStyle.Primary" OnClick="ShowAddModal" />
	</Actions>
</PageHeader>

<InferenceProvidersSection IsLoading="@_isLoading"
						   Providers="_providers"
						   HealthStatus="_healthStatus"
						   HealthChecked="_healthChecked"
						   OnEditProvider="EditProvider"
						   OnDeleteProvider="ShowDeleteConfirmation" />

<InferenceTestSection Providers="_providers"
					  SelectedProviderId="_testProviderId"
					  SelectedProviderIdChanged="OnTestProviderChanged"
					  TestModels="_testModels"
					  SelectedModelId="_selectedTestModelId"
					  SelectedModelIdChanged="OnSelectedTestModelIdChanged"
					  TestPrompt="_testPrompt"
					  TestPromptChanged="OnTestPromptChanged"
					  IsLoadingModels="_isLoadingTestModels"
					  IsTesting="_isTesting"
					  TestResponse="_testResponse"
					  TestModelHelpText="@GetTestModelHelpText()"
					  OnSubmit="TestGeneration" />

<InferenceProviderModal @bind-IsVisible="_showModal" EditProvider="@_editingProvider"
						OnSaved="HandleProviderSaved" OnCancelled="HandleModalCancelled" OnClosed="HandleModalClosed" />

<ConfirmationModal @bind-IsVisible="_showDeleteModal" Title="Delete Provider"
				   Message="@($"Are you sure you want to remove {_providerToDelete?.Name}?")" SubMessage="This action cannot be undone."
				   ConfirmText="Delete" ButtonClass="btn-danger" IsProcessing="_isDeleting" OnConfirm="ConfirmDelete"
				   OnCancel="CancelDelete" />

@code {
	private const string LastTestProviderStorageKey = "vibeswarm.local-inference.last-test-provider";

	private List<InferenceProvider> _providers = [];
	private Dictionary<Guid, bool> _healthStatus = new();
	private HashSet<Guid> _healthChecked = new();
	private bool _isLoading = true;

	// Modal state
	private bool _showModal;
	private InferenceProvider? _editingProvider;

	// Delete state
	private bool _showDeleteModal;
	private InferenceProvider? _providerToDelete;
	private bool _isDeleting;

	// Test inference state
	private Guid? _testProviderId;
	private List<InferenceModel> _testModels = [];
	private string _selectedTestModelId = string.Empty;
	private string _testPrompt = "Say hello in one sentence.";
	private bool _isTesting;
	private bool _isLoadingTestModels;
	private InferenceResponse? _testResponse;

	protected override async Task OnInitializedAsync()
	{
		var preferredProviderId = await TryRestoreLastTestProviderIdAsync();
		await LoadProviders(preferredProviderId);

		if (preferredProviderId.HasValue && _testProviderId != preferredProviderId.Value)
		{
			await PersistLastTestProviderIdAsync(_testProviderId);
		}
	}

	private async Task LoadProviders(Guid? preferredProviderId = null)
	{
		_isLoading = true;
		try
		{
			_providers = (await InferenceProviderService.GetAllAsync()).ToList();
			var enabledProviders = _providers
				.Where(p => p.IsEnabled)
				.ToList();
			if (preferredProviderId.HasValue && enabledProviders.Any(p => p.Id == preferredProviderId.Value))
			{
				_testProviderId = preferredProviderId.Value;
			}
			else if (!_testProviderId.HasValue || !enabledProviders.Any(p => p.Id == _testProviderId.Value))
			{
				_testProviderId = enabledProviders.FirstOrDefault()?.Id;
			}

			await LoadTestModelsAsync();

			foreach (var provider in _providers)
			{
				_ = CheckHealth(provider);
			}
		}
		catch (Exception ex)
		{
			NotificationService.ShowError($"Failed to load inference providers: {ex.Message}");
		}
		finally
		{
			_isLoading = false;
		}
	}

	private async Task CheckHealth(InferenceProvider provider)
	{
		try
		{
			var result = await InferenceService.CheckHealthAsync(provider.Endpoint, provider.ProviderType);
			_healthStatus[provider.Id] = result.IsAvailable;
			_healthChecked.Add(provider.Id);
			await InvokeAsync(StateHasChanged);
		}
		catch
		{
			_healthStatus[provider.Id] = false;
			_healthChecked.Add(provider.Id);
		}
	}

	// Modal handlers

	private void ShowAddModal()
	{
		_editingProvider = null;
		_showModal = true;
	}

	private void EditProvider(InferenceProvider provider)
	{
		_editingProvider = provider;
		_showModal = true;
	}

	private async Task HandleProviderSaved(Guid? newProviderId)
	{
		_showModal = false;
		_editingProvider = null;
		_healthStatus.Clear();
		_healthChecked.Clear();
		await LoadProviders(newProviderId);
	}

	private void HandleModalCancelled()
	{
		_showModal = false;
		_editingProvider = null;
	}

	private void HandleModalClosed()
	{
		_showModal = false;
		_editingProvider = null;
		StateHasChanged();
	}

	// Delete handlers

	private void ShowDeleteConfirmation(InferenceProvider provider)
	{
		_providerToDelete = provider;
		_showDeleteModal = true;
	}

	private void CancelDelete()
	{
		_showDeleteModal = false;
		_providerToDelete = null;
	}

	private async Task ConfirmDelete()
	{
		if (_providerToDelete == null) return;

		_isDeleting = true;
		try
		{
			await InferenceProviderService.DeleteAsync(_providerToDelete.Id);
			_providers.Remove(_providerToDelete);
			_healthStatus.Remove(_providerToDelete.Id);
			_healthChecked.Remove(_providerToDelete.Id);

			if (_testProviderId == _providerToDelete.Id)
			{
				_testProviderId = _providers.FirstOrDefault(p => p.IsEnabled)?.Id;
				_testResponse = null;
				await PersistLastTestProviderIdAsync(_testProviderId);
			}

			await LoadTestModelsAsync();

			NotificationService.ShowSuccess($"Provider \"{_providerToDelete.Name}\" removed.");
			_showDeleteModal = false;
			_providerToDelete = null;
		}
		catch (Exception ex)
		{
			NotificationService.ShowError($"Failed to delete provider: {ex.Message}");
		}
		finally
		{
			_isDeleting = false;
		}
	}

	// Test inference

	private async Task OnTestProviderChanged(Guid? providerId)
	{
		_testProviderId = providerId;
		await PersistLastTestProviderIdAsync(_testProviderId);
		_selectedTestModelId = string.Empty;
		_testResponse = null;
		await LoadTestModelsAsync();
	}

	private Task OnSelectedTestModelIdChanged(string selectedModelId)
	{
		_selectedTestModelId = selectedModelId;
		return Task.CompletedTask;
	}

	private Task OnTestPromptChanged(string testPrompt)
	{
		_testPrompt = testPrompt;
		return Task.CompletedTask;
	}

	private async Task LoadTestModelsAsync()
	{
		_testModels = [];
		if (!_testProviderId.HasValue)
		{
			_selectedTestModelId = string.Empty;
			return;
		}

		_isLoadingTestModels = true;
		try
		{
			_testModels = (await InferenceProviderService.GetModelsAsync(_testProviderId.Value))
				.Where(model => model.IsAvailable)
				.OrderByDescending(model => model.IsDefault)
				.ThenBy(model => model.DisplayName ?? model.ModelId)
				.ToList();
			if (!_testModels.Any(model => model.ModelId == _selectedTestModelId))
			{
				_selectedTestModelId = string.Empty;
			}
		}
		catch (Exception ex)
		{
			_selectedTestModelId = string.Empty;
			NotificationService.ShowError($"Failed to load inference models: {ex.Message}");
		}
		finally
		{
			_isLoadingTestModels = false;
		}
	}

	private async Task TestGeneration()
	{
		var provider = _providers.FirstOrDefault(p => p.Id == _testProviderId);
		if (provider == null || string.IsNullOrWhiteSpace(_testPrompt)) return;

		_isTesting = true;
		_testResponse = null;

		try
		{
			await PersistLastTestProviderIdAsync(provider.Id);
			_testResponse = await InferenceService.GenerateAsync(new InferenceRequest
			{
				Prompt = _testPrompt.Trim(),
				Model = string.IsNullOrWhiteSpace(_selectedTestModelId) ? null : _selectedTestModelId,
				ProviderId = provider.Id,
				Endpoint = provider.Endpoint,
				ProviderType = provider.ProviderType
			});
		}
		catch (Exception ex)
		{
			_testResponse = new InferenceResponse { Success = false, Error = ex.Message };
		}
		finally
		{
			_isTesting = false;
		}
	}

	private async Task<Guid?> TryRestoreLastTestProviderIdAsync()
	{
		try
		{
			var storedProviderId = await JSRuntime.InvokeAsync<string?>("sessionStorage.getItem", LastTestProviderStorageKey);
			if (string.IsNullOrWhiteSpace(storedProviderId))
			{
				return null;
			}

			if (Guid.TryParse(storedProviderId, out var providerId))
			{
				return providerId;
			}

			await PersistLastTestProviderIdAsync(null);
		}
		catch (JSException ex)
		{
			LogTestProviderStorageFailure("restore the last test provider", ex);
		}
		catch (InvalidOperationException ex)
		{
			LogTestProviderStorageFailure("restore the last test provider", ex);
		}
		catch (OperationCanceledException ex)
		{
			LogTestProviderStorageFailure("restore the last test provider", ex);
		}

		return null;
	}

	private async Task PersistLastTestProviderIdAsync(Guid? providerId)
	{
		try
		{
			if (providerId.HasValue)
			{
				await JSRuntime.InvokeVoidAsync("sessionStorage.setItem", LastTestProviderStorageKey, providerId.Value.ToString("D"));
				return;
			}

			await JSRuntime.InvokeVoidAsync("sessionStorage.removeItem", LastTestProviderStorageKey);
		}
		catch (JSException ex)
		{
			LogTestProviderStorageFailure("save the last test provider", ex);
		}
		catch (InvalidOperationException ex)
		{
			LogTestProviderStorageFailure("save the last test provider", ex);
		}
		catch (OperationCanceledException ex)
		{
			LogTestProviderStorageFailure("save the last test provider", ex);
		}
	}

	private static void LogTestProviderStorageFailure(string action, Exception exception)
	{
		Console.Error.WriteLine($"[LocalInference] Unable to {action}: {exception.Message}");
	}

	private string GetTestModelHelpText()
	{
		if (_isLoadingTestModels)
		{
			return "Loading models for the selected provider...";
		}

		if (_testModels.Count == 0)
		{
			return "No discovered models are available for this provider yet.";
		}

		var defaultModel = _testModels.FirstOrDefault(model => model.IsDefault);
		return defaultModel == null
			? "Choose a model to test with this provider."
			: $"Leave unselected to use {defaultModel.DisplayName ?? defaultModel.ModelId}.";
	}

}
