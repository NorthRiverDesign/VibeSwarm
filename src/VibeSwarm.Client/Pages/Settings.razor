@page "/settings"
@attribute [Authorize]
@inject IDatabaseService DatabaseService
@inject NotificationService NotificationService

<PageHeader Title="Settings" />

<ul class="nav nav-tabs mb-4" role="tablist">
<li class="nav-item" role="presentation">
<button class="nav-link @(_activeTab == "app" ? "active" : "")" @onclick='() => SetTab("app")' type="button">
<i class="bi bi-gear me-2 d-none d-sm-inline"></i>App Settings
</button>
</li>
<li class="nav-item" role="presentation">
<button class="nav-link @(_activeTab == "database" ? "active" : "")" @onclick='() => SetTab("database")' type="button">
<i class="bi bi-database me-2 d-none d-sm-inline"></i>Database
</button>
</li>
<li class="nav-item" role="presentation">
<button class="nav-link @(_activeTab == "about" ? "active" : "")" @onclick='() => SetTab("about")' type="button">
<i class="bi bi-info-circle me-2 d-none d-sm-inline"></i>About
</button>
</li>
</ul>

<div class="card mb-4">
<div class="card-body d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-3">
<div class="d-flex flex-column gap-1">
<div class="small text-body-secondary text-uppercase fw-semibold">Database Size</div>
@if (_isLoadingDatabaseSummary && _databaseSummary == null)
{
<div class="d-flex align-items-center gap-2 text-body-secondary">
<span class="spinner-border spinner-border-sm" role="status"></span>
<span>Loading storage details...</span>
</div>
}
else
{
<div class="fs-4 fw-semibold">@SettingsDatabaseTab.FormatBytes(_databaseSummary?.TotalSizeBytes)</div>
<div class="small text-body-secondary d-flex flex-wrap gap-3">
<span>@GetDatabaseProviderLabel()</span>
@if (_databaseSummary != null)
{
<span>@_databaseSummary.JobsCount job(s)</span>
<span>@_databaseSummary.JobMessagesCount message(s)</span>
<span>@_databaseSummary.ProviderUsageRecordsCount usage record(s)</span>
}
</div>
@if (!string.IsNullOrWhiteSpace(_databaseSummary?.Location))
{
<div class="small text-body-secondary font-monospace text-break">@_databaseSummary.Location</div>
}
}
</div>
<div class="d-flex flex-column flex-sm-row gap-2">
<button type="button" class="btn btn-secondary btn-sm" @onclick="RefreshDatabaseSummary" disabled="@_isLoadingDatabaseSummary">
@if (_isLoadingDatabaseSummary)
{
<span class="spinner-border spinner-border-sm me-1" role="status"></span>
}
<i class="bi bi-arrow-clockwise me-1"></i>Refresh Size
</button>
@if (_activeTab != "database")
{
<button type="button" class="btn btn-primary btn-sm" @onclick='() => SetTab("database")'>
<i class="bi bi-database me-1"></i>Open Database Tab
</button>
}
</div>
</div>
</div>

@if (_activeTab == "app")
{
<SettingsAppTab OnSettingsSaved="RefreshDatabaseSummary" />
}
else if (_activeTab == "database")
{
<SettingsDatabaseTab DatabaseSummary="@_databaseSummary" OnDatabaseChanged="RefreshDatabaseSummary" />
}
else
{
<div class="card">
<div class="card-header bg-body-secondary">
<h5 class="mb-0 fw-semibold">
<i class="bi bi-info-circle me-2"></i>About VibeSwarm
</h5>
</div>
<div class="card-body">
<div class="d-flex align-items-center gap-2 mb-3">
<img src="img/logo_icon.png" alt="VibeSwarm" class="brand-icon"
 style="width: 32px; height: 32px;" />
<h5 class="mb-0">VibeSwarm</h5>
</div>
<p class="text-body-secondary small mb-3">
AI coding agent orchestrator that leverages multiple AI models to assist developers
in writing, reviewing, and optimizing code.
</p>
<div class="small text-body-secondary">
<div class="d-flex align-items-center gap-2 mb-2">
<i class="bi bi-pc-display opacity-75"></i>
<span><strong>Platform:</strong> @System.Runtime.InteropServices.RuntimeInformation.OSDescription</span>
</div>
<div class="d-flex align-items-center gap-2 mb-2">
<i class="bi bi-hdd opacity-75"></i>
<span><strong>Runtime:</strong> @System.Runtime.InteropServices.RuntimeInformation.FrameworkDescription</span>
</div>
</div>
</div>
</div>

<div class="card mt-3">
<div class="card-header bg-body-secondary">
<h5 class="mb-0 fw-semibold">
<i class="bi bi-lightbulb me-2"></i>Tips
</h5>
</div>
<div class="card-body small">
<ul class="mb-0 ps-3">
<li class="mb-2">
Set a default projects directory to quickly create new projects without typing
the full path each time.
</li>
<li class="mb-2">
The directory browser helps you navigate the host file system to find the right folder.
</li>
<li>
VibeSwarm can work with any directory that the host process has access to.
</li>
</ul>
</div>
</div>

<div class="mt-3">
<ToolDetectionCard />
</div>
}

@code {
	private string _activeTab = "app";
	private DatabaseStorageSummary? _databaseSummary;
	private bool _isLoadingDatabaseSummary;

	private void SetTab(string tab)
	{
		_activeTab = tab;
	}

	protected override async Task OnInitializedAsync()
	{
		await LoadDatabaseSummary();
	}

	private async Task RefreshDatabaseSummary()
	{
		await LoadDatabaseSummary();
	}

	private async Task LoadDatabaseSummary()
	{
		_isLoadingDatabaseSummary = true;

		try
		{
			_databaseSummary = await DatabaseService.GetStorageSummaryAsync();
		}
		catch (Exception ex)
		{
			NotificationService.ShowError($"Failed to load database size: {ex.Message}");
		}
		finally
		{
			_isLoadingDatabaseSummary = false;
		}
	}

	private string GetDatabaseProviderLabel() => _databaseSummary?.Provider switch
	{
		"sqlite" => "SQLite database",
		"mysql" => "MySQL database",
		"postgresql" => "PostgreSQL database",
		"sqlserver" => "SQL Server database",
		{ Length: > 0 } provider => provider,
		_ => "Database size unavailable"
	};
}
