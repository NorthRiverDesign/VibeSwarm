@page "/settings"
@attribute [Authorize]
@inject ISettingsService SettingsService
@inject AppTimeZoneService AppTimeZoneService
@inject IFileSystemService FileSystemService
@inject NotificationService NotificationService
@inject IDatabaseService DatabaseService
@inject ICriticalErrorLogService CriticalErrorLogService
@using System.Text.Json
@using System.Text.Json.Serialization
@using VibeSwarm.Shared.Models
@using VibeSwarm.Shared.Utilities

<PageHeader Title="Settings" />

<ul class="nav nav-tabs mb-4" role="tablist">
<li class="nav-item" role="presentation">
<button class="nav-link @(_activeTab == "app" ? "active" : "")" @onclick='() => SetTab("app")' type="button">
<i class="bi bi-gear me-2 d-none d-sm-inline"></i>App Settings
</button>
</li>
<li class="nav-item" role="presentation">
<button class="nav-link @(_activeTab == "database" ? "active" : "")" @onclick='() => SetTab("database")' type="button">
<i class="bi bi-database me-2 d-none d-sm-inline"></i>Database
</button>
</li>
<li class="nav-item" role="presentation">
<button class="nav-link @(_activeTab == "about" ? "active" : "")" @onclick='() => SetTab("about")' type="button">
<i class="bi bi-info-circle me-2 d-none d-sm-inline"></i>About
</button>
</li>
</ul>

<div class="card mb-4">
<div class="card-body d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-3">
<div class="d-flex flex-column gap-1">
<div class="small text-body-secondary text-uppercase fw-semibold">Database Size</div>
@if (_isLoadingDatabaseSummary && _databaseSummary == null)
{
<div class="d-flex align-items-center gap-2 text-body-secondary">
<span class="spinner-border spinner-border-sm" role="status"></span>
<span>Loading storage details...</span>
</div>
}
else
{
<div class="fs-4 fw-semibold">@FormatBytes(_databaseSummary?.TotalSizeBytes)</div>
<div class="small text-body-secondary d-flex flex-wrap gap-3">
<span>@GetDatabaseProviderLabel()</span>
@if (_databaseSummary != null)
{
<span>@_databaseSummary.JobsCount job(s)</span>
<span>@_databaseSummary.JobMessagesCount message(s)</span>
<span>@_databaseSummary.ProviderUsageRecordsCount usage record(s)</span>
}
</div>
@if (!string.IsNullOrWhiteSpace(_databaseSummary?.Location))
{
<div class="small text-body-secondary font-monospace text-break">@_databaseSummary.Location</div>
}
}
</div>
<div class="d-flex flex-column flex-sm-row gap-2">
<button type="button" class="btn btn-secondary btn-sm" @onclick="RefreshDatabaseSummary" disabled="@_isLoadingDatabaseSummary">
@if (_isLoadingDatabaseSummary)
{
<span class="spinner-border spinner-border-sm me-1" role="status"></span>
}
<i class="bi bi-arrow-clockwise me-1"></i>Refresh Size
</button>
@if (_activeTab != "database")
{
<button type="button" class="btn btn-primary btn-sm" @onclick='() => SetTab("database")'>
<i class="bi bi-database me-1"></i>Open Database Tab
</button>
}
</div>
</div>
</div>

@if (_activeTab == "app")
{
<div class="card">
<div class="card-header bg-body-secondary">
<h5 class="mb-0 fw-semibold">
<i class="bi bi-gear me-2"></i>Application Settings
</h5>
</div>
<div class="card-body">
@if (_isLoading)
{
<LoadingSpinner />
}
else
{
<EditForm Model="@_settings" OnValidSubmit="SaveSettings">
<DataAnnotationsValidator />

<h6 class="text-body-secondary mb-3">
<i class="bi bi-folder me-1"></i>Project Defaults
</h6>

<div class="mb-3">
<label for="defaultProjectsDirectory" class="form-label">Default Projects Directory</label>
<div class="input-group">
<input type="text" id="defaultProjectsDirectory" class="form-control font-monospace"
   @bind="_settings.DefaultProjectsDirectory" placeholder="@_placeholder" />
<button type="button" class="btn btn-secondary" @onclick="OpenDirectoryBrowser"
title="Browse directories">
<i class="bi bi-folder2-open"></i>
</button>
</div>
<div class="form-text">
This path will be used as the default prefix when creating new projects.
For example, if you set this to <code>@_examplePath</code> and create a project named
"MyApp",
the working path will default to
<code>@_examplePath@Path.DirectorySeparatorChar@("MyApp")</code>.
</div>

@if (!string.IsNullOrEmpty(_settings.DefaultProjectsDirectory))
{
<div class="mt-2 d-flex flex-wrap align-items-center gap-2">
@if (_directoryExists)
{
<span class="badge bg-success-subtle text-success-emphasis">
<i class="bi bi-check-circle me-1"></i>Directory exists
</span>
<button type="button" class="btn btn-primary btn-sm" @onclick="OpenScanProjectsModal">
<i class="bi bi-folder-symlink me-1"></i>Scan For Projects
</button>
}
else
{
<span class="badge bg-warning-subtle text-warning-emphasis">
<i class="bi bi-exclamation-triangle me-1"></i>Directory does not exist
</span>
}
</div>
}
</div>

<div class="mb-3">
<label for="timeZoneId" class="form-label">Timezone</label>
<select id="timeZoneId" class="form-select" @bind="_settings.TimeZoneId">
	@foreach (var group in GetGroupedTimeZones())
	{
		<optgroup label="@group.Key">
			@foreach (var timeZone in group)
			{
				<option value="@timeZone.Id">@DateTimeHelper.GetTimeZoneOptionLabel(timeZone)</option>
			}
		</optgroup>
	}
</select>
<div class="form-text">
Recurring schedules and timestamp displays use this timezone. Existing schedules keep the same local
clock time when you change it.
</div>
</div>

<div class="d-flex flex-column flex-sm-row gap-2 mt-4">
<button type="submit" class="btn btn-primary" disabled="@_isSaving">
@if (_isSaving)
{
<span class="spinner-border spinner-border-sm me-1" role="status"></span>
<span>Saving...</span>
}
else
{
<i class="bi bi-check-lg me-1"></i>
<span>Save Settings</span>
}
</button>
<button type="button" class="btn btn-secondary" @onclick="ReloadSettings" disabled="@_isSaving">
<i class="bi bi-arrow-counterclockwise me-1"></i>
Reset
</button>
</div>

<hr class="my-4" />

<h6 class="text-body-secondary mb-3">
<i class="bi bi-robot me-1"></i>Agent Quality
</h6>

<div class="mb-3">
<div class="form-check form-switch">
<input class="form-check-input" type="checkbox" id="enablePromptStructuring"
   @bind="_settings.EnablePromptStructuring" />
<label class="form-check-label" for="enablePromptStructuring">
Structure job prompts with XML tags
</label>
</div>
<div class="form-text">
Wraps job prompts with project context and constraints using XML tags for clearer agent
instructions.
</div>
</div>

<div class="mb-3">
<div class="form-check form-switch">
<input class="form-check-input" type="checkbox" id="injectRepoMap"
   @bind="_settings.InjectRepoMap" />
<label class="form-check-label" for="injectRepoMap">
Inject repo map into system prompt
</label>
</div>
<div class="form-text">
Auto-generates a compact project file tree and injects it into the agent's system prompt for
faster codebase navigation.
</div>
</div>

	<div class="mb-3">
	<div class="form-check form-switch">
	<input class="form-check-input" type="checkbox" id="injectEfficiencyRules"
   @bind="_settings.InjectEfficiencyRules" />
<label class="form-check-label" for="injectEfficiencyRules">
Inject efficiency rules into system prompt
</label>
</div>
	<div class="form-text">
	Adds rules to prevent agents from modifying unrelated files, adding unnecessary comments, or
	refactoring beyond the task.
	</div>
	</div>

	<div class="mb-3">
	<div class="form-check form-switch">
	<input class="form-check-input" type="checkbox" id="enableCommitAttribution"
	   @bind="_settings.EnableCommitAttribution" />
	<label class="form-check-label" for="enableCommitAttribution">
	Enable provider commit attribution
	</label>
	</div>
	<div class="form-text">
	When enabled, provider-run jobs can add provider-specific commit attribution such as Copilot
	co-author trailers or provider identity on auto-commits. When disabled, jobs should use the
	repository's default git identity without provider attribution.
	</div>
	</div>

	<hr class="my-4" />

	<h6 class="text-body-secondary mb-3">
	<i class="bi bi-exclamation-octagon me-1"></i>Critical Error Logs
	</h6>

	<div class="row g-3">
		<div class="col-12 col-md-6">
			<label for="criticalErrorLogRetentionDays" class="form-label">Retention (days)</label>
			<InputNumber id="criticalErrorLogRetentionDays" @bind-Value="_settings.CriticalErrorLogRetentionDays" class="form-control" />
			<div class="form-text">
				Keep critical crash logs for between @AppSettings.MinCriticalErrorLogRetentionDays and @AppSettings.MaxCriticalErrorLogRetentionDays days.
			</div>
			<ValidationMessage For="@(() => _settings.CriticalErrorLogRetentionDays)" class="text-danger small" />
		</div>
		<div class="col-12 col-md-6">
			<label for="criticalErrorLogMaxEntries" class="form-label">Maximum stored entries</label>
			<InputNumber id="criticalErrorLogMaxEntries" @bind-Value="_settings.CriticalErrorLogMaxEntries" class="form-control" />
			<div class="form-text">
				Once this cap is reached, the oldest critical logs are removed automatically.
			</div>
			<ValidationMessage For="@(() => _settings.CriticalErrorLogMaxEntries)" class="text-danger small" />
		</div>
	</div>

	<div class="mt-3 d-flex flex-wrap gap-2">
		<button type="button" class="btn btn-secondary btn-sm" @onclick="RefreshCriticalErrorLogs" disabled="@_isLoadingCriticalErrorLogs">
			@if (_isLoadingCriticalErrorLogs)
			{
				<span class="spinner-border spinner-border-sm me-1" role="status"></span>
			}
			<i class="bi bi-arrow-clockwise me-1"></i>Refresh Logs
		</button>
		<button type="button" class="btn btn-secondary btn-sm" @onclick="PruneCriticalErrorLogs" disabled="@_isPruningCriticalErrorLogs">
			@if (_isPruningCriticalErrorLogs)
			{
				<span class="spinner-border spinner-border-sm me-1" role="status"></span>
			}
			<i class="bi bi-trash3 me-1"></i>Apply Retention Now
		</button>
	</div>

	<div class="mt-3 border rounded-3">
		<div class="list-group list-group-flush">
			@if (_criticalErrorLogs.Count == 0)
			{
				<div class="list-group-item text-body-secondary small">
					No critical errors have been recorded yet.
				</div>
			}
			else
			{
				@foreach (var entry in _criticalErrorLogs)
				{
					<div class="list-group-item">
						<div class="d-flex flex-column gap-2">
							<div class="d-flex flex-wrap align-items-center gap-2">
								<span class="badge bg-danger-subtle text-danger-emphasis text-uppercase">@entry.Source</span>
								<span class="badge bg-body-secondary text-body-secondary text-uppercase">@entry.Category</span>
								@if (entry.TriggeredRefresh)
								{
									<span class="badge bg-warning-subtle text-warning-emphasis">
										<i class="bi bi-arrow-clockwise me-1"></i>@(string.IsNullOrWhiteSpace(entry.RefreshAction) ? "Refresh triggered" : entry.RefreshAction)
									</span>
								}
								<span class="small text-body-secondary">@entry.CreatedAt.FormatDateTimeShort()</span>
							</div>
							<div class="fw-semibold text-break">@entry.Message</div>
							@if (!string.IsNullOrWhiteSpace(entry.Url))
							{
								<div class="small text-body-secondary text-break">
									<i class="bi bi-link-45deg me-1"></i>@entry.Url
								</div>
							}
							@if (!string.IsNullOrWhiteSpace(entry.TraceId))
							{
								<div class="small text-body-secondary font-monospace text-break">Trace: @entry.TraceId</div>
							}
							@if (!string.IsNullOrWhiteSpace(entry.Details))
							{
								<details class="small">
									<summary class="cursor-pointer">Show details</summary>
									<pre class="mb-0 mt-2 p-2 bg-body-tertiary rounded small font-monospace white-space-pre-wrap">@entry.Details</pre>
								</details>
							}
						</div>
					</div>
				}
			}
		</div>
	</div>
	</EditForm>
	}
	</div>
</div>
}
else if (_activeTab == "database")
{
<div class="card mb-3">
<div class="card-header bg-body-secondary">
<h5 class="mb-0 fw-semibold">
<i class="bi bi-hdd-stack me-2"></i>Storage
</h5>
</div>
<div class="card-body">
@if (_isLoadingDatabaseSummary && _databaseSummary == null)
{
<LoadingSpinner />
}
else if (_databaseSummary != null)
{
<div class="row g-3">
<div class="col-12 col-lg-4">
<div class="border rounded-3 p-3 h-100 bg-body-tertiary">
<div class="small text-body-secondary text-uppercase fw-semibold mb-1">Current Size</div>
<div class="fs-3 fw-semibold">@FormatBytes(_databaseSummary.TotalSizeBytes)</div>
<div class="small text-body-secondary">@GetDatabaseProviderLabel()</div>
@if (!string.IsNullOrWhiteSpace(_databaseSummary.Location))
{
<div class="small text-body-secondary font-monospace text-break mt-2">@_databaseSummary.Location</div>
}
</div>
</div>
<div class="col-12 col-lg-8">
<div class="row g-3">
<div class="col-12 col-sm-6">
<div class="border rounded-3 p-3 h-100">
<div class="small text-body-secondary text-uppercase fw-semibold mb-1">Jobs</div>
<div class="fw-semibold">@_databaseSummary.JobsCount total</div>
<div class="small text-body-secondary">@_databaseSummary.CompletedJobsOlderThanRetentionCount completed older than @DatabaseMaintenanceDefaults.HistoryRetentionDays days</div>
</div>
</div>
<div class="col-12 col-sm-6">
<div class="border rounded-3 p-3 h-100">
<div class="small text-body-secondary text-uppercase fw-semibold mb-1">Messages</div>
<div class="fw-semibold">@_databaseSummary.JobMessagesCount total</div>
<div class="small text-body-secondary">Stored session transcript rows</div>
</div>
</div>
<div class="col-12 col-sm-6">
<div class="border rounded-3 p-3 h-100">
<div class="small text-body-secondary text-uppercase fw-semibold mb-1">Usage Records</div>
<div class="fw-semibold">@_databaseSummary.ProviderUsageRecordsCount total</div>
<div class="small text-body-secondary">@_databaseSummary.ProviderUsageRecordsOlderThanRetentionCount older than @DatabaseMaintenanceDefaults.HistoryRetentionDays days</div>
</div>
</div>
<div class="col-12 col-sm-6">
<div class="border rounded-3 p-3 h-100">
<div class="small text-body-secondary text-uppercase fw-semibold mb-1">Critical Error Logs</div>
<div class="fw-semibold">@_databaseSummary.CriticalErrorLogsCount total</div>
<div class="small text-body-secondary">Managed by the retention settings on this page</div>
</div>
</div>
</div>
</div>
@if (_databaseSummary.DataFileSizeBytes.HasValue || _databaseSummary.WalFileSizeBytes.HasValue || _databaseSummary.SharedMemoryFileSizeBytes.HasValue)
{
<div class="col-12">
<div class="small text-body-secondary d-flex flex-wrap gap-3">
@if (_databaseSummary.DataFileSizeBytes.HasValue)
{
<span>Data: @FormatBytes(_databaseSummary.DataFileSizeBytes)</span>
}
@if (_databaseSummary.WalFileSizeBytes.HasValue)
{
<span>WAL: @FormatBytes(_databaseSummary.WalFileSizeBytes)</span>
}
@if (_databaseSummary.SharedMemoryFileSizeBytes.HasValue)
{
<span>SHM: @FormatBytes(_databaseSummary.SharedMemoryFileSizeBytes)</span>
}
</div>
</div>
}
</div>
}
</div>
</div>

<div class="card mb-3">
<div class="card-header bg-body-secondary">
<h5 class="mb-0 fw-semibold">
<i class="bi bi-arrow-left-right me-2"></i>Migration
</h5>
</div>
<div class="card-body d-flex flex-column gap-3">
@if (_databaseMigrationResult != null)
{
<Alert Type="Alert.AlertType.Info" Class="mb-0">
<div class="d-flex flex-column gap-1">
<span>@_databaseMigrationResult.Message</span>
@if (!string.IsNullOrWhiteSpace(_databaseMigrationResult.ConnectionStringPreview))
{
<span class="small text-body-secondary font-monospace text-break">@_databaseMigrationResult.ConnectionStringPreview</span>
}
</div>
</Alert>
}

@if (_isLoadingDatabaseConfiguration && _databaseConfiguration == null)
{
<LoadingSpinner />
}
else if (_databaseConfiguration != null)
{
@if (_databaseConfiguration.HasEnvironmentOverride)
{
<Alert Type="Alert.AlertType.Warning" Class="mb-0">
Migration is disabled because the current database is controlled by environment variables. Clear
<code>DATABASE_PROVIDER</code> and <code>ConnectionStrings__Default</code> to manage database
switching from the UI.
</Alert>
}

@if (!string.IsNullOrWhiteSpace(_databaseConfiguration.PendingProvider))
{
<Alert Type="Alert.AlertType.Info" Class="mb-0">
<div class="d-flex flex-column gap-1">
<span>Restart pending: VibeSwarm will switch to @GetDatabaseProviderDisplayName(_databaseConfiguration.PendingProvider) after restart.</span>
@if (!string.IsNullOrWhiteSpace(_databaseConfiguration.PendingConnectionStringPreview))
{
<span class="small text-body-secondary font-monospace text-break">@_databaseConfiguration.PendingConnectionStringPreview</span>
}
</div>
</Alert>
}

<div class="row g-3">
<div class="col-12 col-lg-4">
<div class="border rounded-3 p-3 h-100 bg-body-tertiary d-flex flex-column gap-2">
<div class="small text-body-secondary text-uppercase fw-semibold">Current Configuration</div>
<div class="fw-semibold">@GetDatabaseProviderDisplayName(_databaseConfiguration.Provider)</div>
<div class="small text-body-secondary">@_databaseConfiguration.ConfigurationSource</div>
@if (!string.IsNullOrWhiteSpace(_databaseConfiguration.ConnectionStringPreview))
{
<div class="small text-body-secondary font-monospace text-break">@_databaseConfiguration.ConnectionStringPreview</div>
}
<div class="small text-body-secondary">Runtime config path: @_databaseConfiguration.RuntimeConfigurationPath</div>
</div>
</div>
<div class="col-12 col-lg-8">
<div class="border rounded-3 p-3 d-flex flex-column gap-3 h-100">
<div class="row g-3">
<div class="col-12 col-md-4">
<label class="form-label">Target Provider</label>
<select class="form-select" @bind="_databaseMigrationRequest.Provider">
<option value="sqlite">SQLite</option>
<option value="mysql">MySQL</option>
<option value="postgresql">PostgreSQL</option>
<option value="sqlserver">SQL Server</option>
</select>
</div>
<div class="col-12 col-md-8">
<label class="form-label">Target Connection String</label>
<input type="text" class="form-control font-monospace" @bind="_databaseMigrationRequest.ConnectionString"
placeholder="@GetDatabaseMigrationConnectionStringPlaceholder()" />
</div>
</div>

<div class="small text-body-secondary">
Copy the entire VibeSwarm database into an empty target database, then save the new provider and
connection string to the runtime database config file. The current database is left unchanged until
you restart the app.
</div>
<div class="small text-body-secondary">
For SQLite, choose a new file path. For MySQL, PostgreSQL, or SQL Server, point to an empty
database that the app can create tables in.
</div>

@if (!string.IsNullOrWhiteSpace(GetDatabaseMigrationValidationMessage()))
{
<div class="small text-danger">@GetDatabaseMigrationValidationMessage()</div>
}

<div class="d-flex flex-column flex-sm-row gap-2">
<button type="button" class="btn btn-primary btn-sm" @onclick="OpenDatabaseMigrationModal"
disabled="@IsDatabaseMigrationDisabled()">
@if (_isMigratingDatabase)
{
<span class="spinner-border spinner-border-sm me-1" role="status"></span>
}
<i class="bi bi-arrow-left-right me-1"></i>Migrate Database
</button>
<button type="button" class="btn btn-secondary btn-sm" @onclick="RefreshDatabaseConfiguration"
disabled="@_isLoadingDatabaseConfiguration">
<i class="bi bi-arrow-clockwise me-1"></i>Refresh Config
</button>
</div>
</div>
</div>
</div>
}
</div>
</div>

<div class="card mb-3">
<div class="card-header bg-body-secondary">
<h5 class="mb-0 fw-semibold">
<i class="bi bi-trash3 me-2"></i>Cleanup
</h5>
</div>
<div class="card-body d-flex flex-column gap-3">
@if (_databaseMaintenanceResult != null)
{
<Alert Type="Alert.AlertType.Info" Class="mb-0">
<div class="d-flex flex-column gap-1">
<span>@_databaseMaintenanceResult.Message</span>
@if (_databaseMaintenanceResult.SizeBeforeBytes.HasValue || _databaseMaintenanceResult.SizeAfterBytes.HasValue)
{
<span class="small text-body-secondary">
Size: @FormatBytes(_databaseMaintenanceResult.SizeBeforeBytes) -> @FormatBytes(_databaseMaintenanceResult.SizeAfterBytes)
</span>
}
</div>
</Alert>
}

<div class="border rounded-3 p-3 d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3">
<div>
<div class="fw-semibold">Apply critical error log retention</div>
<div class="small text-body-secondary">Prune crash logs now using the retention settings configured on this page.</div>
</div>
<button type="button" class="btn btn-secondary btn-sm" @onclick='() => OpenDatabaseMaintenanceModal(DatabaseMaintenanceOperation.ApplyCriticalErrorLogRetention)' disabled="@_isRunningDatabaseMaintenance">
<i class="bi bi-filter-circle me-1"></i>Run Cleanup
</button>
</div>

<div class="border rounded-3 p-3 d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3">
<div>
<div class="fw-semibold">Delete completed jobs older than @DatabaseMaintenanceDefaults.HistoryRetentionDays days</div>
<div class="small text-body-secondary">Removes old completed jobs and their stored transcript rows. Current candidates: @(_databaseSummary?.CompletedJobsOlderThanRetentionCount ?? 0).</div>
</div>
<button type="button" class="btn btn-danger btn-sm" @onclick='() => OpenDatabaseMaintenanceModal(DatabaseMaintenanceOperation.DeleteCompletedJobsOlderThanRetention)' disabled="@_isRunningDatabaseMaintenance">
<i class="bi bi-trash3 me-1"></i>Delete Old Jobs
</button>
</div>

<div class="border rounded-3 p-3 d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3">
<div>
<div class="fw-semibold">Delete provider usage records older than @DatabaseMaintenanceDefaults.HistoryRetentionDays days</div>
<div class="small text-body-secondary">Clears historical provider usage snapshots that are no longer recent. Current candidates: @(_databaseSummary?.ProviderUsageRecordsOlderThanRetentionCount ?? 0).</div>
</div>
<button type="button" class="btn btn-danger btn-sm" @onclick='() => OpenDatabaseMaintenanceModal(DatabaseMaintenanceOperation.DeleteProviderUsageOlderThanRetention)' disabled="@_isRunningDatabaseMaintenance">
<i class="bi bi-trash3 me-1"></i>Delete Old Usage
</button>
</div>

<div class="border rounded-3 p-3 d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3">
<div>
<div class="fw-semibold">Compact database</div>
<div class="small text-body-secondary">Runs SQLite compaction to reclaim unused space after cleanup. This is only available for SQLite databases.</div>
</div>
<button type="button" class="btn btn-primary btn-sm" @onclick='() => OpenDatabaseMaintenanceModal(DatabaseMaintenanceOperation.CompactDatabase)' disabled="@(_isRunningDatabaseMaintenance || _databaseSummary?.SupportsCompaction != true)">
<i class="bi bi-arrows-collapse me-1"></i>Compact
</button>
</div>
</div>
</div>

<div class="card mb-3">
<div class="card-header bg-body-secondary">
<h5 class="mb-0 fw-semibold">
<i class="bi bi-box-arrow-up me-2"></i>Export
</h5>
</div>
<div class="card-body">
<p class="text-body-secondary small mb-3">
Download a JSON backup of your configuration including projects, ideas, skills, team roles,
and schedules. Provider credentials and job history are not included.
</p>
<a href="/api/database/export" class="btn btn-primary">
<i class="bi bi-download me-2"></i>Download Export
</a>
</div>
</div>

<div class="card">
<div class="card-header bg-body-secondary">
<h5 class="mb-0 fw-semibold">
<i class="bi bi-box-arrow-in-down me-2"></i>Import
</h5>
</div>
<div class="card-body">
<p class="text-body-secondary small mb-3">
Import a previously exported JSON file. Existing records with the same name will be skipped
to avoid duplicates. New ideas will be added to existing projects.
</p>

@if (_importResult == null && !_isImporting)
{
<div class="mb-3">
<label class="form-label">Select export file</label>
<InputFile OnChange="OnImportFileSelected" accept=".json" class="form-control" />
</div>

@if (_importParseError != null)
{
<div class="alert alert-danger d-flex align-items-start gap-2 mb-3">
<i class="bi bi-exclamation-triangle-fill flex-shrink-0 mt-1"></i>
<div>@_importParseError</div>
</div>
}

@if (_importPreview != null)
{
<div class="border rounded p-3 mb-3 bg-body-secondary">
<h6 class="fw-semibold mb-2">Preview</h6>
<div class="d-flex flex-wrap gap-3 small">
<div class="d-flex align-items-center gap-1">
<i class="bi bi-folder text-primary"></i>
<span>@_importPreview.Projects.Count project(s)</span>
</div>
<div class="d-flex align-items-center gap-1">
<i class="bi bi-lightbulb text-warning"></i>
<span>@_importPreview.Projects.Sum(p => p.Ideas.Count) idea(s)</span>
</div>
<div class="d-flex align-items-center gap-1">
<i class="bi bi-tools text-success"></i>
<span>@_importPreview.Skills.Count skill(s)</span>
</div>
<div class="d-flex align-items-center gap-1">
<i class="bi bi-people text-info"></i>
<span>@_importPreview.TeamRoles.Count team role(s)</span>
</div>
<div class="d-flex align-items-center gap-1">
<i class="bi bi-clock text-secondary"></i>
<span>@_importPreview.Schedules.Count schedule(s)</span>
</div>
</div>
@if (_importPreview.ExportedAt != default)
{
<div class="text-body-secondary small mt-2">
Exported @_importPreview.ExportedAt.ToString("g") UTC
</div>
}
</div>

<button class="btn btn-primary" @onclick="ConfirmImport">
<i class="bi bi-check-lg me-1"></i>Import
</button>
}
}
else if (_isImporting)
{
<div class="d-flex align-items-center gap-2 text-body-secondary">
<span class="spinner-border spinner-border-sm" role="status"></span>
<span>Importing...</span>
</div>
}
else if (_importResult != null)
{
@if (_importResult.Imported.Count > 0)
{
<div class="mb-3">
<h6 class="text-success fw-semibold mb-2">
<i class="bi bi-check-circle me-1"></i>Imported (@_importResult.Imported.Count)
</h6>
<ul class="list-unstyled small mb-0">
@foreach (var item in _importResult.Imported)
{
<li class="d-flex align-items-start gap-1 mb-1">
<i class="bi bi-check text-success flex-shrink-0 mt-1"></i>
<span>@item</span>
</li>
}
</ul>
</div>
}

@if (_importResult.Skipped.Count > 0)
{
<div class="mb-3">
<h6 class="text-warning fw-semibold mb-2">
<i class="bi bi-skip-forward me-1"></i>Skipped — already exists (@_importResult.Skipped.Count)
</h6>
<ul class="list-unstyled small mb-0">
@foreach (var item in _importResult.Skipped)
{
<li class="d-flex align-items-start gap-1 mb-1">
<i class="bi bi-dash text-warning flex-shrink-0 mt-1"></i>
<span>@item</span>
</li>
}
</ul>
</div>
}

@if (_importResult.Errors.Count > 0)
{
<div class="mb-3">
<h6 class="text-danger fw-semibold mb-2">
<i class="bi bi-exclamation-triangle me-1"></i>Errors (@_importResult.Errors.Count)
</h6>
<ul class="list-unstyled small mb-0">
@foreach (var item in _importResult.Errors)
{
<li class="d-flex align-items-start gap-1 mb-1">
<i class="bi bi-x text-danger flex-shrink-0 mt-1"></i>
<span>@item</span>
</li>
}
</ul>
</div>
}

@if (_importResult.Imported.Count == 0 && _importResult.Skipped.Count == 0 && _importResult.Errors.Count == 0)
{
<p class="text-body-secondary small">Nothing to import.</p>
}

<button class="btn btn-secondary btn-sm" @onclick="ResetImport">
<i class="bi bi-arrow-counterclockwise me-1"></i>Import another file
</button>
}
</div>
</div>
}
else
{
<div class="card">
<div class="card-header bg-body-secondary">
<h5 class="mb-0 fw-semibold">
<i class="bi bi-info-circle me-2"></i>About VibeSwarm
</h5>
</div>
<div class="card-body">
<div class="d-flex align-items-center gap-2 mb-3">
<img src="img/logo_icon.png" alt="VibeSwarm" class="brand-icon"
 style="width: 32px; height: 32px;" />
<h5 class="mb-0">VibeSwarm</h5>
</div>
<p class="text-body-secondary small mb-3">
AI coding agent orchestrator that leverages multiple AI models to assist developers
in writing, reviewing, and optimizing code.
</p>
<div class="small text-body-secondary">
<div class="d-flex align-items-center gap-2 mb-2">
<i class="bi bi-pc-display opacity-75"></i>
<span><strong>Platform:</strong> @System.Runtime.InteropServices.RuntimeInformation.OSDescription</span>
</div>
<div class="d-flex align-items-center gap-2 mb-2">
<i class="bi bi-hdd opacity-75"></i>
<span><strong>Runtime:</strong> @System.Runtime.InteropServices.RuntimeInformation.FrameworkDescription</span>
</div>
@if (_settings.UpdatedAt.HasValue)
{
<div class="d-flex align-items-center gap-2">
<i class="bi bi-clock-history opacity-75"></i>
<span><strong>Settings Last Updated:</strong> @_settings.UpdatedAt.Value.FormatDateTimeShort()</span>
</div>
}
</div>
</div>
</div>

<div class="card mt-3">
<div class="card-header bg-body-secondary">
<h5 class="mb-0 fw-semibold">
<i class="bi bi-lightbulb me-2"></i>Tips
</h5>
</div>
<div class="card-body small">
<ul class="mb-0 ps-3">
<li class="mb-2">
Set a default projects directory to quickly create new projects without typing
the full path each time.
</li>
<li class="mb-2">
The directory browser helps you navigate the host file system to find the right folder.
</li>
<li>
VibeSwarm can work with any directory that the host process has access to.
</li>
</ul>
</div>
</div>

<div class="mt-3">
<ToolDetectionCard />
</div>
}

@if (_showDirectoryBrowser)
{
<DirectoryBrowser @ref="_directoryBrowser" InitialPath="@_settings.DefaultProjectsDirectory"
  OnDirectorySelected="OnDirectorySelected" OnClosed="CloseDirectoryBrowser" />
}

<ScanProjectsModal @ref="_scanProjectsModal" OnProjectsImported="OnProjectsImported" />
<ConfirmationModal @bind-IsVisible="_showDatabaseMaintenanceModal" Title="@GetDatabaseMaintenanceModalTitle()"
Message="@GetDatabaseMaintenanceModalMessage()" SubMessage="@GetDatabaseMaintenanceModalSubMessage()"
ConfirmText="@GetDatabaseMaintenanceConfirmText()" ButtonClass="@GetDatabaseMaintenanceButtonClass()"
IsProcessing="@_isRunningDatabaseMaintenance" OnConfirm="RunDatabaseMaintenance" />
<ConfirmationModal @bind-IsVisible="_showDatabaseMigrationModal" Title="Migrate Database"
Message="@GetDatabaseMigrationModalMessage()" SubMessage="@GetDatabaseMigrationModalSubMessage()"
ConfirmText="Migrate" ButtonClass="btn-primary" IsProcessing="@_isMigratingDatabase"
OnConfirm="RunDatabaseMigration" />

@code {
private static readonly JsonSerializerOptions ImportJsonOptions = new()
{
	PropertyNameCaseInsensitive = true,
	Converters = { new JsonStringEnumConverter() },
};

private AppSettings _settings = new();
private bool _isLoading = true;
private bool _isSaving = false;
private bool _showDirectoryBrowser = false;
private bool _directoryExists = false;
private DirectoryBrowser? _directoryBrowser;
private ScanProjectsModal? _scanProjectsModal;
private string _activeTab = "app";
private IReadOnlyList<TimeZoneInfo> _timeZones = [];

// Database tab state
private DatabaseExportDto? _importPreview;
private DatabaseImportResult? _importResult;
private string? _importParseError;
private bool _isImporting;
private bool _isLoadingCriticalErrorLogs;
private bool _isPruningCriticalErrorLogs;
private List<CriticalErrorLogEntry> _criticalErrorLogs = [];
private DatabaseStorageSummary? _databaseSummary;
private DatabaseConfigurationInfo? _databaseConfiguration;
private DatabaseMaintenanceResult? _databaseMaintenanceResult;
private DatabaseMigrationResult? _databaseMigrationResult;
private DatabaseMigrationRequest _databaseMigrationRequest = new();
private DatabaseMaintenanceOperation? _pendingDatabaseMaintenanceOperation;
private bool _isLoadingDatabaseSummary;
private bool _isLoadingDatabaseConfiguration;
private bool _isMigratingDatabase;
private bool _isRunningDatabaseMaintenance;
private bool _showDatabaseMigrationModal;
private bool _showDatabaseMaintenanceModal;

private IOrderedEnumerable<IGrouping<string, TimeZoneInfo>> GetGroupedTimeZones()
{
	return _timeZones
		.GroupBy(tz => tz.Id.Contains('/') ? tz.Id.Split('/')[0] : "Other")
		.OrderBy(g => g.Key == "Other" ? 1 : 0)
		.ThenBy(g => g.Key, StringComparer.Ordinal);
}

private string _placeholder => OperatingSystem.IsWindows() ? @"C:\Projects" : "/home/user/projects";
private string _examplePath => OperatingSystem.IsWindows() ? @"C:\Projects" : "/home/user/projects";

private void SetTab(string tab)
{
_activeTab = tab;
}

protected override async Task OnInitializedAsync()
{
_timeZones = AppTimeZoneService.GetAvailableTimeZones();
await AppTimeZoneService.EnsureInitializedAsync();
await LoadSettings();
}

private async Task LoadSettings()
{
_isLoading = true;

try
{
	_settings = await SettingsService.GetSettingsAsync();
	_settings.TimeZoneId = DateTimeHelper.ResolveTimeZone(_settings.TimeZoneId).Id;
	AppTimeZoneService.ApplyTimeZone(_settings.TimeZoneId);
	await CheckDirectoryExists();
	await LoadCriticalErrorLogs();
	await LoadDatabaseSummary();
	await LoadDatabaseConfiguration();
	}
	catch (Exception ex)
	{
NotificationService.ShowError($"Failed to load settings: {ex.Message}");
}
finally
{
_isLoading = false;
}
}

private async Task SaveSettings()
{
_isSaving = true;

try
{
if (!string.IsNullOrWhiteSpace(_settings.DefaultProjectsDirectory))
{
_settings.DefaultProjectsDirectory = _settings.DefaultProjectsDirectory.Trim();
}
else
{
_settings.DefaultProjectsDirectory = null;
}

	_settings.TimeZoneId = DateTimeHelper.ResolveTimeZone(_settings.TimeZoneId).Id;
	_settings = await SettingsService.UpdateSettingsAsync(_settings);
	AppTimeZoneService.ApplyTimeZone(_settings.TimeZoneId);
	await CheckDirectoryExists();
	await LoadCriticalErrorLogs();
	await LoadDatabaseSummary();
	await LoadDatabaseConfiguration();
	NotificationService.ShowSuccess("Settings saved successfully!");
}
catch (Exception ex)
{
NotificationService.ShowError($"Failed to save settings: {ex.Message}");
}
finally
{
_isSaving = false;
}
}

private async Task ReloadSettings()
{
await LoadSettings();
}

private async Task RefreshCriticalErrorLogs()
{
	await LoadCriticalErrorLogs();
}

private async Task RefreshDatabaseSummary()
{
	await LoadDatabaseSummary();
}

private async Task RefreshDatabaseConfiguration()
{
	await LoadDatabaseConfiguration();
}

private async Task PruneCriticalErrorLogs()
{
	_isPruningCriticalErrorLogs = true;

	try
	{
		await CriticalErrorLogService.ApplyRetentionPolicyAsync();
		await LoadCriticalErrorLogs();
		NotificationService.ShowSuccess("Critical error log retention applied.");
	}
	catch (Exception ex)
	{
		NotificationService.ShowError($"Failed to prune critical error logs: {ex.Message}");
	}
	finally
	{
		_isPruningCriticalErrorLogs = false;
	}
}

private async Task LoadCriticalErrorLogs()
{
	_isLoadingCriticalErrorLogs = true;

	try
	{
		_criticalErrorLogs = (await CriticalErrorLogService.GetRecentAsync()).ToList();
	}
	catch (Exception ex)
	{
		NotificationService.ShowError($"Failed to load critical error logs: {ex.Message}");
	}
	finally
	{
		_isLoadingCriticalErrorLogs = false;
	}
}

private async Task LoadDatabaseSummary()
{
	_isLoadingDatabaseSummary = true;

	try
	{
		_databaseSummary = await DatabaseService.GetStorageSummaryAsync();
	}
	catch (Exception ex)
	{
		NotificationService.ShowError($"Failed to load database size: {ex.Message}");
	}
	finally
	{
		_isLoadingDatabaseSummary = false;
	}
}

private async Task LoadDatabaseConfiguration()
{
	_isLoadingDatabaseConfiguration = true;

	try
	{
		_databaseConfiguration = await DatabaseService.GetConfigurationAsync();
		if (string.IsNullOrWhiteSpace(_databaseMigrationRequest.ConnectionString) &&
			(string.IsNullOrWhiteSpace(_databaseMigrationRequest.Provider) || _databaseMigrationRequest.Provider == "sqlite"))
		{
			_databaseMigrationRequest.Provider = _databaseConfiguration.Provider;
		}
	}
	catch (Exception ex)
	{
		NotificationService.ShowError($"Failed to load database configuration: {ex.Message}");
	}
	finally
	{
		_isLoadingDatabaseConfiguration = false;
	}
}

private async Task CheckDirectoryExists()
{
if (!string.IsNullOrWhiteSpace(_settings.DefaultProjectsDirectory))
{
_directoryExists = await FileSystemService.DirectoryExistsAsync(_settings.DefaultProjectsDirectory);
}
else
{
_directoryExists = false;
}
}

private async Task OpenDirectoryBrowser()
{
_showDirectoryBrowser = true;
StateHasChanged();

await Task.Delay(50);

if (_directoryBrowser != null)
{
await _directoryBrowser.ShowAsync(_settings.DefaultProjectsDirectory);
}
}

private async Task OnDirectorySelected(string path)
{
_settings.DefaultProjectsDirectory = path;
_showDirectoryBrowser = false;
await CheckDirectoryExists();
StateHasChanged();
}

private void CloseDirectoryBrowser()
{
_showDirectoryBrowser = false;
}

private async Task OpenScanProjectsModal()
{
if (_scanProjectsModal != null)
{
await _scanProjectsModal.ShowAsync(_settings.DefaultProjectsDirectory);
}
}

private void OnProjectsImported()
{
NotificationService.ShowSuccess("Projects imported successfully!");
StateHasChanged();
}

private async Task OnImportFileSelected(InputFileChangeEventArgs e)
{
_importPreview = null;
_importParseError = null;

var file = e.File;
if (file == null)
	return;

try
{
	using var stream = file.OpenReadStream(maxAllowedSize: 50 * 1024 * 1024); // 50 MB limit
	var export = await JsonSerializer.DeserializeAsync<DatabaseExportDto>(stream, ImportJsonOptions);
	if (export == null)
	{
		_importParseError = "The file could not be parsed as a valid VibeSwarm export.";
		return;
	}
	_importPreview = export;
}
catch (JsonException ex)
{
	_importParseError = $"Invalid JSON: {ex.Message}";
}
catch (Exception ex)
{
	_importParseError = $"Failed to read file: {ex.Message}";
}
}

private async Task ConfirmImport()
{
if (_importPreview == null)
	return;

_isImporting = true;

try
{
	_importResult = await DatabaseService.ImportAsync(_importPreview);
	NotificationService.ShowSuccess("Import complete!");
}
catch (Exception ex)
{
	NotificationService.ShowError($"Import failed: {ex.Message}");
	_isImporting = false;
	return;
}

_isImporting = false;
_importPreview = null;
}

private void ResetImport()
{
_importResult = null;
_importPreview = null;
_importParseError = null;
}

private void OpenDatabaseMaintenanceModal(DatabaseMaintenanceOperation operation)
{
	_pendingDatabaseMaintenanceOperation = operation;
	_showDatabaseMaintenanceModal = true;
}

private void OpenDatabaseMigrationModal()
{
	if (!string.IsNullOrWhiteSpace(GetDatabaseMigrationValidationMessage()))
	{
		return;
	}

	_showDatabaseMigrationModal = true;
}

private async Task RunDatabaseMaintenance()
{
	if (!_pendingDatabaseMaintenanceOperation.HasValue)
	{
		return;
	}

	_isRunningDatabaseMaintenance = true;

	try
	{
		_databaseMaintenanceResult = await DatabaseService.RunMaintenanceAsync(new DatabaseMaintenanceRequest
		{
			Operation = _pendingDatabaseMaintenanceOperation.Value
		});

		if (_pendingDatabaseMaintenanceOperation == DatabaseMaintenanceOperation.ApplyCriticalErrorLogRetention)
		{
			await LoadCriticalErrorLogs();
		}

		await LoadDatabaseSummary();
		_showDatabaseMaintenanceModal = false;
		NotificationService.ShowSuccess(_databaseMaintenanceResult.Message);
	}
	catch (Exception ex)
	{
		NotificationService.ShowError($"Database cleanup failed: {ex.Message}");
	}
	finally
	{
		_isRunningDatabaseMaintenance = false;
	}
}

private async Task RunDatabaseMigration()
{
	var validationMessage = GetDatabaseMigrationValidationMessage();
	if (!string.IsNullOrWhiteSpace(validationMessage))
	{
		NotificationService.ShowError(validationMessage);
		return;
	}

	_isMigratingDatabase = true;

	try
	{
		_databaseMigrationResult = await DatabaseService.MigrateAsync(_databaseMigrationRequest);
		_showDatabaseMigrationModal = false;
		await LoadDatabaseConfiguration();
		NotificationService.ShowSuccess(_databaseMigrationResult.Message);
	}
	catch (Exception ex)
	{
		NotificationService.ShowError($"Database migration failed: {ex.Message}");
	}
	finally
	{
		_isMigratingDatabase = false;
	}
}

private string GetDatabaseMaintenanceModalTitle()
{
	return _pendingDatabaseMaintenanceOperation switch
	{
		DatabaseMaintenanceOperation.ApplyCriticalErrorLogRetention => "Apply Log Retention",
		DatabaseMaintenanceOperation.DeleteCompletedJobsOlderThanRetention => "Delete Old Completed Jobs",
		DatabaseMaintenanceOperation.DeleteProviderUsageOlderThanRetention => "Delete Old Provider Usage",
		DatabaseMaintenanceOperation.CompactDatabase => "Compact Database",
		_ => "Confirm Cleanup"
	};
}

private string GetDatabaseMaintenanceModalMessage()
{
	return _pendingDatabaseMaintenanceOperation switch
	{
		DatabaseMaintenanceOperation.ApplyCriticalErrorLogRetention => "Apply the configured critical error log retention policy now?",
		DatabaseMaintenanceOperation.DeleteCompletedJobsOlderThanRetention => $"Delete completed jobs older than {DatabaseMaintenanceDefaults.HistoryRetentionDays} days?",
		DatabaseMaintenanceOperation.DeleteProviderUsageOlderThanRetention => $"Delete provider usage records older than {DatabaseMaintenanceDefaults.HistoryRetentionDays} days?",
		DatabaseMaintenanceOperation.CompactDatabase => "Compact the SQLite database file now?",
		_ => "Run the selected cleanup operation?"
	};
}

private string? GetDatabaseMaintenanceModalSubMessage()
{
	return _pendingDatabaseMaintenanceOperation switch
	{
		DatabaseMaintenanceOperation.DeleteCompletedJobsOlderThanRetention => "This also removes stored messages and provider-attempt rows for those completed jobs.",
		DatabaseMaintenanceOperation.CompactDatabase => "Compaction can take a moment on larger databases and is only available for SQLite.",
		_ => null
	};
}

private string GetDatabaseMaintenanceConfirmText()
{
	return _pendingDatabaseMaintenanceOperation switch
	{
		DatabaseMaintenanceOperation.ApplyCriticalErrorLogRetention => "Apply Retention",
		DatabaseMaintenanceOperation.DeleteCompletedJobsOlderThanRetention => "Delete Jobs",
		DatabaseMaintenanceOperation.DeleteProviderUsageOlderThanRetention => "Delete Usage",
		DatabaseMaintenanceOperation.CompactDatabase => "Compact",
		_ => "Confirm"
	};
}

private string GetDatabaseMaintenanceButtonClass()
{
	return _pendingDatabaseMaintenanceOperation switch
	{
		DatabaseMaintenanceOperation.DeleteCompletedJobsOlderThanRetention => "btn-danger",
		DatabaseMaintenanceOperation.DeleteProviderUsageOlderThanRetention => "btn-danger",
		DatabaseMaintenanceOperation.CompactDatabase => "btn-primary",
		_ => "btn-secondary"
	};
}

private string GetDatabaseProviderLabel()
{
	return _databaseSummary?.Provider switch
	{
		"sqlite" => "SQLite database",
		"mysql" => "MySQL database",
		"postgresql" => "PostgreSQL database",
		"sqlserver" => "SQL Server database",
		{ Length: > 0 } provider => provider,
		_ => "Database size unavailable"
	};
}

private string GetDatabaseProviderDisplayName(string? provider)
{
	return provider switch
	{
		"sqlite" => "SQLite",
		"mysql" => "MySQL",
		"postgresql" => "PostgreSQL",
		"sqlserver" => "SQL Server",
		{ Length: > 0 } value => value,
		_ => "Unknown"
	};
}

private string GetDatabaseMigrationConnectionStringPlaceholder()
{
	return _databaseMigrationRequest.Provider switch
	{
		"sqlite" => OperatingSystem.IsWindows()
			? @"Data Source=C:\VibeSwarm\vibeswarm.db"
			: "Data Source=/var/lib/vibeswarm/vibeswarm.db",
		"mysql" => "Server=localhost;Database=vibeswarm;User=vibeswarm;Password=secret",
		"postgresql" => "Host=localhost;Database=vibeswarm;Username=vibeswarm;Password=secret",
		"sqlserver" => "Server=localhost;Database=vibeswarm;Trusted_Connection=true;TrustServerCertificate=true",
		_ => string.Empty
	};
}

private bool IsDatabaseMigrationDisabled()
{
	return _isMigratingDatabase ||
		_databaseConfiguration == null ||
		_databaseConfiguration.HasEnvironmentOverride ||
		!string.IsNullOrWhiteSpace(GetDatabaseMigrationValidationMessage());
}

private string? GetDatabaseMigrationValidationMessage()
{
	if (_databaseConfiguration?.HasEnvironmentOverride == true)
	{
		return "Environment variable overrides must be cleared before migrating from the UI.";
	}

	if (string.IsNullOrWhiteSpace(_databaseMigrationRequest.Provider))
	{
		return "Choose a target provider.";
	}

	if (string.IsNullOrWhiteSpace(_databaseMigrationRequest.ConnectionString))
	{
		return "Enter a target connection string.";
	}

	return null;
}

private string GetDatabaseMigrationModalMessage()
{
	return $"Copy all VibeSwarm data to the {GetDatabaseProviderDisplayName(_databaseMigrationRequest.Provider)} database now?";
}

private string GetDatabaseMigrationModalSubMessage()
{
	return "The target database must be empty. The current database remains untouched, and VibeSwarm will switch to the new database after restart.";
}

private static string FormatBytes(long? bytes)
{
	if (!bytes.HasValue)
	{
		return "Unavailable";
	}

	const long kilobyte = 1024;
	const long megabyte = kilobyte * 1024;
	const long gigabyte = megabyte * 1024;

	if (bytes.Value >= gigabyte)
	{
		return $"{bytes.Value / (double)gigabyte:0.#} GB";
	}

	if (bytes.Value >= megabyte)
	{
		return $"{bytes.Value / (double)megabyte:0.#} MB";
	}

	if (bytes.Value >= kilobyte)
	{
		return $"{bytes.Value / (double)kilobyte:0.#} KB";
	}

	return $"{bytes.Value} B";
}
}
