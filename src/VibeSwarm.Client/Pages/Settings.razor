@page "/settings"
@attribute [Authorize]
@inject IDatabaseService DatabaseService
@inject NotificationService NotificationService

<PageHeader Title="Settings" />

<TabStrip Class="mb-4">
	<TabItem Text="App Settings" Icon="gear" IsActive="@(_activeTab == "app")" OnClick='() => SetTab("app")' />
	<TabItem Text="Database" Icon="database" IsActive="@(_activeTab == "database")" OnClick='() => SetTab("database")' />
	<TabItem Text="About" Icon="info-circle" IsActive="@(_activeTab == "about")" OnClick='() => SetTab("about")' />
</TabStrip>

@if (_activeTab == "app")
{
	<SettingsAppTab OnSettingsSaved="RefreshDatabaseSummary" />
}
else if (_activeTab == "database")
{
<SettingsDatabaseTab DatabaseSummary="@_databaseSummary" OnDatabaseChanged="RefreshDatabaseSummary" />
}
else
{
<Card Title="@($"About {AppBranding.Name}")" Icon="info-circle">
	<div class="d-flex align-items-center gap-2 mb-3">
		<img src="img/logo_icon.png" alt="@AppBranding.Name" class="brand-icon" />
		<h5 class="mb-0">@AppBranding.Name</h5>
	</div>
	<p class="text-body-secondary small mb-3">@AppBranding.Tagline</p>
	<div class="small text-body-secondary">
		<div class="d-flex align-items-center gap-2 mb-2">
			<i class="bi bi-pc-display opacity-75"></i>
			<span><strong>Platform:</strong> @System.Runtime.InteropServices.RuntimeInformation.OSDescription</span>
		</div>
		<div class="d-flex align-items-center gap-2 mb-2">
			<i class="bi bi-hdd opacity-75"></i>
			<span><strong>Runtime:</strong> @System.Runtime.InteropServices.RuntimeInformation.FrameworkDescription</span>
		</div>
	</div>
</Card>

<Card Title="Tips" Icon="lightbulb" Class="mt-3" BodyClass="small">
	<ul class="mb-0 ps-3">
		<li class="mb-2">
			Set a default projects directory to quickly create new projects without typing
			the full path each time.
		</li>
		<li class="mb-2">
			The directory browser helps you navigate the host file system to find the right folder.
		</li>
		<li>
			VibeSwarm can work with any directory that the host process has access to.
		</li>
	</ul>
</Card>

<div class="mt-3">
<ToolDetectionCard />
</div>
}

@code {
	private string _activeTab = "app";
	private DatabaseStorageSummary? _databaseSummary;

	private void SetTab(string tab)
	{
		_activeTab = tab;
	}

	protected override async Task OnInitializedAsync()
	{
		await LoadDatabaseSummary();
	}

	private async Task RefreshDatabaseSummary()
	{
		await LoadDatabaseSummary();
	}

	private async Task LoadDatabaseSummary()
	{
		try
		{
			_databaseSummary = await DatabaseService.GetStorageSummaryAsync();
		}
		catch (Exception ex)
		{
			NotificationService.ShowError($"Failed to load database size: {ex.Message}");
		}
	}
}
