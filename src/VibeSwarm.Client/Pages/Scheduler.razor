@page "/scheduler"
@attribute [Authorize]
@implements IDisposable
@inject IJobScheduleService JobScheduleService
@inject IJobService JobService
@inject AppTimeZoneService AppTimeZoneService
@inject NotificationService NotificationService
@inject NavigationManager NavigationManager

<PageHeader Title="Scheduler">
	<Actions>
		<ActionButton Icon="plus" Text="Add" Style="ActionButton.ButtonStyle.Primary" OnClick="ShowAddModal" />
	</Actions>
</PageHeader>

@if (_isLoading)
{
	<LoadingSpinner Text="Loading schedules..." />
}
else if (!_schedules.Any())
{
	<EmptyState Icon="calendar-event" Title="No schedules yet"
				Message="Create a recurring schedule to automatically queue jobs or generate fresh ideas for one of your projects." />
}
else
{
	<div class="list-group">
		@foreach (var schedule in _schedules)
		{
			<div class="list-group-item d-flex flex-column flex-md-row align-items-md-start gap-3 p-3 hover-bg-tertiary">
				<div class="flex-grow-1 min-width-0">
					<div class="d-flex align-items-center gap-2 flex-wrap">
						<span class="fw-semibold">@GetScheduleTitle(schedule)</span>
						<span class="badge @(schedule.IsEnabled ? "bg-success-subtle text-success-emphasis" : "bg-secondary-subtle text-secondary-emphasis")">
							@(schedule.IsEnabled ? "Active" : "Paused")
						</span>
						<span class="badge @(schedule.ScheduleType == JobScheduleType.GenerateIdeas ? "bg-warning-subtle text-warning-emphasis" : "bg-primary-subtle text-primary-emphasis")">
							@(schedule.ScheduleType == JobScheduleType.GenerateIdeas ? "Idea Generation" : "Job Running")
						</span>
						<span class="small text-body-secondary d-inline-flex align-items-center gap-1">
							<i class="bi bi-folder opacity-75"></i>
							@(schedule.Project?.Name ?? "Unknown project")
						</span>
						@if (schedule.ScheduleType == JobScheduleType.GenerateIdeas)
						{
							<span class="small text-body-secondary d-inline-flex align-items-center gap-1">
								<i class="bi bi-stars opacity-75"></i>
								@(schedule.InferenceProvider?.Name ?? "Unknown inference provider")
							</span>
						}
						else if (schedule.ExecutionTarget == JobScheduleExecutionTarget.TeamRole)
						{
							<span class="small text-body-secondary d-inline-flex align-items-center gap-1">
								<i class="bi bi-person-badge opacity-75"></i>
								@(schedule.TeamRole?.Name ?? "Unknown agent")
							</span>
						}
						else
						{
							<span class="small text-body-secondary d-inline-flex align-items-center gap-1">
								<i class="bi bi-cpu opacity-75"></i>
								@(schedule.Provider?.Name ?? "Unknown provider")
							</span>
						}
						@if (!string.IsNullOrWhiteSpace(schedule.ModelId))
						{
							<span class="small text-body-secondary d-inline-flex align-items-center gap-1">
								<i class="bi bi-diagram-3 opacity-75"></i>
								@schedule.ModelId
							</span>
						}
						@if (schedule.ScheduleType == JobScheduleType.GenerateIdeas)
						{
							<span class="small text-body-secondary d-inline-flex align-items-center gap-1">
								<i class="bi bi-list-ol opacity-75"></i>
								@($"{schedule.IdeaCount} idea{(schedule.IdeaCount == 1 ? string.Empty : "s")}")
							</span>
						}
					</div>
					<div class="small text-body-secondary mt-1">@DescribeSchedule(schedule)</div>
					<div class="d-flex flex-wrap gap-2 gap-md-3 mt-2 small text-body-secondary">
						<span class="d-inline-flex align-items-center gap-1" title="@schedule.NextRunAtUtc.FormatDateTimeShort()">
							<i class="bi bi-calendar-event opacity-75"></i>
							Next @FormatRelativeTime(schedule.NextRunAtUtc)
						</span>
						@if (schedule.LastRunAtUtc.HasValue)
						{
							<span class="d-inline-flex align-items-center gap-1" title="@schedule.LastRunAtUtc.Value.FormatDateTimeShort()">
								<i class="bi bi-clock-history opacity-75"></i>
								Last @FormatRelativeTime(schedule.LastRunAtUtc.Value)
							</span>
						}
					</div>
					@if (!string.IsNullOrWhiteSpace(schedule.LastError))
					{
						<div class="small text-danger mt-2">
							<i class="bi bi-exclamation-triangle me-1"></i>@TruncateText(schedule.LastError, 180)
						</div>
					}
				@{
					var activeJob = GetActiveJobForSchedule(schedule.Id);
				}
				@if (activeJob != null)
				{
					<div class="d-flex align-items-center gap-2 mt-2 px-2 py-1 bg-info-subtle rounded small cursor-pointer"
						 @onclick="() => NavigateToJob(activeJob.Id)" @onclick:stopPropagation="true">
						<div class="spinner-border spinner-border-sm text-info flex-shrink-0" role="status" style="width: 14px; height: 14px; border-width: 2px;">
							<span class="visually-hidden">Running...</span>
						</div>
						<span class="text-info-emphasis fw-medium">Job running</span>
						@if (!string.IsNullOrEmpty(activeJob.CurrentActivity))
						{
							<span class="text-body-secondary fst-italic text-truncate" style="max-width: min(250px, 40vw);">@activeJob.CurrentActivity</span>
						}
						<i class="bi bi-arrow-right-short text-info-emphasis ms-auto flex-shrink-0"></i>
					</div>
				}
				</div>
				<div class="d-flex flex-wrap gap-2 flex-shrink-0 align-items-center">
					<ActionButton Icon="@(schedule.IsEnabled ? "pause-fill" : "play-fill")"
								  Text="@(schedule.IsEnabled ? "Pause" : "Resume")"
								  Size="ActionButton.ButtonSize.Small"
								  OnClick="@(() => ToggleScheduleAsync(schedule))" />
					<ActionButton Icon="pencil" Text="Edit" Size="ActionButton.ButtonSize.Small"
								  HideTextOnMobile="true" OnClick="@(() => EditSchedule(schedule))" />
					<ActionButton Icon="trash" Text="Delete" Size="ActionButton.ButtonSize.Small"
								  Style="ActionButton.ButtonStyle.Danger" HideTextOnMobile="true"
								  OnClick="@(() => ShowDeleteConfirmation(schedule))" />
				</div>
			</div>
		}
	</div>
}

<JobScheduleModal @bind-IsVisible="_showScheduleModal" EditSchedule="_editingSchedule" OnSaved="HandleScheduleSaved"
				  OnCancelled="HandleModalCancelled" OnClosed="HandleScheduleModalClosed" />

<ConfirmationModal @bind-IsVisible="_showDeleteModal" Title="Delete Schedule"
				   Message="@GetDeleteConfirmationMessage()"
				   SubMessage="@GetDeleteConfirmationSubMessage()"
				   ConfirmText="Delete" ButtonClass="btn-danger" IsProcessing="_isDeleting"
				   OnConfirm="ConfirmDelete" OnCancel="CancelDelete" />

@code {
	private List<JobSchedule> _schedules = [];
	private List<JobSummary> _activeJobs = [];
	private bool _isLoading = true;
	private bool _showScheduleModal;
	private JobSchedule? _editingSchedule;
	private bool _showDeleteModal;
	private JobSchedule? _scheduleToDelete;
	private bool _isDeleting;
	private Timer? _refreshTimer;

	protected override async Task OnInitializedAsync()
	{
		await AppTimeZoneService.EnsureInitializedAsync();
		_refreshTimer = new Timer(_ => InvokeAsync(StateHasChanged), null, TimeSpan.FromMinutes(1), TimeSpan.FromMinutes(1));
		await LoadSchedules();
	}

	private async Task LoadSchedules()
	{
		_isLoading = true;
		try
		{
			var schedulesTask = JobScheduleService.GetAllAsync();
			var activeJobsTask = JobService.GetActiveJobsAsync();
			await Task.WhenAll(schedulesTask, activeJobsTask);
			_schedules = schedulesTask.Result.ToList();
			_activeJobs = activeJobsTask.Result.Where(j => j.JobScheduleId.HasValue).ToList();
		}
		catch (Exception ex)
		{
			NotificationService.ShowError($"Failed to load schedules: {ex.Message}");
		}
		finally
		{
			_isLoading = false;
		}
	}

	private void ShowAddModal()
	{
		_showDeleteModal = false;
		_scheduleToDelete = null;
		_editingSchedule = null;
		_showScheduleModal = true;
		StateHasChanged();
	}

	private void EditSchedule(JobSchedule schedule)
	{
		_showDeleteModal = false;
		_scheduleToDelete = null;
		_editingSchedule = schedule;
		_showScheduleModal = true;
		StateHasChanged();
	}

	private async Task HandleScheduleSaved(Guid? scheduleId)
	{
		_showScheduleModal = false;
		_editingSchedule = null;
		await LoadSchedules();
	}

	private void HandleModalCancelled()
	{
		_showScheduleModal = false;
		_editingSchedule = null;
	}

	private void HandleScheduleModalClosed()
	{
		_showScheduleModal = false;
		_editingSchedule = null;
		StateHasChanged();
	}

	private async Task ToggleScheduleAsync(JobSchedule schedule)
	{
		try
		{
			await JobScheduleService.SetEnabledAsync(schedule.Id, !schedule.IsEnabled);
			NotificationService.ShowSuccess(schedule.IsEnabled ? "Schedule paused." : "Schedule resumed.");
			await LoadSchedules();
		}
		catch (Exception ex)
		{
			NotificationService.ShowError($"Error updating schedule: {ex.Message}");
		}
	}

	private void ShowDeleteConfirmation(JobSchedule schedule)
	{
		_showScheduleModal = false;
		_editingSchedule = null;
		_scheduleToDelete = schedule;
		_showDeleteModal = true;
		StateHasChanged();
	}

	private void CancelDelete()
	{
		_showDeleteModal = false;
		_scheduleToDelete = null;
	}

	private async Task ConfirmDelete()
	{
		if (_scheduleToDelete == null)
		{
			return;
		}

		_isDeleting = true;
		try
		{
			await JobScheduleService.DeleteAsync(_scheduleToDelete.Id);
			NotificationService.ShowSuccess("Schedule deleted.");
			_showDeleteModal = false;
			_scheduleToDelete = null;
			await LoadSchedules();
		}
		catch (Exception ex)
		{
			NotificationService.ShowError($"Error deleting schedule: {ex.Message}");
		}
		finally
		{
			_isDeleting = false;
		}
	}

	private string DescribeSchedule(JobSchedule schedule)
	{
		var time = $"{schedule.HourUtc:D2}:{schedule.MinuteUtc:D2}";
		var action = schedule.ScheduleType == JobScheduleType.GenerateIdeas
			? $"generate {schedule.IdeaCount} idea{(schedule.IdeaCount == 1 ? string.Empty : "s")} with {schedule.InferenceProvider?.Name ?? "Unknown inference provider"}"
			: schedule.ExecutionTarget == JobScheduleExecutionTarget.TeamRole
				? schedule.TeamRole?.Name ?? "Unknown agent"
				: schedule.Provider?.Name ?? "Unknown provider";
		return schedule.Frequency switch
		{
			JobScheduleFrequency.Hourly => $"{action} hourly at minute {schedule.MinuteUtc:D2} past the hour",
			JobScheduleFrequency.Weekly => $"{action} weekly on {schedule.WeeklyDay} at {time}",
			JobScheduleFrequency.Monthly => $"{action} monthly on day {schedule.DayOfMonth} at {time}",
			_ => $"{action} daily at {time}"
		};
	}

	private static string FormatRelativeTime(DateTime value) => value.FormatRelativeToNow();

	private static string GetScheduleTitle(JobSchedule schedule)
	{
		if (schedule.ScheduleType == JobScheduleType.GenerateIdeas)
		{
			return $"Generate {schedule.IdeaCount} idea{(schedule.IdeaCount == 1 ? string.Empty : "s")}";
		}

		return TruncateText(schedule.Prompt, 110);
	}

	private string GetDeleteConfirmationMessage()
	{
		if (_scheduleToDelete == null)
		{
			return "Are you sure you want to delete this schedule?";
		}

		var summary = _scheduleToDelete.ScheduleType == JobScheduleType.GenerateIdeas
			? GetScheduleTitle(_scheduleToDelete)
			: TruncateText(_scheduleToDelete.Prompt ?? string.Empty, 90);
		return $"Are you sure you want to delete this schedule? {summary}";
	}

	private string GetDeleteConfirmationSubMessage()
		=> _scheduleToDelete?.ScheduleType == JobScheduleType.GenerateIdeas
			? "This will stop future automatic idea generation for this project."
			: "This will stop future automatic jobs for this prompt. Existing jobs will remain.";

	private JobSummary? GetActiveJobForSchedule(Guid scheduleId)
		=> _activeJobs.FirstOrDefault(j => j.JobScheduleId == scheduleId);

	private void NavigateToJob(Guid jobId)
		=> NavigationManager.NavigateTo($"/jobs/view/{jobId}");

	private static string TruncateText(string text, int maxLength)
	{
		if (string.IsNullOrEmpty(text) || text.Length <= maxLength)
		{
			return text;
		}

		return text[..maxLength] + "...";
	}

	public void Dispose()
	{
		_refreshTimer?.Dispose();
	}
}
