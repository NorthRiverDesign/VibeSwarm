@page "/jobs/view/{JobId:guid}"
@attribute [Authorize]
@inject IJobService JobService
@inject IIdeaService IdeaService
@inject IVersionControlService VersionControlService
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime
@inject NotificationService NotificationService
@using System.Threading

@if (IsLoading)
{
    <LoadingSpinner />
}
else if (Job == null)
{
    <Breadcrumb
    Items="@(new List<Breadcrumb.BreadcrumbItem> { new("Projects", "/projects", "folder"), new("Job Not Found") })" />
    <Alert Type="Alert.AlertType.Warning" Message="Job not found." />
}
else
{
    @* Breadcrumb Navigation *@
    <Breadcrumb Items="@_breadcrumbItems" />

    @* Page Header Section *@
    <JobHeaderSection Status="@Job.Status" JobTitle="@Job.Title" CancellationRequested="@Job.CancellationRequested"
                      GitHubRepository="@Job.Project?.GitHubRepository" BranchName="@_branchName" ProjectId="@Job.ProjectId"
                      ProjectName="@(Job.Project?.Name ?? "Unknown")" ProviderName="@Job.Provider?.Name"
                      ProcessId="@Job.ProcessId" CreatedAt="@Job.CreatedAt" StartedAt="@Job.StartedAt" CompletedAt="@Job.CompletedAt"
					   ExecutionDuration="@Job.ExecutionDuration" ModelUsed="@Job.ModelUsed" RetryCount="@Job.RetryCount"
					   PlanningProviderName="@Job.PlanningProvider?.Name" PlanningModelUsed="@Job.PlanningModelUsed"
					   InputTokens="@Job.InputTokens" OutputTokens="@Job.OutputTokens" TotalCostUsd="@Job.TotalCostUsd"
					   PlanningInputTokens="@Job.PlanningInputTokens" PlanningOutputTokens="@Job.PlanningOutputTokens"
					   PlanningCostUsd="@Job.PlanningCostUsd" ExecutionInputTokens="@Job.ExecutionInputTokens"
					   ExecutionOutputTokens="@Job.ExecutionOutputTokens" ExecutionCostUsd="@Job.ExecutionCostUsd"
					   CanRetry="@CanRetry" CanCancel="@CanCancel" CanForceCancel="@CanForceCancel"
					   ShowRetryOptions="@(Job.Status == JobStatus.Failed || Job.Status == JobStatus.Cancelled || Job.Status == JobStatus.Stalled)" IsRetrying="@IsRetrying"
					   IsCancelling="@IsCancelling" IsForceCancelling="@IsForceCancelling" OnRetry="RetryJob"
					   ShowGitActions="@ShowGitActions" IsGitSyncing="@_isSyncingWithOrigin"
					   IsGitRefreshing="@_isRefreshingBranches" IsGitPruning="@_isPruningBranches"
					   OnRetryWithOptions="ShowRetryModal" OnCreateBranch="ShowCreateBranchModal" OnSync="SyncWithOrigin"
					   OnRefresh="RefreshBranches" OnPruneBranches="PruneRemoteBranches"
					   OnCancel="CancelJob" OnForceCancel="ForceCancelJob"
					   CanForceReset="@CanForceReset" IsForceResetting="@IsForceResetting" OnForceReset="ForceResetJob"
					   CurrentActivity="@Job.CurrentActivity" LastActivityAt="@Job.LastActivityAt" CurrentCycle="@Job.CurrentCycle"
					   MaxCycles="@Job.MaxCycles" CycleMode="@Job.CycleMode" TeamRoleName="@Job.TeamRole?.Name"
					   PlaywrightEnabled="@Job.PlaywrightEnabled" EnvironmentCount="@Job.EnvironmentSnapshots.Count"
					   EnvironmentTooltip="@BuildEnvironmentTooltip()" />

    @* Main Content - Column Layout *@
    <div class="row g-3 g-lg-4">
        <div class="col-12 col-xl-5 order-2 order-xl-1 @(ShowSidebarContent ? string.Empty : "d-none")">
            @* User Interaction Section - shown when job is paused waiting for input *@
            @if (Job.Status == JobStatus.Paused && !string.IsNullOrEmpty(Job.PendingInteractionPrompt))
            {
                <UserInteractionPanel Prompt="@Job.PendingInteractionPrompt" Choices="@_interactionChoices"
                                      IsSubmitting="@_isSubmittingResponse" ErrorMessage="@_interactionError"
                                      RequestedAt="@Job.InteractionRequestedAt" OnSubmitChoice="SubmitInteractionResponse"
                                      OnSubmitResponse="SubmitInteractionResponse" />
            }

			@if (ShowJobOutcomeSummary)
			{
				<JobOutcomeSummaryCard Status="@Job.Status"
									   ChangedFilesCount="@Job.ChangedFilesCount"
									   BuildVerified="@Job.BuildVerified"
									   GitCommitHash="@Job.GitCommitHash"
									   PullRequestUrl="@Job.PullRequestUrl"
									   PullRequestNumber="@Job.PullRequestNumber"
									   BuildOutput="@Job.BuildOutput" />
			}

            @* Git Diff Loading State *@
            @if (_isGitRepository && _isLoadingGitDiff)
            {
                <div class="card mb-3 mb-lg-4">
                    <div class="card-header bg-body-secondary">
                        <div class="d-flex align-items-center">
                            <i class="bi bi-git me-2 opacity-75"></i>
                            <strong>Git Changes</strong>
                        </div>
                    </div>
                    <div class="card-body text-center py-4">
                        <div class="spinner-border text-primary mb-3" role="status">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                        <p class="text-body-secondary mb-0">
                            <i class="bi bi-hourglass-split me-1"></i>Analyzing git changes...
                        </p>
                    </div>
                </div>
            }
            @* Git Diff Viewer - shown after job completes if changes were detected *@
            else if (_isGitRepository && !IsJobActive && !string.IsNullOrEmpty(Job.GitDiff))
            {
                <GitDiffViewer DiffFiles="@_parsedDiffFiles" @bind-IsVisible="_showGitDiff"
                               IsVerifying="@_isComparingWorkingCopy"
                               ShowVerificationStatus="@(_workingCopyComparisonDone && !_changesPushed && string.IsNullOrEmpty(Job.GitCommitHash))"
                               IsVerified="@_workingCopyMatches" IsDiverged="@(!_workingCopyMatches)"
                               IsCommitted="@(!string.IsNullOrEmpty(Job.GitCommitHash))" MissingFiles="@_workingCopyMissingFiles"
                               ExtraFiles="@_workingCopyExtraFiles" ModifiedFiles="@_workingCopyModifiedFiles"
                               OnRecheck="CompareWithWorkingCopy" />

                @* Commit Section - shown when there are git changes *@
                <CommitSection CommitMessage="@_commitMessage" CommitMessageChanged="@((msg) => _commitMessage = msg)"
                                BranchName="@_branchName" IsLoadingSummary="@_isLoadingSummary"
                                HasAISummary="@(!string.IsNullOrWhiteSpace(Job.SessionSummary))" SummaryError="@_summaryError"
                                PushError="@_pushError" IsPushing="@_isPushing" PushStatus="@_pushStatus" IsPushed="@_changesPushed"
                                PushedCommitHash="@_pushedCommitHash" CanPush="@CanPush" TargetBranch="@EffectiveTargetBranch"
                                DeliveryMode="@Job.GitChangeDeliveryMode" CanCreatePullRequest="@CanCreatePullRequest"
                                IsCreatingPullRequest="@_isCreatingPullRequest" PullRequestUrl="@Job.PullRequestUrl"
                                PullRequestNumber="@Job.PullRequestNumber" CanMergeBranch="@CanMergeBranch"
                                IsMergingBranch="@_isMergingBranch"
                                IsAutoCommitted="@(!string.IsNullOrEmpty(Job.GitCommitHash) && !_changesPushed)"
                                CommitMessageUsed="@(Job.SessionSummary ?? _commitMessage)" OnCommitAndPush="CommitAndPushChanges"
                                OnCreatePullRequest="CreatePullRequest" OnMergeBranch="MergeBranchIntoTarget"
                                OnRefreshSummary="RefreshSummary" />
            }
            else if (_isGitRepository && !IsJobActive && Job.Status == JobStatus.Completed &&
            string.IsNullOrEmpty(Job.GitDiff))
            {
                @* No changes detected placeholder *@
                <div class="card mb-3 mb-lg-4">
                    <div class="card-header bg-body-secondary">
                        <div class="d-flex align-items-center">
                            <i class="bi bi-git me-2 opacity-75"></i>
                            <strong>Git Changes</strong>
                        </div>
                    </div>
                    <div class="card-body text-center">
                        <p class="text-body-secondary mb-3">
                            <i class="bi bi-info-circle me-2 opacity-75"></i>No file changes detected.
                        </p>
                        <button class="btn btn-secondary btn-sm" @onclick="CheckGitDiffAsync" disabled="@_isCheckingGitDiff">
                            @if (_isCheckingGitDiff)
                            {
                                <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                                <span>Checking...</span>
                            }
                            else
                            {
                                <i class="bi bi-arrow-repeat me-1"></i>
                                <span>Check again</span>
                            }
                        </button>
                    </div>
                </div>
            }

            @* Working Directory Changes - shown for failed/cancelled jobs *@
            @if (_isGitRepository && !IsJobActive && (Job.Status == JobStatus.Failed || Job.Status == JobStatus.Cancelled)
                    &&
                    Job?.Project?.WorkingPath != null)
            {
                <UncommittedChangesCard DiffFiles="@_uncommittedDiffFiles" IsChecking="@_isCheckingUncommittedChanges"
                                        HasChecked="@_hasCheckedUncommittedChanges" HasChanges="@_hasUncommittedChanges"
                                        ErrorMessage="@_uncommittedChangesError" JobFailed="@(Job.Status == JobStatus.Failed)"
                                        CommitMessage="@_uncommittedCommitMessage"
                                        CommitMessageChanged="@((msg) => _uncommittedCommitMessage = msg)"
                                        IsCommitting="@_isCommittingUncommittedChanges" IsDiscarding="@_isDiscardingChanges"
                                        OnCheck="CheckUncommittedChangesAsync" OnRefresh="CheckUncommittedChangesAsync"
                                        OnCommit="CommitUncommittedChangesAsync" OnDiscard="DiscardUncommittedChangesAsync" />
            }
        </div>

        @* Right Column - Session Panel (Live Output, Console, Command, Conversation) *@
        <div class="col-12 @(ShowSidebarContent ? "col-xl-7 order-1 order-xl-2" : string.Empty) d-flex flex-column">
            <JobSessionPanel Messages="@(Job!.Messages.ToList())" Status="@Job.Status" IsJobActive="@IsJobActive"
                              GoalPrompt="@Job.GoalPrompt" GoalPromptIdeaText="@GetGoalPromptIdeaText()"
                             AttachedIdeaFiles="@(_linkedIdea?.Attachments ?? Array.Empty<IdeaAttachment>())"
                              GoalPromptTimestamp="@Job.CreatedAt" OnCopyGoalPrompt="CopyPromptToClipboard"
                              OnGoalPromptChanged="UpdateJobPrompt"
                              ErrorMessage="@Job.ErrorMessage" ConsoleOutput="@Job.ConsoleOutput" CommandUsed="@Job.CommandUsed"
                             PlanningCommandUsed="@Job.PlanningCommandUsed" ExecutionCommandUsed="@Job.ExecutionCommandUsed"
                             SessionId="@Job.SessionId" LiveOutputLines="@_liveOutput.ToList()"
                             LiveMessages="@_pendingSessionMessages.ToList()" MaxOutputLines="@MaxOutputLines"
                             CurrentActivity="@Job.CurrentActivity"
                             OnClearLiveOutput="ClearLiveOutput" OnSendFollowUp="ContinueJobWithFollowUp" />
        </div>
    </div>

	<CreateBranchModal @bind-IsVisible="_showCreateBranchModal" CurrentBranch="@_branchName"
					   IsCreating="@_isCreatingBranch" ErrorMessage="@_createBranchError" OnCreate="CreateBranch" />

	@* Retry Job Modal *@
	<RetryJobModal @bind-IsVisible="_showRetryModal" Job="Job" OnRetry="HandleRetryWithOptions" />
}

@code {
    [Parameter]
    public Guid JobId { get; set; }

    [SupplyParameterFromQuery(Name = "returnUrl")]
    public string? ReturnUrl { get; set; }

    // Shared state accessed by multiple partial files
    private Job? Job { get; set; }
	private bool IsLoading { get; set; } = true;
	private bool _isRefreshing = false;
	private bool _disposed = false;
	private Timer? _refreshTimer;
	private DateTime _pageLoadTime = DateTime.UtcNow;
	private Guid? _loadedJobId;
	private bool ShowJobOutcomeSummary => Job != null && Job.Status is JobStatus.Completed or JobStatus.Failed or JobStatus.Cancelled or JobStatus.Stalled;

    // Toggle states for collapsible sections
    private bool _showGitDiff = true;
    private string? _liveCommand = null;

    // Git diff state
    private List<DiffFile> _parsedDiffFiles = new();

    // Live output buffer
    private const int MaxOutputLines = 500;
    private readonly List<OutputLine> _liveOutput = new();
    private readonly List<JobMessage> _pendingSessionMessages = new();

    private List<Breadcrumb.BreadcrumbItem> _breadcrumbItems => new()
    {
        new Breadcrumb.BreadcrumbItem("Projects", "/projects", "folder"),
        new Breadcrumb.BreadcrumbItem(Job?.Project?.Name ?? "Project", $"/projects/{Job?.ProjectId}"),
        new Breadcrumb.BreadcrumbItem(GetJobDisplayTitle())
    };

    private bool CanCancel => Job != null &&
        (Job.Status == JobStatus.New ||
        Job.Status == JobStatus.Pending ||
        Job.Status == JobStatus.Started ||
        Job.Status == JobStatus.Planning ||
        Job.Status == JobStatus.Processing) &&
        !Job.CancellationRequested;

    private bool CanForceCancel => Job != null &&
        (Job.Status == JobStatus.Started || Job.Status == JobStatus.Planning || Job.Status == JobStatus.Processing) &&
        Job.CancellationRequested;

    private bool CanRetry => Job != null && Job.Status != JobStatus.Completed;

    private bool CanForceReset => Job != null &&
        Job.Status != JobStatus.Completed &&
        Job.Status != JobStatus.Failed &&
        Job.Status != JobStatus.Cancelled;

    private bool IsJobActive => Job != null &&
        (Job.Status == JobStatus.New ||
        Job.Status == JobStatus.Pending ||
        Job.Status == JobStatus.Started ||
        Job.Status == JobStatus.Planning ||
        Job.Status == JobStatus.Processing ||
        Job.Status == JobStatus.Paused);

    private bool ShowGitActions => Job?.Project?.WorkingPath != null && _isGitRepository && !IsJobActive;

    private bool ShowSidebarContent
        => (Job?.Status == JobStatus.Paused && !string.IsNullOrEmpty(Job.PendingInteractionPrompt))
            || (_isGitRepository && _isLoadingGitDiff)
            || (_isGitRepository && !IsJobActive && !string.IsNullOrEmpty(Job?.GitDiff))
            || (_isGitRepository && !IsJobActive && Job?.Status == JobStatus.Completed && string.IsNullOrEmpty(Job?.GitDiff))
            || (_isGitRepository && !IsJobActive && (Job?.Status == JobStatus.Failed || Job?.Status == JobStatus.Cancelled)
                && Job?.Project?.WorkingPath != null);

    private bool CanPush => !_isPushing &&
        !string.IsNullOrWhiteSpace(_commitMessage) &&
        !_changesPushed &&
        Job?.Project?.WorkingPath != null;

    private string? EffectiveTargetBranch => string.IsNullOrWhiteSpace(Job?.TargetBranch)
        ? Job?.Project?.DefaultTargetBranch
        : Job?.TargetBranch;

    private bool CanCreatePullRequest => Job?.Project?.WorkingPath != null &&
        !_isPushing &&
        !_isCreatingPullRequest &&
        !_isMergingBranch &&
        !string.IsNullOrWhiteSpace(_commitMessage) &&
        string.IsNullOrWhiteSpace(Job?.PullRequestUrl) &&
        !string.IsNullOrWhiteSpace(_branchName) &&
        !string.IsNullOrWhiteSpace(EffectiveTargetBranch) &&
        !string.Equals(_branchName, EffectiveTargetBranch, StringComparison.Ordinal);

    private bool CanMergeBranch => Job?.Project?.WorkingPath != null &&
        !_isPushing &&
        !_isCreatingPullRequest &&
        !_isMergingBranch &&
        Job?.MergedAt == null &&
        !string.IsNullOrWhiteSpace(_branchName) &&
        !string.IsNullOrWhiteSpace(EffectiveTargetBranch) &&
        !string.Equals(_branchName, EffectiveTargetBranch, StringComparison.Ordinal);

    private string BuildEnvironmentTooltip()
    {
        var snapshots = Job?.EnvironmentSnapshots;
        if (snapshots == null || snapshots.Count == 0)
        {
            return "No environments exposed";
        }

        return string.Join(", ", snapshots.Select(e => $"{e.Name} ({e.Stage})"));
    }

	protected override async Task OnInitializedAsync()
	{
		StartAutoRefresh();
		await EnsureCurrentJobLoadedAsync();
	}

	protected override async Task OnParametersSetAsync()
	{
		await EnsureCurrentJobLoadedAsync();
	}

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Fire-and-forget with timeout protection for SignalR
            _ = InitializeSignalRSafe();
            await Task.Delay(500);
            if (!_disposed)
                await RefreshJobSafely();
        }
    }

    private void StartAutoRefresh()
    {
        _refreshTimer = new Timer(async _ =>
        {
            if (_disposed) return;

            try
            {
                var secondsSincePageLoad = (DateTime.UtcNow - _pageLoadTime).TotalSeconds;
                var isTerminal = Job?.Status is JobStatus.Completed or JobStatus.Failed or JobStatus.Cancelled;
                var shouldPoll = (secondsSincePageLoad < 10 && !isTerminal) || IsJobActive;

                // When SignalR is actively connected and the job is running, skip the poll —
                // SignalR already pushes all status changes, so polling only wastes CPU/battery.
                // Keep polling as a fallback when SignalR is disconnected or during early page load.
                if (_signalRConnected && IsJobActive)
                    shouldPoll = false;

                if (shouldPoll && !_isRefreshing)
                {
                    await InvokeAsync(async () => await RefreshJobSafely());
                }
            }
            catch (ObjectDisposedException) { }
            catch { }
        }, null, TimeSpan.FromSeconds(10), TimeSpan.FromSeconds(10));
    }

    private async Task RefreshJobSafely()
    {
        if (_isRefreshing || _disposed) return;

        try
        {
            _isRefreshing = true;
            await LoadJob();
            StateHasChanged();
        }
        catch (ObjectDisposedException) { }
        catch (Exception)
        {
            // Swallow refresh errors to prevent ErrorBoundary from triggering a full page reload.
            // The next poll or SignalR push will retry automatically.
        }
        finally
        {
            _isRefreshing = false;
        }
    }

	private string GetJobDisplayTitle()
	{
		if (Job == null) return "Job";
		if (!string.IsNullOrEmpty(Job.Title)) return TruncateTitle(Job.Title, 40);
		return TruncateTitle(Job.GoalPrompt, 40);
	}

	private async Task EnsureCurrentJobLoadedAsync()
	{
		if (_loadedJobId == JobId)
		{
			return;
		}

		var previousJobId = _loadedJobId;
		_loadedJobId = JobId;

		await HandleJobSelectionChangedAsync(previousJobId);
	}

	private async Task HandleJobSelectionChangedAsync(Guid? previousJobId)
	{
		if (previousJobId.HasValue && previousJobId.Value != JobId)
		{
			await UnsubscribeFromJobAsync(previousJobId.Value);
		}

		ResetJobDetailState();
		IsLoading = true;
		_pageLoadTime = DateTime.UtcNow;

		await LoadJob();
		await LoadBranchName();

		if (_signalRConnected)
		{
			await SubscribeToSignalRGroups();
		}
	}

    private static string TruncateTitle(string text, int maxLength)
    {
        if (string.IsNullOrEmpty(text) || text.Length <= maxLength) return text;
        return text[..maxLength] + "...";
    }

    #region UI Actions

    private void ClearLiveOutput() { lock (_liveOutput) { _liveOutput.Clear(); } }

    private async Task CopyCommandToClipboard(string command)
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("copyToClipboard", command);
            NotificationService.ShowSuccess("Command copied to clipboard!", "Copied");
        }
        catch (Exception ex)
        {
            NotificationService.ShowError($"Failed to copy to clipboard: {ex.Message}", "Copy Failed");
        }
    }

    private async Task CopyPromptToClipboard()
    {
        if (Job != null && !string.IsNullOrEmpty(Job.GoalPrompt))
        {
            try
            {
                await JSRuntime.InvokeVoidAsync("copyToClipboard", Job.GoalPrompt);
                NotificationService.ShowSuccess("Prompt copied to clipboard!", "Copied");
            }
            catch (Exception ex)
            {
                NotificationService.ShowError($"Failed to copy to clipboard: {ex.Message}", "Copy Failed");
            }
        }
    }

    private async Task UpdateJobPrompt(string newPrompt)
    {
        if (Job == null || string.IsNullOrWhiteSpace(newPrompt)) return;

        try
        {
            var shouldSyncTitle = JobTitleHelper.ShouldSyncTitleWithGoalPrompt(Job.Title, Job.GoalPrompt);
            var success = await JobService.UpdateJobPromptAsync(Job.Id, newPrompt);
            if (success)
            {
                Job.GoalPrompt = newPrompt;
                if (shouldSyncTitle)
                {
                    Job.Title = JobTitleHelper.BuildSafeJobTitle(null, newPrompt);
                }

                NotificationService.ShowSuccess("Prompt updated successfully!", "Saved");
                StateHasChanged();
            }
            else
            {
                NotificationService.ShowError("Could not update prompt. Job may have already started.", "Update Failed");
            }
        }
        catch (Exception ex)
        {
            NotificationService.ShowError($"Failed to update prompt: {ex.Message}", "Update Failed");
        }
    }

    private string? GetGoalPromptIdeaText()
    {
        if (Job == null)
        {
            return null;
        }

        return JobTitleHelper.ShouldSyncTitleWithGoalPrompt(Job.Title, Job.GoalPrompt)
            ? null
            : Job.Title;
    }

    #endregion
}
