@page "/providers"
@attribute [Authorize]
@inject IProviderService ProviderService
@inject ICommonProviderSetupService CommonProviderSetupService
@inject HttpProviderService HttpProviderService
@inject NotificationService NotificationService

<PageHeader Title="Providers">
	<Actions>
		<ActionButton Icon="plus" Text="Add" Style="ActionButton.ButtonStyle.Primary" OnClick="ShowAddModal" />
	</Actions>
</PageHeader>

<ProviderHostSetupSection IsLoading="@IsLoading"
						  Statuses="CommonProviderStatuses"
						  Providers="ProvidersList"
						  ActiveProviderTab="@_activeProviderTab"
						  ActiveProviderTabChanged="SetActiveProviderTab"
						  IsRefreshing="@IsRefreshingCommonProviders"
						  InstallingProviderType="@InstallingProviderType"
						  SavingAuthenticationProviderType="@SavingAuthenticationProviderType"
						  ProviderModels="ProviderModels"
						  UsageSummaries="UsageSummaries"
						  TestResults="TestResults"
						  RefreshModelsErrors="RefreshModelsErrors"
						  TestingId="@TestingId"
						  RefreshingModelsId="@RefreshingModelsId"
						  UpdatingCliId="@UpdatingCliId"
						  OnRefreshStatuses="RefreshCommonProviderStatusesAsync"
						  OnInstallProvider="InstallCommonProviderAsync"
						  OnSaveAuthentication="SaveCommonProviderAuthenticationAsync"
						  OnAddConnection="HandleAddConnection"
						  OnToggleEnabled="ToggleEnabled"
						  OnTestConnection="TestConnection"
						  OnRefreshModels="RefreshModels"
						  OnUpdateCli="UpdateCli"
						  OnShowSelectDefaultModel="ShowSelectDefaultModelModal"
						  OnMakeDefault="MakeDefault"
						  OnEditProvider="EditProvider"
						  OnDeleteProvider="ShowDeleteConfirmation" />


@* Provider Modal for Add/Edit *@
<ProviderModal @bind-IsVisible="ShowProviderModal" EditProvider="@EditingProvider"
			   SuggestedProviderType="SuggestedProviderType" SuggestedConnectionMode="SuggestedConnectionMode"
			   OnSaved="HandleProviderSaved" OnCancelled="HandleModalCancelled" OnClosed="HandleProviderModalClosed" />

@* Delete Confirmation Modal *@
<ConfirmationModal @bind-IsVisible="ShowDeleteModal" Title="Delete Provider"
				   Message="@($"Are you sure you want to delete {ProviderToDelete?.Name}?")" SubMessage="This action cannot be undone."
				   ConfirmText="Delete" IsProcessing="@IsDeleting" OnConfirm="ConfirmDelete" OnCancel="CancelDelete" />

@* Select Default Model Modal *@
<DefaultModelModal @bind-IsVisible="ShowDefaultModelModal" Provider="@DefaultModelProvider" Models="@DefaultModelList"
				   IsLoading="@IsLoadingDefaultModels" IsSelecting="@IsSettingDefaultModel" OnModelSelected="SelectDefaultModel"
				   OnClose="HandleDefaultModelModalClosed" />

@code {
	private List<Provider> ProvidersList { get; set; } = new();
	private bool IsLoading { get; set; } = true;
	private string _activeProviderTab = "";
	private bool ShowProviderModal { get; set; }
	private Provider? EditingProvider { get; set; }
	private ProviderType? SuggestedProviderType { get; set; }
	private ProviderConnectionMode? SuggestedConnectionMode { get; set; }
	private Guid? TestingId { get; set; }
	private Guid? RefreshingModelsId { get; set; }
	private Guid? UpdatingCliId { get; set; }
	private Dictionary<Guid, string> RefreshModelsErrors { get; set; } = new();
	private Dictionary<Guid, ConnectionTestResult> TestResults { get; set; } = new();
	private Dictionary<Guid, List<ProviderModel>> ProviderModels { get; set; } = new();
	private Dictionary<Guid, ProviderUsageSummary> UsageSummaries { get; set; } = new();
	private List<CommonProviderSetupStatus> CommonProviderStatuses { get; set; } = new();
	private ProviderType? InstallingProviderType { get; set; }
	private ProviderType? SavingAuthenticationProviderType { get; set; }
	private bool IsRefreshingCommonProviders { get; set; }

	// Delete confirmation state
	private bool ShowDeleteModal { get; set; }
	private Provider? ProviderToDelete { get; set; }
	private bool IsDeleting { get; set; }

	// Default model selection state
	private bool ShowDefaultModelModal { get; set; }
	private Provider? DefaultModelProvider { get; set; }
	private List<ProviderModel> DefaultModelList { get; set; } = new();
	private bool IsLoadingDefaultModels { get; set; }
	private bool IsSettingDefaultModel { get; set; }

	protected override async Task OnInitializedAsync()
	{
		await LoadPageData();
	}

	private async Task LoadPageData()
	{
		IsLoading = true;
		try
		{
			ProvidersList = (await ProviderService.GetAllAsync()).ToList();

			ProviderModels.Clear();
			foreach (var provider in ProvidersList)
			{
				var models = await ProviderService.GetModelsAsync(provider.Id);
				ProviderModels[provider.Id] = models.ToList();
			}

			UsageSummaries = await HttpProviderService.GetAllUsageSummariesAsync();
			CommonProviderStatuses = (await CommonProviderSetupService.GetStatusesAsync()).ToList();
			if (string.IsNullOrEmpty(_activeProviderTab) && CommonProviderStatuses.Count > 0)
			{
				_activeProviderTab = CommonProviderStatuses[0].ProviderType.ToString();
			}
		}
		catch (Exception ex)
		{
			NotificationService.ShowError($"Failed to load providers: {ex.Message}");
		}
		finally
		{
			IsLoading = false;
		}
	}

	private void ShowAddModal()
	{
		ShowAddModal(null, null);
	}

	private void ShowAddModal(ProviderType? providerType, ProviderConnectionMode? connectionMode)
	{
		ShowDeleteModal = false;
		ProviderToDelete = null;

		EditingProvider = null;
		SuggestedProviderType = providerType;
		SuggestedConnectionMode = connectionMode;
		ShowProviderModal = true;
		StateHasChanged();
	}

	private Task HandleAddConnection((ProviderType ProviderType, ProviderConnectionMode ConnectionMode) request)
	{
		ShowAddModal(request.ProviderType, request.ConnectionMode);
		return Task.CompletedTask;
	}

	private Task SetActiveProviderTab(string activeProviderTab)
	{
		_activeProviderTab = activeProviderTab;
		return Task.CompletedTask;
	}

	private void EditProvider(Provider provider)
	{
		ShowDeleteModal = false;
		ProviderToDelete = null;

		EditingProvider = provider;
		SuggestedProviderType = null;
		SuggestedConnectionMode = null;
		ShowProviderModal = true;
		StateHasChanged();
	}

	private async Task HandleProviderSaved(Guid? newProviderId)
	{
		ShowProviderModal = false;
		EditingProvider = null;
		SuggestedProviderType = null;
		SuggestedConnectionMode = null;
		await LoadPageData();

		if (newProviderId.HasValue)
		{
			var provider = ProvidersList.FirstOrDefault(item => item.Id == newProviderId.Value);
			if (provider != null)
			{
				await TestConnection(provider);

				if (TestResults.TryGetValue(provider.Id, out var result) && result.IsConnected)
				{
					await RefreshModels(provider);
				}
			}
		}
	}

	private async Task RefreshCommonProviderStatusesAsync()
	{
		IsRefreshingCommonProviders = true;
		try
		{
			CommonProviderStatuses = (await CommonProviderSetupService.RefreshAsync()).ToList();
			ProvidersList = (await ProviderService.GetAllAsync()).ToList();

			ProviderModels.Clear();
			foreach (var provider in ProvidersList)
			{
				var models = await ProviderService.GetModelsAsync(provider.Id);
				ProviderModels[provider.Id] = models.ToList();
			}

			UsageSummaries = await HttpProviderService.GetAllUsageSummariesAsync();
			NotificationService.ShowSuccess("Provider scan completed.");
		}
		catch (Exception ex)
		{
			NotificationService.ShowError($"Provider scan failed: {ex.Message}");
		}
		finally
		{
			IsRefreshingCommonProviders = false;
		}
	}

	private void HandleModalCancelled()
	{
		ShowProviderModal = false;
		EditingProvider = null;
		SuggestedProviderType = null;
		SuggestedConnectionMode = null;
	}

	private void HandleProviderModalClosed()
	{
		ShowProviderModal = false;
		EditingProvider = null;
		SuggestedProviderType = null;
		SuggestedConnectionMode = null;
		StateHasChanged();
	}

	private void ShowDeleteConfirmation(Provider provider)
	{
		ShowProviderModal = false;
		EditingProvider = null;

		ProviderToDelete = provider;
		ShowDeleteModal = true;
		StateHasChanged();
	}

	private void CancelDelete()
	{
		ShowDeleteModal = false;
		ProviderToDelete = null;
	}

	private async Task ConfirmDelete()
	{
		if (ProviderToDelete == null)
		{
			return;
		}

		IsDeleting = true;
		try
		{
			await ProviderService.DeleteAsync(ProviderToDelete.Id);
			ShowDeleteModal = false;
			ProviderToDelete = null;
			await LoadPageData();
		}
		finally
		{
			IsDeleting = false;
		}
	}

	private async Task ToggleEnabled(Provider provider)
	{
		try
		{
			await ProviderService.SetEnabledAsync(provider.Id, !provider.IsEnabled);
			await LoadPageData();
		}
		catch (Exception)
		{
		}
	}

	private async Task MakeDefault(Provider provider)
	{
		try
		{
			await ProviderService.SetDefaultAsync(provider.Id);
			await LoadPageData();
		}
		catch (Exception)
		{
		}
	}

	private async Task TestConnection(Provider provider)
	{
		TestingId = provider.Id;
		TestResults.Remove(provider.Id);
		StateHasChanged();

		try
		{
			var result = await ProviderService.TestConnectionWithDetailsAsync(provider.Id);
			TestResults[provider.Id] = result;
		}
		catch (Exception ex)
		{
			TestResults[provider.Id] = new ConnectionTestResult
			{
				IsConnected = false,
				ErrorMessage = $"Unexpected error: {ex.Message}"
			};
		}
		finally
		{
			TestingId = null;
		}
	}

	private async Task RefreshModels(Provider provider)
	{
		RefreshingModelsId = provider.Id;
		RefreshModelsErrors.Remove(provider.Id);
		StateHasChanged();

		try
		{
			var models = await ProviderService.RefreshModelsAsync(provider.Id);
			ProviderModels[provider.Id] = models.ToList();
			await LoadPageData();
		}
		catch (TimeoutException ex)
		{
			RefreshModelsErrors[provider.Id] = ex.Message;
		}
		catch (Exception ex)
		{
			RefreshModelsErrors[provider.Id] = $"Error refreshing models: {ex.Message}";
		}
		finally
		{
			RefreshingModelsId = null;
		}
	}

	private async Task UpdateCli(Provider provider)
	{
		UpdatingCliId = provider.Id;
		StateHasChanged();

		try
		{
			var result = await HttpProviderService.UpdateCliAsync(provider.Id);

			if (result.Success)
			{
				var versionInfo = string.IsNullOrEmpty(result.PreviousVersion) || result.PreviousVersion == result.NewVersion
					? $"Version: {result.NewVersion}"
					: $"Updated from {result.PreviousVersion} to {result.NewVersion}";
				NotificationService.ShowSuccess($"{provider.Name} CLI updated successfully. {versionInfo}", "CLI Updated");

				UsageSummaries = await HttpProviderService.GetAllUsageSummariesAsync();
			}
			else
			{
				NotificationService.ShowError($"Failed to update {provider.Name} CLI: {result.ErrorMessage}", "CLI Update Failed");
			}
		}
		catch (Exception ex)
		{
			NotificationService.ShowError($"Error updating {provider.Name} CLI: {ex.Message}", "CLI Update Failed");
		}
		finally
		{
			UpdatingCliId = null;
			StateHasChanged();
		}
	}

	private async Task InstallCommonProviderAsync(ProviderType providerType)
	{
		InstallingProviderType = providerType;
		try
		{
			var result = await CommonProviderSetupService.InstallAsync(providerType);
			if (result.Success)
			{
				NotificationService.ShowSuccess(result.Message, "Provider Installed");
			}
			else
			{
				NotificationService.ShowError(result.ErrorMessage ?? $"Failed to install {providerType}.", "Install Failed");
			}
		}
		catch (Exception ex)
		{
			NotificationService.ShowError($"Error installing {providerType}: {ex.Message}", "Install Failed");
		}
		finally
		{
			InstallingProviderType = null;
			await LoadPageData();
			StateHasChanged();
		}
	}

	private async Task SaveCommonProviderAuthenticationAsync(CommonProviderSetupRequest request)
	{
		SavingAuthenticationProviderType = request.ProviderType;
		try
		{
			var result = await CommonProviderSetupService.SaveAuthenticationAsync(request);
			if (result.Success)
			{
				NotificationService.ShowSuccess(result.Message, "Authentication Saved");
				await LoadPageData();

				if (result.Status?.ProviderId is Guid providerId)
				{
					var provider = ProvidersList.FirstOrDefault(item => item.Id == providerId);
					if (provider != null)
					{
						await TestConnection(provider);
						if (TestResults.TryGetValue(provider.Id, out var connectionResult) && connectionResult.IsConnected)
						{
							await RefreshModels(provider);
						}
					}
				}
			}
			else
			{
				NotificationService.ShowError(result.ErrorMessage ?? $"Failed to save authentication for {request.ProviderType}.", "Authentication Failed");
			}
		}
		catch (Exception ex)
		{
			NotificationService.ShowError($"Error saving authentication for {request.ProviderType}: {ex.Message}", "Authentication Failed");
		}
		finally
		{
			SavingAuthenticationProviderType = null;
			StateHasChanged();
		}
	}

	private async Task ShowSelectDefaultModelModal(Provider provider)
	{
		ShowDeleteModal = false;
		ProviderToDelete = null;
		ShowProviderModal = false;
		EditingProvider = null;

		DefaultModelProvider = provider;
		ShowDefaultModelModal = true;
		IsLoadingDefaultModels = true;
		StateHasChanged();

		try
		{
			var models = await ProviderService.RefreshModelsAsync(provider.Id);
			var modelsList = models.ToList();
			ProviderModels[provider.Id] = modelsList;
			DefaultModelList = modelsList.ToList();
		}
		catch (Exception)
		{
			if (ProviderModels.TryGetValue(provider.Id, out var cachedModels))
			{
				DefaultModelList = cachedModels.ToList();
			}
		}
		finally
		{
			IsLoadingDefaultModels = false;
			StateHasChanged();
		}
	}

	private async Task SelectDefaultModel(ProviderModel model)
	{
		if (DefaultModelProvider == null)
		{
			return;
		}

		IsSettingDefaultModel = true;
		StateHasChanged();

		try
		{
			await ProviderService.SetDefaultModelAsync(DefaultModelProvider.Id, model.Id);

			foreach (var providerModel in DefaultModelList)
			{
				providerModel.IsDefault = providerModel.Id == model.Id;
			}

			if (ProviderModels.TryGetValue(DefaultModelProvider.Id, out var providerModels))
			{
				foreach (var providerModel in providerModels)
				{
					providerModel.IsDefault = providerModel.Id == model.Id;
				}
			}
		}
		catch (Exception)
		{
		}
		finally
		{
			IsSettingDefaultModel = false;
			StateHasChanged();
		}
	}

	private void HandleDefaultModelModalClosed()
	{
		ShowDefaultModelModal = false;
		DefaultModelProvider = null;
		DefaultModelList = [];
		StateHasChanged();
	}
}
