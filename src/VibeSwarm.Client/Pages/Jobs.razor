@page "/jobs"
@page "/jobs/{ProjectFilter:guid?}"
@attribute [Authorize]
@inject IJobService JobService
@inject IProjectService ProjectService
@inject IProviderService ProviderService
@inject IJobTemplateService JobTemplateService
@inject IVersionControlService VersionControlService
@inject NavigationManager NavigationManager
@inject NotificationService NotificationService
@inject IJSRuntime JSRuntime
@implements IAsyncDisposable
@using System.Threading
@using Microsoft.AspNetCore.SignalR.Client

@* Mobile: Project filter dropdown *@
<div class="d-lg-none mb-3 jobs-mobile-filters">
	<div class="d-grid gap-2">
		<select class="form-select w-100" @onchange="OnProjectFilterChanged" disabled="@_isLoadingProjects" aria-label="Filter jobs by project">
			@if (_isLoadingProjects)
			{
				<option value="">Loading projects...</option>
			}
			else
			{
				<option value="" selected="@(_selectedProjectId == null)">All Projects</option>
				@foreach (var project in _projects)
				{
					<option value="@project.Id" selected="@(_selectedProjectId == project.Id)">
						@(project.IsActive ? "" : "[Inactive] ")@project.Name (@GetJobCountForProject(project.Id))
					</option>
				}
			}
		</select>
		<div class="row g-2">
			<div class="@(_selectedProjectId.HasValue ? "col-12 col-sm-7" : "col-12")">
				<select class="form-select" value="@_statusFilter" @onchange="OnStatusFilterChanged" aria-label="Filter jobs by status">
					<option value="all">All jobs</option>
					<option value="active">Active jobs</option>
					<option value="completed">Completed jobs</option>
					<option value="failed">Failed jobs</option>
				</select>
			</div>
			@if (_selectedProjectId.HasValue)
			{
				<div class="col-12 col-sm-5">
					<button type="button" class="btn btn-primary w-100" @onclick="ShowCreateJobModal"
							disabled="@_isLoadingProjects">
						<i class="bi bi-plus-lg me-1"></i>Create Job
					</button>
				</div>
			}
		</div>
	</div>
</div>

@* Desktop: Inbox-style split layout *@
<div class="jobs-inbox-layout flex-grow-1 d-flex flex-column flex-lg-row">
	@* Project Sidebar (desktop only) *@
	<aside class="jobs-project-sidebar d-none d-lg-flex flex-column border-end bg-body flex-shrink-0">
		<div class="p-3 border-bottom">
			<h5 class="mb-0 fw-semibold d-flex align-items-center gap-2">
				<i class="bi bi-inbox"></i> Jobs
				@if (_selectedProjectId.HasValue)
				{
					<button type="button" class="btn btn-sm btn-primary ms-auto" @onclick="ShowCreateJobModal"
							title="Create Job" disabled="@_isLoadingProjects">
						<i class="bi bi-plus-lg me-1"></i><span class="d-none d-xl-inline">Create Job</span>
					</button>
				}
			</h5>
		</div>
		<div class="flex-grow-1 overflow-auto">
			@* All Projects option *@
			<button type="button"
					class="project-filter-item w-100 text-start border-0 bg-transparent d-flex align-items-center gap-2 p-3 cursor-pointer @(_selectedProjectId == null ? "active" : "")"
					@onclick="() => SelectProject(null)">
				<i class="bi bi-collection"></i>
				<span class="flex-grow-1">All Projects</span>
				<span class="badge bg-secondary-subtle text-secondary-emphasis rounded-pill">@GetOverallJobCount()</span>
			</button>

			<div class="border-top"></div>

			@if (_isLoadingProjects)
			{
				<LoadingSpinner Text="Loading projects..." />
			}
			else
			{
				@* Project list *@
				@foreach (var project in _projects)
				{
					var jobCount = GetJobCountForProject(project.Id);
					var activeCount = GetActiveCountForProject(project.Id);
					<button type="button"
							class="project-filter-item w-100 text-start border-0 bg-transparent d-flex align-items-center gap-2 p-3 cursor-pointer @(_selectedProjectId == project.Id ? "active" : "") @(!project.IsActive ? "opacity-50" : "")"
							@onclick="() => SelectProject(project.Id)">
						<i class="bi bi-folder"></i>
						<span class="flex-grow-1 text-truncate">@project.Name</span>
						@if (!project.IsActive)
						{
							<i class="bi bi-pause-circle text-secondary" title="Inactive"></i>
						}
						@if (activeCount > 0)
						{
							<span class="badge bg-info rounded-pill">@activeCount</span>
						}
						<span class="badge bg-secondary-subtle text-secondary-emphasis rounded-pill">@jobCount</span>
					</button>
				}
			}
		</div>

		@* Status filter buttons in sidebar footer *@
		<div class="p-3 border-top">
			<div class="btn-group w-100" role="group">
				<button type="button" class="btn btn-sm @(_statusFilter == "all" ? "btn-primary" : "btn-secondary")"
						@onclick='() => SetStatusFilter("all")'>All</button>
				<button type="button" class="btn btn-sm @(_statusFilter == "active" ? "btn-info" : "btn-secondary")"
						@onclick='() => SetStatusFilter("active")'>Active</button>
				<button type="button"
						class="btn btn-sm @(_statusFilter == "completed" ? "btn-success" : "btn-secondary")"
						@onclick='() => SetStatusFilter("completed")'>Done</button>
				<button type="button" class="btn btn-sm @(_statusFilter == "failed" ? "btn-danger" : "btn-secondary")"
						@onclick='() => SetStatusFilter("failed")'>Failed</button>
			</div>
		</div>
	</aside>

	@* Job List Panel *@
	<div class="jobs-list-panel flex-grow-1 d-flex flex-column min-width-0 bg-body">
		@* Stats header *@
		@if (!ShowJobsLoadingSpinner && HasTokenData())
		{
			<div class="d-flex flex-wrap align-items-center gap-2 p-2 px-3 border-bottom bg-body-secondary small">
				@if (GetTotalInputTokens() > 0 || GetTotalOutputTokens() > 0)
				{
					<span class="d-flex align-items-center gap-1">
						<i class="bi bi-arrow-left-right opacity-75"></i>
						@TokenHelper.FormatTokenCount(GetTotalInputTokens() + GetTotalOutputTokens()) tokens
					</span>
				}
				@if (GetTotalCost() > 0)
				{
					<span class="d-flex align-items-center gap-1 text-success fw-medium">
						<i class="bi bi-currency-dollar opacity-75"></i>
						@TokenHelper.FormatCost(GetTotalCost())
					</span>
				}
				<span class="ms-auto text-body-secondary">
					@_jobsResult.TotalCount jobs
				</span>
			</div>
		}

		@* Job list *@
		<div class="flex-grow-1 overflow-auto">
			@if (ShowJobsLoadingSpinner)
			{
				<LoadingSpinner Text="Loading jobs..." />
			}
			else if (GetOverallJobCount() == 0)
			{
				<EmptyState Icon="list-check" Title="No jobs yet"
							Message="Jobs are created when you run AI agent tasks on your projects.">
					@if (_selectedProjectId.HasValue)
					{
						<button type="button" class="btn btn-sm btn-primary" @onclick="ShowCreateJobModal">
							<i class="bi bi-plus-lg me-1"></i>Create Job
						</button>
					}
					else
					{
						<a href="/projects" class="btn btn-sm btn-primary">
							<i class="bi bi-folder me-1"></i>Go to Projects
						</a>
					}
				</EmptyState>
			}
			else if (!_jobsResult.Items.Any())
			{
				<EmptyState Icon="@GetFilterEmptyIcon()" Title="@GetFilterEmptyTitle()" Message="@GetFilterEmptyMessage()">
					@if (_selectedProjectId.HasValue)
					{
						<button type="button" class="btn btn-sm btn-primary" @onclick="ShowCreateJobModal">
							<i class="bi bi-plus-lg me-1"></i>Create Job
						</button>
					}
				</EmptyState>
			}
			else
			{
				@foreach (var job in _jobsResult.Items)
				{
					<JobListItem Status="@job.Status.ToString()" Prompt="@GetJobDisplayTitle(job)"
								 ProjectName="@(job.ProjectName ?? "Unknown")" ShowProjectName="@(_selectedProjectId == null)"
								 ProviderName="@job.ProviderName" ModelUsed="@job.ModelUsed"
								 PlanningProviderName="@job.PlanningProviderName" PlanningModelUsed="@job.PlanningModelUsed"
								 Activity="@((job.Status == JobStatus.Started || job.Status == JobStatus.Planning || job.Status == JobStatus.Processing) ? (job.CurrentActivity ?? "Working...") : null)"
								 TimeDisplay="@GetTimeDisplay(job)" Cost="@job.TotalCostUsd" InputTokens="@job.InputTokens"
								 OutputTokens="@job.OutputTokens" CurrentCycle="@job.CurrentCycle" MaxCycles="@job.MaxCycles"
								 CycleMode="@job.CycleMode" TeamRoleName="@job.TeamRoleName"
								 PlaywrightEnabled="@job.PlaywrightEnabled" EnvironmentCount="@job.EnvironmentCount"
								 ChangedFilesCount="@job.ChangedFilesCount" BuildVerified="@job.BuildVerified"
								 GitCommitHash="@job.GitCommitHash" PullRequestUrl="@job.PullRequestUrl"
								 PullRequestNumber="@job.PullRequestNumber" MergedAt="@job.MergedAt"
								 OnClick="@(() => NavigateToJob(job.Id))" />
				}
			}
		</div>

		<PaginationControls PageNumber="@_pageNumber" PageSize="@JobsPageSize" TotalCount="@_jobsResult.TotalCount"
							IsLoading="@(_isRefreshing || _isLoadingJobs)" OnPreviousPage="LoadPreviousPage" OnNextPage="LoadNextPage" />
	</div>
</div>

@* Create Job Modal *@
<CreateJobModal @bind-IsVisible="_showCreateJobModal" JobModel="@_newJob" Providers="@GetAllowedCreateJobProviders()"
				AvailableModels="@_availableModels" Branches="@_branches" CurrentBranch="@_currentBranch"
				ShowBranchSelector="@(_branches.Any())" IsLoadingModels="@_isLoadingModels" IsSaving="@_isSaving"
				ErrorMessage="@_createJobError" @bind-SelectedModelId="@_selectedModelId" OnProviderChanged="OnCreateJobProviderChanged"
				TemplateLibrary="@_jobTemplates" OnTemplateLibraryChanged="LoadJobTemplates" OnSubmit="HandleCreateJob" />

@code {
    [Parameter]
    public Guid? ProjectFilter { get; set; }

    private const int JobsPageSize = 25;

    private JobsListResult _jobsResult = new();
    private IEnumerable<Project> _projects = Enumerable.Empty<Project>();
    private bool _isLoadingProjects = true;
    private bool _isLoadingJobs = true;
    private bool _hasLoadedJobsInitially;
    private string _statusFilter = "all";
    private Guid? _selectedProjectId;
    private int _pageNumber = 1;
    private HubConnection? _hubConnection;
    private Timer? _refreshTimer;
    private bool _isRefreshing = false;
    private CancellationTokenSource? _signalRCts;
    private bool ShowJobsLoadingSpinner => _isLoadingJobs && !_hasLoadedJobsInitially;

    // Create Job modal state
    private bool _showCreateJobModal;
    private Job _newJob = new();
    private List<Provider> _providers = new();
    private List<ProviderModel> _availableModels = new();
    private List<JobTemplate> _jobTemplates = new();
    private List<GitBranchInfo> _branches = new();
    private string? _currentBranch;
	private bool _isLoadingModels;
	private bool _isSaving;
	private string? _createJobError;

	private void OnStatusFilterChanged(ChangeEventArgs e)
	{
		SetStatusFilter(e.Value?.ToString() ?? "all");
	}
    private string _selectedModelId = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        _selectedProjectId = ProjectFilter;
        await LoadData();
        await LoadJobTemplates();
        StartAutoRefresh();
    }

    protected override void OnParametersSet()
    {
        if (ProjectFilter != _selectedProjectId)
        {
            _selectedProjectId = ProjectFilter;
            _pageNumber = 1;
            if (!_isLoadingJobs)
            {
                _ = RefreshJobsSafely();
            }
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Fire-and-forget with timeout protection for SignalR
            _ = InitializeSignalRSafe();
        }
    }

    /// <summary>
    /// Safe wrapper for SignalR initialization with timeout
    /// </summary>
    private async Task InitializeSignalRSafe()
    {
        try
        {
            _signalRCts = new CancellationTokenSource();
            using var timeoutCts = new CancellationTokenSource(TimeSpan.FromSeconds(10));
            using var linkedCts = CancellationTokenSource.CreateLinkedTokenSource(
            _signalRCts.Token, timeoutCts.Token);

            await InitializeSignalR(linkedCts.Token);
        }
        catch (OperationCanceledException)
        {
        }
        catch (Exception)
        {
        }
    }

    private void StartAutoRefresh()
    {
        _refreshTimer = new Timer(async _ =>
        {
            if (HasActiveJobs() && !_isRefreshing)
            {
                try
                {
                    await InvokeAsync(async () =>
                    {
                        await RefreshJobsSafely();
                    });
                }
                catch (ObjectDisposedException) { }
                catch (Exception)
                {
                }
            }
        }, null, TimeSpan.FromSeconds(10), TimeSpan.FromSeconds(10));
    }

    private bool HasActiveJobs()
    {
        return _jobsResult.ProjectCounts.Sum(count => count.ActiveCount) > 0;
    }

    private async Task RefreshJobsSafely()
    {
        if (_isRefreshing) return;

        try
        {
            _isRefreshing = true;
            await LoadJobsAsync();
            StateHasChanged();
        }
        catch (Exception)
        {
        }
        finally
        {
            _isRefreshing = false;
        }
    }

    private async Task InitializeSignalR(CancellationToken cancellationToken)
    {
        try
        {
            _hubConnection = new HubConnectionBuilder()
            .WithUrl(NavigationManager.ToAbsoluteUri("/hubs/job"))
            .WithAutomaticReconnect(new[] { TimeSpan.Zero, TimeSpan.FromSeconds(2), TimeSpan.FromSeconds(5),
TimeSpan.FromSeconds(10) })
            .Build();

            _hubConnection.On<string, string>("JobStatusChanged", async (jobId, status) =>
            {
                await OnJobStatusChanged(jobId, status);
            });

            _hubConnection.On<string, string, DateTime>("JobActivityUpdated", async (jobId, activity, timestamp) =>
            {
                await OnJobActivityUpdated(jobId, activity, timestamp);
            });

            _hubConnection.On<string, string>("JobCreated", async (jobId, projectId) =>
            {
                await OnJobCreated(jobId, projectId);
            });

            _hubConnection.On<string, string>("JobDeleted", async (jobId, projectId) =>
            {
                await OnJobDeleted(jobId, projectId);
            });

            _hubConnection.On<string, bool, string?>("JobCompleted", async (jobId, success, errorMessage) =>
            {
                await OnJobCompleted(jobId, success, errorMessage);
            });

            _hubConnection.On("JobListChanged", async () =>
            {
                await OnJobListChanged();
            });

            _hubConnection.On<string, int, int>("JobCycleProgress", async (jobId, currentCycle, maxCycles) =>
            {
                if (Guid.TryParse(jobId, out var id))
                {
                    var job = _jobsResult.Items.FirstOrDefault(j => j.Id == id);
                    if (job != null)
                    {
                        job.CurrentCycle = currentCycle;
                        job.MaxCycles = maxCycles;
                        await InvokeAsync(StateHasChanged);
                    }
                }
            });

            // Handle reconnection - re-subscribe to groups
            _hubConnection.Reconnected += async (connectionId) =>
            {
                try { await _hubConnection.InvokeAsync("SubscribeToJobList"); } catch { }
            };

            await _hubConnection.StartAsync(cancellationToken);
            await _hubConnection.InvokeAsync("SubscribeToJobList");
        }
        catch (Exception ex) when (ex is not OperationCanceledException)
        {
        }
    }

    private async Task OnJobStatusChanged(string jobId, string status)
    {
        if (Guid.TryParse(jobId, out var id) && Enum.TryParse<JobStatus>(status, out var newStatus))
        {
            var job = _jobsResult.Items.FirstOrDefault(j => j.Id == id);
            if (job != null)
            {
                job.Status = newStatus;
                if (newStatus == JobStatus.Started)
                {
                    job.StartedAt = DateTime.UtcNow;
                }
                else if (newStatus == JobStatus.Completed || newStatus == JobStatus.Failed || newStatus == JobStatus.Cancelled)
                {
                    job.CompletedAt = DateTime.UtcNow;
                }
                await InvokeAsync(StateHasChanged);
            }
        }

        if (!_isRefreshing)
        {
            _ = Task.Run(async () =>
            {
                await Task.Delay(500);
                await InvokeAsync(async () => await RefreshJobsSafely());
            });
        }
    }

    private async Task OnJobActivityUpdated(string jobId, string activity, DateTime timestamp)
    {
        if (Guid.TryParse(jobId, out var id))
        {
            var job = _jobsResult.Items.FirstOrDefault(j => j.Id == id);
            if (job != null)
            {
                job.CurrentActivity = activity;
                await InvokeAsync(StateHasChanged);
            }
        }
    }

    private async Task OnJobCreated(string jobId, string projectId)
    {
        if (!_isRefreshing)
        {
            await InvokeAsync(async () => await RefreshJobsSafely());
        }
    }

    public async Task OnJobDeleted(string jobId, string projectId)
    {
        if (!_isRefreshing)
        {
            await InvokeAsync(async () => await RefreshJobsSafely());
        }
    }

    public async Task OnJobCompleted(string jobId, bool success, string? errorMessage)
    {
        if (Guid.TryParse(jobId, out var id))
        {
            var job = _jobsResult.Items.FirstOrDefault(j => j.Id == id);
            if (job != null)
            {
                job.Status = success ? JobStatus.Completed : JobStatus.Failed;
                job.CompletedAt = DateTime.UtcNow;
                if (!string.IsNullOrEmpty(errorMessage))
                {
                    job.ErrorMessage = errorMessage;
                }
                await InvokeAsync(StateHasChanged);
            }
        }

        if (!_isRefreshing)
        {
            await InvokeAsync(async () => await RefreshJobsSafely());
        }
    }

    public async Task OnJobListChanged()
    {
        if (!_isRefreshing)
        {
            await InvokeAsync(async () => await RefreshJobsSafely());
        }
    }

    private async Task LoadData()
    {
        var jobsTask = LoadJobsAsync();
        var projectsTask = LoadProjectsAsync();

        await Task.WhenAll(jobsTask, projectsTask);
    }

    private async Task LoadProjectsAsync()
    {
        _isLoadingProjects = true;
        try
        {
            _projects = await ProjectService.GetAllAsync();
        }
        catch (Exception ex)
        {
            NotificationService.ShowError($"Failed to load projects: {ex.Message}");
        }
        finally
        {
            _isLoadingProjects = false;
        }
    }

    private async Task LoadJobsAsync()
    {
        _isLoadingJobs = true;
        try
        {
            _jobsResult = await JobService.GetPagedAsync(_selectedProjectId, _statusFilter, _pageNumber, JobsPageSize);
            _pageNumber = _jobsResult.PageNumber;
            _hasLoadedJobsInitially = true;
        }
        catch (Exception ex)
        {
            NotificationService.ShowError($"Failed to load jobs: {ex.Message}");
        }
        finally
        {
            _isLoadingJobs = false;
        }
    }

    private void SetStatusFilter(string filter)
    {
        _statusFilter = filter;
        _pageNumber = 1;
        _ = RefreshJobsSafely();
    }

    private void SelectProject(Guid? projectId)
    {
        _selectedProjectId = projectId;
        _pageNumber = 1;
        // Update URL without full navigation to preserve state
        var url = projectId.HasValue ? $"/jobs/{projectId}" : "/jobs";
        NavigationManager.NavigateTo(url, forceLoad: false, replace: true);
        _ = RefreshJobsSafely();
    }

    private void OnProjectFilterChanged(ChangeEventArgs e)
    {
        if (Guid.TryParse(e.Value?.ToString(), out var projectId))
        {
            SelectProject(projectId);
        }
        else
        {
            SelectProject(null);
        }
    }

    private int GetJobCountForProject(Guid projectId) => _jobsResult.ProjectCounts.FirstOrDefault(c => c.ProjectId == projectId)?.TotalCount ?? 0;
    private int GetActiveCountForProject(Guid projectId) => _jobsResult.ProjectCounts.FirstOrDefault(c => c.ProjectId == projectId)?.ActiveCount ?? 0;
    private int GetOverallJobCount() => _jobsResult.ProjectCounts.Sum(c => c.TotalCount);

    // Token and cost summary methods
    private int GetTotalInputTokens() => _jobsResult.TotalInputTokens;
    private int GetTotalOutputTokens() => _jobsResult.TotalOutputTokens;
    private decimal GetTotalCost() => _jobsResult.TotalCostUsd;
    private bool HasTokenData() => GetTotalInputTokens() > 0 || GetTotalOutputTokens() > 0 || GetTotalCost() > 0;

    private string GetFilterEmptyIcon() => _statusFilter switch
    {
        "active" => "activity",
        "completed" => "check-circle",
        "failed" => "x-circle",
        _ => "inbox"
    };

    private string GetFilterEmptyTitle() => _statusFilter switch
    {
        "active" => "No active jobs",
        "completed" => "No completed jobs",
        "failed" => "No failed jobs",
        _ => "No jobs"
    };

    private string GetFilterEmptyMessage() => _statusFilter switch
    {
        "active" => "There are no jobs currently running. Start a new job from a project.",
        "completed" => "No jobs have been completed yet.",
        "failed" => "No jobs have failed. That's good news!",
        _ => "No jobs to display."
    };

    private void NavigateToJob(Guid jobId)
    {
        // Include project filter as query param so we can return to the same view
        var returnUrl = _selectedProjectId.HasValue ? $"/jobs/{_selectedProjectId}" : "/jobs";
        NavigationManager.NavigateTo($"/jobs/view/{jobId}?returnUrl={Uri.EscapeDataString(returnUrl)}");
    }

    private static string TruncatePrompt(string prompt, int maxLength)
    {
        if (string.IsNullOrEmpty(prompt) || prompt.Length <= maxLength)
            return prompt;
        return prompt[..maxLength] + "...";
    }

    private static string GetTimeDisplay(JobSummary job)
    {
        if (job.CompletedAt.HasValue)
        {
            var duration = job.CompletedAt.Value - (job.StartedAt ?? job.CreatedAt);
            return $"Completed in {FormatDuration(duration)}";
        }
        if (job.StartedAt.HasValue)
        {
            var duration = DateTime.UtcNow - job.StartedAt.Value;
            return $"Running for {FormatDuration(duration)}";
        }
        return $"Created {FormatTimeAgo(job.CreatedAt)}";
    }

    private static string FormatDuration(TimeSpan duration)
    {
        if (duration.TotalMinutes < 1) return $"{duration.Seconds}s";
        if (duration.TotalHours < 1) return $"{duration.Minutes}m {duration.Seconds}s";
        return $"{(int)duration.TotalHours}h {duration.Minutes}m";
    }

    private static string FormatTimeAgo(DateTime time)
    {
        var elapsed = DateTime.UtcNow - time;
        if (elapsed.TotalMinutes < 1) return "just now";
        if (elapsed.TotalMinutes < 60) return $"{(int)elapsed.TotalMinutes}m ago";
        if (elapsed.TotalHours < 24) return $"{(int)elapsed.TotalHours}h ago";
        return $"{(int)elapsed.TotalDays}d ago";
    }

    private static string GetJobDisplayTitle(JobSummary job)
    {
        // Use Title if available, otherwise use GoalPrompt
        return !string.IsNullOrEmpty(job.Title) ? job.Title : job.GoalPrompt;
    }

    private async Task LoadPreviousPage()
    {
        if (_pageNumber <= 1 || _isRefreshing)
        {
            return;
        }

        _pageNumber--;
        await RefreshJobsSafely();
    }

    private async Task LoadNextPage()
    {
        if (_isRefreshing || (_pageNumber * JobsPageSize) >= _jobsResult.TotalCount)
        {
            return;
        }

        _pageNumber++;
        await RefreshJobsSafely();
    }

    // Create Job modal methods
    private async Task ShowCreateJobModal()
    {
        if (!_selectedProjectId.HasValue) return;

        _newJob = new Job
        {
            ProjectId = _selectedProjectId.Value
        };
        _createJobError = null;
        _selectedModelId = string.Empty;
        _availableModels.Clear();
        _branches.Clear();
        _newJob.ReasoningEffort = null;

        try
        {
            await LoadJobTemplates();
            // Load providers
            _providers = (await ProviderService.GetAllAsync()).ToList();

            // Load branch info for the selected project
            var project = _projects.FirstOrDefault(p => p.Id == _selectedProjectId.Value);
            if (project != null && !string.IsNullOrEmpty(project.WorkingPath))
            {
                try
                {
                    var isRepo = await VersionControlService.IsGitRepositoryAsync(project.WorkingPath);
                    if (isRepo)
                    {
                        _currentBranch = await VersionControlService.GetCurrentBranchAsync(project.WorkingPath);
                        _branches = (await VersionControlService.GetBranchesAsync(project.WorkingPath)).ToList();
                        _newJob.Branch = _currentBranch;
                    }
                }
                catch
                {
                    // Ignore git errors — branch selection will be hidden
                }
            }

            var defaultProvider = GetPreferredCreateJobProvider();
            if (defaultProvider != null)
            {
                _newJob.ProviderId = defaultProvider.Id;
                await LoadCreateJobModels(defaultProvider.Id);
            }
        }
        catch (Exception ex)
        {
            _createJobError = $"Error loading data: {ex.Message}";
        }

        _showCreateJobModal = true;
    }

    private async Task OnCreateJobProviderChanged(Guid providerId)
    {
        if (providerId != Guid.Empty && !GetAllowedCreateJobProviders().Any(provider => provider.Id == providerId))
        {
            _createJobError = "This provider is not enabled for the selected project.";
            return;
        }

        _newJob.ProviderId = providerId;
        _selectedModelId = string.Empty;
        _availableModels.Clear();
        _createJobError = null;

        if (providerId != Guid.Empty)
        {
            await LoadCreateJobModels(providerId);
        }
    }

    private async Task LoadCreateJobModels(Guid providerId)
    {
        _isLoadingModels = true;
        try
        {
            _availableModels = (await ProviderService.GetModelsAsync(providerId))
                .Where(model => model.IsAvailable)
                .OrderByDescending(model => model.IsDefault)
                .ThenBy(model => model.DisplayName ?? model.ModelId)
                .ToList();

            if (_selectedProjectId.HasValue)
            {
                _selectedModelId = ProjectExecutionDefaults.ResolveModelId(GetSelectedProject(), providerId, _availableModels);
                var provider = GetAllowedCreateJobProviders().FirstOrDefault(item => item.Id == providerId);
                _newJob.ReasoningEffort = provider != null
                    ? ProjectExecutionDefaults.ResolveReasoningEffort(GetSelectedProject(), provider)
                    : null;
            }
        }
        finally
        {
            _isLoadingModels = false;
        }
    }

    private Project? GetSelectedProject()
    {
        return _selectedProjectId.HasValue
            ? _projects.FirstOrDefault(project => project.Id == _selectedProjectId.Value)
            : null;
    }

    private List<Provider> GetAllowedCreateJobProviders()
    {
        return ProjectExecutionDefaults.GetAllowedProviders(GetSelectedProject(), _providers);
    }

    private Provider? GetPreferredCreateJobProvider()
    {
        return ProjectExecutionDefaults.GetPreferredProvider(GetSelectedProject(), _providers);
    }

    private async Task HandleCreateJob()
    {
        if (_newJob.ProviderId == Guid.Empty)
        {
            _createJobError = "Please select a provider.";
            return;
        }

        _isSaving = true;
        _createJobError = null;

        try
        {
            _newJob.ModelUsed = string.IsNullOrEmpty(_selectedModelId) ? null : _selectedModelId;
            var createdJob = await JobService.CreateAsync(_newJob);
            _showCreateJobModal = false;
            _pageNumber = 1;
            NotificationService.ShowSuccess("Job created successfully.");
            await RefreshJobsSafely();
        }
        catch (Exception ex)
        {
            _createJobError = $"Error creating job: {ex.Message}";
        }
        finally
        {
            _isSaving = false;
        }
    }

    private async Task LoadJobTemplates()
    {
        _jobTemplates = (await JobTemplateService.GetAllAsync()).ToList();
    }

    public async ValueTask DisposeAsync()
    {
        _signalRCts?.Cancel();
        _signalRCts?.Dispose();
        _refreshTimer?.Dispose();

        if (_hubConnection != null)
        {
            try
            {
                await _hubConnection.DisposeAsync();
            }
            catch
            {
                // Ignore disposal errors
            }
        }
    }
}
