@page "/projects/{ProjectId:guid}"
@attribute [Authorize]
@inject IProjectService ProjectService
@inject IJobService JobService
@inject IProviderService ProviderService
@inject IVersionControlService VersionControlService
@inject IIdeaService IdeaService
@inject IInferenceService InferenceService
@inject IInferenceProviderService InferenceProviderService
@inject IAutoPilotService AutoPilotService
@inject NavigationManager NavigationManager
@inject NotificationService NotificationService
@implements IAsyncDisposable
@using VibeSwarm.Client.Models
@using VibeSwarm.Shared.Inference
@using VibeSwarm.Shared.Models
@using VibeSwarm.Shared.Services
@using VibeSwarm.Shared.Utilities
@using VibeSwarm.Shared.VersionControl
@using VibeSwarm.Shared.VersionControl.Models
@using Microsoft.AspNetCore.SignalR.Client

@if (IsLoading)
{
    <LoadingSpinner />
}
else if (Project == null)
{
    <Breadcrumb
    Items="@(new List<Breadcrumb.BreadcrumbItem> { new("Projects", "/projects", "folder"), new("Not Found") })" />
    <Alert Type="Alert.AlertType.Warning" Message="Project not found." />
}
else
{
    @* Project Header Component *@
    <ProjectDetailHeaderCompact Name="@Project.Name" WorkingPath="@Project.WorkingPath"
                                GitHubRepository="@Project.GitHubRepository" IsGitRepository="@IsGitRepository"
                                IsLoadingGitInfo="@_isLoadingGitInfo" Branches="@Branches" CurrentBranch="@CurrentBranch"
                                CurrentCommitHash="@CurrentCommitHash" IsGitOperationInProgress="@IsGitOperationInProgress"
                                GitOperationMessage="@GitOperationMessage" GitOperationSuccess="@GitOperationSuccess"
                                GitProgressMessage="@GitProgressMessage" HasUncommittedChanges="@_hasUncommittedChangesHeader"
                                UncommittedFilesCount="@_uncommittedFilesCount" HasTokenData="@HasProjectTokenData()"
                                TotalInputTokens="@GetProjectTotalInputTokens()" TotalOutputTokens="@GetProjectTotalOutputTokens()"
                                TotalCost="@GetProjectTotalCost()" OnCreateBranch="ShowCreateBranchModal" OnSync="SyncWithOrigin"
                                OnRefresh="RefreshBranches" OnBranchSelected="RequestBranchSwitch"
                                OnUncommittedChangesClick="ShowUncommittedChangesModal" OnClearGitMessage="ClearGitMessage"
                                OnEdit="ShowEditProjectModal" OnPruneBranches="PruneRemoteBranches"
                                ShowMergeBranchAction="@HasMergeBranchTargets" IsMerging="@_isMergingBranch"
                                OnMergeBranch="ShowMergeBranchModal" IsActive="@(Project?.IsActive ?? true)"
                                OnToggleActive="ToggleProjectActive"
                                AutoPilotStatus="@_autoPilotStatus"
                                IsIdeasProcessingActive="@IsIdeasProcessingActive"
                                IdeasUnprocessedCount="@IdeasUnprocessedCount"
                                ActiveJob="@ActiveJob"
                                IsStoppingAll="@_isStoppingAll"
                                CanSuggestIdeas="@CanSuggestIdeas"
                                OnStop="StopAllActive"
                                OnSuggestIdeas="SuggestIdeasFromCodebase" />

    @* Tabbed Content Area *@
    <div class="project-detail-tabs mt-3">
        <ul class="nav nav-tabs d-none d-sm-flex" role="tablist">
            <li class="nav-item" role="presentation">
                <button type="button" class="nav-link @(IsActiveTab("ideas") ? "active" : string.Empty)"
                        @onclick='@(() => SetActiveTab("ideas"))' role="tab">
                    <i class="bi bi-lightbulb me-1"></i>
                    <span>Ideas</span>
                    @if (IdeasTotalCount > 0)
                    {
                        <span class="badge bg-secondary ms-1">@IdeasTotalCount</span>
                    }
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button type="button" class="nav-link @(IsActiveTab("jobs") ? "active" : string.Empty)"
                        @onclick='@(() => SetActiveTab("jobs"))' role="tab">
                    <i class="bi bi-list-task me-1"></i>
                    <span>Jobs</span>
                    @if (JobsTotalCount > 0)
                    {
                        <span class="badge bg-secondary ms-1">@JobsTotalCount</span>
                    }
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button type="button" class="nav-link @(IsActiveTab("environments") ? "active" : string.Empty)"
                        @onclick='@(() => SetActiveTab("environments"))' role="tab">
                    <i class="bi bi-globe2 me-1"></i>
                    <span>Environments</span>
                    @if (EnabledEnvironmentCount > 0)
                    {
                        <span class="badge bg-secondary ms-1">@EnabledEnvironmentCount</span>
                    }
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button type="button" class="nav-link @(IsActiveTab("changes") ? "active" : string.Empty) @(!IsGitRepository ? "disabled" : string.Empty)"
                        @onclick="OpenChangesTabAsync" role="tab"
                        disabled="@(!IsGitRepository)">
                    <i class="bi bi-file-diff me-1"></i>
                    <span>Changes</span>
                    @if (HasChangesTabContent && _workingTreeStatus.ChangedFilesCount > 0)
                    {
                        <span class="badge bg-warning text-dark ms-1">@_workingTreeStatus.ChangedFilesCount</span>
                    }
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button type="button" class="nav-link @(IsActiveTab("autopilot") ? "active" : string.Empty)"
                        @onclick='@(() => SetActiveTab("autopilot"))' role="tab">
                    <i class="bi bi-robot me-1"></i>
                    <span>Auto-Pilot</span>
                    @if (_autoPilotStatus != null && !AutoPilotPanel.IsTerminal(_autoPilotStatus.Status))
                    {
                        <span class="badge @AutoPilotPanel.GetStatusBadgeClass(_autoPilotStatus.Status) ms-1">
                            @_autoPilotStatus.Status.ToString()
                        </span>
                    }
                </button>
            </li>
        </ul>

        <ul class="nav nav-tabs d-flex d-sm-none flex-nowrap align-items-stretch" role="tablist">
            <li class="nav-item flex-fill" role="presentation">
                <button type="button" class="nav-link w-100 @(IsActiveTab("ideas") ? "active" : string.Empty)"
                        @onclick='@(() => SetActiveTab("ideas"))' role="tab">
                    <i class="bi bi-lightbulb me-1"></i>
                    <span>Ideas</span>
                    @if (IdeasTotalCount > 0)
                    {
                        <span class="badge bg-secondary ms-1">@IdeasTotalCount</span>
                    }
                </button>
            </li>
            <li class="nav-item flex-fill" role="presentation">
                <button type="button" class="nav-link w-100 @(IsActiveTab("jobs") ? "active" : string.Empty)"
                        @onclick='@(() => SetActiveTab("jobs"))' role="tab">
                    <i class="bi bi-list-task me-1"></i>
                    <span>Jobs</span>
                    @if (JobsTotalCount > 0)
                    {
                        <span class="badge bg-secondary ms-1">@JobsTotalCount</span>
                    }
                </button>
            </li>
            <li class="nav-item flex-fill" role="presentation">
                <div class="dropdown h-100">
                    <button type="button" class="nav-link dropdown-toggle w-100 h-100 @(IsOverflowTabActive ? "active" : string.Empty)"
                            data-bs-toggle="dropdown" aria-expanded="false" title="More project tabs">
                        <i class="bi @GetOverflowToggleIcon() me-1"></i>
                        <span>@GetOverflowTabLabel()</span>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end w-100 shadow-sm">
                        <li>
                            <button type="button" class="dropdown-item d-flex align-items-center justify-content-between gap-2 @(IsActiveTab("environments") ? "active" : string.Empty)"
                                    @onclick='@(() => SetActiveTab("environments"))'>
                                <span class="d-flex align-items-center gap-2">
                                    <i class="bi bi-globe2"></i>
                                    <span>Environments</span>
                                </span>
                                @if (EnabledEnvironmentCount > 0)
                                {
                                    <span class="badge bg-secondary">@EnabledEnvironmentCount</span>
                                }
                            </button>
                        </li>
                        <li>
                            <button type="button" class="dropdown-item d-flex align-items-center justify-content-between gap-2 @(IsActiveTab("changes") ? "active" : string.Empty)"
                                    @onclick="OpenChangesTabAsync"
                                    disabled="@(!IsGitRepository)">
                                <span class="d-flex align-items-center gap-2">
                                    <i class="bi bi-file-diff"></i>
                                    <span>Changes</span>
                                </span>
                                @if (HasChangesTabContent && _workingTreeStatus.ChangedFilesCount > 0)
                                {
                                    <span class="badge bg-warning text-dark">@_workingTreeStatus.ChangedFilesCount</span>
                                }
                            </button>
                        </li>
                        <li>
                            <button type="button" class="dropdown-item d-flex align-items-center justify-content-between gap-2 @(IsActiveTab("autopilot") ? "active" : string.Empty)"
                                    @onclick='@(() => SetActiveTab("autopilot"))'>
                                <span class="d-flex align-items-center gap-2">
                                    <i class="bi bi-robot"></i>
                                    <span>Auto-Pilot</span>
                                </span>
                                @if (_autoPilotStatus != null && !AutoPilotPanel.IsTerminal(_autoPilotStatus.Status))
                                {
                                    <span class="badge @AutoPilotPanel.GetStatusBadgeClass(_autoPilotStatus.Status)">
                                        @_autoPilotStatus.Status.ToString()
                                    </span>
                                }
                            </button>
                        </li>
                    </ul>
                </div>
            </li>
        </ul>
    </div>

    <div class="tab-content pt-3">
        @if (_activeTab == "ideas")
        {
            <div class="tab-pane fade show active">
                @if (_isLoadingIdeas)
                {
                    <div class="border rounded-3 bg-body-tertiary p-3 p-lg-4">
                        <SkeletonLoader Lines="4" LineHeight="20" />
                    </div>
                }
                else
                {
                <IdeasPanel Ideas="@Ideas" TotalIdeasCount="@IdeasTotalCount" CurrentPage="@_ideasPageNumber"
                            PageSize="@IdeasPageSize" IsPageLoading="@_isLoadingIdeasPage" UnprocessedIdeasCount="@IdeasUnprocessedCount"
                            CurrentProjectId="@ProjectId" IsProcessingActive="@IsIdeasProcessingActive"
                            IsTogglingProcessing="@_isTogglingIdeasProcessing" HasDefaultProvider="@HasDefaultProvider"
                            HasActiveJobs="@HasActiveJobs" IsAddingIdea="@_isAddingIdea" ProcessingIdeaIds="@ProcessingIdeaIds"
                            CurrentAutoCommitMode="@(Project?.AutoCommitMode ?? AutoCommitMode.Off)"
                            IsGitRepository="@IsGitRepository"
                            DefaultProcessingProviderId="@GetDefaultIdeasProcessingProviderId()"
                            DefaultProcessingModelId="@GetDefaultIdeasProcessingModelId()"
                            OnStartProcessing="StartIdeasProcessing" OnStartProcessingWithOptions="StartIdeasProcessingWithOptions"
                            OnStopProcessing="StopIdeasProcessing" OnAddIdea="AddIdea" OnUpdateIdea="UpdateIdea"
                            OnDeleteIdea="DeleteIdea" OnCopyIdea="CopyIdea" OnMoveIdea="MoveIdea" OnStartSingleIdea="StartSingleIdea"
                            OnExpandIdea="ExpandIdea" OnCancelExpansion="CancelIdeaExpansion" OnApproveExpansion="ApproveIdeaExpansion"
                            OnRejectExpansion="RejectIdeaExpansion" AvailableLocalModels="@_availableLocalModels"
                            HasInference="@_hasInference" AvailableProviders="@Providers.Where(p => p.IsEnabled).ToList()"
                            AvailableInferenceProviders="@_availableInferenceProviders"
                            DefaultInferenceProviderId="@(Project?.IdeaInferenceProviderId)"
                            DefaultInferenceModelId="@(Project?.IdeaInferenceModelId)"
                            OnSuggestIdeas="SuggestIdeasFromCodebase" OnPreviousPage="LoadPreviousIdeasPage"
                            OnNextPage="LoadNextIdeasPage" />
                }
            </div>
        }
        @if (_activeTab == "jobs")
        {
            <div class="tab-pane fade show active">
                @if (_isLoadingJobs)
                {
                    <div class="border rounded-3 bg-body-tertiary p-3 p-lg-4">
                        <SkeletonLoader Lines="5" LineHeight="20" />
                    </div>
                }
                else
                {
                <ProjectJobsList Jobs="@PagedJobs" TotalJobsCount="@JobsTotalCount" CurrentPage="@_jobsPageNumber"
                                  PageSize="@ProjectJobsPageSize" IsPageLoading="@_isLoadingJobsPage" HasActiveJobs="@HasActiveJobs"
                                  HasCompletedJobs="@HasCompletedJobs" SearchQuery="@_jobSearchQuery" StatusFilter="@_jobStatusFilter"
                                  OnDeleteJob="DeleteJob" OnRetryJob="RetryJob" OnCreateJob="ShowCreateJobModal" OnPreviousPage="LoadPreviousJobsPage"
                                  OnNextPage="LoadNextJobsPage" OnCancelAll="CancelAllJobs"
                                  OnDeleteCompleted="DeleteCompletedJobs" OnSearchChanged="HandleJobSearchChanged"
                                  OnStatusFilterChanged="HandleJobStatusFilterChanged" />
                }
            </div>
        }
        @if (_activeTab == "environments")
        {
            <div class="tab-pane fade show active">
                @if (!string.IsNullOrEmpty(_environmentError))
                {
                    <Alert Type="Alert.AlertType.Danger" Message="@_environmentError" Class="mb-3" />
                }
                <div class="border rounded-3 bg-body-tertiary p-3 p-lg-4">
                    <EditForm Model="@Project" OnValidSubmit="SaveEnvironments">
                        <ProjectEnvironmentsEditor Project="@Project" />
                        <div class="d-flex justify-content-end mt-3 pt-3 border-top">
                            <button type="submit" class="btn btn-primary" disabled="@_isSavingEnvironments"
                                    title="@(_isSavingEnvironments ? "Saving environments" : "Save environment changes")">
                                @if (_isSavingEnvironments)
                                {
                                    <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                                }
                                <i class="bi bi-check-lg me-1"></i>Save Environments
                            </button>
                        </div>
                    </EditForm>
                </div>
            </div>
        }
        @if (_activeTab == "changes")
        {
            <div class="tab-pane fade show active">
                @if (_isLoadingChangesTab)
                {
                    <div class="d-flex align-items-center justify-content-center gap-2 py-5 text-body-secondary">
                        <span class="spinner-border spinner-border-sm" role="status"></span>
                        <span>Loading changes...</span>
                    </div>
                }
                else if (!string.IsNullOrEmpty(_changesTabLoadError))
                {
                    <Alert Type="Alert.AlertType.Danger" Message="@_changesTabLoadError" />
                }
                else if (_changesTabDiffFiles != null && _changesTabDiffFiles.Any())
                {
                    @if (_changesTabShowingCommittedDiff && _changesTabCommittedJobs.Any())
                    {
                        <div class="alert alert-success py-2 mb-3">
                            <div class="d-flex align-items-center gap-2 mb-2">
                                <i class="bi bi-git"></i>
                                <strong>Showing committed changes from @ShortCommitHash(_changesTabCommittedHash)</strong>
                            </div>
                            <div class="d-flex flex-wrap gap-1">
                                @foreach (var job in _changesTabCommittedJobs.Take(5))
                                {
                                    <span class="badge bg-success-subtle text-success border border-success-subtle">
                                        <i class="bi bi-check-circle me-1"></i>@TruncateForToast(job.Title ?? job.GoalPrompt, 40)
                                    </span>
                                }
                                @if (_changesTabCommittedJobs.Count > 5)
                                {
                                    <span class="badge bg-secondary-subtle text-secondary">
                                        +@(_changesTabCommittedJobs.Count - 5) more
                                    </span>
                                }
                            </div>
                            <div class="mt-2 small text-body-secondary">
                                <i class="bi bi-info-circle me-1"></i>The working directory is clean, so this view is using the linked commit diff.
                            </div>
                        </div>
                    }

                    @if (_changesTabShowingPersistedDiff && _changesTabPendingJobs.Any())
                    {
                        <div class="alert alert-info py-2 mb-3">
                            <div class="d-flex align-items-center gap-2 mb-2">
                                <i class="bi bi-shield-check"></i>
                                <strong>Showing the last captured diff for @_changesTabPendingJobs[0].DisplayTitle</strong>
                            </div>
                            <div class="small text-body-secondary">
                                <i class="bi bi-info-circle me-1"></i>This project is currently clean, so VibeSwarm is showing the diff captured on the job record instead.
                            </div>
                        </div>
                    }

                    @* Pending Jobs Section *@
                    @if (!_changesTabShowingCommittedDiff && !_changesTabShowingPersistedDiff && _changesTabPendingJobs != null && _changesTabPendingJobs.Any())
                    {
                        <div class="alert alert-info py-2 mb-3">
                            <div class="d-flex align-items-center gap-2 mb-2">
                                <i class="bi bi-info-circle"></i>
                                <strong>@_changesTabPendingJobs.Count completed job(s) may have contributed to these changes</strong>
                            </div>
                            <div class="d-flex flex-wrap gap-1">
                                @foreach (var job in _changesTabPendingJobs.Take(5))
                                {
                                    <span class="badge bg-success-subtle text-success border border-success-subtle">
                                        <i class="bi bi-check-circle me-1"></i>@TruncateForToast(job.Title ?? job.GoalPrompt, 40)
                                    </span>
                                }
                                @if (_changesTabPendingJobs.Count > 5)
                                {
                                    <span class="badge bg-secondary-subtle text-secondary">
                                        +@(_changesTabPendingJobs.Count - 5) more
                                    </span>
                                }
                            </div>
                            <div class="mt-2 small text-body-secondary">
                                <i class="bi bi-lightbulb me-1"></i>Committing will link this commit to these jobs.
                            </div>
                        </div>
                    }

                    @* Diff Viewer *@
                    <div class="mb-3">
                        <div class="d-flex align-items-center justify-content-between mb-2">
                            <span class="text-body-secondary small">
                                <i class="bi bi-files me-1"></i>
                                @_changesTabDiffFiles.Count file(s) modified
                                <span class="ms-2">
                                    <span class="text-success">+@_changesTabDiffFiles.Sum(f => f.Additions)</span>
                                    <span class="text-danger ms-1">-@_changesTabDiffFiles.Sum(f => f.Deletions)</span>
                                </span>
                            </span>
                            <div class="btn-group btn-group-sm">
                                <button type="button" class="btn btn-secondary" @onclick="ExpandAllChangesTab" title="Expand all"
                                        disabled="@_changesTabAllExpanded">
                                    <i class="bi bi-arrows-expand"></i>
                                </button>
                                <button type="button" class="btn btn-secondary" @onclick="CollapseAllChangesTab" title="Collapse all"
                                        disabled="@(_changesTabExpandedItems.Count == 0)">
                                    <i class="bi bi-arrows-collapse"></i>
                                </button>
                            </div>
                        </div>

                        <div class="accordion border rounded overflow-y-auto" id="changesTabAccordion"
                             style="max-height: min(400px, 50vh);">
                            @foreach (var (file, index) in _changesTabDiffFiles.Select((f, i) => (f, i)))
                            {
                                var isExpanded = _changesTabExpandedItems.Contains(index);
                                <div class="accordion-item">
                                    <h2 class="accordion-header">
                                        <button class="accordion-button @(isExpanded ? "" : "collapsed") py-2 px-3" type="button"
                                                @onclick="() => ToggleChangesTabExpanded(index)">
                                            <span class="d-flex align-items-center gap-2 w-100">
                                                @if (file.IsNew)
                                                {
                                                    <i class="bi bi-file-earmark-plus text-success" title="New file"></i>
                                                }
                                                else if (file.IsDeleted)
                                                {
                                                    <i class="bi bi-file-earmark-minus text-danger" title="Deleted file"></i>
                                                }
                                                else
                                                {
                                                    <i class="bi bi-file-earmark-diff text-warning" title="Modified file"></i>
                                                }
                                                <span class="font-monospace small text-truncate flex-grow-1">@file.FileName</span>
                                                <span class="small">
                                                    @if (file.Additions > 0)
                                                    {
                                                        <span class="text-success fw-medium">+@file.Additions</span>
                                                    }
                                                    @if (file.Deletions > 0)
                                                    {
                                                        <span class="text-danger fw-medium ms-1">-@file.Deletions</span>
                                                    }
                                                </span>
                                            </span>
                                        </button>
                                    </h2>
                                    <div class="accordion-collapse collapse @(isExpanded ? "show" : "")">
                                        <div class="accordion-body p-0">
                                            @if (!file.IsDeleted)
                                            {
                                                <div class="terminal-output overscroll-contain white-space-pre-wrap overflow-auto p-2 small" style="max-height: 300px;">
                                                    @((MarkupString)FormatDiffContent(file.DiffContent))
                                                </div>
                                            }
                                            else
                                            {
                                                <div class="p-3 text-body-secondary small">
                                                    <i class="bi bi-trash me-1"></i>File deleted
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>

                    @if (!_changesTabShowingCommittedDiff && !_changesTabShowingPersistedDiff)
                    {
                        <hr class="my-3" />

                        @* Commit Section *@
                        <div class="mb-3">
                            <div class="d-flex align-items-center justify-content-between mb-2">
                                <label for="changesTabCommitMessage" class="form-label fw-medium mb-0">
                                    <i class="bi bi-chat-square-text me-1"></i>Commit Message
                                </label>
                                @if (_changesTabPendingJobs != null && _changesTabPendingJobs.Any() && string.IsNullOrWhiteSpace(_changesTabCommitMessage))
                                {
                                    <button type="button" class="btn btn-sm btn-primary" @onclick="GenerateChangesTabCommitMessage"
                                            title="Generate commit message from job summaries">
                                        <i class="bi bi-magic me-1"></i>Generate
                                    </button>
                                }
                            </div>
                            <textarea class="form-control font-monospace" id="changesTabCommitMessage" @bind="_changesTabCommitMessage"
                                      @bind:event="oninput" rows="5" placeholder="Enter commit message..."
                                      disabled="@_isChangesTabCommitting"></textarea>
                        </div>

                        @if (!string.IsNullOrEmpty(_changesTabCommitError))
                        {
                            <div class="alert alert-danger py-2">
                                <i class="bi bi-exclamation-triangle me-1"></i>@_changesTabCommitError
                            </div>
                        }

                        @* Discard Confirmation *@
                        @if (_changesTabShowDiscardConfirm)
                        {
                            <div class="alert alert-warning py-3">
                                <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
                                    <div>
                                        <i class="bi bi-exclamation-triangle me-2"></i>
                                        <strong>Are you sure?</strong> This will permanently discard all uncommitted changes.
                                    </div>
                                    <div class="d-flex gap-2">
                                        <button type="button" class="btn btn-secondary btn-sm" @onclick="@(() => _changesTabShowDiscardConfirm = false)">
                                            Cancel
                                        </button>
                                        <button type="button" class="btn btn-danger btn-sm" @onclick="ChangesTabDiscardAll"
                                                disabled="@_isChangesTabDiscarding">
                                            @if (_isChangesTabDiscarding)
                                            {
                                                <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                                            }
                                            Yes, Discard All
                                        </button>
                                    </div>
                                </div>
                            </div>
                        }

                        @* Action Buttons *@
                        @if (!_changesTabShowDiscardConfirm)
                        {
                            <div class="d-flex flex-column flex-sm-row justify-content-between gap-2">
                                <button type="button" class="btn btn-danger" @onclick="@(() => _changesTabShowDiscardConfirm = true)"
                                        disabled="@(_isChangesTabCommitting || _isChangesTabDiscarding)">
                                    <i class="bi bi-trash me-1"></i>Discard All
                                </button>
                                <div class="d-flex gap-2">
                                    <button type="button" class="btn btn-secondary" @onclick="ChangesTabCommitOnly"
                                            disabled="@(_isChangesTabCommitting || _isChangesTabDiscarding || string.IsNullOrWhiteSpace(_changesTabCommitMessage))">
                                        @if (_isChangesTabCommitting && _isChangesTabCommitOnly)
                                        {
                                            <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                                            <span>Committing...</span>
                                        }
                                        else
                                        {
                                            <i class="bi bi-check-circle me-1"></i>
                                            <span>Commit Only</span>
                                        }
                                    </button>
                                    <button type="button" class="btn btn-primary" @onclick="ChangesTabCommitAndPush"
                                            disabled="@(_isChangesTabCommitting || _isChangesTabDiscarding || string.IsNullOrWhiteSpace(_changesTabCommitMessage))">
                                        @if (_isChangesTabCommitting && !_isChangesTabCommitOnly)
                                        {
                                            <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                                            <span>Pushing...</span>
                                        }
                                        else
                                        {
                                            <i class="bi bi-cloud-arrow-up me-1"></i>
                                            <span>Commit & Push</span>
                                        }
                                    </button>
                                </div>
                            </div>
                        }
                    }
                }
                else
                {
                    <div class="text-center py-5 text-body-secondary">
                        <i class="bi bi-check-circle fs-1 d-block mb-2"></i>
                        <p class="mb-0">@(_changesTabEmptyStateMessage ?? "No project changes are available to show.")</p>
                    </div>
                }
            </div>
        }
        @if (_activeTab == "autopilot")
        {
            <div class="tab-pane fade show active">
                <AutoPilotPanel @ref="_autoPilotPanel" ProjectId="@ProjectId"
                                AvailableProviders="@Providers.Where(p => p.IsEnabled).ToList()"
                                AvailableInferenceProviders="@_availableInferenceProviders"
                                Project="@Project" />
            </div>
        }
    </div>

    @* Create Branch Modal *@
    <CreateBranchModal @bind-IsVisible="_showCreateBranchModal" CurrentBranch="@CurrentBranch"
                       IsCreating="@_isCreatingBranch" ErrorMessage="@_createBranchError" OnCreate="CreateBranch" />

    @* Branch Switch Confirmation Modal *@
    <BranchSwitchModal @bind-IsVisible="_showBranchSwitchModal" CurrentBranch="@CurrentBranch" TargetBranch="@_targetBranch"
                       IsChecking="@_isCheckingUncommittedChanges" IsSwitching="@_isSwitchingBranch"
                       HasUncommittedChanges="@_hasUncommittedChanges" ErrorMessage="@_branchSwitchError" OnSwitch="ConfirmBranchSwitch"
                       OnCancel="CloseBranchSwitchModal" />

    @* Merge Branch Modal *@
    <MergeBranchModal @bind-IsVisible="_showMergeBranchModal" CurrentBranch="@CurrentBranch"
                      TargetBranches="@MergeTargetBranches" SelectedTargetBranch="@_mergeTargetBranch"
                      PushAfterMerge="@_mergePushAfterMerge" IsCheckingPreview="@_isCheckingMergePreview"
                      IsMerging="@_isMergingBranch" PreviewMessage="@_mergePreviewMessage"
                      PreviewError="@_mergePreviewError" IsAlreadyUpToDate="@_isMergeAlreadyUpToDate"
                      CreatePullRequest="@_mergeCreatePullRequest"
                      PullRequestTitle="@_mergePrTitle" IsCreatingPullRequest="@_isCreatingPullRequest"
                      IsGitHubCliAvailable="@_isGitHubCliAvailable"
                      OnTargetBranchChanged="HandleMergeTargetBranchChanged"
                      OnPushAfterMergeChanged="HandleMergePushAfterMergeChanged"
                      OnCreatePullRequestChanged="HandleMergeCreatePullRequestChanged"
                      OnPullRequestTitleChanged="HandleMergePrTitleChanged"
                      OnMerge="MergeCurrentBranchAsync" OnCreatePullRequestSubmit="CreatePullRequestAsync"
