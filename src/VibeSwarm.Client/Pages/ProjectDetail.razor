@page "/projects/{ProjectId:guid}"
@attribute [Authorize]
@inject IProjectService ProjectService
@inject IJobService JobService
@inject IProviderService ProviderService
@inject IJobTemplateService JobTemplateService
@inject IVersionControlService VersionControlService
@inject IIdeaService IdeaService
@inject IInferenceService InferenceService
@inject IInferenceProviderService InferenceProviderService
@inject IAutoPilotService AutoPilotService
@inject NavigationManager NavigationManager
@inject NotificationService NotificationService
@inject QueuePanelStateService QueuePanelStateService
@implements IAsyncDisposable

@if (IsLoading)
{
    <LoadingSpinner />
}
else if (Project == null)
{
    <Breadcrumb
    Items="@(new List<Breadcrumb.BreadcrumbItem> { new("Projects", "/projects", "folder"), new("Not Found") })" />
    <Alert Type="Alert.AlertType.Warning" Message="Project not found." />
}
else
{
    @* Project Header Component *@
    <ProjectDetailHeaderCompact Name="@Project.Name" WorkingPath="@Project.WorkingPath"
                                GitHubRepository="@Project.GitHubRepository" IsGitRepository="@IsGitRepository"
                                IsLoadingGitInfo="@_isLoadingGitInfo" Branches="@Branches" CurrentBranch="@CurrentBranch"
                                CurrentCommitHash="@CurrentCommitHash" IsGitOperationInProgress="@IsGitOperationInProgress"
                                GitOperationMessage="@GitOperationMessage" GitOperationSuccess="@GitOperationSuccess"
                                GitProgressMessage="@GitProgressMessage" HasUncommittedChanges="@_hasUncommittedChangesHeader"
                                UncommittedFilesCount="@_uncommittedFilesCount" HasTokenData="@HasProjectTokenData()"
                                TotalInputTokens="@GetProjectTotalInputTokens()" TotalOutputTokens="@GetProjectTotalOutputTokens()"
                                TotalCost="@GetProjectTotalCost()" OnCreateBranch="ShowCreateBranchModal" OnSync="SyncWithOrigin"
                                OnRefresh="RefreshBranches" OnBranchSelected="RequestBranchSwitch"
                                OnUncommittedChangesClick="ShowUncommittedChangesModal" OnClearGitMessage="ClearGitMessage"
                                OnEdit="ShowEditProjectModal" OnPruneBranches="PruneRemoteBranches"
                                ShowMergeBranchAction="@HasMergeBranchTargets" IsMerging="@_isMergingBranch"
                                OnMergeBranch="ShowMergeBranchModal" IsActive="@(Project?.IsActive ?? true)"
                                OnToggleActive="ToggleProjectActive"
                                AutoPilotStatus="@_autoPilotStatus"
                                IsIdeasProcessingActive="@IsIdeasProcessingActive"
                                IdeasUnprocessedCount="@IdeasUnprocessedCount"
                                ActiveJob="@ActiveJob"
                                IsStoppingAll="@_isStoppingAll"
                                CanSuggestIdeas="@CanSuggestIdeas"
                                OnStop="StopAllActive"
                                OnSuggestIdeas="SuggestIdeasFromCodebase" />

    @* Tabbed Content Area — horizontal scroll on mobile, underline-active on all sizes *@
    <nav class="vs-tabs project-detail-tabs mt-3" role="tablist">
        <button type="button" class="vs-tab @(IsActiveTab("ideas") ? "active" : "")"
                @onclick='@(() => SetActiveTab("ideas"))' role="tab" aria-selected="@IsActiveTab("ideas")">
            <i class="bi bi-lightbulb"></i>
            <span>Ideas</span>
            @if (IdeasTotalCount > 0)
            {
                <CountPill Value="@IdeasTotalCount.ToString()" Active="@(IsActiveTab("ideas"))" />
            }
        </button>
        <button type="button" class="vs-tab @(IsActiveTab("jobs") ? "active" : "")"
                @onclick='@(() => SetActiveTab("jobs"))' role="tab" aria-selected="@IsActiveTab("jobs")">
            <i class="bi bi-list-task"></i>
            <span>Jobs</span>
            @if (JobsTotalCount > 0)
            {
                <CountPill Value="@JobsTotalCount.ToString()" Active="@(IsActiveTab("jobs"))" />
            }
        </button>
        <button type="button" class="vs-tab @(IsActiveTab("environments") ? "active" : "")"
                @onclick='@(() => SetActiveTab("environments"))' role="tab" aria-selected="@IsActiveTab("environments")">
            <i class="bi bi-box-seam"></i>
            <span>Environments</span>
            @if (EnabledEnvironmentCount > 0)
            {
                <CountPill Value="@EnabledEnvironmentCount.ToString()" Active="@(IsActiveTab("environments"))" />
            }
        </button>
        <button type="button" class="vs-tab @(IsActiveTab("changes") ? "active" : "") @(!IsGitRepository ? "disabled opacity-50" : "")"
                @onclick="OpenChangesTabAsync" role="tab" aria-selected="@IsActiveTab("changes")"
                disabled="@(!IsGitRepository)">
            <i class="bi bi-code-square"></i>
            <span>Changes</span>
            @if (HasChangesTabContent && _workingTreeStatus.ChangedFilesCount > 0)
            {
                <CountPill Value="@_workingTreeStatus.ChangedFilesCount.ToString()" Active="@(IsActiveTab("changes"))" />
            }
        </button>
        <button type="button" class="vs-tab @(IsActiveTab("autopilot") ? "active" : "")"
                @onclick='@(() => SetActiveTab("autopilot"))' role="tab" aria-selected="@IsActiveTab("autopilot")">
            <i class="bi bi-compass"></i>
            <span>Auto-Pilot</span>
            @if (_autoPilotStatus != null && !AutoPilotPanel.IsTerminal(_autoPilotStatus.Status))
            {
                <CountPill Value="@_autoPilotStatus.Status.ToString()" Active="@(IsActiveTab("autopilot"))" />
            }
        </button>
    </nav>

    <div class="tab-content pt-3">
        @if (_activeTab == "ideas")
        {
            <div class="tab-pane fade show active">
                @if (_isLoadingIdeas)
                {
                    <div class="border rounded-3 bg-body-tertiary p-3 p-lg-4">
                        <SkeletonLoader Lines="4" LineHeight="20" />
                    </div>
                }
                else
                {
                <IdeasPanel Ideas="@Ideas" TotalIdeasCount="@IdeasTotalCount" CurrentPage="@_ideasPageNumber"
                            PageSize="@IdeasPageSize" IsPageLoading="@_isLoadingIdeasPage" UnprocessedIdeasCount="@IdeasUnprocessedCount"
                            CurrentProjectId="@ProjectId" IsProcessingActive="@IsIdeasProcessingActive"
                            IsTogglingProcessing="@_isTogglingIdeasProcessing" HasDefaultProvider="@HasDefaultProvider"
                            HasActiveJobs="@HasActiveJobs" IsAddingIdea="@_isAddingIdea" ProcessingIdeaIds="@ProcessingIdeaIds"
                            CurrentAutoCommitMode="@(Project?.AutoCommitMode ?? AutoCommitMode.Off)"
                            IsGitRepository="@IsGitRepository"
                            DefaultProcessingProviderId="@GetDefaultIdeasProcessingProviderId()"
                            DefaultProcessingModelId="@GetDefaultIdeasProcessingModelId()"
                            OnStartProcessing="StartIdeasProcessing" OnStartProcessingWithOptions="StartIdeasProcessingWithOptions"
                            OnStopProcessing="StopIdeasProcessing" OnAddIdea="AddIdea" OnUpdateIdea="UpdateIdea"
                            OnDeleteIdea="DeleteIdea" OnCopyIdea="CopyIdea" OnMoveIdea="MoveIdea" OnStartSingleIdea="StartSingleIdea"
                            OnExpandIdea="ExpandIdea" OnCancelExpansion="CancelIdeaExpansion" OnApproveExpansion="ApproveIdeaExpansion"
                            OnRejectExpansion="RejectIdeaExpansion" AvailableLocalModels="@_availableLocalModels"
                            HasInference="@_hasInference" AvailableProviders="@Providers.Where(p => p.IsEnabled).ToList()"
                            AvailableInferenceProviders="@_availableInferenceProviders"
                            DefaultInferenceProviderId="@(Project?.IdeaInferenceProviderId)"
                            DefaultInferenceModelId="@(Project?.IdeaInferenceModelId)"
                            OnSuggestIdeas="SuggestIdeasFromCodebase" OnPreviousPage="LoadPreviousIdeasPage"
                            OnNextPage="LoadNextIdeasPage" />
                }
            </div>
        }
        @if (_activeTab == "jobs")
        {
            <div class="tab-pane fade show active">
                @if (_isLoadingJobs)
                {
                    <div class="border rounded-3 bg-body-tertiary p-3 p-lg-4">
                        <SkeletonLoader Lines="5" LineHeight="20" />
                    </div>
                }
                else
                {
                <ProjectJobsList Jobs="@PagedJobs" TotalJobsCount="@JobsTotalCount" CurrentPage="@_jobsPageNumber"
                                  PageSize="@ProjectJobsPageSize" IsPageLoading="@_isLoadingJobsPage" HasActiveJobs="@HasActiveJobs"
                                  HasCompletedJobs="@HasCompletedJobs" SearchQuery="@_jobSearchQuery" StatusFilter="@_jobStatusFilter"
                                  OnDeleteJob="DeleteJob" OnRetryJob="RetryJob" OnCreateJob="ShowCreateJobModal" OnPreviousPage="LoadPreviousJobsPage"
                                  OnNextPage="LoadNextJobsPage" OnCancelAll="CancelAllJobs"
                                  OnDeleteCompleted="DeleteCompletedJobs" OnRetrySelected="RetrySelectedJobs"
                                  OnCancelSelected="CancelSelectedJobs" OnPrioritizeSelected="PrioritizeSelectedJobs"
                                  OnSearchChanged="HandleJobSearchChanged"
                                  OnStatusFilterChanged="HandleJobStatusFilterChanged" />
                }
            </div>
        }
        @if (_activeTab == "environments")
        {
            <div class="tab-pane fade show active d-flex flex-column gap-3">
                @if (!string.IsNullOrEmpty(_environmentError))
                {
                    <Alert Type="Alert.AlertType.Danger" Message="@_environmentError" Class="mb-0" />
                }
                <EditForm Model="@Project" OnValidSubmit="SaveEnvironments">
                    <ProjectEnvironmentsEditor Project="@Project" />
                    <div class="d-flex justify-content-end gap-2 mt-3">
                        <button type="submit" class="btn btn-primary btn-sm" disabled="@_isSavingEnvironments"
                                title="@(_isSavingEnvironments ? "Saving environments" : "Save environment changes")">
                            @if (_isSavingEnvironments)
                            {
                                <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                            }
                            <i class="bi bi-check-lg me-1"></i>Save environments
                        </button>
                    </div>
                </EditForm>
            </div>
        }
        @if (_activeTab == "changes")
        {
            <div class="tab-pane fade show active">
                <ProjectChangesTab @ref="_changesTab" WorkingPath="@(Project?.WorkingPath ?? string.Empty)"
                                   Jobs="@(_changesJobs ?? new List<Job>())" IsGitRepository="@IsGitRepository"
                                   HasUncommittedChanges="@_hasUncommittedChangesHeader"
                                   UncommittedFilesCount="@_uncommittedFilesCount"
                                   WorkingTreeStatus="@_workingTreeStatus"
                                   OnGitOperationCompleted="HandleChangesTabGitOperation"
                                   OnChangesCommitted="HandleChangesTabCommitted" />
            </div>
        }
        @if (_activeTab == "autopilot")
        {
            <div class="tab-pane fade show active">
                <AutoPilotPanel @ref="_autoPilotPanel" ProjectId="@ProjectId"
                                AvailableProviders="@Providers.Where(p => p.IsEnabled).ToList()"
                                AvailableInferenceProviders="@_availableInferenceProviders"
                                Project="@Project" />
            </div>
        }
    </div>

    @* Create Branch Modal *@
    <CreateBranchModal @bind-IsVisible="_showCreateBranchModal" CurrentBranch="@CurrentBranch"
                       IsCreating="@_isCreatingBranch" ErrorMessage="@_createBranchError" OnCreate="CreateBranch" />

    @* Branch Switch Confirmation Modal *@
    <BranchSwitchModal @bind-IsVisible="_showBranchSwitchModal" CurrentBranch="@CurrentBranch" TargetBranch="@_targetBranch"
                       IsChecking="@_isCheckingUncommittedChanges" IsSwitching="@_isSwitchingBranch"
                       HasUncommittedChanges="@_hasUncommittedChanges" ErrorMessage="@_branchSwitchError" OnSwitch="ConfirmBranchSwitch"
                       OnCancel="CloseBranchSwitchModal" />

    @* Merge Branch Modal *@
    <MergeBranchModal @bind-IsVisible="_showMergeBranchModal" CurrentBranch="@CurrentBranch"
                      TargetBranches="@MergeTargetBranches" SelectedTargetBranch="@_mergeTargetBranch"
                      PushAfterMerge="@_mergePushAfterMerge" IsCheckingPreview="@_isCheckingMergePreview"
                      IsMerging="@_isMergingBranch" PreviewMessage="@_mergePreviewMessage"
                      PreviewError="@_mergePreviewError" IsAlreadyUpToDate="@_isMergeAlreadyUpToDate"
                      ConflictFiles="@_mergeConflictFiles"
                      CreatePullRequest="@_mergeCreatePullRequest"
                      PullRequestTitle="@_mergePrTitle" IsCreatingPullRequest="@_isCreatingPullRequest"
                      IsGitHubCliAvailable="@_isGitHubCliAvailable"
                      OnTargetBranchChanged="HandleMergeTargetBranchChanged"
                      OnPushAfterMergeChanged="HandleMergePushAfterMergeChanged"
                      OnCreatePullRequestChanged="HandleMergeCreatePullRequestChanged"
                      OnPullRequestTitleChanged="HandleMergePrTitleChanged"
                      OnConflictResolutionChanged="HandleMergeConflictResolutionChanged"
                      OnMerge="MergeCurrentBranchAsync" OnCreatePullRequestSubmit="CreatePullRequestAsync"
                      OnCancel="CloseMergeBranchModal" />

    @* Uncommitted Changes Modal *@
    <UncommittedChangesModal @bind-IsVisible="_showUncommittedChangesModal" IsLoading="@_isLoadingUncommittedDiff"
                             ErrorMessage="@_uncommittedDiffError" DiffFiles="@_uncommittedDiffFiles" PendingJobs="@_pendingCommitJobs"
                             CommitError="@_uncommittedCommitError" CommitProgress="@_commitPushStep" ShowPushRetry="@_pushRetryAvailable"
                             OnRetryPush="RetryPush" IsCommitting="@_isCommittingChanges" IsDiscarding="@_isDiscardingChanges"
                             ShowDiscardConfirmation="@_showDiscardConfirmation" OnCommitAndPush="CommitAndPushUncommittedChanges"
                             OnCommitOnly="CommitOnlyUncommittedChanges"
                             OnShowDiscard="ShowDiscardConfirmation" OnConfirmDiscard="DiscardAllChanges"
                             OnCancelDiscard="CloseDiscardConfirmation" />

    @* Create Job Modal *@
    <CreateJobModal @bind-IsVisible="_showCreateJobModal" JobModel="@NewJob" Project="@Project" Providers="@GetAllowedJobProviders()"
                    AvailableModels="@AvailableModels" Branches="@Branches" CurrentBranch="@CurrentBranch"
                    ShowBranchSelector="@(IsGitRepository && Branches.Any())" IsLoadingModels="@IsLoadingModels" IsSaving="@IsSaving"
                    ErrorMessage="@ErrorMessage" @bind-SelectedModelId="@SelectedModelId" ProviderHint="@GetProviderHint()" OnProviderChanged="OnProviderChanged"
                    TemplateLibrary="@JobTemplates" OnTemplateLibraryChanged="LoadJobTemplates" OnSubmit="HandleCreateJob" />

    @* Edit Project Modal *@
    <ProjectModal @bind-IsVisible="_showEditProjectModal" EditProject="@Project" OnSaved="HandleProjectSaved"
                  OnCancelled="HandleProjectModalCancelled" OnClosed="HandleProjectModalClosed" />
}

@code {
    [Parameter]
    public Guid ProjectId { get; set; }

    private const int ProjectJobsPageSize = 10;
    private const int IdeasPageSize = 10;

    private Project? Project { get; set; }
    private List<JobSummary> PagedJobs { get; set; } = new();
    private List<Provider> Providers { get; set; } = new();
    private Job NewJob { get; set; } = new();
    private bool IsLoading { get; set; } = true;
    private bool _isLoadingJobsPage;
    private bool _isLoadingIdeasPage;
    private bool IsSaving { get; set; }
    private string? ErrorMessage { get; set; }
    private System.Threading.Timer? _refreshTimer;

    // Model selection
    private List<ProviderModel> AvailableModels { get; set; } = new();
    private List<JobTemplate> JobTemplates { get; set; } = new();
    private string SelectedModelId { get; set; } = string.Empty;
    private bool IsLoadingModels { get; set; }

    // Git-related properties
    private bool IsGitRepository { get; set; }
    private bool _isLoadingGitInfo { get; set; } = true; // Start true, will be set false after check
    private List<GitBranchInfo> Branches { get; set; } = new();
    private string? CurrentBranch { get; set; }
    private string? CurrentCommitHash { get; set; }
    private bool IsGitOperationInProgress { get; set; }
    private string? GitOperationMessage { get; set; }
    private bool GitOperationSuccess { get; set; }
    private string? GitProgressMessage { get; set; }

    // Create branch modal state
    private bool _showCreateBranchModal { get; set; }
    private bool _isCreatingBranch { get; set; }
    private string? _createBranchError { get; set; }

    // Create job modal state
    private bool _showCreateJobModal { get; set; }

    // Edit project modal state
    private bool _showEditProjectModal { get; set; }

    // Branch switch confirmation modal state
    private bool _showBranchSwitchModal { get; set; }
    private string? _targetBranch { get; set; }
    private bool _isCheckingUncommittedChanges { get; set; }
    private bool _hasUncommittedChanges { get; set; }
    private bool _isSwitchingBranch { get; set; }
    private string? _branchSwitchError { get; set; }

    // Merge branch modal state
    private bool _showMergeBranchModal { get; set; }
    private string? _mergeTargetBranch { get; set; }
    private bool _mergePushAfterMerge { get; set; } = true;
    private bool _mergeCreatePullRequest { get; set; }
    private string? _mergePrTitle { get; set; }
    private bool _isCreatingPullRequest { get; set; }
    private bool _isGitHubCliAvailable { get; set; }
    private bool _isCheckingMergePreview { get; set; }
    private bool _isMergingBranch { get; set; }
    private string? _mergePreviewMessage { get; set; }
    private string? _mergePreviewError { get; set; }
    private bool _isMergeAlreadyUpToDate { get; set; }
    private List<MergeConflictFile> _mergeConflictFiles { get; set; } = new();

    // Uncommitted changes modal state
    private bool _hasUncommittedChangesHeader { get; set; }
    private int _uncommittedFilesCount { get; set; }
    private GitWorkingTreeStatus _workingTreeStatus = new();
    private bool _showUncommittedChangesModal { get; set; }
    private bool _isLoadingUncommittedDiff { get; set; }
    private string? _uncommittedDiffError { get; set; }
    private List<DiffFile> _uncommittedDiffFiles { get; set; } = new();
    private List<Job> _pendingCommitJobs { get; set; } = new();
    private string? _uncommittedCommitError { get; set; }
    private string? _commitPushStep { get; set; }
    private bool _pushRetryAvailable { get; set; }
    private string? _lastSuccessfulCommitHash { get; set; }
    private bool _isCommittingChanges { get; set; }
    private bool _showDiscardConfirmation { get; set; }
    private bool _isDiscardingChanges { get; set; }

    // Tab state
    private string _activeTab = "ideas";
    private int EnabledEnvironmentCount => Project?.Environments.Count(environment => environment.IsEnabled) ?? 0;
    private bool IsOverflowTabActive => _activeTab is "environments" or "changes" or "autopilot";

    // Auto-pilot state
    private AutoPilotPanel? _autoPilotPanel;
    private IterationLoop? _autoPilotStatus;

    // Environment editing state
    private bool _isSavingEnvironments;
    private string? _environmentError;

    // Changes tab component
    private ProjectChangesTab? _changesTab;
    private bool HasChangesTabContent => IsGitRepository;
    private List<string> MergeTargetBranches => Branches
        .Where(branch => !branch.IsRemote && !string.Equals(branch.Name, CurrentBranch, StringComparison.Ordinal))
        .Select(branch => branch.Name)
        .Distinct(StringComparer.Ordinal)
        .OrderBy(branch => branch, StringComparer.OrdinalIgnoreCase)
        .ToList();
    private bool HasMergeBranchTargets => !string.IsNullOrWhiteSpace(CurrentBranch) && MergeTargetBranches.Count > 0;

    // Prune state
    private bool _isPruningBranches { get; set; }

    // Ideas state
    private List<Idea> Ideas { get; set; } = new();
    private int _jobsPageNumber = 1;
    private int _ideasPageNumber = 1;
    private int JobsTotalCount { get; set; }
    private int IdeasTotalCount { get; set; }
    private int IdeasUnprocessedCount { get; set; }
    private int ProjectActiveJobsCount { get; set; }
    private int ProjectCompletedJobsCount { get; set; }
    private bool _isAddingIdea { get; set; }
    private bool IsIdeasProcessingActive { get; set; }
    private bool _isTogglingIdeasProcessing { get; set; }
    private bool HasDefaultProvider => GetAllowedJobProviders().Any();
    private HashSet<Guid> ProcessingIdeaIds { get; set; } = new();
    private CancellationTokenSource? _expandCts;
    private Guid? _expandingIdeaId;

    // Inference state for idea expansion
    private List<DiscoveredModel> _availableLocalModels { get; set; } = new();
    private List<InferenceProvider> _availableInferenceProviders { get; set; } = new();
    private bool _hasInference { get; set; }

    private bool HasActiveJobs => ProjectActiveJobsCount > 0;
    private bool HasCompletedJobs => ProjectCompletedJobsCount > 0;

    private JobSummary? ActiveJob => _activeJobSummary;

    private bool CanSuggestIdeas => _hasInference || Providers.Any(p => p.IsEnabled);

    private bool _isStoppingAll;

    private void SetActiveTab(string tab)
    {
        _activeTab = tab;
    }

    private bool IsActiveTab(string tab)
    {
        return string.Equals(_activeTab, tab, StringComparison.Ordinal);
    }

    private string GetOverflowTabLabel()
    {
        return _activeTab switch
        {
            "environments" => "Environments",
            "changes" => "Changes",
            "autopilot" => "Auto-Pilot",
            _ => "More"
        };
    }

    private string GetOverflowToggleIcon()
    {
        return _activeTab switch
        {
            "environments" => "bi-globe2",
            "changes" => "bi-file-diff",
            "autopilot" => "bi-robot",
            _ => "bi-three-dots"
        };
    }
}
