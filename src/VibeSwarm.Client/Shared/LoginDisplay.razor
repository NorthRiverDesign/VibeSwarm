@using Microsoft.AspNetCore.Components.Authorization
@inject ChangePasswordModalService ChangePasswordModalService
@inject NotificationService NotificationService
@inject ThemeService ThemeService

<AuthorizeView>
    <Authorized>
        <div class="d-flex align-items-center justify-content-end gap-2 w-100">
            @* Desktop: User info with gear dropdown on the right *@
            <div class="d-none d-lg-flex justify-content-between align-items-center w-100 gap-1">
                <div class="d-flex align-items-center gap-2 text-secondary">
                    <i class="bi bi-person-circle"></i>
                    <span class="fw-semibold text-body-emphasis">@context.User.Identity?.Name</span>
                </div>
                <div class="d-flex align-items-center gap-3">
                    <NotificationsPanel />
                    <div class="dropup">
                        <button class="btn btn-link text-secondary p-0 lh-1" type="button" data-bs-toggle="dropdown"
                                aria-expanded="false" title="User options">
                            <i class="bi bi-gear"></i>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end shadow" style="min-width: 16rem;">
                            <li>
                                <ThemeSelector SelectedTheme="_selectedTheme" IsLoading="_isUpdatingTheme"
                                               OnThemeSelected="HandleThemeSelected" />
                            </li>
                            <li>
                                <hr class="dropdown-divider">
                            </li>
                            <li>
                                <button class="dropdown-item" type="button" @onclick="ShowChangePasswordModal">
                                    <i class="bi bi-key me-2"></i>Change Password
                                </button>
                            </li>
                            <li>
                                <hr class="dropdown-divider">
                            </li>
                            <li>
                                <a class="dropdown-item" href="/logout">
                                    <i class="bi bi-box-arrow-right me-2"></i>Log Out
                                </a>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>

            @* Mobile: Compact dropdown with user icon *@
            <div class="dropdown d-lg-none">
                <button class="btn btn-link text-secondary p-0 fs-5 d-flex align-items-center" type="button"
                        data-bs-toggle="dropdown" aria-expanded="false" title="User menu">
                    <i class="bi bi-person-circle me-1"></i>
                    <i class="bi bi-chevron-down small" style="font-size: 0.65rem; margin-left: 0.125rem;"></i>
                </button>
                <ul class="dropdown-menu dropdown-menu-end shadow" style="min-width: 16rem;">
                    <li class="dropdown-header">
                        <span class="fw-semibold">@context.User.Identity?.Name</span>
                    </li>
                    <li>
                        <hr class="dropdown-divider">
                    </li>
                    <li>
                        <ThemeSelector SelectedTheme="_selectedTheme" IsLoading="_isUpdatingTheme"
                                       OnThemeSelected="HandleThemeSelected" />
                    </li>
                    <li>
                        <hr class="dropdown-divider">
                    </li>
                    <li>
                        <button class="dropdown-item" type="button" @onclick="ShowChangePasswordModal">
                            <i class="bi bi-key me-2"></i>Change Password
                        </button>
                    </li>
                    <li>
                        <hr class="dropdown-divider">
                    </li>
                    <li>
                        <a class="dropdown-item" href="/logout">
                            <i class="bi bi-box-arrow-right me-2"></i>Log Out
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </Authorized>
    <NotAuthorized>
        <a href="/login" class="btn btn-sm btn-primary">Login</a>
    </NotAuthorized>
</AuthorizeView>

@code {
    private ThemePreference _selectedTheme = ThemePreference.System;
    private bool _hasLoadedThemePreference;
    private bool _isUpdatingTheme;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _hasLoadedThemePreference)
        {
            return;
        }

        _hasLoadedThemePreference = true;
        _selectedTheme = await ThemeService.GetThemePreferenceAsync();
        await InvokeAsync(StateHasChanged);
    }

    private void ShowChangePasswordModal()
    {
        ChangePasswordModalService.Show();
    }

    private async Task HandleThemeSelected(ThemePreference themePreference)
    {
        if (_isUpdatingTheme || _selectedTheme == themePreference)
        {
            return;
        }

        var previousTheme = _selectedTheme;
        _selectedTheme = themePreference;
        _isUpdatingTheme = true;

        try
        {
            await ThemeService.UpdateThemePreferenceAsync(themePreference);
        }
        catch (Exception ex)
        {
            _selectedTheme = previousTheme;
            NotificationService.ShowError(ex.Message, "Theme update failed");
        }
        finally
        {
            _isUpdatingTheme = false;
            await InvokeAsync(StateHasChanged);
        }
    }
}
