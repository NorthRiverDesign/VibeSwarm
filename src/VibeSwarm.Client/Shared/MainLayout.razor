@inherits LayoutComponentBase
@inject IJSRuntime JSRuntime
@inject NotificationService NotificationService
@inject AppTimeZoneService AppTimeZoneService
@inject IJobService JobService
@inject IIdeaService IdeaService
@inject ICriticalErrorLogService CriticalErrorLogService
@inject ChangePasswordModalService ChangePasswordModalService
@inject HttpClient HttpClient
@inject NavigationManager NavigationManager
@implements IAsyncDisposable
@implements IDisposable
@using Microsoft.AspNetCore.SignalR.Client
@using System.Text.Json

<div class="app-layout d-flex flex-column min-vh-100">
    @* Mobile Header *@
    <header class="app-header d-lg-none sticky-top d-flex align-items-center gap-3 flex-shrink-0 bg-body-secondary border-bottom">
        <button id="mobile-menu-toggle" class="btn btn-link nav-toggle d-flex align-items-center justify-content-center p-0 bg-transparent border-0 rounded fs-4" @onclick="ToggleMobileMenu"
                aria-label="Toggle navigation">
            <i class="bi bi-list"></i>
        </button>
        <a class="app-brand d-flex align-items-center gap-2 text-decoration-none fw-semibold" href="/">
            <img src="img/logo_icon.png" alt="VibeSwarm" class="object-fit-contain" style="width: 24px; height: 24px;" />
            <span class="brand-text">VibeSwarm</span>
        </a>
        <div class="ms-auto d-flex align-items-center gap-2">
            <NotificationsPanel />
            <LoginDisplay />
        </div>
    </header>

    @* Sidebar Navigation *@
    <nav id="app-sidebar" class="app-sidebar position-fixed d-flex flex-column @(_mobileMenuOpen ? "open" : "")">
        <div class="p-4 border-bottom d-none d-lg-flex flex-shrink-0">
            <a class="app-brand d-flex align-items-center gap-2 text-decoration-none fw-semibold" href="/">
                <img src="img/logo_icon.png" alt="VibeSwarm" class="object-fit-contain" style="width: 24px; height: 24px;" />
                <span class="brand-text">VibeSwarm</span>
            </a>
        </div>

        <div class="flex-grow-1 p-3 d-flex flex-column gap-1 overflow-y-auto" style="min-height: 0;">
            <button class="nav-item d-flex align-items-center gap-3 rounded fw-medium text-decoration-none border-0 bg-transparent w-100 text-start cursor-pointer search-nav-btn" @onclick="OpenSearch" title="Search (Ctrl+K)">
                <i class="bi bi-search"></i>
                <span class="flex-grow-1">Search</span>
                <kbd class="border rounded px-1 text-secondary d-none d-lg-inline" style="font-size: 0.65rem; background: transparent;">⌃K</kbd>
            </button>
            <NavLink class="nav-item d-flex align-items-center gap-3 rounded fw-medium text-decoration-none" href="/" Match="NavLinkMatch.All" @onclick="CloseMobileMenu">
                <i class="bi bi-house-door"></i>
                <span>Dashboard</span>
            </NavLink>
            <NavLink class="nav-item d-flex align-items-center gap-3 rounded fw-medium text-decoration-none" href="/projects" @onclick="CloseMobileMenu">
                <i class="bi bi-folder"></i>
                <span>Projects</span>
            </NavLink>
            <NavLink class="nav-item d-flex align-items-center gap-3 rounded fw-medium text-decoration-none" href="/jobs" @onclick="CloseMobileMenu">
                <i class="bi bi-list-check"></i>
                <span>Jobs</span>
            </NavLink>
            <NavLink class="nav-item d-flex align-items-center gap-3 rounded fw-medium text-decoration-none" href="/scheduler" @onclick="CloseMobileMenu">
                <i class="bi bi-calendar-event"></i>
                <span>Scheduler</span>
            </NavLink>
            <NavLink class="nav-item d-flex align-items-center gap-3 rounded fw-medium text-decoration-none" href="/providers" @onclick="CloseMobileMenu">
                <i class="bi bi-cpu"></i>
                <span>Providers</span>
            </NavLink>
            <NavLink class="nav-item d-flex align-items-center gap-3 rounded fw-medium text-decoration-none" href="/inference" @onclick="CloseMobileMenu">
                <i class="bi bi-hdd-network"></i>
                <span>Inference</span>
            </NavLink>
            <NavLink class="nav-item d-flex align-items-center gap-3 rounded fw-medium text-decoration-none" href="/skills" @onclick="CloseMobileMenu">
                <i class="bi bi-lightbulb"></i>
                <span>Skills</span>
            </NavLink>
            <NavLink class="nav-item d-flex align-items-center gap-3 rounded fw-medium text-decoration-none" href="/teams" @onclick="CloseMobileMenu">
                <i class="bi bi-people"></i>
                <span>Teams</span>
            </NavLink>
            <AuthorizeView Roles="Admin">
                <Authorized>
                    <NavLink class="nav-item d-flex align-items-center gap-3 rounded fw-medium text-decoration-none" href="/users" @onclick="CloseMobileMenu">
                        <i class="bi bi-people"></i>
                        <span>Users</span>
                    </NavLink>
                </Authorized>
            </AuthorizeView>
            <NavLink class="nav-item d-flex align-items-center gap-3 rounded fw-medium text-decoration-none" href="/settings" @onclick="CloseMobileMenu">
                <i class="bi bi-sliders"></i>
                <span>Settings</span>
            </NavLink>
        </div>

        <div class="p-3 border-top d-none d-lg-flex">
            <LoginDisplay />
        </div>
    </nav>

    @* Notifications Panel Overlay — rendered outside sticky header to avoid fixed-in-sticky clipping on mobile *@
    <NotificationsPanelOverlay />

    @* Mobile Menu Overlay *@
    @if (_mobileMenuOpen)
    {
        <div id="sidebar-overlay" class="sidebar-overlay position-fixed d-lg-none" @onclick="CloseMobileMenu"></div>
    }

    @* Main Content *@
    <main class="app-main flex-grow-1">
        <div class="main-content mw-100">
            <ErrorBoundary @ref="_errorBoundary">
                <ChildContent>
                    @Body
                </ChildContent>
                <ErrorContent Context="exception">
                    @{
                        _ = ReportFatalUiErrorAsync(exception);
                    }
                    <div class="d-flex align-items-center justify-content-center w-100" style="min-height: 50vh;">
                        <div class="text-center p-4 mx-auto" style="max-width: 500px;">
                            <div class="mb-4">
                                <i class="bi bi-exclamation-octagon text-danger" style="font-size: 3rem;"></i>
                            </div>
                            <h4 class="text-body mb-3">Something Went Wrong</h4>
                            <p class="text-muted mb-4">An unexpected error occurred while loading this page.</p>
                            <div class="d-flex flex-column flex-sm-row gap-2 justify-content-center">
                                <button class="btn btn-primary" @onclick="ForceReloadPage">
                                    <i class="bi bi-arrow-clockwise me-2"></i>Try Again
                                </button>
                                <button class="btn btn-secondary" @onclick="ForceNavigateToDashboard">
                                    <i class="bi bi-house me-2"></i>Go to Dashboard
                                </button>
                            </div>
                            @if (IsDevelopment())
                            {
                                <div class="mt-4 text-start">
                                    <details>
                                        <summary class="text-muted small" style="cursor: pointer;">Technical Details
                                        </summary>
                                        <pre class="bg-body-tertiary p-3 rounded mt-2 small text-danger overflow-auto"
                                             style="max-height: 200px;">@exception.Message
                                            @exception.StackTrace</pre>
                                        </details>
                                    </div>
                                }
                            </div>
                        </div>
                    </ErrorContent>
                </ErrorBoundary>
            </div>
        </main>
    </div>

    <AuthenticationKeepAlive />
    <AppUpdateBanner />
    <InstallPromptBanner />
    <ToastContainer />

    @* Global Search Modal *@
    <GlobalSearchModal @bind-IsVisible="_showSearchModal" />

    @* Change Password Modal - rendered outside sidebar to avoid stacking context issues *@
    <ModalDialog @bind-IsVisible="_showChangePasswordModal" Title="Change Password" Icon="key"
                 Size="ModalDialog.ModalSize.Default">
        <ChildContent>
            <EditForm Model="@_changePasswordModel" OnValidSubmit="HandleChangePassword">
                <DataAnnotationsValidator />

                @if (!string.IsNullOrEmpty(_changePasswordError))
                {
                    <div class="text-danger small mb-3">
                        <i class="bi bi-exclamation-circle me-1"></i>@_changePasswordError
                    </div>
                }

                <div class="mb-3">
                    <label for="currentPassword" class="form-label">Current Password</label>
                    <InputText id="currentPassword" type="password" @bind-Value="_changePasswordModel.CurrentPassword"
                               class="form-control" />
                    <ValidationMessage For="@(() => _changePasswordModel.CurrentPassword)" class="text-danger small" />
                </div>

                <div class="mb-3">
                    <label for="newPassword" class="form-label">New Password</label>
                    <InputText id="newPassword" type="password" @bind-Value="_changePasswordModel.NewPassword"
                               class="form-control" />
                    <ValidationMessage For="@(() => _changePasswordModel.NewPassword)" class="text-danger small" />
                    <div class="form-text">
                        Password must be at least 8 characters and contain uppercase, lowercase, and a digit.
                    </div>
                </div>

                <div class="mb-3">
                    <label for="confirmPassword" class="form-label">Confirm New Password</label>
                    <InputText id="confirmPassword" type="password" @bind-Value="_changePasswordModel.ConfirmPassword"
                               class="form-control" />
                    <ValidationMessage For="@(() => _changePasswordModel.ConfirmPassword)" class="text-danger small" />
                </div>

                <div class="d-flex justify-content-end gap-2">
                    <button type="button" class="btn btn-secondary" @onclick="CloseChangePasswordModal">Cancel</button>
                    <button type="submit" class="btn btn-primary" disabled="@_isChangingPassword">
                        @if (_isChangingPassword)
                        {
                            <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                        }
                        Change Password
                    </button>
                </div>
            </EditForm>
        </ChildContent>
    </ModalDialog>

@code {
    [CascadingParameter]
    private Task<AuthenticationState>? AuthenticationStateTask { get; set; }

    private ErrorBoundary? _errorBoundary;
    private bool _hubInitialized = false;
    private HubConnection? _globalHubConnection;
    private bool _mobileMenuOpen = false;
    // Search Modal
    private bool _showSearchModal;

    // Change Password Modal
    private bool _showChangePasswordModal;
    private bool _isChangingPassword;
    private string? _changePasswordError;
    private ChangePasswordModel _changePasswordModel = new();
    private string? _lastReportedFatalErrorSignature;

    protected override void OnInitialized()
    {
        ChangePasswordModalService.OnShowModal += ShowChangePasswordModal;
        ChangePasswordModalService.OnHideModal += CloseChangePasswordModal;
    }

    protected override async Task OnInitializedAsync()
    {
        await AppTimeZoneService.EnsureInitializedAsync();
    }

    private void ShowChangePasswordModal()
    {
        _changePasswordModel = new ChangePasswordModel();
        _changePasswordError = null;
        _showChangePasswordModal = true;
        InvokeAsync(StateHasChanged);
    }

    private void CloseChangePasswordModal()
    {
        _showChangePasswordModal = false;
        InvokeAsync(StateHasChanged);
    }

    private async Task HandleChangePassword()
    {
        _changePasswordError = null;

        _isChangingPassword = true;

        try
        {
            var request = new
            {
                CurrentPassword = _changePasswordModel.CurrentPassword,
                NewPassword = _changePasswordModel.NewPassword
            };

            var response = await HttpClient.PostAsJsonAsync("/api/auth/change-password", request);

            if (response.IsSuccessStatusCode)
            {
                NotificationService.ShowSuccess("Password changed successfully.");
                _changePasswordModel = new ChangePasswordModel();
                _showChangePasswordModal = false;
            }
            else
            {
                var error = await response.Content.ReadFromJsonAsync<ChangePasswordResult>();
                _changePasswordError = error?.Message ?? "Failed to change password.";
            }
        }
        catch (Exception ex)
        {
            _changePasswordError = $"An error occurred: {ex.Message}";
        }
        finally
        {
            _isChangingPassword = false;
        }
    }

    private void OpenSearch()
    {
        CloseMobileMenu();
        _showSearchModal = true;
    }

    private void ToggleMobileMenu()
    {
        _mobileMenuOpen = !_mobileMenuOpen;
    }

    private void CloseMobileMenu()
    {
        _mobileMenuOpen = false;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await InitializeGlobalHub();
            await RegisterSearchShortcut();
        }
    }

    private DotNetObjectReference<MainLayout>? _dotNetRef;

    private async Task RegisterSearchShortcut()
    {
        try
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            await JSRuntime.InvokeVoidAsync("vibeSwarmRegisterSearchShortcut", _dotNetRef);
        }
        catch
        {
            // Non-critical - keyboard shortcut is a convenience feature
        }
    }

    [JSInvokable]
    public void OpenSearchFromShortcut()
    {
        _showSearchModal = true;
        InvokeAsync(StateHasChanged);
    }

    private async Task InitializeGlobalHub()
    {
        if (_hubInitialized) return;

        try
        {
            _globalHubConnection = new HubConnectionBuilder()
            .WithUrl(NavigationManager.ToAbsoluteUri("/hubs/job"))
            .WithAutomaticReconnect(new[] { TimeSpan.Zero, TimeSpan.FromSeconds(2), TimeSpan.FromSeconds(5),
TimeSpan.FromSeconds(10) })
            .Build();

            // Register global event handlers for toast notifications across all pages
            _globalHubConnection.On<string, bool, string?>("JobCompleted", async (jobId, success, errorMessage) =>
            {
                await OnGlobalJobCompleted(jobId, success, errorMessage);
            });

            _globalHubConnection.On<string, string>("IdeaCreated", async (ideaId, projectId) =>
            {
                await OnGlobalIdeaCreated(ideaId);
            });

            _globalHubConnection.On<string, string>("IdeaUpdated", async (ideaId, projectId) =>
            {
                await OnGlobalIdeaUpdated(ideaId);
            });

            _globalHubConnection.On<string, string, string>("IdeaStarted", async (ideaId, projectId, jobId) =>
            {
                await OnGlobalIdeaStarted(ideaId, jobId);
            });

            _globalHubConnection.On<string, string, string, List<string>?, string?>("JobInteractionRequired",
            async (jobId, prompt, interactionType, choices, defaultResponse) =>
            {
                await InvokeAsync(() =>
    {
                NotificationService.ShowWarning($"Job requires input: {(prompt.Length > 60 ? prompt[..60] + "..." : prompt)}",
    "Interaction Required");
                StateHasChanged();
            });
            });

            _globalHubConnection.On<string, string, string, string?>("ProviderRateLimited",
            async (providerId, providerName, message, resetTimeStr) =>
            {
                await InvokeAsync(() =>
                {
                    var resetInfo = "";
                    if (DateTime.TryParse(resetTimeStr, null, System.Globalization.DateTimeStyles.RoundtripKind, out var resetTime))
                    {
                        var remaining = resetTime - DateTime.UtcNow;
                        if (remaining.TotalMinutes > 0)
                        {
                            resetInfo = remaining.TotalHours >= 1
                                ? $" Resets in ~{remaining.TotalHours:F0}h {remaining.Minutes}m."
                                : $" Resets in ~{remaining.TotalMinutes:F0}m.";
                        }
                    }
                    NotificationService.ShowWarning($"{providerName} rate limited.{resetInfo} Jobs will resume automatically.",
                        "Provider Rate Limited");
                    StateHasChanged();
                });
            });

            _globalHubConnection.Reconnected += async (connectionId) =>
            {
                try { await _globalHubConnection.InvokeAsync("SubscribeToGlobalEvents"); } catch { }
            };

            using var timeoutCts = new CancellationTokenSource(TimeSpan.FromSeconds(10));
            await _globalHubConnection.StartAsync(timeoutCts.Token);
            await _globalHubConnection.InvokeAsync("SubscribeToGlobalEvents");
            _hubInitialized = true;
        }
        catch (OperationCanceledException)
        {
            _hubInitialized = true;
        }
        catch (Exception)
        {
            _hubInitialized = true;
        }
    }

    // Global SignalR event handlers for cross-page notifications
    private void OnConnectionStateChanged(string state)
    {
    }

    private Task OnGlobalJobStatusChanged(string jobId, string status)
    {
        return Task.CompletedTask;
    }

    private Task OnGlobalJobActivityUpdated(string jobId, string activity, DateTime timestamp)
    {
        return Task.CompletedTask;
    }

    private Task OnGlobalJobCreated(string jobId, string projectId)
    {
        return Task.CompletedTask;
    }

    private Task OnGlobalJobDeleted(string jobId, string projectId)
    {
        return Task.CompletedTask;
    }

    private async Task OnGlobalJobCompleted(string jobId, bool success, string? errorMessage)
    {
        if (!TryBeginToastEvent($"job-completed:{jobId}:{success}:{errorMessage}"))
        {
            return;
        }

        if (Guid.TryParse(jobId, out var id))
        {
            try
            {
                var job = await JobService.GetByIdAsync(id);
                await InvokeAsync(() =>
                {
                    ShowJobCompletedToast(job, success, errorMessage);
                    StateHasChanged();
                });
            }
            catch
            {
                await InvokeAsync(() =>
                {
                    NotificationService.ShowJobCompleted(id, success, null, errorMessage);
                    StateHasChanged();
                });
            }
        }
    }

    private Task OnGlobalIdeaCreated(string ideaId)
    {
        return Task.CompletedTask;
    }

    private Task OnGlobalIdeaUpdated(string ideaId)
    {
        return Task.CompletedTask;
    }

    private Task OnGlobalIdeaStarted(string ideaId, string jobId)
    {
        return Task.CompletedTask;
    }

    private Task OnGlobalJobListChanged()
    {
        return Task.CompletedTask;
    }

    private Task OnGlobalJobMessageAdded(string jobId)
    {
        return Task.CompletedTask;
    }

    private Task OnGlobalProcessStarted(string jobId, int processId, string command)
    {
        return Task.CompletedTask;
    }

    private Task OnGlobalProcessExited(string jobId, int processId, int exitCode, double durationSeconds)
    {
        return Task.CompletedTask;
    }

    private void ShowJobCompletedToast(Job? job, bool success, string? errorMessage)
    {
        if (success)
        {
            var jobTitle = TruncateForToast(job?.Title, 80, "Job");
            var projectName = job?.Project?.Name;
            var scope = projectName is null ? string.Empty : $" in '{projectName}'";
            var changeInfo = job?.ChangedFilesCount switch
            {
                > 0 => $" {job.ChangedFilesCount} file(s) changed.",
                0 => " No files changed.",
                _ => string.Empty
            };

            NotificationService.Show(
                $"{jobTitle} completed successfully{scope}.{changeInfo}",
                "Job Completed",
                NotificationType.Success,
                5000,
                "View Job",
                job?.Id is Guid jobId ? $"/jobs/view/{jobId}" : null);
            return;
        }

        NotificationService.Show(
            errorMessage ?? $"{TruncateForToast(job?.Title, 80, "Job")} failed.",
            "Job Failed",
            NotificationType.Error,
            8000,
            "View Job",
            job?.Id is Guid failedJobId ? $"/jobs/view/{failedJobId}" : null);
    }

    private readonly Dictionary<string, DateTime> _recentToastEvents = new();

    private bool TryBeginToastEvent(string eventKey)
    {
        var now = DateTime.UtcNow;
        var expiry = now.AddSeconds(-5);

        foreach (var staleKey in _recentToastEvents
                     .Where(entry => entry.Value < expiry)
                     .Select(entry => entry.Key)
                     .ToList())
        {
            _recentToastEvents.Remove(staleKey);
        }

        if (_recentToastEvents.TryGetValue(eventKey, out var lastSeen) &&
            now - lastSeen < TimeSpan.FromSeconds(5))
        {
            return false;
        }

        _recentToastEvents[eventKey] = now;
        return true;
    }

    private static string TruncateForToast(string? text, int maxLength, string fallback)
    {
        if (string.IsNullOrWhiteSpace(text))
        {
            return fallback;
        }

        var value = text.Trim();
        return value.Length <= maxLength
            ? value
            : $"{value[..(maxLength - 3)]}...";
    }

    private async Task OnShowNotification(string title, string message, string type)
    {
        await InvokeAsync(() =>
        {
            var notificationType = type?.ToLower() switch
            {
                "success" => NotificationType.Success,
                "error" => NotificationType.Error,
                "warning" => NotificationType.Warning,
                _ => NotificationType.Info
            };

            NotificationService.Show(message, title, notificationType);
            StateHasChanged();
        });
    }

    private void RecoverFromError()
    {
        _errorBoundary?.Recover();
    }

    private async Task ForceReloadPage()
    {
        await LogRefreshActionAsync("page-reload");

        try
        {
            await JSRuntime.InvokeVoidAsync("location.reload", true);
        }
        catch
        {
            // JSInterop can fail after iOS app suspension - fall back to NavigationManager
            try { NavigationManager.NavigateTo(NavigationManager.Uri, forceLoad: true); } catch { }
        }
    }

    private async Task ForceNavigateToDashboard()
    {
        await LogRefreshActionAsync("navigate-dashboard");

        try
        {
            await JSRuntime.InvokeVoidAsync("eval", "window.location.href = '/'");
        }
        catch
        {
            // JSInterop can fail after iOS app suspension - fall back to NavigationManager
            try { NavigationManager.NavigateTo("/", forceLoad: true); } catch { }
        }
    }

    private void NavigateToDashboard()
    {
        _errorBoundary?.Recover();
        NavigationManager.NavigateTo("/", forceLoad: false);
    }

    private static bool IsDevelopment()
    {
#if DEBUG
return true;
#else
        return false;
#endif
    }

    private Task ReportFatalUiErrorAsync(Exception exception)
    {
        var signature = $"{exception.GetType().FullName}:{exception.Message}";
        if (string.Equals(_lastReportedFatalErrorSignature, signature, StringComparison.Ordinal))
        {
            return Task.CompletedTask;
        }

        _lastReportedFatalErrorSignature = signature;
        return LogCriticalErrorAsync(
            category: "ui-error-boundary",
            message: exception.Message,
            details: exception.ToString(),
            triggeredRefresh: false,
            refreshAction: null);
    }

    private Task LogRefreshActionAsync(string refreshAction)
    {
        return LogCriticalErrorAsync(
            category: "ui-recovery-action",
            message: $"User initiated {refreshAction} after a fatal UI error.",
            details: null,
            triggeredRefresh: true,
            refreshAction: refreshAction);
    }

    private async Task LogCriticalErrorAsync(string category, string message, string? details, bool triggeredRefresh, string? refreshAction)
    {
        try
        {
            await CriticalErrorLogService.LogAsync(new CriticalErrorLogEntry
            {
                Source = "client",
                Category = category,
                Severity = "critical",
                Message = message,
                Details = details,
                Url = NavigationManager.Uri,
                TriggeredRefresh = triggeredRefresh,
                RefreshAction = refreshAction,
                AdditionalDataJson = JsonSerializer.Serialize(new
                {
                    currentUri = NavigationManager.Uri
                })
            });
        }
        catch
        {
        }
    }

    public void Dispose()
    {
        ChangePasswordModalService.OnShowModal -= ShowChangePasswordModal;
        ChangePasswordModalService.OnHideModal -= CloseChangePasswordModal;
    }

    public async ValueTask DisposeAsync()
    {
        Dispose();
        _dotNetRef?.Dispose();
        if (_globalHubConnection != null)
        {
            try
            {
                if (_globalHubConnection.State == HubConnectionState.Connected)
                {
                    await _globalHubConnection.InvokeAsync("UnsubscribeFromGlobalEvents");
                }
                await _globalHubConnection.DisposeAsync();
            }
            catch
            {
                // Ignore disposal errors
            }
        }
    }

}
