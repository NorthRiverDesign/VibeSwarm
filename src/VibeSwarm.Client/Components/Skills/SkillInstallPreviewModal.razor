@* Preview + explicit-confirm gate shown before any marketplace / local-path install lands. *@
@inject HttpSkillInstallerService InstallerService

<ModalDialog IsVisible="IsVisible" IsVisibleChanged="HandleVisibilityChanged"
			 Title="@($"Review skill: {Preview?.Name}")" Icon="shield-check"
			 Size="ModalDialog.ModalSize.Large" OnClose="HandleClose">
	<ChildContent>
		@if (Preview is null)
		{
			<LoadingSpinner Text="Loading preview..." />
		}
		else
		{
			<div class="d-flex flex-column gap-3">
				<div class="d-flex flex-wrap gap-3">
					<div class="flex-grow-1 min-width-0">
						<div class="small text-body-secondary mb-1">Name</div>
						<div class="fw-semibold font-monospace">@Preview.Name</div>
					</div>
					<div class="flex-grow-1 min-width-0">
						<div class="small text-body-secondary mb-1">Source</div>
						<div class="font-monospace small text-break">@FormatSource(Preview)</div>
					</div>
				</div>

				@if (!string.IsNullOrWhiteSpace(Preview.Description))
				{
					<div>
						<div class="small text-body-secondary mb-1">Description</div>
						<div>@Preview.Description</div>
					</div>
				}

				<div class="d-flex flex-wrap gap-3 small text-body-secondary">
					<span class="d-flex align-items-center gap-1">
						<i class="bi bi-file-text opacity-75"></i>
						@Preview.Content.Length chars
					</span>
					<span class="d-flex align-items-center gap-1">
						<i class="bi bi-folder2-open opacity-75"></i>
						@Preview.Files.Count file(s)
					</span>
					@if (Preview.HasScripts)
					{
						<span class="d-flex align-items-center gap-1 text-warning fw-semibold">
							<i class="bi bi-terminal"></i>
							Contains executable scripts
						</span>
					}
					@if (Preview.NameExists)
					{
						<span class="d-flex align-items-center gap-1 text-warning">
							<i class="bi bi-exclamation-circle"></i>
							Skill already exists — install will be skipped.
						</span>
					}
				</div>

				<div>
					<div class="small text-body-secondary mb-1">
						<i class="bi bi-shield-lock opacity-75 me-1"></i>allowed-tools
					</div>
					@if (string.IsNullOrWhiteSpace(Preview.AllowedTools))
					{
						<div class="text-warning small">
							Not declared — this skill can request any tool the agent has access to.
						</div>
					}
					else
					{
						<code class="small">@Preview.AllowedTools</code>
					}
				</div>

				@if (Preview.Warnings.Count > 0)
				{
					<Alert Type="Alert.AlertType.Warning" Class="mb-0">
						<div class="fw-semibold mb-2">Warnings</div>
						<ul class="mb-0 ps-3">
							@foreach (var warning in Preview.Warnings)
							{
								<li>@warning</li>
							}
						</ul>
					</Alert>
				}

				<div>
					<div class="small text-body-secondary mb-1">Files to install</div>
					<div class="border rounded p-2" style="max-height: 280px; overflow-y: auto;">
						@if (Preview.Files.Count == 0)
						{
							<div class="small text-body-secondary">No files listed.</div>
						}
						else
						{
							<div class="d-flex flex-column gap-2">
								@foreach (var group in GroupFiles(Preview.Files))
								{
									@if (group.IsRoot)
									{
										@* Root-level files render flat without a collapsible header so SKILL.md is always visible. *@
										@foreach (var file in group.Files)
										{
											<div class="d-flex align-items-center gap-2 small font-monospace">
												<i class="bi @(file.IsExecutable ? "bi-terminal text-warning" : "bi-file-earmark")"></i>
												<span class="flex-grow-1 text-truncate">@file.RelativePath</span>
												<span class="text-body-secondary">@FormatSize(file.Size)</span>
											</div>
										}
									}
									else
									{
										<details open>
											<summary class="cursor-pointer small fw-semibold d-flex align-items-center gap-2">
												<i class="bi bi-folder2"></i>
												<span class="font-monospace">@group.Name/</span>
												<span class="text-body-secondary fw-normal">
													@group.Files.Count file@(group.Files.Count == 1 ? "" : "s") · @FormatSize(group.TotalSize)
												</span>
												@if (group.HasExecutables)
												{
													<span class="badge bg-warning-subtle text-warning-emphasis">
														<i class="bi bi-terminal me-1"></i>executable
													</span>
												}
											</summary>
											<div class="d-flex flex-column gap-1 ps-4 mt-1">
												@foreach (var file in group.Files)
												{
													<div class="d-flex align-items-center gap-2 small font-monospace">
														<i class="bi @(file.IsExecutable ? "bi-terminal text-warning" : "bi-file-earmark")"></i>
														<span class="flex-grow-1 text-truncate">@StripGroupPrefix(group, file)</span>
														<span class="text-body-secondary">@FormatSize(file.Size)</span>
													</div>
												}
											</div>
										</details>
									}
								}
							</div>
						}
					</div>
				</div>

				@if (RequiresAcknowledgement(Preview))
				{
					<div class="form-check">
						<input class="form-check-input" type="checkbox" id="skill-install-ack" @bind="_acknowledged" />
						<label class="form-check-label small" for="skill-install-ack">
							I reviewed the warnings above and want to install this skill anyway.
						</label>
					</div>
				}

				@if (_errorMessage != null)
				{
					<Alert Type="Alert.AlertType.Danger" Message="@_errorMessage" Class="mb-0" />
				}
			</div>
		}
	</ChildContent>
	<FooterContent>
		<ActionButton Text="Cancel" OnClick="HandleClose" Disabled="_isInstalling" />
		<ActionButton Text="@(_isInstalling ? "Installing..." : "Install skill")"
					  Style="ActionButton.ButtonStyle.Primary"
					  Icon="box-arrow-in-down"
					  OnClick="HandleInstallAsync"
					  IsLoading="_isInstalling"
					  Disabled="@IsInstallDisabled()" />
	</FooterContent>
</ModalDialog>

@code {
	[Parameter] public bool IsVisible { get; set; }
	[Parameter] public EventCallback<bool> IsVisibleChanged { get; set; }
	[Parameter] public SkillInstallPreview? Preview { get; set; }
	[Parameter] public SkillInstallRequest? Request { get; set; }
	[Parameter] public EventCallback<SkillInstallResult> OnInstalled { get; set; }

	private bool _acknowledged;
	private bool _isInstalling;
	private string? _errorMessage;
	private SkillInstallPreview? _previousPreview;

	protected override void OnParametersSet()
	{
		// Reset the acknowledgement checkbox whenever the preview actually changes — keeps
		// the "I reviewed this" step honest across successive installs.
		if (!ReferenceEquals(Preview, _previousPreview))
		{
			_acknowledged = false;
			_errorMessage = null;
			_previousPreview = Preview;
		}
	}

	private bool IsInstallDisabled()
	{
		if (_isInstalling || Preview is null || Request is null)
		{
			return true;
		}

		if (Preview.NameExists)
		{
			return true;
		}

		return RequiresAcknowledgement(Preview) && !_acknowledged;
	}

	private static bool RequiresAcknowledgement(SkillInstallPreview preview)
		=> preview.HasScripts || preview.Warnings.Count > 0 || string.IsNullOrWhiteSpace(preview.AllowedTools);

	private async Task HandleInstallAsync()
	{
		if (Preview is null || Request is null)
		{
			return;
		}

		_isInstalling = true;
		_errorMessage = null;
		try
		{
			var result = await InstallerService.InstallAsync(Request);
			await OnInstalled.InvokeAsync(result);
		}
		catch (Exception ex)
		{
			_errorMessage = $"Install failed: {ex.Message}";
		}
		finally
		{
			_isInstalling = false;
		}
	}

	private async Task HandleVisibilityChanged(bool visible)
	{
		IsVisible = visible;
		await IsVisibleChanged.InvokeAsync(visible);
	}

	private async Task HandleClose()
	{
		IsVisible = false;
		await IsVisibleChanged.InvokeAsync(false);
	}

	private static string FormatSource(SkillInstallPreview preview)
	{
		return preview.SourceType switch
		{
			SkillSourceType.Marketplace => preview.SourceRef is null
				? preview.SourceUri ?? "marketplace"
				: $"{preview.SourceUri} @ {Shorten(preview.SourceRef)}",
			SkillSourceType.ZipImport => $"ZIP: {preview.SourceUri}",
			SkillSourceType.LocalPath => $"Folder: {preview.SourceUri}",
			_ => preview.SourceUri ?? preview.SourceType.ToString(),
		};
	}

	private static string Shorten(string gitRef)
		=> gitRef.Length > 8 && !gitRef.Contains('/') ? gitRef[..8] : gitRef;

	private static string FormatSize(long bytes)
	{
		if (bytes < 1024)
		{
			return $"{bytes} B";
		}
		if (bytes < 1024 * 1024)
		{
			return $"{bytes / 1024.0:0.#} KB";
		}
		return $"{bytes / (1024.0 * 1024.0):0.#} MB";
	}

	/// <summary>
	/// Buckets files by top-level directory so multi-folder skills render as an outline
	/// (SKILL.md at the root, then a `references/` and `scripts/` group) rather than a flat
	/// list. Root-level files get a single synthetic group flagged <c>IsRoot</c>.
	/// </summary>
	private static IEnumerable<FileGroup> GroupFiles(IReadOnlyList<SkillFileEntry> files)
	{
		var buckets = new Dictionary<string, List<SkillFileEntry>>(StringComparer.OrdinalIgnoreCase);
		var rootFiles = new List<SkillFileEntry>();

		foreach (var file in files)
		{
			var slash = file.RelativePath.IndexOf('/');
			if (slash < 0)
			{
				rootFiles.Add(file);
				continue;
			}

			var topLevel = file.RelativePath[..slash];
			if (!buckets.TryGetValue(topLevel, out var list))
			{
				list = [];
				buckets[topLevel] = list;
			}
			list.Add(file);
		}

		if (rootFiles.Count > 0)
		{
			yield return new FileGroup("(root)", rootFiles, IsRoot: true);
		}

		foreach (var bucket in buckets.OrderBy(kvp => kvp.Key, StringComparer.OrdinalIgnoreCase))
		{
			yield return new FileGroup(bucket.Key, bucket.Value, IsRoot: false);
		}
	}

	private static string StripGroupPrefix(FileGroup group, SkillFileEntry file)
	{
		var prefix = group.Name + "/";
		return file.RelativePath.StartsWith(prefix, StringComparison.OrdinalIgnoreCase)
			? file.RelativePath[prefix.Length..]
			: file.RelativePath;
	}

	private sealed record FileGroup(string Name, IReadOnlyList<SkillFileEntry> Files, bool IsRoot)
	{
		public long TotalSize => Files.Sum(file => file.Size);
		public bool HasExecutables => Files.Any(file => file.IsExecutable);
	}
}
