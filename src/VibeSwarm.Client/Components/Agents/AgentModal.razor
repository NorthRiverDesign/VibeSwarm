@inject IAgentService AgentService
@inject ISkillService SkillService
@inject IProviderService ProviderService
@inject NotificationService NotificationService

<ModalDialog IsVisible="IsVisible" IsVisibleChanged="HandleModalVisibilityChanged"
			 Title="@(IsEdit ? "Edit Agent" : "Add Agent")" Icon="@(IsEdit ? "pencil" : "cpu")"
			 Size="ModalDialog.ModalSize.Large" OnClose="HandleClose">
	<ChildContent>
		<EditForm Model="@Agent" OnValidSubmit="HandleValidSubmit">
			<DataAnnotationsValidator />
			<ValidationSummary class="text-danger mb-3" />

			<div class="mb-3">
				<label for="team-role-name" class="form-label">Name</label>
				<InputText id="team-role-name" @bind-Value="Agent.Name" class="form-control"
						   placeholder="Security Reviewer" />
				<ValidationMessage For="@(() => Agent.Name)" class="text-danger small" />
			</div>

			<div class="mb-3">
				<label for="team-role-description" class="form-label">Purpose</label>
				<InputTextArea id="team-role-description" @bind-Value="Agent.Description" class="form-control"
							   rows="4" placeholder="Short summary of this role's purpose..." />
				<div class="form-text">Shown in project agent pickers and execution summaries.</div>
			</div>

			<div class="mb-3">
				<label for="team-role-responsibilities" class="form-label">Agent Instructions</label>
				<InputTextArea id="team-role-responsibilities" @bind-Value="Agent.Responsibilities" class="form-control"
							   rows="6" placeholder="Describe what this role owns, reviews, or specializes in..." />
				<ValidationMessage For="@(() => Agent.Responsibilities)" class="text-danger small" />
				<div class="form-text">Use this to capture what the agent owns, reviews, and how it should approach the work.</div>
			</div>

			<div class="row g-3 mb-3">
				<div class="col-12 col-lg-6">
					<label for="team-role-provider" class="form-label">Default Provider</label>
					@if (!_providers.Any())
					{
						<div class="rounded border bg-body-tertiary p-3 small text-body-secondary">
							No enabled providers are available yet. You can still save this agent and choose a provider when assigning it to a project.
						</div>
					}
					else
					{
						<InputSelect TValue="Guid?" id="team-role-provider"
									 Value="Agent.DefaultProviderId"
									 ValueChanged="HandleDefaultProviderChanged"
									 ValueExpression="@(() => Agent.DefaultProviderId)"
									 class="form-select">
							<option value="">Choose when assigned to a project</option>
							@foreach (var provider in _providers)
							{
								<option value="@provider.Id">@provider.Name</option>
							}
						</InputSelect>
						<div class="form-text">Used when this agent is assigned to a project or selected for a job.</div>
					}
				</div>
				<div class="col-12 col-lg-6">
					<label for="team-role-model" class="form-label">Default Model</label>
					<InputSelect TValue="string" id="team-role-model"
								 Value="@(Agent.DefaultModelId ?? string.Empty)"
								 ValueChanged="HandleDefaultModelChanged"
								 ValueExpression="@(() => Agent.DefaultModelId)"
								 class="form-select"
								 disabled="@(!Agent.DefaultProviderId.HasValue || !CurrentProviderModels.Any())">
						<option value="">Use provider default model</option>
						@foreach (var model in CurrentProviderModels)
						{
							<option value="@model.ModelId">@(model.DisplayName ?? model.ModelId)@((model.IsDefault ? " (Default)" : string.Empty))</option>
						}
					</InputSelect>
					<div class="form-text">
						@if (!Agent.DefaultProviderId.HasValue)
						{
							<span>Select a default provider first.</span>
						}
						else if (!CurrentProviderModels.Any())
						{
							<span>No cached models found for this provider yet. The provider default will be used.</span>
						}
						else
						{
							<span>Projects can keep this default or override it per assignment.</span>
						}
					</div>
				</div>
				<div class="col-12 col-lg-6">
					<label for="team-role-reasoning" class="form-label">Default Reasoning</label>
					<InputSelect TValue="string" id="team-role-reasoning"
								 Value="@(Agent.DefaultReasoningEffort ?? string.Empty)"
								 ValueChanged="HandleDefaultReasoningChanged"
								 ValueExpression="@(() => Agent.DefaultReasoningEffort)"
								 class="form-select"
								 disabled="@(!Agent.DefaultProviderId.HasValue || !CurrentReasoningOptions.Any())">
						<option value="">Use provider default reasoning</option>
						@foreach (var reasoning in CurrentReasoningOptions)
						{
							<option value="@reasoning">@reasoning</option>
						}
					</InputSelect>
					<div class="form-text">
						@if (!Agent.DefaultProviderId.HasValue)
						{
							<span>Select a default provider first.</span>
						}
						else if (!CurrentReasoningOptions.Any())
						{
							<span>This provider does not expose configurable reasoning levels.</span>
						}
						else
						{
							<span>Projects can keep this reasoning default or override it per assignment.</span>
						}
					</div>
				</div>
			</div>

			<div class="border rounded bg-body-tertiary p-3 mb-3">
				<div class="fw-semibold mb-2">Default Execution Profile</div>
				<div class="row g-3">
					<div class="col-12 col-lg-6">
						<label for="team-role-cycle-mode" class="form-label">Cycle Mode</label>
						<InputSelect id="team-role-cycle-mode" @bind-Value="Agent.DefaultCycleMode" class="form-select">
							<option value="@CycleMode.SingleCycle">Single Cycle</option>
							<option value="@CycleMode.FixedCount">Fixed Count</option>
							<option value="@CycleMode.Autonomous">Autonomous</option>
						</InputSelect>
						<div class="form-text">Applied when this agent is selected directly for a job or schedule.</div>
					</div>
					@if (Agent.DefaultCycleMode != CycleMode.SingleCycle)
					{
						<div class="col-12 col-lg-6">
							<label for="team-role-max-cycles" class="form-label">Max Cycles</label>
							<InputNumber id="team-role-max-cycles" @bind-Value="Agent.DefaultMaxCycles" class="form-control" min="1" max="100" />
							<ValidationMessage For="@(() => Agent.DefaultMaxCycles)" class="text-danger small" />
							<div class="form-text">Safety limit for fixed-count or autonomous execution.</div>
						</div>
						<div class="col-12 col-lg-6">
							<label for="team-role-session-mode" class="form-label">Session Mode</label>
							<InputSelect id="team-role-session-mode" @bind-Value="Agent.DefaultCycleSessionMode" class="form-select">
								<option value="@CycleSessionMode.ContinueSession">Continue Session</option>
								<option value="@CycleSessionMode.FreshSession">Fresh Session</option>
							</InputSelect>
							<div class="form-text">Controls whether the agent resumes the same provider session between cycles.</div>
						</div>
						<div class="col-12">
							<label for="team-role-cycle-review" class="form-label">Cycle Review Prompt (Optional)</label>
							<InputTextArea id="team-role-cycle-review" @bind-Value="Agent.DefaultCycleReviewPrompt" class="form-control"
										   rows="4" placeholder="Review instructions used between cycles..." />
							<div class="form-text">Optional review instructions applied between cycles for this agent.</div>
						</div>
					}
				</div>
			</div>

			<div class="mb-3">
				<label class="form-label">Skills</label>
				@if (!_skills.Any())
				{
					<div class="text-body-secondary small">No skills available yet. Skills can be added later from the Skills page.</div>
				}
				else
				{
					<div class="border rounded bg-body-tertiary p-3">
						<div class="row g-2">
							@foreach (var skill in _skills)
							{
								var inputId = $"team-role-skill-{skill.Id}";
								<div class="col-12 col-md-6">
									<div class="form-check">
										<input id="@inputId" class="form-check-input" type="checkbox"
											   checked="@IsSkillSelected(skill.Id)"
											   @onchange="(args) => ToggleSkill(skill, args.Value is true)" />
										<label class="form-check-label" for="@inputId">
											<span class="fw-semibold">@skill.Name</span>
											@if (!skill.IsEnabled)
											{
												<span class="text-body-secondary small ms-1">(Disabled)</span>
											}
											@if (!string.IsNullOrWhiteSpace(skill.Description))
											{
												<span class="d-block text-body-secondary small">@skill.Description</span>
											}
										</label>
									</div>
								</div>
							}
						</div>
					</div>
				}
			</div>

			<div class="mb-3">
				<div class="form-check form-switch">
					<InputCheckbox id="team-role-enabled" @bind-Value="Agent.IsEnabled" class="form-check-input" />
					<label class="form-check-label" for="team-role-enabled">
						Enabled
					</label>
				</div>
				<div class="form-text">Disabled agents stay saved but should not be assigned to new projects.</div>
			</div>

			@if (!string.IsNullOrEmpty(ErrorMessage))
			{
				<div class="text-danger small mb-3">
					<i class="bi bi-exclamation-circle me-1"></i>@ErrorMessage
				</div>
			}

			<div class="d-flex gap-2 justify-content-end">
				<button type="button" class="btn btn-secondary" @onclick="HandleCancel">Cancel</button>
				<button type="submit" class="btn btn-primary" disabled="@IsSaving">
					@if (IsSaving)
					{
						<span class="spinner-border spinner-border-sm me-1" role="status"></span>
					}
					@(IsSaving ? "Saving..." : (IsEdit ? "Update Agent" : "Add Agent"))
				</button>
			</div>
		</EditForm>
	</ChildContent>
</ModalDialog>

@code {
	[Parameter]
	public bool IsVisible { get; set; }

	[Parameter]
	public EventCallback<bool> IsVisibleChanged { get; set; }

	[Parameter]
	public Agent? EditAgent { get; set; }

	[Parameter]
	public EventCallback<Guid?> OnSaved { get; set; }

	[Parameter]
	public EventCallback OnCancelled { get; set; }

	[Parameter]
	public EventCallback OnClosed { get; set; }

	private Agent Agent { get; set; } = new();
	private List<Skill> _skills = [];
	private List<Provider> _providers = [];
	private readonly Dictionary<Guid, List<ProviderModel>> _providerModelsByProviderId = [];
	private bool IsEdit => EditAgent != null;
	private bool IsSaving { get; set; }
	private string? ErrorMessage { get; set; }
	private bool _previousIsVisible;
	private IReadOnlyList<ProviderModel> CurrentProviderModels => Agent.DefaultProviderId.HasValue && _providerModelsByProviderId.TryGetValue(Agent.DefaultProviderId.Value, out var models)
		? models
		: [];
	private IReadOnlyList<string> CurrentReasoningOptions => Agent.DefaultProviderId.HasValue
		? _providers
			.Where(provider => provider.Id == Agent.DefaultProviderId.Value)
			.SelectMany(ProviderCapabilities.GetSupportedReasoningEfforts)
			.Distinct(StringComparer.Ordinal)
			.ToList()
		: [];

	protected override async Task OnInitializedAsync()
	{
		await LoadSkillsAsync();
		await LoadProvidersAsync();
	}

	protected override async Task OnParametersSetAsync()
	{
		if (IsVisible && !_previousIsVisible)
		{
			await LoadProvidersAsync();
			ResetState();

			if (EditAgent != null)
			{
				Agent = new Agent
				{
					Id = EditAgent.Id,
					Name = EditAgent.Name,
					Description = EditAgent.Description,
					Responsibilities = EditAgent.Responsibilities,
					DefaultProviderId = EditAgent.DefaultProviderId,
					DefaultProvider = EditAgent.DefaultProvider,
					DefaultModelId = EditAgent.DefaultModelId,
					DefaultReasoningEffort = EditAgent.DefaultReasoningEffort,
					DefaultCycleMode = EditAgent.DefaultCycleMode,
					DefaultCycleSessionMode = EditAgent.DefaultCycleSessionMode,
					DefaultMaxCycles = EditAgent.DefaultMaxCycles,
					DefaultCycleReviewPrompt = EditAgent.DefaultCycleReviewPrompt,
					IsEnabled = EditAgent.IsEnabled,
					CreatedAt = EditAgent.CreatedAt,
					UpdatedAt = EditAgent.UpdatedAt,
					SkillLinks = EditAgent.SkillLinks
						.Select(link => new AgentSkill
						{
							AgentId = EditAgent.Id,
							SkillId = link.SkillId,
							Skill = link.Skill
						})
						.ToList()
				};
			}

			if (Agent.DefaultProviderId.HasValue)
			{
				if (!_providers.Any(provider => provider.Id == Agent.DefaultProviderId.Value) && Agent.DefaultProvider != null)
				{
					_providers.Add(Agent.DefaultProvider);
					_providers = _providers
						.OrderByDescending(provider => provider.IsDefault)
						.ThenBy(provider => provider.Name)
						.ToList();
				}

				await LoadProviderModelsAsync(Agent.DefaultProviderId.Value);
			}
		}

		_previousIsVisible = IsVisible;
	}

	private async Task LoadSkillsAsync()
	{
		try
		{
			_skills = (await SkillService.GetAllAsync())
				.OrderByDescending(skill => skill.IsEnabled)
				.ThenBy(skill => skill.Name)
				.ToList();
		}
		catch
		{
			_skills = [];
		}
	}

	private async Task LoadProvidersAsync()
	{
		_providers = (await ProviderService.GetAllAsync())
			.Where(provider => provider.IsEnabled)
			.OrderByDescending(provider => provider.IsDefault)
			.ThenBy(provider => provider.Name)
			.ToList();
	}

	private async Task HandleDefaultProviderChanged(Guid? providerId)
	{
		Agent.DefaultProviderId = providerId;
		Agent.DefaultProvider = providerId.HasValue
			? _providers.FirstOrDefault(provider => provider.Id == providerId.Value)
			: null;
		Agent.DefaultModelId = null;
		Agent.DefaultReasoningEffort = null;

		if (providerId.HasValue)
		{
			await LoadProviderModelsAsync(providerId.Value);
		}
	}

	private Task HandleDefaultModelChanged(string? modelId)
	{
		Agent.DefaultModelId = string.IsNullOrWhiteSpace(modelId) ? null : modelId.Trim();
		return Task.CompletedTask;
	}

	private Task HandleDefaultReasoningChanged(string? reasoningEffort)
	{
		Agent.DefaultReasoningEffort = string.IsNullOrWhiteSpace(reasoningEffort)
			? null
			: ProviderCapabilities.NormalizeReasoningEffort(reasoningEffort);
		return Task.CompletedTask;
	}

	private async Task LoadProviderModelsAsync(Guid providerId)
	{
		try
		{
			_providerModelsByProviderId[providerId] = (await ProviderService.GetModelsAsync(providerId))
				.Where(model => model.IsAvailable)
				.OrderByDescending(model => model.IsDefault)
				.ThenBy(model => model.DisplayName ?? model.ModelId)
				.ToList();
		}
		catch
		{
			_providerModelsByProviderId[providerId] = [];
		}

		if (!string.IsNullOrWhiteSpace(Agent.DefaultModelId) &&
			(!_providerModelsByProviderId.TryGetValue(providerId, out var models) ||
			 !models.Any(model => string.Equals(model.ModelId, Agent.DefaultModelId, StringComparison.Ordinal))))
		{
			Agent.DefaultModelId = null;
		}
	}

	private bool IsSkillSelected(Guid skillId)
	{
		return Agent.SkillLinks.Any(link => link.SkillId == skillId);
	}

	private void ToggleSkill(Skill skill, bool isSelected)
	{
		var existing = Agent.SkillLinks.FirstOrDefault(link => link.SkillId == skill.Id);
		if (isSelected && existing == null)
		{
			Agent.SkillLinks.Add(new AgentSkill
			{
				AgentId = Agent.Id,
				SkillId = skill.Id,
				Skill = skill
			});
		}
		else if (!isSelected && existing != null)
		{
			Agent.SkillLinks.Remove(existing);
		}
	}

	private async Task HandleValidSubmit()
	{
		IsSaving = true;
		ErrorMessage = null;

		try
		{
			var nameExists = await AgentService.NameExistsAsync(Agent.Name, IsEdit ? Agent.Id : null);
			if (nameExists)
			{
				ErrorMessage = "An agent with this name already exists.";
				IsSaving = false;
				return;
			}

			Guid? newAgentId = null;
			if (IsEdit)
			{
				await AgentService.UpdateAsync(Agent);
				NotificationService.ShowSuccess("Agent updated successfully.");
			}
			else
			{
				var created = await AgentService.CreateAsync(Agent);
				newAgentId = created.Id;
				NotificationService.ShowSuccess("Agent added successfully.");
			}

			await OnSaved.InvokeAsync(newAgentId);
			await CloseModal();
		}
		catch (Exception ex)
		{
			ErrorMessage = $"Error saving agent: {ex.Message}";
		}
		finally
		{
			IsSaving = false;
		}
	}

	private async Task HandleCancel()
	{
		await OnCancelled.InvokeAsync();
		await CloseModal();
	}

	private async Task HandleClose()
	{
		ResetState();
		await OnClosed.InvokeAsync();
	}

	private async Task HandleModalVisibilityChanged(bool visible)
	{
		if (!visible)
		{
			ResetState();
			await IsVisibleChanged.InvokeAsync(false);
		}
	}

	private async Task CloseModal()
	{
		IsVisible = false;
		await IsVisibleChanged.InvokeAsync(false);
		ResetState();
	}

	private void ResetState()
	{
		Agent = new Agent();
		ErrorMessage = null;
		IsSaving = false;
		_providerModelsByProviderId.Clear();
	}
}
