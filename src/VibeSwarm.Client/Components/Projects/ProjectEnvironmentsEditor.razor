@using VibeSwarm.Shared.Data

<div class="mb-3">
<label class="form-label d-flex align-items-center gap-2 mb-2">
<i class="bi bi-globe2"></i>
<span>Environments</span>
</label>

<Alert Type="Alert.AlertType.Info" Class="py-2 px-3 small">
@if (Project.Environments.Any())
{
<span>Configured web environments are added to job context and automatically enable Playwright MCP for browser-based validation.</span>
}
else
{
<span>Add staging URLs, release pages, or other deployment targets. Web environments can optionally store login credentials securely.</span>
}
</Alert>

@if (!Project.Environments.Any())
{
<div class="border rounded p-3 bg-body-tertiary small text-body-secondary">
No environments configured yet.
</div>
}
else
{
<div class="d-grid gap-3">
@foreach (var environment in Project.Environments.OrderBy(environment => environment.SortOrder).ToList())
{
<div class="border rounded p-3 bg-body-tertiary">
<div class="d-flex justify-content-between align-items-center gap-2 mb-3 flex-wrap">
<div class="d-flex align-items-center gap-2 flex-wrap">
<span class="badge @(environment.IsPrimary ? "text-bg-primary" : "bg-secondary-subtle text-secondary-emphasis")">
@(environment.IsPrimary ? "Primary" : "Environment")
</span>
<span class="small text-body-secondary">@environment.Type</span>
@if (!environment.IsEnabled)
{
<span class="badge bg-secondary-subtle text-secondary-emphasis">Disabled</span>
}
</div>
<div class="d-flex gap-2">
@if (!environment.IsPrimary)
{
<button type="button" class="btn btn-sm btn-secondary" @onclick="() => SetPrimaryEnvironment(environment.Id)">
<i class="bi bi-star me-1"></i>Make Primary
</button>
}
<button type="button" class="btn btn-sm btn-danger" @onclick="() => RemoveEnvironment(environment.Id)">
<i class="bi bi-trash me-1"></i>Remove
</button>
</div>
</div>

<div class="row g-3">
<div class="col-12 col-lg-4">
<label class="form-label">Name</label>
<input class="form-control" @bind="environment.Name" placeholder="Staging" />
</div>
<div class="col-12 col-lg-3">
<label class="form-label">Type</label>
<InputSelect TValue="EnvironmentType" class="form-select" Value="environment.Type" ValueChanged="value => SetEnvironmentType(environment, value)" ValueExpression="@(() => environment.Type)">
<option value="@EnvironmentType.Web">Web</option>
<option value="@EnvironmentType.Release">Release</option>
<option value="@EnvironmentType.Other">Other</option>
</InputSelect>
</div>
<div class="col-12 col-lg-5">
<label class="form-label">URL</label>
<input class="form-control" @bind="environment.Url" placeholder="https://staging.example.com" />
</div>
<div class="col-12">
<label class="form-label">Description</label>
<textarea class="form-control" rows="2" @bind="environment.Description" placeholder="What this environment is for, deployment notes, or anything agents should know."></textarea>
</div>
<div class="col-12">
<div class="form-check form-switch">
<InputCheckbox id="@($"env-enabled-{environment.Id}")" @bind-Value="environment.IsEnabled" class="form-check-input" />
<label class="form-check-label" for="@($"env-enabled-{environment.Id}")">Enabled</label>
</div>
</div>

@if (environment.Type == EnvironmentType.Web)
{
<div class="col-12">
<div class="small text-body-secondary mb-2">Optional credentials for Playwright-based login and validation.</div>
</div>
<div class="col-12 col-lg-6">
<label class="form-label">Username</label>
<input class="form-control" @bind="environment.Username" placeholder="tester@example.com" />
</div>
<div class="col-12 col-lg-6">
<label class="form-label">Password</label>
<input type="password" class="form-control" @bind="environment.Password"
placeholder="@(environment.HasPassword ? "Leave blank to keep saved password" : "Password")" />
@if (environment.HasPassword)
{
<div class="form-text d-flex align-items-center justify-content-between gap-2 flex-wrap">
<span>Password is already stored securely.</span>
<div class="form-check m-0">
<InputCheckbox id="@($"clear-password-{environment.Id}")" @bind-Value="environment.ClearPassword" class="form-check-input" />
<label class="form-check-label" for="@($"clear-password-{environment.Id}")">Clear saved password</label>
</div>
</div>
}
</div>
}
</div>
</div>
}
</div>
}

<div class="mt-3">
<button type="button" class="btn btn-secondary" @onclick="AddEnvironment">
<i class="bi bi-plus-lg me-1"></i>Add Environment
</button>
</div>
</div>

@code {
[Parameter, EditorRequired]
public Project Project { get; set; } = new();

private void AddEnvironment()
{
var environment = new ProjectEnvironment
{
Id = Guid.NewGuid(),
Name = $"Environment {Project.Environments.Count + 1}",
Type = EnvironmentType.Web,
Url = string.Empty,
IsPrimary = Project.Environments.Count == 0,
IsEnabled = true,
SortOrder = Project.Environments.Count,
CreatedAt = DateTime.UtcNow,
UpdatedAt = DateTime.UtcNow
};

Project.Environments.Add(environment);
EnsurePrimaryEnvironment();
}

private void RemoveEnvironment(Guid environmentId)
{
var environment = Project.Environments.FirstOrDefault(item => item.Id == environmentId);
if (environment == null)
{
return;
}

Project.Environments.Remove(environment);
NormalizeOrder();
EnsurePrimaryEnvironment();
}

private void SetPrimaryEnvironment(Guid environmentId)
{
foreach (var environment in Project.Environments)
{
environment.IsPrimary = environment.Id == environmentId;
}
}

private void SetEnvironmentType(ProjectEnvironment environment, EnvironmentType value)
{
environment.Type = value;
if (environment.Type != EnvironmentType.Web)
{
environment.Username = null;
environment.Password = null;
environment.ClearPassword = true;
}
}

private void EnsurePrimaryEnvironment()
{
if (!Project.Environments.Any())
{
return;
}

var primary = Project.Environments.FirstOrDefault(environment => environment.IsPrimary) ?? Project.Environments.First();
foreach (var environment in Project.Environments)
{
environment.IsPrimary = environment.Id == primary.Id;
}
}

private void NormalizeOrder()
{
var ordered = Project.Environments.OrderBy(environment => environment.SortOrder).ToList();
for (var index = 0; index < ordered.Count; index++)
{
ordered[index].SortOrder = index;
}

Project.Environments = ordered;
}
}
