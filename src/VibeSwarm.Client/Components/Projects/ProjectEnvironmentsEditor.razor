@using VibeSwarm.Shared.Data

@if (!_environments.Any())
{
	<div class="border rounded p-3 bg-body-tertiary">
		<div class="d-flex align-items-center justify-content-between gap-2 flex-wrap">
			<div>
				<div class="fw-semibold d-flex align-items-center gap-2">
					<i class="bi bi-globe2"></i>
					<span>Project Environments</span>
				</div>
				<div class="small text-body-secondary mt-1">
					Add deployed URLs or release pages so jobs can target the right environment instead of assuming localhost.
				</div>
			</div>
			<button type="button" class="btn btn-primary btn-sm" @onclick="AddEnvironment">
				<i class="bi bi-plus-lg me-1"></i>Add Environment
			</button>
		</div>
	</div>
}
else
{
	<div class="d-grid gap-3">
		<div class="d-flex align-items-center justify-content-between gap-2 flex-wrap">
			<div>
				<div class="fw-semibold d-flex align-items-center gap-2">
					<i class="bi bi-globe2"></i>
					<span>Project Environments</span>
				</div>
				<div class="small text-body-secondary mt-1">
					Configured environments are included in job context and Web environments enable Playwright MCP.
				</div>
			</div>
			<button type="button" class="btn btn-primary btn-sm" @onclick="AddEnvironment">
				<i class="bi bi-plus-lg me-1"></i>Add Environment
			</button>
		</div>

		@foreach (var environment in _environments.Select((value, index) => new { value, index }))
		{
			var item = environment.value;
			<div class="border rounded p-3 bg-body-tertiary">
				<div class="d-flex align-items-start justify-content-between gap-2 flex-wrap mb-3">
					<div class="d-flex align-items-center gap-2 flex-wrap">
						<span class="badge text-bg-primary">#@(environment.index + 1)</span>
						<span class="badge bg-secondary-subtle text-secondary-emphasis">@item.Type</span>
						@if (item.IsDefault)
						{
							<span class="badge bg-success-subtle text-success-emphasis">Default</span>
						}
						@if (!item.IsEnabled)
						{
							<span class="badge bg-secondary-subtle text-secondary-emphasis">Disabled</span>
						}
					</div>
					<div class="btn-group btn-group-sm" role="group">
						<button type="button" class="btn btn-secondary" title="Move up"
								@onclick="() => MoveEnvironmentUp(item.Id)" disabled="@(environment.index == 0)">
							<i class="bi bi-arrow-up"></i>
						</button>
						<button type="button" class="btn btn-secondary" title="Move down"
								@onclick="() => MoveEnvironmentDown(item.Id)" disabled="@(environment.index >= _environments.Count - 1)">
							<i class="bi bi-arrow-down"></i>
						</button>
						<button type="button" class="btn btn-danger" title="Remove environment"
								@onclick="() => RemoveEnvironment(item.Id)">
							<i class="bi bi-x-lg"></i>
						</button>
					</div>
				</div>

				<div class="row g-3">
					<div class="col-12 col-lg-4">
						<label class="form-label">Name</label>
						<InputText @bind-Value="item.Name" class="form-control" placeholder="Staging" />
					</div>
					<div class="col-12 col-lg-4">
						<label class="form-label">Type</label>
						<InputSelect @bind-Value="item.Type" @bind-Value:after="() => OnEnvironmentTypeChanged(item)" class="form-select">
							<option value="@EnvironmentType.Web">Web</option>
							<option value="@EnvironmentType.GitHubReleases">GitHub Releases</option>
							<option value="@EnvironmentType.Generic">Generic</option>
						</InputSelect>
					</div>
					<div class="col-12 col-lg-4">
						<label class="form-label">URL</label>
						<InputText @bind-Value="item.Url" class="form-control" placeholder="https://staging.example.com" />
					</div>
					<div class="col-12">
						<label class="form-label">Notes</label>
						<InputTextArea @bind-Value="item.Notes" class="form-control" rows="2"
									   placeholder="Optional instructions for agents, such as login flow, deployment notes, or release context." />
					</div>
				</div>

				<div class="d-flex flex-wrap align-items-center gap-3 mt-3">
					<div class="form-check form-switch m-0">
						<InputCheckbox id="@($"env-enabled-{item.Id}")" @bind-Value="item.IsEnabled" class="form-check-input" />
						<label class="form-check-label" for="@($"env-enabled-{item.Id}")">Enabled</label>
					</div>
					<div class="form-check form-switch m-0">
						<InputCheckbox id="@($"env-default-{item.Id}")" Value="@item.IsDefault"
									   ValueChanged="@(value => ToggleDefaultEnvironment(item.Id, value))" class="form-check-input" />
						<label class="form-check-label" for="@($"env-default-{item.Id}")">Default environment</label>
					</div>
				</div>

				@if (item.Type == EnvironmentType.Web)
				{
					<div class="border rounded p-3 mt-3 bg-body">
						<div class="fw-semibold d-flex align-items-center gap-2 mb-2">
							<i class="bi bi-person-lock"></i>
							<span>Web Login</span>
						</div>
						<div class="small text-body-secondary mb-3">
							Credentials are encrypted at rest and only decrypted for job execution.
						</div>
						<div class="row g-3">
							<div class="col-12 col-lg-6">
								<label class="form-label">Username</label>
								<InputText @bind-Value="item.Username" class="form-control" placeholder="tester@example.com" />
							</div>
							<div class="col-12 col-lg-6">
								<label class="form-label">Password</label>
								<InputText @bind-Value="item.Password" class="form-control" type="password"
										   placeholder="Leave blank to keep the saved password" />
								@if (item.HasPassword)
								{
									<div class="form-text d-flex align-items-center justify-content-between gap-2 flex-wrap">
										<span>Saved password is already stored securely.</span>
										<div class="form-check m-0">
											<InputCheckbox id="@($"env-clear-password-{item.Id}")" @bind-Value="item.ClearPassword" class="form-check-input" />
											<label class="form-check-label" for="@($"env-clear-password-{item.Id}")">Clear saved password</label>
										</div>
									</div>
								}
							</div>
						</div>
					</div>
				}
			</div>
		}
	</div>
}

@code {
	[Parameter, EditorRequired]
	public Project Project { get; set; } = new();

	private List<ProjectEnvironment> _environments => Project.Environments.OrderBy(environment => environment.SortOrder).ToList();

	private void AddEnvironment()
	{
		Project.Environments.Add(new ProjectEnvironment
		{
			Id = Guid.NewGuid(),
			Name = $"Environment {Project.Environments.Count + 1}",
			Type = EnvironmentType.Web,
			IsEnabled = true,
			IsDefault = Project.Environments.Count == 0,
			SortOrder = Project.Environments.Count
		});
		NormalizeOrder();
	}

	private void RemoveEnvironment(Guid environmentId)
	{
		var environment = Project.Environments.FirstOrDefault(item => item.Id == environmentId);
		if (environment == null)
		{
			return;
		}

		Project.Environments.Remove(environment);
		NormalizeOrder();
	}

	private void MoveEnvironmentUp(Guid environmentId)
	{
		var ordered = _environments;
		var index = ordered.FindIndex(environment => environment.Id == environmentId);
		if (index <= 0)
		{
			return;
		}

		(ordered[index - 1], ordered[index]) = (ordered[index], ordered[index - 1]);
		Project.Environments = ordered;
		NormalizeOrder();
	}

	private void MoveEnvironmentDown(Guid environmentId)
	{
		var ordered = _environments;
		var index = ordered.FindIndex(environment => environment.Id == environmentId);
		if (index < 0 || index >= ordered.Count - 1)
		{
			return;
		}

		(ordered[index + 1], ordered[index]) = (ordered[index], ordered[index + 1]);
		Project.Environments = ordered;
		NormalizeOrder();
	}

	private void ToggleDefaultEnvironment(Guid environmentId, bool isDefault)
	{
		foreach (var environment in Project.Environments)
		{
			environment.IsDefault = isDefault && environment.Id == environmentId;
		}

		if (!Project.Environments.Any(environment => environment.IsDefault) && Project.Environments.Count == 1)
		{
			Project.Environments.First().IsDefault = true;
		}
	}

	private void OnEnvironmentTypeChanged(ProjectEnvironment environment)
	{
		if (environment.Type == EnvironmentType.Web)
		{
			return;
		}

		environment.Username = null;
		environment.Password = null;
		environment.ClearPassword = true;
	}

	private void NormalizeOrder()
	{
		Project.Environments = Project.Environments
			.OrderBy(environment => environment.SortOrder)
			.Select((environment, index) =>
			{
				environment.SortOrder = index;
				if (environment.CreatedAt == default)
				{
					environment.CreatedAt = DateTime.UtcNow;
				}
				environment.UpdatedAt = DateTime.UtcNow;
				return environment;
			})
			.ToList();

		var defaultEnvironment = Project.Environments.FirstOrDefault(environment => environment.IsDefault && environment.IsEnabled)
			?? Project.Environments.FirstOrDefault(environment => environment.IsEnabled)
			?? Project.Environments.FirstOrDefault();
		foreach (var environment in Project.Environments)
		{
			environment.IsDefault = defaultEnvironment != null && environment.Id == defaultEnvironment.Id;
		}
	}
}
