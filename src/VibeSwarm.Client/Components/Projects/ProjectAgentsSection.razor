
<div class="mb-3">
<label class="form-label d-flex align-items-center gap-2 mb-2">
<i class="bi bi-people"></i>
<span>Agents</span>
</label>

<Alert Type="Alert.AlertType.Info" Class="py-2 px-3 small">
@if (Project.AgentAssignments.Any())
{
<span>Assign reusable agents to this project so jobs can reference consistent purpose, provider/model choices, and execution defaults.</span>
}
else
{
<span>No project-specific agents configured yet. Add agents to define the specialists available to this repository.</span>
}
</Alert>

@if (!AvailableAgents.Any())
{
<div class="text-warning small mt-2">
<i class="bi bi-exclamation-triangle me-1"></i>No agents available yet. Create them from the Agents page first.
</div>
}
else if (!AvailableProviders.Any())
{
<div class="text-warning small mt-2">
<i class="bi bi-exclamation-triangle me-1"></i>No enabled providers are available to assign to agents yet.
</div>
}
else
{
<div class="border rounded p-3 bg-body-tertiary">
<div class="small text-body-secondary fw-semibold mb-2">Assigned Agents</div>
@if (Project.AgentAssignments.Any())
{
<div class="d-grid gap-3 mb-3">
@foreach (var assignment in Project.AgentAssignments.OrderBy(assignment => ResolveAgent(assignment.AgentId)?.Name ?? string.Empty).ToList())
{
var agent = ResolveAgent(assignment.AgentId);
var providerSelectId = $"team-provider-{assignment.AgentId}";
var modelSelectId = $"team-model-{assignment.AgentId}";
var reasoningSelectId = $"team-reasoning-{assignment.AgentId}";
var models = ResolveProviderModels(assignment.ProviderId)
.Where(model => model.IsAvailable)
.OrderByDescending(model => model.IsDefault)
.ThenBy(model => model.DisplayName ?? model.ModelId)
.ToList();
var assignmentProvider = AvailableProviders.FirstOrDefault(provider => provider.Id == assignment.ProviderId);
var reasoningOptions = assignmentProvider != null ? ProviderCapabilities.GetSupportedReasoningEfforts(assignmentProvider) : [];

<div class="rounded border bg-body p-3">
<div class="d-flex align-items-start justify-content-between gap-2 flex-wrap">
<div class="min-width-0 flex-grow-1">
<div class="d-flex align-items-center gap-2 flex-wrap">
<span class="fw-semibold">@(agent?.Name ?? "Unknown Agent")</span>
@if (agent != null && !agent.IsEnabled)
{
<span class="badge bg-secondary-subtle text-secondary-emphasis">Disabled</span>
}
</div>
@if (!string.IsNullOrWhiteSpace(agent?.Description))
{
<div class="small text-body-secondary mt-1">@agent.Description</div>
}
@if (agent?.SkillLinks.Any(link => link.Skill != null) == true)
{
<div class="d-flex flex-wrap gap-1 mt-2">
@foreach (var skillLink in agent.SkillLinks.Where(link => link.Skill != null).Take(4))
{
<span class="badge bg-primary-subtle text-primary-emphasis">@skillLink.Skill!.Name</span>
}
@if (agent.SkillLinks.Count > 4)
{
<span class="badge bg-secondary-subtle text-secondary-emphasis">+@(agent.SkillLinks.Count - 4)</span>
}
</div>
}
@if (agent != null && agent.DefaultCycleMode != CycleMode.SingleCycle)
{
<div class="d-flex flex-wrap gap-1 mt-2">
<span class="badge bg-body-secondary text-body-secondary border" title="Cycle mode from agent defaults">
<i class="bi bi-arrow-repeat me-1"></i>
@(agent.DefaultCycleMode == CycleMode.FixedCount
	? $"{agent.DefaultMaxCycles} fixed cycles"
	: $"autonomous up to {agent.DefaultMaxCycles} cycles")
</span>
</div>
}
</div>
<button type="button" class="btn btn-sm btn-danger" @onclick="() => OnRemove.InvokeAsync(assignment.AgentId)" title="Remove agent">
<i class="bi bi-x-lg"></i>
</button>
</div>

<div class="row g-3 mt-1">
<div class="col-12 col-lg-6">
<label for="@providerSelectId" class="form-label small mb-1">
<i class="bi bi-cpu me-1"></i>Assigned Provider
</label>
<InputSelect TValue="Guid" id="@providerSelectId"
 Value="assignment.ProviderId"
 ValueChanged="@(async (Guid value) => await HandleProviderChanged(assignment.AgentId, value))"
 ValueExpression="@(() => assignment.ProviderId)"
 class="form-select form-select-sm">
@foreach (var provider in AvailableProviders)
{
<option value="@provider.Id">@provider.Name</option>
}
</InputSelect>
</div>
<div class="col-12 col-lg-6">
<label for="@modelSelectId" class="form-label small mb-1">
<i class="bi bi-diagram-3 me-1"></i>Default Model
</label>
<InputSelect TValue="string" id="@modelSelectId"
 Value="@(assignment.PreferredModelId ?? string.Empty)"
 ValueChanged="@(async (string? value) => await HandlePreferredSelectionChanged(assignment.AgentId, value, assignment.PreferredReasoningEffort))"
 ValueExpression="@(() => assignment.PreferredModelId)"
 class="form-select form-select-sm"
 disabled="@(!models.Any())">
<option value="">Use provider default model</option>
@foreach (var model in models)
{
<option value="@model.ModelId">@(model.DisplayName ?? model.ModelId)@((model.IsDefault ? " (Default)" : string.Empty))</option>
}
</InputSelect>
<div class="form-text">
@if (!models.Any())
{
<span>No cached models found for this provider yet. The provider default will be used.</span>
}
else
{
<span>New agent-backed work can start with this model unless a workflow overrides it.</span>
}
</div>
</div>
<div class="col-12 col-lg-6">
<label for="@reasoningSelectId" class="form-label small mb-1">
<i class="bi bi-lightning-charge me-1"></i>Default Reasoning
</label>
<InputSelect TValue="string" id="@reasoningSelectId"
 Value="@(assignment.PreferredReasoningEffort ?? string.Empty)"
 ValueChanged="@(async (string? value) => await HandlePreferredSelectionChanged(assignment.AgentId, assignment.PreferredModelId, value))"
 ValueExpression="@(() => assignment.PreferredReasoningEffort)"
 class="form-select form-select-sm"
 disabled="@(!reasoningOptions.Any())">
<option value="">Use provider default reasoning</option>
@foreach (var reasoning in reasoningOptions)
{
<option value="@reasoning">@reasoning</option>
}
</InputSelect>
<div class="form-text">
@if (!reasoningOptions.Any())
{
<span>This provider does not expose configurable reasoning levels.</span>
}
else
{
<span>New agent-backed work can start with this reasoning level unless a workflow overrides it.</span>
}
</div>
</div>
</div>
</div>
}
</div>
}
else
{
<div class="small text-body-secondary fst-italic mb-3">No agents assigned to this project yet.</div>
}

@if (Project.AgentAssignments.Count(a => a.IsEnabled) >= 2)
{
<div class="border-top pt-3 mt-3">
<div class="form-check form-switch">
<InputCheckbox id="modal-enableTeamSwarm" @bind-Value="Project.EnableTeamSwarm" class="form-check-input" />
<label class="form-check-label" for="modal-enableTeamSwarm">
<i class="bi bi-diagram-3 me-1"></i>Enable Agent Swarm
</label>
</div>
<div class="form-text">When enabled, creating a job automatically fans out into parallel agent jobs — one per assigned agent. Each agent works in the same repository with an agent-specific system prompt.</div>
</div>
}

<div class="small text-body-secondary fw-semibold mb-2">Add Agent</div>
<div class="d-grid gap-2">
@foreach (var agent in AvailableAgents.OrderByDescending(role => role.IsEnabled).ThenBy(role => role.Name))
{
var isAssigned = IsAgentAssigned(agent.Id);
<button type="button" class="btn @(isAssigned ? "btn-secondary" : "btn-primary") d-flex align-items-center justify-content-between gap-2 text-start flex-wrap"
@onclick="() => OnAdd.InvokeAsync(agent)" disabled="@isAssigned">
<span class="text-start min-width-0">
										<span class="fw-semibold">@agent.Name</span>
										@if (!string.IsNullOrWhiteSpace(agent.Description))
										{
											<span class="text-body-secondary ms-sm-2 d-block d-sm-inline">@agent.Description</span>
										}
										@if (agent.DefaultProvider != null || !string.IsNullOrWhiteSpace(agent.DefaultModelId) || !string.IsNullOrWhiteSpace(agent.DefaultReasoningEffort))
										{
											<span class="d-block small text-body-secondary mt-1">
												@if (agent.DefaultProvider != null)
												{
													<span><i class="bi bi-cpu me-1"></i>@agent.DefaultProvider.Name</span>
												}
												@if (!string.IsNullOrWhiteSpace(agent.DefaultModelId))
												{
													<span class="ms-sm-2 d-block d-sm-inline"><i class="bi bi-diagram-3 me-1"></i>@agent.DefaultModelId</span>
												}
												@if (!string.IsNullOrWhiteSpace(agent.DefaultReasoningEffort))
												{
													<span class="ms-sm-2 d-block d-sm-inline"><i class="bi bi-lightning-charge me-1"></i>@agent.DefaultReasoningEffort</span>
												}
											</span>
										}
									</span>
									@if (isAssigned)
									{
<i class="bi bi-check-lg"></i>
}
else
{
<i class="bi bi-plus-lg"></i>
}
</button>
}
</div>
</div>
}
</div>

@code {
[Parameter, EditorRequired]
public ProjectModalFormModel Project { get; set; } = default!;

[Parameter]
public IReadOnlyList<Agent> AvailableAgents { get; set; } = [];

[Parameter]
public IReadOnlyList<Provider> AvailableProviders { get; set; } = [];

[Parameter, EditorRequired]
public Func<Guid, Agent?> ResolveAgent { get; set; } = _ => null;

[Parameter, EditorRequired]
public Func<Guid, bool> IsAgentAssigned { get; set; } = _ => false;

[Parameter, EditorRequired]
public Func<Guid, IReadOnlyList<ProviderModel>> ResolveProviderModels { get; set; } = _ => [];

[Parameter]
public EventCallback<Guid> OnRemove { get; set; }

[Parameter]
public EventCallback<Agent> OnAdd { get; set; }

[Parameter]
public EventCallback<ProjectAgentProviderChange> OnProviderChanged { get; set; }

[Parameter]
public EventCallback<ProjectAgentModelSelectionChange> OnPreferredModelChanged { get; set; }

private Task HandleProviderChanged(Guid agentId, Guid providerId)
{
return OnProviderChanged.InvokeAsync(new ProjectAgentProviderChange
{
AgentId = agentId,
ProviderId = providerId
});
}

private Task HandlePreferredSelectionChanged(Guid agentId, string? preferredModelId, string? preferredReasoningEffort)
{
return OnPreferredModelChanged.InvokeAsync(new ProjectAgentModelSelectionChange
{
AgentId = agentId,
PreferredModelId = string.IsNullOrWhiteSpace(preferredModelId) ? null : preferredModelId,
PreferredReasoningEffort = string.IsNullOrWhiteSpace(preferredReasoningEffort) ? null : preferredReasoningEffort
});
}
}
