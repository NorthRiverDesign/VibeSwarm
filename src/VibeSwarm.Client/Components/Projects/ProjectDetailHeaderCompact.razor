@* Compact project detail header with title, Git info, and stats *@

<Breadcrumb Items="@_breadcrumbItems" />

<div class="card mb-3 border-0 shadow-sm rounded-3">
	<div class="card-body bg-body-secondary p-3 rounded-3">
		<div class="d-flex flex-column gap-2 gap-md-3">
			<div class="d-flex align-items-start justify-content-between gap-2 gap-md-3">
				<div class="min-width-0">
					<h3 class="mb-0 fs-5 fw-semibold text-break">@Name</h3>
				</div>

				<div class="d-flex align-items-center gap-2 flex-shrink-0">
					@if (IsGitRepository)
					{
						<div class="d-none d-lg-flex align-items-center gap-2">
							@if (Branches.Any())
							{
								<GitBranchSelector Branches="@Branches" CurrentBranch="@CurrentBranch"
												   CurrentCommitHash="@CurrentCommitHash" IsDisabled="@IsGitOperationInProgress"
												   OnBranchSelected="OnBranchSelected" />
							}
							else if (!string.IsNullOrEmpty(CurrentBranch))
							{
								<span class="badge bg-body-tertiary text-body d-flex align-items-center gap-1 px-2 py-1"
									  title="Current branch: @CurrentBranch">
									<i class="bi bi-git text-danger"></i>
									<span class="fw-medium">@CurrentBranch</span>
									@if (!string.IsNullOrEmpty(CurrentCommitHash))
									{
										<span class="font-monospace text-body-secondary small">@CurrentCommitHash[..Math.Min(7, CurrentCommitHash.Length)]</span>
									}
								</span>
							}

							@if (HasUncommittedChanges)
							{
								<UncommittedChangesButton FilesCount="@UncommittedFilesCount" OnClick="OnUncommittedChangesClick" />
							}
						</div>
					}
					else if (IsLoadingGitInfo)
					{
						<span class="badge bg-body-tertiary text-body-secondary d-flex align-items-center gap-1 px-2 py-1">
							<span class="spinner-border spinner-border-sm" role="status" style="width: 0.75rem; height: 0.75rem;"></span>
							<span class="d-none d-sm-inline small">Checking Git...</span>
						</span>
					}

					<ProjectActionsDropdown OnEdit="OnEdit" IsActive="IsActive"
											OnToggleActive="OnToggleActive" ShowSyncAction="@IsGitRepository"
											ShowCreateBranchAction="@IsGitRepository" ShowMergeBranchAction="@ShowMergeBranchAction"
											ShowRefreshAction="@IsGitRepository" ShowPruneBranchesAction="@IsGitRepository"
											IsSyncing="@(_currentGitOperation == "sync")" IsRefreshing="@(_currentGitOperation == "refresh")"
											IsPruning="@(_currentGitOperation == "prune")" IsMerging="@IsMerging"
											OnCreateBranch="OnCreateBranch" OnMergeBranch="OnMergeBranch" OnSync="OnSync"
											OnRefresh="OnRefresh" OnPruneBranches="OnPruneBranches"
											GitHubRepository="@GitHubRepository" />
				</div>
			</div>

			@if (IsGitRepository)
			{
				<div class="d-grid d-lg-none gap-2">
					@if (Branches.Any())
					{
						<div class="min-width-0">
							<GitBranchSelector Branches="@Branches" CurrentBranch="@CurrentBranch"
											   CurrentCommitHash="@CurrentCommitHash" IsDisabled="@IsGitOperationInProgress"
											   OnBranchSelected="OnBranchSelected" />
						</div>
					}
					else if (!string.IsNullOrEmpty(CurrentBranch))
					{
						<span class="badge bg-body-tertiary text-body d-inline-flex align-items-center justify-content-center gap-1 px-2 py-2"
							  title="Current branch: @CurrentBranch">
							<i class="bi bi-git text-danger"></i>
							<span class="fw-medium text-truncate">@CurrentBranch</span>
						</span>
					}

					@if (HasUncommittedChanges)
					{
						<div class="d-flex justify-content-start">
							<UncommittedChangesButton FilesCount="@UncommittedFilesCount" OnClick="OnUncommittedChangesClick" />
						</div>
					}
				</div>
			}

			@{
				var autoPilotActive = AutoPilotStatus != null && !AutoPilotPanel.IsTerminal(AutoPilotStatus.Status);
			}
			@if (autoPilotActive || IsIdeasProcessingActive || ActiveJob != null)
			{
				<div class="d-flex flex-column flex-sm-row align-items-stretch align-items-sm-center gap-2 mt-2 pt-2 border-top border-body-tertiary small">
					<div class="d-flex flex-wrap align-items-center gap-2 min-width-0">
						@if (autoPilotActive)
						{
							<span class="badge @AutoPilotPanel.GetStatusBadgeClass(AutoPilotStatus!.Status) d-inline-flex align-items-center gap-1 flex-shrink-0"
								  title="Auto-Pilot: @AutoPilotStatus.Status — @AutoPilotStatus.CompletedIterations iteration(s) completed">
								@if (AutoPilotStatus.Status == IterationLoopStatus.Running)
								{
									<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
								}
								<i class="bi bi-robot"></i>
								Auto-Pilot
								@if (AutoPilotStatus.CompletedIterations > 0)
								{
									<span class="opacity-75">(@AutoPilotStatus.CompletedIterations)</span>
								}
							</span>
						}

						@if (IsIdeasProcessingActive)
						{
							<span class="badge text-bg-info d-inline-flex align-items-center gap-1 flex-shrink-0"
								  title="Ideas are being queued and run automatically">
								<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
								<i class="bi bi-lightbulb"></i>
								Ideas
								@if (IdeasUnprocessedCount > 0)
								{
									<span class="opacity-75">(@IdeasUnprocessedCount pending)</span>
								}
							</span>
						}

						@if (ActiveJob != null)
						{
							<div class="d-flex align-items-center gap-1 text-body-secondary min-width-0 flex-shrink-1">
								<i class="bi bi-gear-fill spin flex-shrink-0 opacity-75" style="font-size: 0.75rem;"></i>
								<span class="text-truncate" style="max-width: min(100%, 20rem);" title="@ActiveJob.DisplayTitle">@ActiveJob.DisplayTitle</span>
								@if (!string.IsNullOrEmpty(ActiveJob.CurrentActivity))
								{
									<span class="text-body-secondary text-truncate flex-shrink-1" style="max-width: min(100%, 16rem);">
										- @ActiveJob.CurrentActivity
									</span>
								}
							</div>
						}
					</div>

					<div class="d-grid d-sm-flex align-items-stretch align-items-sm-center gap-2 ms-sm-auto">
						@if (CanSuggestIdeas && !IsIdeasProcessingActive)
						{
							<button type="button" class="btn btn-sm btn-secondary" @onclick="OnSuggestIdeas"
									title="Suggest ideas from codebase analysis">
								<i class="bi bi-stars me-1"></i>
								<span>Suggest</span>
							</button>
						}

						<button type="button" class="btn btn-sm btn-danger" @onclick="OnStop"
								disabled="@IsStoppingAll" title="Stop all running processes">
							@if (IsStoppingAll)
							{
								<span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
							}
							else
							{
								<i class="bi bi-stop-fill me-1"></i>
							}
							Stop
						</button>
					</div>
				</div>
			}

			@{
				var showPath = string.IsNullOrEmpty(GitHubRepository);
				var showTokens = HasTokenData && (TotalInputTokens > 0 || TotalOutputTokens > 0);
			}
			@if (showPath || showTokens)
			{
				<div class="d-flex flex-column flex-sm-row align-items-stretch align-items-sm-center gap-2 gap-md-3 mt-2 pt-2 border-top border-body-tertiary small">
					@if (showPath)
					{
						<div class="d-flex align-items-center gap-1 text-body-secondary min-width-0">
							<i class="bi bi-folder opacity-75"></i>
							<code class="bg-body-tertiary px-2 py-1 rounded-1 text-truncate d-inline-block"
								  style="max-width: min(100%, 28rem);" title="@WorkingPath">@WorkingPath</code>
						</div>
					}

					@if (showTokens)
					{
						<div class="d-flex flex-wrap align-items-center gap-2 gap-md-3 ms-sm-auto">
							<div class="d-flex align-items-center gap-1 text-body-secondary" title="Total tokens (input / output)">
								<i class="bi bi-braces opacity-75"></i>
								<span>@TokenHelper.FormatTokenCount(TotalInputTokens) / @TokenHelper.FormatTokenCount(TotalOutputTokens)</span>
							</div>
						</div>
					}
				</div>
			}

			<AlertMessage Message="@GitOperationMessage" IsSuccess="@GitOperationSuccess"
						  ProgressMessage="@GitProgressMessage" OnDismiss="OnClearGitMessage" />
		</div>
	</div>
</div>

@code {
	[Parameter, EditorRequired]
	public string Name { get; set; } = string.Empty;

	[Parameter, EditorRequired]
	public string WorkingPath { get; set; } = string.Empty;

	[Parameter]
	public string? GitHubRepository { get; set; }

	[Parameter]
	public bool IsGitRepository { get; set; }

	[Parameter]
	public bool IsLoadingGitInfo { get; set; }

	private List<Breadcrumb.BreadcrumbItem> _breadcrumbItems => new()
	{
		new Breadcrumb.BreadcrumbItem("Projects", "/projects", "folder"),
		new Breadcrumb.BreadcrumbItem(Name)
	};

	[Parameter]
	public List<GitBranchInfo> Branches { get; set; } = new();

	[Parameter]
	public string? CurrentBranch { get; set; }

	[Parameter]
	public string? CurrentCommitHash { get; set; }

	[Parameter]
	public bool IsGitOperationInProgress { get; set; }

	[Parameter]
	public string? GitOperationMessage { get; set; }

	[Parameter]
	public bool GitOperationSuccess { get; set; }

	[Parameter]
	public string? GitProgressMessage { get; set; }

	[Parameter]
	public bool HasUncommittedChanges { get; set; }

	[Parameter]
	public int UncommittedFilesCount { get; set; }

	[Parameter]
	public bool HasTokenData { get; set; }

	[Parameter]
	public int TotalInputTokens { get; set; }

	[Parameter]
	public int TotalOutputTokens { get; set; }

	[Parameter]
	public decimal TotalCost { get; set; }

	[Parameter]
	public EventCallback OnCreateBranch { get; set; }

	[Parameter]
	public bool ShowMergeBranchAction { get; set; }

	[Parameter]
	public bool IsMerging { get; set; }

	[Parameter]
	public EventCallback OnMergeBranch { get; set; }

	[Parameter]
	public EventCallback OnSync { get; set; }

	[Parameter]
	public EventCallback OnRefresh { get; set; }

	[Parameter]
	public EventCallback OnPruneBranches { get; set; }

	[Parameter]
	public EventCallback<string> OnBranchSelected { get; set; }

	[Parameter]
	public EventCallback OnUncommittedChangesClick { get; set; }

	[Parameter]
	public EventCallback OnClearGitMessage { get; set; }

	[Parameter]
	public EventCallback OnEdit { get; set; }

	[Parameter]
	public bool IsActive { get; set; } = true;

	[Parameter]
	public EventCallback OnToggleActive { get; set; }

	[Parameter]
	public IterationLoop? AutoPilotStatus { get; set; }

	[Parameter]
	public bool IsIdeasProcessingActive { get; set; }

	[Parameter]
	public int IdeasUnprocessedCount { get; set; }

	[Parameter]
	public JobSummary? ActiveJob { get; set; }

	[Parameter]
	public bool IsStoppingAll { get; set; }

	[Parameter]
	public bool CanSuggestIdeas { get; set; }

	[Parameter]
	public EventCallback OnStop { get; set; }

	[Parameter]
	public EventCallback OnSuggestIdeas { get; set; }

	private string? _currentGitOperation => IsGitOperationInProgress
		? GitProgressMessage?.Contains("Pruning") == true ? "prune"
		: GitProgressMessage?.Contains("Fetching") == true ? "refresh"
		: "sync"
		: null;
}
