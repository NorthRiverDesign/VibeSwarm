
<div class="mb-3">
<label class="form-label d-flex align-items-center gap-2 mb-2">
<i class="bi bi-diagram-3"></i>
<span>Job Execution</span>
</label>

<Alert Type="Alert.AlertType.Info" Class="py-2 px-3 small">
@if (Project.ProviderSelections.Any())
{
<span>This project will prefer providers in the order shown below. Each provider can also carry a project-specific default model for new jobs.</span>
}
else
{
<span>No providers selected yet. If you save without a provider list, the project can use any enabled provider system-wide.</span>
}
</Alert>

@if (!AvailableProviders.Any())
{
<div class="text-warning small mt-2">
<i class="bi bi-exclamation-triangle me-1"></i>No enabled providers available. Configure a provider first.
</div>
}
else
{
<div class="border rounded p-3 bg-body-tertiary">
<div class="small text-body-secondary fw-semibold mb-2">Priority Order</div>
@if (Project.ProviderSelections.Any())
{
<DragDropList TItem="ProjectProvider"
              Items="@(Project.ProviderSelections.OrderBy(pp => pp.Priority).ToList())"
              OnReorder="OnReorder"
              Class="d-grid gap-3 mb-3">
    <ItemTemplate Context="selection">
        @{
            var provider = ResolveProvider(selection.ProviderId);
            var models = ResolveProviderModels(selection.ProviderId)
                .Where(model => model.IsAvailable)
                .OrderByDescending(model => model.IsDefault)
                .ThenBy(model => model.DisplayName ?? model.ModelId)
                .ToList();
            var modelInputId = $"provider-model-{selection.ProviderId}";
            var reasoningInputId = $"provider-reasoning-{selection.ProviderId}";
            var reasoningOptions = provider != null ? ProviderCapabilities.GetSupportedReasoningEfforts(provider) : [];
        }
        <div class="rounded border bg-body p-3">
        <div class="d-flex align-items-start justify-content-between gap-2 flex-wrap">
        <div class="min-width-0 flex-grow-1">
        <div class="d-flex align-items-center gap-2 flex-wrap">
        <span class="badge text-bg-primary">#@(selection.Priority + 1)</span>
        <span class="fw-semibold">@(provider?.Name ?? "Unknown Provider")</span>
        @if (provider != null)
        {
        <span class="badge bg-secondary-subtle text-secondary-emphasis">@provider.Type</span>
        }
        </div>
        </div>
        <div class="d-flex flex-wrap justify-content-end gap-2">
        <button type="button" class="btn btn-sm btn-danger" @onclick="() => OnRemove.InvokeAsync(selection.ProviderId)" title="Remove provider">
        <i class="bi bi-x-lg"></i>
        </button>
        </div>
        </div>

        <div class="mt-3">
        <label for="@modelInputId" class="form-label small mb-1">
        <i class="bi bi-cpu me-1"></i>Default Job Model
        </label>
         <InputSelect TValue="string" id="@modelInputId"
                      Value="@(selection.PreferredModelId ?? string.Empty)"
                      ValueChanged="@(async (string? value) => await HandlePreferredSelectionChanged(selection.ProviderId, value, selection.PreferredReasoningEffort))"
                      ValueExpression="@(() => selection.PreferredModelId)"
                      class="form-select form-select-sm"
                      disabled="@(!models.Any())">
        <option value="">Use provider default model</option>
        @foreach (var model in models)
        {
        <option value="@model.ModelId">@(model.DisplayName ?? model.ModelId)@((model.IsDefault ? " (Default)" : string.Empty))</option>
        }
        </InputSelect>
        <div class="form-text">
        @if (!models.Any())
        {
        <span>No cached models found for this provider yet. The provider default will be used until models are refreshed.</span>
        }
        else
        {
        <span>New jobs start with this project default before any job-specific model override.</span>
        }
        </div>
        </div>

        <div class="mt-3">
        <label for="@reasoningInputId" class="form-label small mb-1">
        <i class="bi bi-lightning-charge me-1"></i>Default Job Reasoning
        </label>
        <InputSelect TValue="string" id="@reasoningInputId"
                     Value="@(selection.PreferredReasoningEffort ?? string.Empty)"
                     ValueChanged="@(async (string? value) => await HandlePreferredSelectionChanged(selection.ProviderId, selection.PreferredModelId, value))"
                     ValueExpression="@(() => selection.PreferredReasoningEffort)"
                     class="form-select form-select-sm"
                     disabled="@(!reasoningOptions.Any())">
        <option value="">Use provider default reasoning</option>
        @foreach (var reasoning in reasoningOptions)
        {
        <option value="@reasoning">@reasoning</option>
        }
        </InputSelect>
        <div class="form-text">
        @if (!reasoningOptions.Any())
        {
        <span>This provider does not expose configurable reasoning levels.</span>
        }
        else
        {
        <span>New jobs start with this reasoning level unless a job-specific override is chosen.</span>
        }
        </div>
        </div>
        </div>
    </ItemTemplate>
</DragDropList>
}
else
{
<div class="small text-body-secondary fst-italic mb-3">No project-specific provider priority configured.</div>
}

<div class="small text-body-secondary fw-semibold mb-2">Add Provider</div>
<div class="d-grid gap-2">
@foreach (var provider in AvailableProviders)
{
var isSelected = IsProviderSelected(provider.Id);
<button type="button" class="btn @(isSelected ? "btn-secondary" : "btn-primary") d-flex align-items-center justify-content-between gap-2 text-start flex-wrap"
@onclick="() => OnAdd.InvokeAsync(provider)" disabled="@isSelected">
<span class="text-start min-width-0">
<span class="fw-semibold">@provider.Name</span>
<span class="text-body-secondary ms-sm-2 d-block d-sm-inline">@provider.Type</span>
</span>
@if (isSelected)
{
<i class="bi bi-check-lg"></i>
}
else
{
<i class="bi bi-plus-lg"></i>
}
</button>
}
</div>
</div>
}
</div>

@code {
[Parameter, EditorRequired]
public ProjectModalFormModel Project { get; set; } = default!;

[Parameter]
public IReadOnlyList<Provider> AvailableProviders { get; set; } = [];

[Parameter, EditorRequired]
public Func<Guid, Provider?> ResolveProvider { get; set; } = _ => null;

[Parameter, EditorRequired]
public Func<Guid, bool> IsProviderSelected { get; set; } = _ => false;

[Parameter, EditorRequired]
public Func<Guid, IReadOnlyList<ProviderModel>> ResolveProviderModels { get; set; } = _ => [];

[Parameter]
public EventCallback<DragDropReorderArgs> OnReorder { get; set; }

[Parameter]
public EventCallback<Guid> OnRemove { get; set; }

[Parameter]
public EventCallback<Provider> OnAdd { get; set; }

[Parameter]
public EventCallback<ProjectProviderModelSelectionChange> OnPreferredModelChanged { get; set; }

private Task HandlePreferredSelectionChanged(Guid providerId, string? preferredModelId, string? preferredReasoningEffort)
{
return OnPreferredModelChanged.InvokeAsync(new ProjectProviderModelSelectionChange
{
ProviderId = providerId,
PreferredModelId = string.IsNullOrWhiteSpace(preferredModelId) ? null : preferredModelId,
PreferredReasoningEffort = string.IsNullOrWhiteSpace(preferredReasoningEffort) ? null : preferredReasoningEffort
});
}
}
