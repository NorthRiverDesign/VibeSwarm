@* Modal component for adding and editing projects *@
@using VibeSwarm.Client.Components.Projects
@using VibeSwarm.Shared.Data
@using VibeSwarm.Shared.Models
@using VibeSwarm.Shared.Providers
@using VibeSwarm.Shared.Services
@inject IProjectService ProjectService
@inject IProviderService ProviderService
@inject ISettingsService SettingsService
@inject NotificationService NotificationService

<ModalDialog IsVisible="IsVisible" IsVisibleChanged="HandleModalVisibilityChanged"
			 Title="@(IsEdit ? "Edit Project" : "New Project")" Icon="@(IsEdit ? "pencil" : "folder-plus")"
			 Size="ModalDialog.ModalSize.Default" OnClose="HandleClose">
	<ChildContent>
		<EditForm Model="@Project" OnValidSubmit="HandleValidSubmit">
			<DataAnnotationsValidator />
			<ValidationSummary class="text-danger mb-3" />

			<div class="mb-3">
				<label for="modal-name" class="form-label">Name</label>
				<InputText id="modal-name" @bind-Value="Project.Name" class="form-control" placeholder="My Project" />
				<ValidationMessage For="@(() => Project.Name)" class="text-danger small" />
			</div>

			<div class="mb-3">
				<label for="modal-description" class="form-label">Description</label>
				<InputTextArea id="modal-description" @bind-Value="Project.Description" class="form-control" rows="2"
							   placeholder="Brief description..." />
			</div>

			@if (!IsEdit)
			{
				<div class="mb-3">
					<label class="form-label d-flex align-items-center gap-2 mb-2">
						<i class="bi bi-box-arrow-in-down-right"></i>
						<span>Project Source</span>
					</label>
					<div class="border rounded p-3 bg-body-tertiary">
						<div class="d-grid gap-2">
							<button type="button" class="btn @(_formState.GetSourceModeButtonClass(ProjectCreationMode.ExistingDirectory)) text-start"
									@onclick="() => SelectSourceMode(ProjectCreationMode.ExistingDirectory)">
								<div class="fw-semibold"><i class="bi bi-folder2-open me-2"></i>Use Existing Local Directory</div>
								<div class="small text-body-secondary mt-1">Point the project at a local working path without cloning or creating a GitHub repo.</div>
							</button>
							<button type="button" class="btn @(_formState.GetSourceModeButtonClass(ProjectCreationMode.CloneGitHubRepository)) text-start"
									@onclick="() => SelectSourceMode(ProjectCreationMode.CloneGitHubRepository)">
								<div class="fw-semibold"><i class="bi bi-github me-2"></i>Clone Existing GitHub Repository</div>
								<div class="small text-body-secondary mt-1">Clone an existing GitHub repository into a new local project workspace.</div>
							</button>
							<button type="button" class="btn @(_formState.GetSourceModeButtonClass(ProjectCreationMode.CreateGitHubRepository)) text-start"
									@onclick="() => SelectSourceMode(ProjectCreationMode.CreateGitHubRepository)">
								<div class="fw-semibold"><i class="bi bi-cloud-plus me-2"></i>Create New GitHub Repository</div>
								<div class="small text-body-secondary mt-1">Create a repository on GitHub and set up this project around it.</div>
							</button>
						</div>

						@if (_formState.CreationMode == ProjectCreationMode.CloneGitHubRepository)
						{
								<div class="mt-3 pt-3 border-top">
									<label for="modal-githubRepo" class="form-label">
										<i class="bi bi-github me-1"></i>GitHub Repository
									</label>
									<div class="input-group">
										<span class="input-group-text">github.com/</span>
										<input id="modal-githubRepo" type="text" class="form-control"
											   value="@_formState.GitHubRepositoryInput" @oninput="OnGitHubRepositoryChanged"
											   placeholder="owner/repo" />
								</div>
								@if (!string.IsNullOrWhiteSpace(_formState.GitHubRepositoryError))
								{
									<div class="text-danger small mt-1">
										<i class="bi bi-exclamation-circle me-1"></i>@_formState.GitHubRepositoryError
									</div>
								}
								<div class="form-text">
									Enter a GitHub repository to clone (for example, <code>microsoft/vscode</code>).
								</div>
							</div>
						}
						else if (_formState.CreationMode == ProjectCreationMode.CreateGitHubRepository)
						{
							<div class="mt-3 pt-3 border-top">
								<div class="mb-3">
									<label for="modal-newGithubRepo" class="form-label">
										<i class="bi bi-github me-1"></i>Repository Name
									</label>
									<input id="modal-newGithubRepo" type="text" class="form-control"
										   value="@_formState.GitHubRepositoryInput" @oninput="OnGitHubRepositoryChanged"
										   placeholder="my-project or owner/my-project" />
									@if (!string.IsNullOrWhiteSpace(_formState.GitHubRepositoryError))
									{
										<div class="text-danger small mt-1">
											<i class="bi bi-exclamation-circle me-1"></i>@_formState.GitHubRepositoryError
										</div>
									}
									<div class="form-text">
										Enter either <code>repo-name</code> to create under your authenticated account, or <code>owner/repo-name</code> for an organization or explicit owner.
									</div>
								</div>

								<div class="mb-3">
									<label for="modal-newGithubRepoDescription" class="form-label">
										Repository Description <span class="text-body-secondary fw-normal">(optional)</span>
									</label>
									<input id="modal-newGithubRepoDescription" type="text" class="form-control"
										   @bind="_formState.NewGitHubRepositoryDescription" @bind:event="oninput"
										   placeholder="A brief description of your project" />
								</div>

								<div class="mb-3">
									<label class="form-label">Visibility</label>
									<div class="d-flex flex-column flex-sm-row gap-2 gap-sm-3">
										<div class="form-check">
											<input class="form-check-input" type="radio" name="projectVisibility" id="projectVisibilityPublic"
												   checked="@(!_formState.NewGitHubRepositoryPrivate)" @onchange="() => _formState.NewGitHubRepositoryPrivate = false">
											<label class="form-check-label" for="projectVisibilityPublic">
												<i class="bi bi-globe me-1"></i>Public
											</label>
										</div>
										<div class="form-check">
											<input class="form-check-input" type="radio" name="projectVisibility" id="projectVisibilityPrivate"
												   checked="@_formState.NewGitHubRepositoryPrivate" @onchange="() => _formState.NewGitHubRepositoryPrivate = true">
											<label class="form-check-label" for="projectVisibilityPrivate">
												<i class="bi bi-lock me-1"></i>Private
											</label>
										</div>
									</div>
								</div>

								<div class="mb-3">
									<label for="modal-newGithubRepoGitignore" class="form-label">
										.gitignore Template <span class="text-body-secondary fw-normal">(optional)</span>
									</label>
									<select id="modal-newGithubRepoGitignore" class="form-select" @bind="_formState.NewGitHubGitignoreTemplate">
										<option value="">None</option>
										<option value="Node">Node</option>
										<option value="Python">Python</option>
										<option value="CSharp">C#</option>
										<option value="Java">Java</option>
										<option value="Go">Go</option>
										<option value="Rust">Rust</option>
										<option value="VisualStudio">Visual Studio</option>
										<option value="Unity">Unity</option>
									</select>
								</div>

								<div class="mb-3">
									<label for="modal-newGithubRepoLicense" class="form-label">
										License <span class="text-body-secondary fw-normal">(optional)</span>
									</label>
									<select id="modal-newGithubRepoLicense" class="form-select" @bind="_formState.NewGitHubLicenseTemplate">
										<option value="">None</option>
										<option value="mit">MIT</option>
										<option value="apache-2.0">Apache 2.0</option>
										<option value="gpl-3.0">GPL 3.0</option>
										<option value="bsd-2-clause">BSD 2-Clause</option>
										<option value="mpl-2.0">MPL 2.0</option>
										<option value="unlicense">Unlicense</option>
									</select>
								</div>

								<div class="form-check">
									<input class="form-check-input" type="checkbox" id="modal-newGithubRepoReadme" @bind="_formState.NewGitHubInitializeReadme">
									<label class="form-check-label" for="modal-newGithubRepoReadme">
										Initialize with README
									</label>
								</div>

								<Alert Type="Alert.AlertType.Info" Class="py-2 px-3 small mt-3 mb-0">
									<span class="text-break"><i class="bi bi-lightbulb me-1"></i>Creating a GitHub repository requires <code class="text-break">gh auth login</code> on the host machine.</span>
								</Alert>
							</div>
						}
					</div>
				</div>
			}

			<div class="mb-3">
				<label for="modal-workingPath" class="form-label">Working Path</label>
				<div class="input-group">
					<InputText id="modal-workingPath" @bind-Value="Project.WorkingPath" class="form-control"
							   placeholder="@_formState.WorkingPathPlaceholder" />
					<button type="button" class="btn btn-secondary" @onclick="OpenDirectoryBrowser"
							title="Browse directories">
						<i class="bi bi-folder2-open"></i>
					</button>
				</div>
				<ValidationMessage For="@(() => Project.WorkingPath)" class="text-danger small" />
				<div class="form-text">@_formState.GetWorkingPathHelpText()</div>
			</div>

			<div class="mb-3">
				<label for="modal-autoCommitMode" class="form-label">
					<i class="bi bi-git me-1"></i>Auto-Commit
				</label>
				<InputSelect id="modal-autoCommitMode" @bind-Value="Project.AutoCommitMode" class="form-select">
					<option value="@AutoCommitMode.Off">Off - Manual commit required</option>
					<option value="@AutoCommitMode.CommitOnly">Commit Only - Auto-commit after job completion</option>
					<option value="@AutoCommitMode.CommitAndPush">Commit & Push - Auto-commit and push after job
						completion</option>
				</InputSelect>
				<div class="form-text">Automatically commit (and optionally push) changes after successful job completion.</div>
			</div>

			<div class="mb-3">
				<label for="modal-gitChangeDeliveryMode" class="form-label">
					<i class="bi bi-box-arrow-up-right me-1"></i>Result Delivery
				</label>
				<InputSelect id="modal-gitChangeDeliveryMode" @bind-Value="Project.GitChangeDeliveryMode" class="form-select">
					<option value="@GitChangeDeliveryMode.CommitToBranch">Commit to branch</option>
					<option value="@GitChangeDeliveryMode.PullRequest">Create pull request</option>
				</InputSelect>
				<div class="form-text">
					Choose whether successful jobs should stay on their working branch or be delivered through a pull request.
				</div>
			</div>

			@if (Project.GitChangeDeliveryMode == GitChangeDeliveryMode.PullRequest)
			{
				<div class="mb-3">
					<label for="modal-defaultTargetBranch" class="form-label">
						<i class="bi bi-signpost-split me-1"></i>Default Target Branch
					</label>
					<InputText id="modal-defaultTargetBranch" @bind-Value="Project.DefaultTargetBranch" class="form-control"
							   placeholder="develop" />
					<div class="form-text">
						New jobs will target this branch when creating pull requests or merging completed work.
					</div>
				</div>
			}

			<div class="mb-3">
				<div class="form-check form-switch">
					<InputCheckbox id="modal-ideasAutoExpand" @bind-Value="Project.IdeasAutoExpand" class="form-check-input" />
					<label class="form-check-label" for="modal-ideasAutoExpand">
						<i class="bi bi-stars me-1"></i>Auto-Expand Ideas
					</label>
				</div>
				<div class="form-text">When enabled, ideas without an approved expansion are first turned into a fuller specification before a job is created.</div>
			</div>

			<div class="mb-3">
				<label class="form-label d-flex align-items-center gap-2 mb-2">
					<i class="bi bi-map"></i>
					<span>Planning</span>
				</label>

				<Alert Type="Alert.AlertType.Info" Class="py-2 px-3 small">
					<span>Planning runs idea expansion through Claude Code or Copilot plan mode so users can review a structured implementation plan before a job is created.</span>
				</Alert>

				<div class="form-check form-switch mt-2">
					<InputCheckbox id="modal-planningEnabled" @bind-Value="Project.PlanningEnabled" @bind-Value:after="HandlePlanningEnabledChanged" class="form-check-input" />
					<label class="form-check-label" for="modal-planningEnabled">
						<i class="bi bi-lightbulb me-1"></i>Enable Planning
					</label>
				</div>
				<div class="form-text">When enabled, manual and automatic idea expansion use the selected provider and optional model to generate a reviewed feature plan.</div>

				@if (Project.PlanningEnabled)
				{
					@if (!GetPlanningProviders().Any())
					{
						<div class="text-warning small mt-2">
							<i class="bi bi-exclamation-triangle me-1"></i>Planning needs an enabled Claude or Copilot provider. Configure one under Providers first.
						</div>
					}
					else
					{
						<div class="border rounded p-3 bg-body-tertiary mt-3">
							<div class="mb-3">
								<label for="modal-planningProvider" class="form-label">
									<i class="bi bi-cpu me-1"></i>Planning Provider
								</label>
								<InputSelect TValue="Guid?" id="modal-planningProvider" @bind-Value="Project.PlanningProviderId" @bind-Value:after="HandlePlanningProviderChanged" class="form-select">
									@foreach (var provider in GetPlanningProviders())
									{
										<option value="@provider.Id">@provider.Name (@provider.Type)</option>
									}
								</InputSelect>
								<div class="form-text">Only GitHub Copilot and Claude providers currently support project planning.</div>
							</div>

							<div>
								<label for="modal-planningModel" class="form-label">
									<i class="bi bi-sliders me-1"></i>Planning Model
									<span class="text-body-secondary fw-normal">(optional)</span>
								</label>
								<InputSelect id="modal-planningModel" @bind-Value="Project.PlanningModelId" class="form-select" disabled="@(!Project.PlanningProviderId.HasValue || !_planningModels.Any())">
									<option value="">Use provider default model</option>
									@foreach (var model in _planningModels)
									{
										<option value="@model.ModelId">@(model.DisplayName ?? model.ModelId)@((model.IsDefault ? " (Default)" : string.Empty))</option>
									}
								</InputSelect>
								<div class="form-text">
									@if (Project.PlanningProviderId.HasValue && !_planningModels.Any())
									{
										<span>No cached models found for this provider yet. The provider default will be used until models are refreshed.</span>
									}
									else
									{
										<span>Leave this blank to use the provider's default planning model.</span>
									}
								</div>
							</div>
						</div>
					}
				}
			</div>

			<div class="mb-3">
				<label class="form-label d-flex align-items-center gap-2 mb-2">
					<i class="bi bi-diagram-3"></i>
					<span>Provider Priority</span>
				</label>

				<Alert Type="Alert.AlertType.Info" Class="py-2 px-3 small">
					@if (Project.ProviderSelections.Any())
					{
						<span>This project will prefer providers in the order shown below. Jobs can fall back to the next provider when one is unavailable or at limit.</span>
					}
					else
					{
						<span>No providers selected yet. If you save without a provider list, the project can use any enabled provider system-wide.</span>
					}
				</Alert>

				@if (!_availableProviders.Any())
				{
					<div class="text-warning small mt-2">
						<i class="bi bi-exclamation-triangle me-1"></i>No enabled providers available. Configure a provider first.
					</div>
				}
				else
				{
					<div class="border rounded p-2 bg-body-tertiary">
						<div class="small text-body-secondary fw-semibold mb-2">Priority Order</div>
						@if (Project.ProviderSelections.Any())
						{
							<div class="d-grid gap-2 mb-3">
								@foreach (var selection in Project.ProviderSelections.OrderBy(pp => pp.Priority).ToList())
								{
									var provider = ResolveProvider(selection.ProviderId);
									<div class="d-flex align-items-start justify-content-between gap-2 flex-wrap rounded border bg-body p-2">
										<div class="min-width-0 flex-grow-1">
											<div class="d-flex align-items-center gap-2 flex-wrap">
												<span class="badge text-bg-primary">#@(selection.Priority + 1)</span>
												<span class="fw-semibold">@(provider?.Name ?? "Unknown Provider")</span>
												@if (provider != null)
												{
													<span class="badge bg-secondary-subtle text-secondary-emphasis">@provider.Type</span>
												}
											</div>
										</div>
										<div class="d-flex flex-wrap justify-content-end gap-2">
											<button type="button" class="btn btn-sm btn-secondary" @onclick="() => MoveProviderSelectionUp(selection.ProviderId)"
												disabled="@(selection.Priority == 0)" title="Move up">
												<i class="bi bi-arrow-up"></i>
											</button>
											<button type="button" class="btn btn-sm btn-secondary" @onclick="() => MoveProviderSelectionDown(selection.ProviderId)"
												disabled="@(selection.Priority >= Project.ProviderSelections.Count - 1)" title="Move down">
												<i class="bi bi-arrow-down"></i>
											</button>
											<button type="button" class="btn btn-sm btn-danger" @onclick="() => RemoveProviderSelection(selection.ProviderId)" title="Remove provider">
												<i class="bi bi-x-lg"></i>
											</button>
										</div>
									</div>
								}
							</div>
						}
						else
						{
							<div class="small text-body-secondary fst-italic mb-3">No project-specific provider priority configured.</div>
						}

						<div class="small text-body-secondary fw-semibold mb-2">Add Provider</div>
						<div class="d-grid gap-2">
							@foreach (var provider in _availableProviders)
							{
								var isSelected = IsProviderSelected(provider.Id);
								<button type="button" class="btn @(isSelected ? "btn-secondary" : "btn-outline-secondary") d-flex align-items-center justify-content-between gap-2 text-start flex-wrap"
										@onclick="() => AddProviderSelection(provider)" disabled="@isSelected">
									<span class="text-start min-width-0">
										<span class="fw-semibold">@provider.Name</span>
										<span class="text-body-secondary ms-sm-2 d-block d-sm-inline">@provider.Type</span>
									</span>
									@if (isSelected)
									{
										<i class="bi bi-check-lg"></i>
									}
									else
									{
										<i class="bi bi-plus-lg"></i>
									}
								</button>
							}
						</div>
					</div>
				}
			</div>

					<div class="mb-3">
						<label for="modal-promptContext" class="form-label">
							<i class="bi bi-chat-left-text me-1"></i>Prompt Context
							<span class="text-body-secondary fw-normal">(optional)</span>
						</label>
						<InputTextArea id="modal-promptContext" @bind-Value="Project.PromptContext" class="form-control"
									   rows="3"
									   placeholder="Optional instructions injected into every job prompt for this project (e.g., coding conventions, framework preferences)" />
						<div class="form-text">These instructions are automatically included in every job prompt for this
							project to guide AI agents.</div>
						</div>
						@if (IsEdit)
						{
							<div class="mb-3">
								<div class="form-check form-switch">
									<InputCheckbox id="modal-isActive" @bind-Value="Project.IsActive" class="form-check-input" />
									<label class="form-check-label" for="modal-isActive">
										<i
										class="bi bi-@(Project.IsActive ? "check-circle text-success" : "pause-circle text-secondary") me-1"></i>
										@(Project.IsActive ? "Active" : "Inactive")
									</label>
								</div>
								<div class="form-text">Inactive projects are hidden from the dashboard and shown with reduced emphasis
									elsewhere.</div>
								</div>
							}
							@if (!string.IsNullOrEmpty(_cloneProgressMessage))
							{
								<Alert Type="Alert.AlertType.Info" Message="@_cloneProgressMessage" Class="mb-3" />
							}

							@if (!string.IsNullOrEmpty(ErrorMessage))
							{
								<div class="text-danger small mb-3">
									<i class="bi bi-exclamation-circle me-1"></i>@ErrorMessage
								</div>
							}

							<div class="d-flex flex-column-reverse flex-sm-row gap-2 justify-content-end">
								<button type="button" class="btn btn-secondary" @onclick="HandleCancel">Cancel</button>
								<button type="submit" class="btn btn-primary" disabled="@IsSaving">
									@if (IsSaving)
									{
										<span class="spinner-border spinner-border-sm me-1" role="status"></span>
									}
									@if (IsSaving && !string.IsNullOrEmpty(_cloneProgressMessage))
									{
										@_cloneProgressMessage
									}
									else
									{
										@_formState.GetSubmitButtonText(IsSaving, IsEdit)
									}
								</button>
							</div>
						</EditForm>
					</ChildContent>
				</ModalDialog>

				@if (_showDirectoryBrowser)
				{
					<DirectoryBrowser @ref="_directoryBrowser" InitialPath="@_defaultProjectsDirectory"
									  OnDirectorySelected="OnDirectorySelected" OnClosed="CloseDirectoryBrowser" />
				}

@code {
	[Parameter]
	public bool IsVisible { get; set; }

	[Parameter]
	public EventCallback<bool> IsVisibleChanged { get; set; }

	[Parameter]
	public Project? EditProject { get; set; }

	[Parameter]
	public EventCallback<Guid?> OnSaved { get; set; }

	[Parameter]
	public EventCallback OnCancelled { get; set; }

	[Parameter]
	public EventCallback OnClosed { get; set; }

	private Project Project { get; set; } = new();
	private bool IsEdit => EditProject != null;
	private bool IsSaving { get; set; }
	private string? ErrorMessage { get; set; }
	private bool _previousIsVisible;
	private string? _cloneProgressMessage;
	private bool _showDirectoryBrowser;
	private DirectoryBrowser? _directoryBrowser;
	private string? _defaultProjectsDirectory;
	private List<Provider> _availableProviders = [];
	private List<ProviderModel> _planningModels = [];
	private readonly ProjectModalState _formState = new();

	protected override async Task OnInitializedAsync()
	{
		await LoadDefaultProjectsDirectory();
		await LoadProvidersAsync();
	}

	protected override async Task OnParametersSetAsync()
	{
		if (IsVisible && !_previousIsVisible)
		{
			await LoadProvidersAsync();
			ResetState();

			if (EditProject != null)
			{
				var editableProject = await ProjectService.GetByIdAsync(EditProject.Id) ?? EditProject;
				Project = CloneProjectForEditing(editableProject);
				_formState.LoadFromProject(Project);
				EnsurePlanningProviderSelection();
				await LoadPlanningModelsAsync();
			}
			else
			{
				Project = new Project();
				_formState.SelectSourceMode(Project, ProjectCreationMode.ExistingDirectory);
				SeedDefaultProviderSelection();
				EnsurePlanningProviderSelection();
			}
		}

		_previousIsVisible = IsVisible;
	}

	private async Task LoadDefaultProjectsDirectory()
	{
		try
		{
			_defaultProjectsDirectory = await SettingsService.GetDefaultProjectsDirectoryAsync();
			_formState.SetDefaultProjectsDirectory(_defaultProjectsDirectory);
		}
		catch
		{
			// Ignore errors loading default directory
		}
	}

	private void OnGitHubRepositoryChanged(ChangeEventArgs e)
	{
		_formState.UpdateGitHubRepositoryInput(Project, e.Value?.ToString());
	}

	private void SelectSourceMode(ProjectCreationMode mode)
	{
		ErrorMessage = null;
		_formState.SelectSourceMode(Project, mode);
	}

	private async Task HandleValidSubmit()
	{
		if (!_formState.Validate(Project))
		{
			return;
		}

		IsSaving = true;
		ErrorMessage = null;
		_cloneProgressMessage = null;

		try
		{
			Guid? newProjectId = null;

			if (IsEdit)
			{
				await ProjectService.UpdateAsync(Project);
				NotificationService.ShowSuccess("Project updated successfully.");
			}
			else
			{
				_cloneProgressMessage = _formState.GetProgressMessage();
				StateHasChanged();

				var created = await ProjectService.CreateProjectAsync(_formState.BuildProjectCreationRequest(Project));
				newProjectId = created.Id;
				NotificationService.ShowSuccess(_formState.GetSuccessMessage());
			}

			await OnSaved.InvokeAsync(newProjectId);
			await CloseModal();
		}
		catch (Exception ex)
		{
			if (!_formState.TryMapSubmissionError(ex.Message))
			{
				ErrorMessage = $"Error saving project: {ex.Message}";
			}
		}
		finally
		{
			IsSaving = false;
			_cloneProgressMessage = null;
		}
	}

	private async Task HandleCancel()
	{
		await OnCancelled.InvokeAsync();
		await CloseModal();
	}

	private async Task HandleClose()
	{
		ResetState();
		await OnClosed.InvokeAsync();
	}

	private async Task HandleModalVisibilityChanged(bool visible)
	{
		if (!visible)
		{
			ResetState();
			await IsVisibleChanged.InvokeAsync(false);
		}
	}

	private async Task CloseModal()
	{
		IsVisible = false;
		await IsVisibleChanged.InvokeAsync(false);
		ResetState();
	}

	private void ResetState()
	{
		Project = new Project();
		ErrorMessage = null;
		IsSaving = false;
		_cloneProgressMessage = null;
		_planningModels = [];
		_formState.Reset();
	}

	private async Task OpenDirectoryBrowser()
	{
		_showDirectoryBrowser = true;
		StateHasChanged();

		// Wait for the component to render
		await Task.Delay(50);

		if (_directoryBrowser != null)
		{
			var initialPath = !string.IsNullOrEmpty(Project.WorkingPath)
			? Project.WorkingPath
			: _defaultProjectsDirectory;
			await _directoryBrowser.ShowAsync(initialPath);
		}
	}

	private void OnDirectorySelected(string path)
	{
		Project.WorkingPath = path;
		_showDirectoryBrowser = false;
		StateHasChanged();
	}

	private void CloseDirectoryBrowser()
	{
		_showDirectoryBrowser = false;
	}

	private async Task LoadProvidersAsync()
	{
		_availableProviders = (await ProviderService.GetAllAsync())
			.Where(p => p.IsEnabled)
			.OrderBy(p => p.Name)
			.ToList();
	}

	private Provider? ResolveProvider(Guid providerId)
	{
		return _availableProviders.FirstOrDefault(p => p.Id == providerId)
			?? EditProject?.ProviderSelections.FirstOrDefault(pp => pp.ProviderId == providerId)?.Provider;
	}

	private bool IsProviderSelected(Guid providerId)
	{
		return Project.ProviderSelections.Any(pp => pp.ProviderId == providerId);
	}

	private void AddProviderSelection(Provider provider)
	{
		if (IsProviderSelected(provider.Id))
		{
			return;
		}

		Project.ProviderSelections.Add(new ProjectProvider
		{
			ProviderId = provider.Id,
			Provider = provider,
			Priority = Project.ProviderSelections.Count,
			IsEnabled = true,
			CreatedAt = DateTime.UtcNow,
			UpdatedAt = DateTime.UtcNow
		});

		NormalizeProviderSelectionOrder();
		EnsurePlanningProviderSelection();
	}

	private void RemoveProviderSelection(Guid providerId)
	{
		var selection = Project.ProviderSelections.FirstOrDefault(pp => pp.ProviderId == providerId);
		if (selection == null)
		{
			return;
		}

		Project.ProviderSelections.Remove(selection);
		NormalizeProviderSelectionOrder();
		EnsurePlanningProviderSelection();
	}

	private void MoveProviderSelectionUp(Guid providerId)
	{
		var ordered = Project.ProviderSelections.OrderBy(pp => pp.Priority).ToList();
		var index = ordered.FindIndex(pp => pp.ProviderId == providerId);
		if (index <= 0)
		{
			return;
		}

		(ordered[index - 1], ordered[index]) = (ordered[index], ordered[index - 1]);
		Project.ProviderSelections = ordered;
		NormalizeProviderSelectionOrder();
		EnsurePlanningProviderSelection();
	}

	private void MoveProviderSelectionDown(Guid providerId)
	{
		var ordered = Project.ProviderSelections.OrderBy(pp => pp.Priority).ToList();
		var index = ordered.FindIndex(pp => pp.ProviderId == providerId);
		if (index < 0 || index >= ordered.Count - 1)
		{
			return;
		}

		(ordered[index + 1], ordered[index]) = (ordered[index], ordered[index + 1]);
		Project.ProviderSelections = ordered;
		NormalizeProviderSelectionOrder();
		EnsurePlanningProviderSelection();
	}

	private void NormalizeProviderSelectionOrder()
	{
		Project.ProviderSelections = Project.ProviderSelections
			.OrderBy(pp => pp.Priority)
			.Select((selection, index) =>
			{
				selection.Priority = index;
				selection.ProjectId = Project.Id;
				selection.Provider ??= ResolveProvider(selection.ProviderId);
				selection.UpdatedAt = DateTime.UtcNow;
				return selection;
			})
			.ToList();
	}

	private void SeedDefaultProviderSelection()
	{
		if (Project.ProviderSelections.Any())
		{
			return;
		}

		var defaultProvider = _availableProviders.FirstOrDefault(p => p.IsDefault);
		if (defaultProvider != null)
		{
			AddProviderSelection(defaultProvider);
		}
	}

	private IEnumerable<Provider> GetPlanningProviders()
	{
		return _availableProviders
			.Where(IsPlanningCapableProvider)
			.OrderBy(provider => provider.Name)
			.ToList();
	}

	private static bool IsPlanningCapableProvider(Provider provider)
	{
		return provider.Type is ProviderType.Claude or ProviderType.Copilot;
	}

	private async Task HandlePlanningEnabledChanged()
	{
		EnsurePlanningProviderSelection();
		await LoadPlanningModelsAsync();
	}

	private async Task HandlePlanningProviderChanged()
	{
		Project.PlanningModelId = null;
		EnsurePlanningProviderSelection();
		await LoadPlanningModelsAsync();
	}

	private void EnsurePlanningProviderSelection()
	{
		if (!Project.PlanningEnabled)
		{
			return;
		}

		var planningProviders = GetPlanningProviders().ToList();
		if (planningProviders.Count == 0)
		{
			Project.PlanningProviderId = null;
			Project.PlanningModelId = null;
			_planningModels = [];
			return;
		}

		if (!Project.PlanningProviderId.HasValue || !planningProviders.Any(provider => provider.Id == Project.PlanningProviderId.Value))
		{
			Project.PlanningProviderId = planningProviders[0].Id;
			Project.PlanningModelId = null;
			_planningModels = [];
		}
	}

	private async Task LoadPlanningModelsAsync()
	{
		_planningModels = [];
		if (!Project.PlanningEnabled || !Project.PlanningProviderId.HasValue)
		{
			return;
		}

		try
		{
			_planningModels = (await ProviderService.GetModelsAsync(Project.PlanningProviderId.Value))
				.Where(model => model.IsAvailable)
				.OrderByDescending(model => model.IsDefault)
				.ThenBy(model => model.DisplayName ?? model.ModelId)
				.ToList();
		}
		catch
		{
			_planningModels = [];
		}

		if (!string.IsNullOrWhiteSpace(Project.PlanningModelId) &&
			!_planningModels.Any(model => string.Equals(model.ModelId, Project.PlanningModelId, StringComparison.Ordinal)))
		{
			Project.PlanningModelId = null;
		}
	}

	private Project CloneProjectForEditing(Project source)
	{
		return new Project
		{
			Id = source.Id,
			Name = source.Name,
			Description = source.Description,
			WorkingPath = source.WorkingPath,
			GitHubRepository = source.GitHubRepository,
			AutoCommitMode = source.AutoCommitMode,
			GitChangeDeliveryMode = source.GitChangeDeliveryMode,
			DefaultTargetBranch = source.DefaultTargetBranch,
			PlanningEnabled = source.PlanningEnabled,
			PlanningProviderId = source.PlanningProviderId,
			PlanningModelId = source.PlanningModelId,
			IdeasAutoExpand = source.IdeasAutoExpand,
			PromptContext = source.PromptContext,
			IsActive = source.IsActive,
			CreatedAt = source.CreatedAt,
			UpdatedAt = source.UpdatedAt,
			ProviderSelections = source.ProviderSelections
				.OrderBy(pp => pp.Priority)
				.Select(pp => new ProjectProvider
				{
					Id = pp.Id,
					ProjectId = pp.ProjectId,
					ProviderId = pp.ProviderId,
					Priority = pp.Priority,
					IsEnabled = pp.IsEnabled,
					PreferredModelId = pp.PreferredModelId,
					CreatedAt = pp.CreatedAt,
					UpdatedAt = pp.UpdatedAt,
					Provider = ResolveProvider(pp.ProviderId)
				})
				.ToList(),
			Environments = (source.Environments ?? [])
				.OrderBy(environment => environment.SortOrder)
				.Select(environment => new ProjectEnvironment
				{
					Id = environment.Id,
					ProjectId = environment.ProjectId,
					Name = environment.Name,
					Description = environment.Description,
					Type = environment.Type,
					Stage = environment.Stage,
					Url = environment.Url,
					IsPrimary = environment.IsPrimary,
					IsEnabled = environment.IsEnabled,
					SortOrder = environment.SortOrder,
					Username = environment.Username,
					Password = environment.Password,
					ClearPassword = false,
					UsernameCiphertext = environment.UsernameCiphertext,
					PasswordCiphertext = environment.PasswordCiphertext,
					CreatedAt = environment.CreatedAt,
					UpdatedAt = environment.UpdatedAt
				})
				.ToList()
		};
	}
}
