@* Modal component for adding and editing projects *@
@using VibeSwarm.Client.Components.Projects
@using VibeSwarm.Client.Models
@using VibeSwarm.Shared.Data
@using VibeSwarm.Shared.Models
@using VibeSwarm.Shared.Providers
@using VibeSwarm.Shared.Services
@using VibeSwarm.Shared.Validation
@inject IProjectService ProjectService
@inject IProviderService ProviderService
@inject ITeamRoleService TeamRoleService
@inject IInferenceProviderService InferenceProviderService
@inject ISettingsService SettingsService
@inject NotificationService NotificationService

<ModalDialog IsVisible="IsVisible" IsVisibleChanged="HandleModalVisibilityChanged"
Title="@(IsEdit ? "Edit Project" : "New Project")" Icon="@(IsEdit ? "pencil" : "folder-plus")"
Size="ModalDialog.ModalSize.Large" DialogClass="vs-modal-dialog-wide-lg" OnClose="HandleClose"
BodyClass="vs-project-modal-body">
<ChildContent>
<EditForm Model="@FormModel" OnValidSubmit="HandleValidSubmit" class="overflow-x-hidden mw-100">
<DataAnnotationsValidator />
<ValidationSummary class="text-danger mb-3" />

<ProjectBasicsSection Project="@FormModel"
WorkingPathPlaceholder="@_formState.WorkingPathPlaceholder"
WorkingPathHelpText="@_formState.GetWorkingPathHelpText(FormModel)"
OnBrowseWorkingPath="OpenDirectoryBrowser" />

<ProjectSourceSection FormModel="@FormModel" FormState="@_formState" IsEdit="@IsEdit"
OnSourceModeSelected="SelectSourceMode"
OnGitHubRepositoryChanged="OnGitHubRepositoryChanged"
OnBrowseGitHubRepositories="OpenGitHubRepositoryBrowser" />

<ProjectAutomationSection Project="@FormModel" IsEdit="@IsEdit" />

<ProjectIdeaGenerationSection Project="@FormModel"
AvailableInferenceProviders="@_availableInferenceProviders"
InferenceModels="@_ideaInferenceModels"
OnProviderChanged="HandleIdeaInferenceProviderChanged" />

<ProjectPlanningSection Project="@FormModel" AvailableProviders="@GetPlanningProviders().ToList()"
PlanningModels="@_planningModels"
OnPlanningEnabledChanged="HandlePlanningEnabledChanged"
OnPlanningProviderChanged="HandlePlanningProviderChanged" />

<ProjectProviderPrioritySection Project="@FormModel" AvailableProviders="@_availableProviders"
ResolveProvider="ResolveProvider" IsProviderSelected="IsProviderSelected"
ResolveProviderModels="GetProviderModels"
OnReorder="ReorderProviderSelection"
OnRemove="RemoveProviderSelection" OnAdd="AddProviderSelection"
OnPreferredModelChanged="HandlePreferredModelChanged" />

<ProjectTeamRolesSection Project="@FormModel" AvailableTeamRoles="@_availableTeamRoles"
AvailableProviders="@_availableProviders" ResolveTeamRole="ResolveTeamRole"
IsTeamRoleAssigned="IsTeamRoleAssigned" ResolveProviderModels="GetProviderModels"
OnRemove="RemoveTeamAssignment" OnAdd="AddTeamAssignment"
OnProviderChanged="HandleTeamAssignmentProviderChanged"
OnPreferredModelChanged="HandleTeamAssignmentPreferredModelChanged" />

<ProjectInstructionsSection Project="@FormModel" />

<ProjectBuildVerificationSection Project="@FormModel" />

@if (!string.IsNullOrEmpty(_cloneProgressMessage))
{
<Alert Type="Alert.AlertType.Info" Message="@_cloneProgressMessage" Class="mb-3" />
}

@if (!string.IsNullOrEmpty(ErrorMessage))
{
<div class="text-danger small mb-3">
<i class="bi bi-exclamation-circle me-1"></i>@ErrorMessage
</div>
}

<div class="d-flex flex-column-reverse flex-sm-row gap-2 justify-content-end">
<button type="button" class="btn btn-secondary" @onclick="HandleCancel">Cancel</button>
<button type="submit" class="btn btn-primary" disabled="@IsSaving">
@if (IsSaving)
{
<span class="spinner-border spinner-border-sm me-1" role="status"></span>
}
@if (IsSaving && !string.IsNullOrEmpty(_cloneProgressMessage))
{
@_cloneProgressMessage
}
else
{
@_formState.GetSubmitButtonText(FormModel, IsSaving, IsEdit)
}
</button>
</div>
</EditForm>
</ChildContent>
</ModalDialog>

@if (_showDirectoryBrowser)
{
<DirectoryBrowser @ref="_directoryBrowser" InitialPath="@_defaultProjectsDirectory"
OnDirectorySelected="OnDirectorySelected" OnClosed="CloseDirectoryBrowser" />
}

@if (_showGitHubRepositoryBrowser)
{
<GitHubRepositoryBrowserModal IsVisible="@_showGitHubRepositoryBrowser"
IsVisibleChanged="HandleGitHubRepositoryBrowserVisibilityChanged"
SelectedRepository="@FormModel.GetNormalizedGitHubRepository()"
OnRepositorySelected="HandleGitHubRepositorySelected" />
}

@code {
[Parameter]
public bool IsVisible { get; set; }

[Parameter]
public EventCallback<bool> IsVisibleChanged { get; set; }

[Parameter]
public Project? EditProject { get; set; }

[Parameter]
public EventCallback<Guid?> OnSaved { get; set; }

[Parameter]
public EventCallback OnCancelled { get; set; }

[Parameter]
public EventCallback OnClosed { get; set; }

private bool IsEdit => EditProject != null;
private bool IsSaving { get; set; }
private string? ErrorMessage { get; set; }
private bool _previousIsVisible;
private string? _cloneProgressMessage;
private bool _showDirectoryBrowser;
private bool _showGitHubRepositoryBrowser;
private DirectoryBrowser? _directoryBrowser;
private string? _defaultProjectsDirectory;
private List<Provider> _availableProviders = [];
private List<TeamRole> _availableTeamRoles = [];
private List<ProviderModel> _planningModels = [];
private List<InferenceProvider> _availableInferenceProviders = [];
private List<InferenceModel> _ideaInferenceModels = [];
private readonly Dictionary<Guid, List<ProviderModel>> _providerModelsByProviderId = [];
private readonly ProjectModalState _formState = new();
private ProjectModalFormModel FormModel { get; set; } = new();

protected override async Task OnInitializedAsync()
{
await LoadDefaultProjectsDirectory();
await LoadProvidersAsync();
await LoadTeamRolesAsync();
await LoadInferenceProvidersAsync();
}

protected override async Task OnParametersSetAsync()
{
if (IsVisible && !_previousIsVisible)
{
await LoadProvidersAsync();
await LoadTeamRolesAsync();
ResetState();

if (EditProject != null)
{
var editableProject = await ProjectService.GetByIdAsync(EditProject.Id) ?? EditProject;
FormModel = ProjectModalFormModel.FromProject(CloneProjectForEditing(editableProject));
_formState.LoadFromProject(FormModel);
EnsurePlanningProviderSelection();
await LoadPlanningModelsAsync();
await LoadProviderSelectionModelsAsync();
await LoadIdeaInferenceModelsAsync();
}
else
{
FormModel = new ProjectModalFormModel();
_formState.SelectSourceMode(FormModel, ProjectCreationMode.ExistingDirectory);
await SeedDefaultProviderSelectionAsync();
EnsurePlanningProviderSelection();
await LoadProviderSelectionModelsAsync();
}
}

_previousIsVisible = IsVisible;
}

private async Task LoadDefaultProjectsDirectory()
{
try
{
_defaultProjectsDirectory = await SettingsService.GetDefaultProjectsDirectoryAsync();
_formState.SetDefaultProjectsDirectory(_defaultProjectsDirectory);
}
catch
{
}
}

private void OnGitHubRepositoryChanged(string? repositoryInput)
{
_formState.UpdateGitHubRepositoryInput(FormModel, repositoryInput);
}

private void SelectSourceMode(ProjectCreationMode mode)
{
ErrorMessage = null;
_formState.SelectSourceMode(FormModel, mode);
}

private async Task HandleValidSubmit()
{
IsSaving = true;
ErrorMessage = null;
_cloneProgressMessage = null;

try
{
Guid? newProjectId = null;

if (IsEdit)
{
await ProjectService.UpdateAsync(FormModel.ToProject());
NotificationService.ShowSuccess("Project updated successfully.");
}
else
{
_cloneProgressMessage = _formState.GetProgressMessage(FormModel);
StateHasChanged();

var created = await ProjectService.CreateProjectAsync(_formState.BuildProjectCreationRequest(FormModel));
newProjectId = created.Id;
NotificationService.ShowSuccess(_formState.GetSuccessMessage(FormModel));
}

await OnSaved.InvokeAsync(newProjectId);
await CloseModal();
}
catch (Exception ex)
{
ErrorMessage = $"Error saving project: {ex.Message}";
}
finally
{
IsSaving = false;
_cloneProgressMessage = null;
}
}

private async Task HandleCancel()
{
await OnCancelled.InvokeAsync();
await CloseModal();
}

private async Task HandleClose()
{
ResetState();
await OnClosed.InvokeAsync();
}

private async Task HandleModalVisibilityChanged(bool visible)
{
if (!visible)
{
ResetState();
await IsVisibleChanged.InvokeAsync(false);
}
}

private async Task CloseModal()
{
IsVisible = false;
await IsVisibleChanged.InvokeAsync(false);
ResetState();
}

	private void ResetState()
	{
		FormModel = new ProjectModalFormModel();
		ErrorMessage = null;
		IsSaving = false;
		_cloneProgressMessage = null;
		_showGitHubRepositoryBrowser = false;
		_planningModels = [];
		_providerModelsByProviderId.Clear();
	}

private async Task OpenDirectoryBrowser()
{
_showDirectoryBrowser = true;
StateHasChanged();

await Task.Delay(50);

if (_directoryBrowser != null)
{
var initialPath = !string.IsNullOrEmpty(FormModel.WorkingPath)
? FormModel.WorkingPath
: _defaultProjectsDirectory;
await _directoryBrowser.ShowAsync(initialPath);
}
}

private void OnDirectorySelected(string path)
{
FormModel.WorkingPath = path;
_showDirectoryBrowser = false;
StateHasChanged();
}

	private void CloseDirectoryBrowser()
	{
		_showDirectoryBrowser = false;
	}

	private Task OpenGitHubRepositoryBrowser()
	{
		_showGitHubRepositoryBrowser = true;
		return Task.CompletedTask;
	}

	private Task HandleGitHubRepositoryBrowserVisibilityChanged(bool visible)
	{
		_showGitHubRepositoryBrowser = visible;
		return Task.CompletedTask;
	}

	private Task HandleGitHubRepositorySelected(string repository)
	{
		OnGitHubRepositoryChanged(repository);
		_showGitHubRepositoryBrowser = false;
		return Task.CompletedTask;
	}

	private async Task LoadProvidersAsync()
	{
_availableProviders = (await ProviderService.GetAllAsync())
.Where(provider => provider.IsEnabled)
.OrderByDescending(provider => provider.IsDefault)
.ThenBy(provider => provider.Name)
.ToList();
	}

	private async Task LoadTeamRolesAsync()
	{
		_availableTeamRoles = (await TeamRoleService.GetAllAsync())
			.OrderByDescending(teamRole => teamRole.IsEnabled)
			.ThenBy(teamRole => teamRole.Name)
			.ToList();
	}

private Provider? ResolveProvider(Guid providerId)
{
return _availableProviders.FirstOrDefault(provider => provider.Id == providerId)
?? EditProject?.ProviderSelections.FirstOrDefault(selection => selection.ProviderId == providerId)?.Provider;
}

private bool IsProviderSelected(Guid providerId)
{
return FormModel.ProviderSelections.Any(selection => selection.ProviderId == providerId);
}

private TeamRole? ResolveTeamRole(Guid teamRoleId)
{
return _availableTeamRoles.FirstOrDefault(teamRole => teamRole.Id == teamRoleId)
?? EditProject?.TeamAssignments.FirstOrDefault(assignment => assignment.TeamRoleId == teamRoleId)?.TeamRole;
}

private bool IsTeamRoleAssigned(Guid teamRoleId)
{
return FormModel.TeamAssignments.Any(assignment => assignment.TeamRoleId == teamRoleId);
}

private async Task AddProviderSelection(Provider provider)
{
if (IsProviderSelected(provider.Id))
{
return;
}

FormModel.ProviderSelections.Add(new ProjectProvider
{
ProviderId = provider.Id,
Provider = provider,
Priority = FormModel.ProviderSelections.Count,
IsEnabled = true,
CreatedAt = DateTime.UtcNow,
UpdatedAt = DateTime.UtcNow
});

NormalizeProviderSelectionOrder();
EnsurePlanningProviderSelection();
await LoadProviderModelsAsync(provider.Id);
}

private async Task AddTeamAssignment(TeamRole teamRole)
{
if (IsTeamRoleAssigned(teamRole.Id))
{
return;
}

	var defaultProvider = FormModel.ProviderSelections
		.OrderBy(selection => selection.Priority)
		.Select(selection => ResolveProvider(selection.ProviderId))
		.FirstOrDefault(provider => provider != null && teamRole.DefaultProviderId.HasValue && provider.Id == teamRole.DefaultProviderId.Value)
		?? ResolveProvider(teamRole.DefaultProviderId ?? Guid.Empty)
		?? FormModel.ProviderSelections
	.OrderBy(selection => selection.Priority)
	.Select(selection => ResolveProvider(selection.ProviderId))
	.FirstOrDefault(provider => provider != null)
	?? _availableProviders.FirstOrDefault();
if (defaultProvider == null)
{
	return;
}

FormModel.TeamAssignments.Add(new ProjectTeamRole
{
	TeamRoleId = teamRole.Id,
	TeamRole = teamRole,
	ProviderId = defaultProvider.Id,
	Provider = defaultProvider,
	PreferredModelId = teamRole.DefaultProviderId == defaultProvider.Id
		? teamRole.DefaultModelId
		: null,
	IsEnabled = true,
	CreatedAt = DateTime.UtcNow,
	UpdatedAt = DateTime.UtcNow
});

await LoadProviderModelsAsync(defaultProvider.Id);
}

private void RemoveProviderSelection(Guid providerId)
{
var selection = FormModel.ProviderSelections.FirstOrDefault(projectProvider => projectProvider.ProviderId == providerId);
if (selection == null)
{
return;
}

FormModel.ProviderSelections.Remove(selection);
_providerModelsByProviderId.Remove(providerId);
NormalizeProviderSelectionOrder();
EnsurePlanningProviderSelection();
}

private void RemoveTeamAssignment(Guid teamRoleId)
{
var assignment = FormModel.TeamAssignments.FirstOrDefault(projectTeamRole => projectTeamRole.TeamRoleId == teamRoleId);
if (assignment == null)
{
	return;
}

FormModel.TeamAssignments.Remove(assignment);
}

private void ReorderProviderSelection(DragDropReorderArgs args)
{
var ordered = FormModel.ProviderSelections.OrderBy(projectProvider => projectProvider.Priority).ToList();
if (args.OldIndex < 0 || args.OldIndex >= ordered.Count || args.NewIndex < 0 || args.NewIndex >= ordered.Count)
{
return;
}

var item = ordered[args.OldIndex];
ordered.RemoveAt(args.OldIndex);
ordered.Insert(args.NewIndex, item);
FormModel.ProviderSelections = ordered;
NormalizeProviderSelectionOrder();
EnsurePlanningProviderSelection();
}

private async Task HandlePreferredModelChanged(ProjectProviderModelSelectionChange change)
{
var selection = FormModel.ProviderSelections.FirstOrDefault(projectProvider => projectProvider.ProviderId == change.ProviderId);
if (selection == null)
{
return;
}

if (!_providerModelsByProviderId.ContainsKey(change.ProviderId))
{
await LoadProviderModelsAsync(change.ProviderId);
}

selection.PreferredModelId = string.IsNullOrWhiteSpace(change.PreferredModelId)
? null
: change.PreferredModelId.Trim();
selection.UpdatedAt = DateTime.UtcNow;
}

private async Task HandleTeamAssignmentProviderChanged(ProjectTeamRoleProviderChange change)
{
var assignment = FormModel.TeamAssignments.FirstOrDefault(projectTeamRole => projectTeamRole.TeamRoleId == change.TeamRoleId);
if (assignment == null)
{
	return;
}

assignment.ProviderId = change.ProviderId;
assignment.Provider = ResolveProvider(change.ProviderId);
assignment.PreferredModelId = null;
assignment.UpdatedAt = DateTime.UtcNow;
await LoadProviderModelsAsync(change.ProviderId);
}

private async Task HandleTeamAssignmentPreferredModelChanged(ProjectTeamRoleModelSelectionChange change)
{
var assignment = FormModel.TeamAssignments.FirstOrDefault(projectTeamRole => projectTeamRole.TeamRoleId == change.TeamRoleId);
if (assignment == null)
{
	return;
}

if (!_providerModelsByProviderId.ContainsKey(assignment.ProviderId))
{
	await LoadProviderModelsAsync(assignment.ProviderId);
}

assignment.PreferredModelId = string.IsNullOrWhiteSpace(change.PreferredModelId)
	? null
	: change.PreferredModelId.Trim();
assignment.UpdatedAt = DateTime.UtcNow;
}

private void NormalizeProviderSelectionOrder()
{
FormModel.ProviderSelections = FormModel.ProviderSelections
.Select((selection, index) =>
{
selection.Priority = index;
selection.ProjectId = FormModel.Id;
selection.Provider ??= ResolveProvider(selection.ProviderId);
selection.UpdatedAt = DateTime.UtcNow;
return selection;
})
.ToList();
}

private async Task SeedDefaultProviderSelectionAsync()
{
if (FormModel.ProviderSelections.Any())
{
return;
}

var defaultProvider = _availableProviders.FirstOrDefault(provider => provider.IsDefault) ?? _availableProviders.FirstOrDefault();
if (defaultProvider != null)
{
await AddProviderSelection(defaultProvider);
}
}

private IEnumerable<Provider> GetPlanningProviders()
{
return _availableProviders
.Where(IsPlanningCapableProvider)
.OrderBy(provider => provider.Name)
.ToList();
}

private static bool IsPlanningCapableProvider(Provider provider)
{
return provider.Type is ProviderType.Claude or ProviderType.Copilot;
}

private async Task HandlePlanningEnabledChanged()
{
EnsurePlanningProviderSelection();
await LoadPlanningModelsAsync();
}

private async Task HandlePlanningProviderChanged()
{
FormModel.PlanningModelId = null;
EnsurePlanningProviderSelection();
await LoadPlanningModelsAsync();
}

private void EnsurePlanningProviderSelection()
{
if (!FormModel.PlanningEnabled)
{
return;
}

var planningProviders = GetPlanningProviders().ToList();
if (planningProviders.Count == 0)
{
FormModel.PlanningProviderId = null;
FormModel.PlanningModelId = null;
_planningModels = [];
return;
}

if (!FormModel.PlanningProviderId.HasValue || !planningProviders.Any(provider => provider.Id == FormModel.PlanningProviderId.Value))
{
FormModel.PlanningProviderId = planningProviders[0].Id;
FormModel.PlanningModelId = null;
_planningModels = [];
}
}

private async Task LoadPlanningModelsAsync()
{
_planningModels = [];
if (!FormModel.PlanningEnabled || !FormModel.PlanningProviderId.HasValue)
{
return;
}

try
{
_planningModels = (await ProviderService.GetModelsAsync(FormModel.PlanningProviderId.Value))
.Where(model => model.IsAvailable)
.OrderByDescending(model => model.IsDefault)
.ThenBy(model => model.DisplayName ?? model.ModelId)
.ToList();
}
catch
{
_planningModels = [];
}

if (!string.IsNullOrWhiteSpace(FormModel.PlanningModelId) &&
!_planningModels.Any(model => string.Equals(model.ModelId, FormModel.PlanningModelId, StringComparison.Ordinal)))
{
FormModel.PlanningModelId = null;
}
}

private async Task LoadInferenceProvidersAsync()
{
try
{
_availableInferenceProviders = (await InferenceProviderService.GetEnabledAsync()).ToList();
await LoadIdeaInferenceModelsAsync();
}
catch
{
_availableInferenceProviders = [];
}
}

private async Task HandleIdeaInferenceProviderChanged()
{
FormModel.IdeaInferenceModelId = null;
await LoadIdeaInferenceModelsAsync();
}

private async Task LoadIdeaInferenceModelsAsync()
{
_ideaInferenceModels = [];
if (!FormModel.IdeaInferenceProviderId.HasValue)
{
return;
}

try
{
_ideaInferenceModels = (await InferenceProviderService.GetModelsAsync(FormModel.IdeaInferenceProviderId.Value))
.Where(model => model.IsAvailable)
.OrderByDescending(model => model.IsDefault)
.ThenBy(model => model.DisplayName ?? model.ModelId)
.ToList();
}
catch
{
_ideaInferenceModels = [];
}

if (!string.IsNullOrWhiteSpace(FormModel.IdeaInferenceModelId) &&
!_ideaInferenceModels.Any(model => string.Equals(model.ModelId, FormModel.IdeaInferenceModelId, StringComparison.Ordinal)))
{
FormModel.IdeaInferenceModelId = null;
}
}

private IReadOnlyList<ProviderModel> GetProviderModels(Guid providerId)
{
return _providerModelsByProviderId.TryGetValue(providerId, out var models)
? models
: [];
}

private async Task LoadProviderSelectionModelsAsync()
{
foreach (var providerId in FormModel.ProviderSelections
	.Select(projectProvider => projectProvider.ProviderId)
	.Concat(FormModel.TeamAssignments.Select(projectTeamRole => projectTeamRole.ProviderId))
	.Distinct())
{
await LoadProviderModelsAsync(providerId);
}
}

private async Task LoadProviderModelsAsync(Guid providerId)
{
try
{
var models = (await ProviderService.GetModelsAsync(providerId))
.Where(model => model.IsAvailable)
.OrderByDescending(model => model.IsDefault)
.ThenBy(model => model.DisplayName ?? model.ModelId)
.ToList();
_providerModelsByProviderId[providerId] = models;
}
catch
{
_providerModelsByProviderId[providerId] = [];
}

var selection = FormModel.ProviderSelections.FirstOrDefault(projectProvider => projectProvider.ProviderId == providerId);
	if (selection != null &&
	!string.IsNullOrWhiteSpace(selection.PreferredModelId) &&
	!_providerModelsByProviderId[providerId].Any(model => string.Equals(model.ModelId, selection.PreferredModelId, StringComparison.Ordinal)))
	{
	selection.PreferredModelId = null;
	}

	foreach (var assignment in FormModel.TeamAssignments.Where(projectTeamRole => projectTeamRole.ProviderId == providerId))
	{
		if (!string.IsNullOrWhiteSpace(assignment.PreferredModelId) &&
			!_providerModelsByProviderId[providerId].Any(model => string.Equals(model.ModelId, assignment.PreferredModelId, StringComparison.Ordinal)))
		{
			assignment.PreferredModelId = null;
		}
	}
}

private Project CloneProjectForEditing(Project source)
{
return new Project
{
Id = source.Id,
Name = source.Name,
Description = source.Description,
WorkingPath = source.WorkingPath,
GitHubRepository = source.GitHubRepository,
AutoCommitMode = source.AutoCommitMode,
GitChangeDeliveryMode = source.GitChangeDeliveryMode,
DefaultTargetBranch = source.DefaultTargetBranch,
PlanningEnabled = source.PlanningEnabled,
PlanningProviderId = source.PlanningProviderId,
PlanningModelId = source.PlanningModelId,
PromptContext = source.PromptContext,
Memory = source.Memory,
BuildVerificationEnabled = source.BuildVerificationEnabled,
BuildCommand = source.BuildCommand,
TestCommand = source.TestCommand,
IdeaInferenceProviderId = source.IdeaInferenceProviderId,
IdeaInferenceModelId = source.IdeaInferenceModelId,
IsActive = source.IsActive,
CreatedAt = source.CreatedAt,
	UpdatedAt = source.UpdatedAt,
	ProviderSelections = source.ProviderSelections
.OrderBy(projectProvider => projectProvider.Priority)
.Select(projectProvider => new ProjectProvider
{
Id = projectProvider.Id,
ProjectId = projectProvider.ProjectId,
ProviderId = projectProvider.ProviderId,
Priority = projectProvider.Priority,
IsEnabled = projectProvider.IsEnabled,
PreferredModelId = projectProvider.PreferredModelId,
CreatedAt = projectProvider.CreatedAt,
UpdatedAt = projectProvider.UpdatedAt,
Provider = ResolveProvider(projectProvider.ProviderId)
	})
	.ToList(),
	TeamAssignments = source.TeamAssignments
	.Select(projectTeamRole => new ProjectTeamRole
	{
		Id = projectTeamRole.Id,
		ProjectId = projectTeamRole.ProjectId,
		TeamRoleId = projectTeamRole.TeamRoleId,
		ProviderId = projectTeamRole.ProviderId,
		PreferredModelId = projectTeamRole.PreferredModelId,
		IsEnabled = projectTeamRole.IsEnabled,
		CreatedAt = projectTeamRole.CreatedAt,
		UpdatedAt = projectTeamRole.UpdatedAt,
		TeamRole = ResolveTeamRole(projectTeamRole.TeamRoleId),
		Provider = ResolveProvider(projectTeamRole.ProviderId)
	})
	.ToList(),
	Environments = (source.Environments ?? [])
.OrderBy(environment => environment.SortOrder)
.Select(environment => new ProjectEnvironment
{
Id = environment.Id,
ProjectId = environment.ProjectId,
Name = environment.Name,
Description = environment.Description,
Type = environment.Type,
Stage = environment.Stage,
Url = environment.Url,
IsPrimary = environment.IsPrimary,
IsEnabled = environment.IsEnabled,
SortOrder = environment.SortOrder,
Username = environment.Username,
Password = environment.Password,
ClearPassword = false,
UsernameCiphertext = environment.UsernameCiphertext,
PasswordCiphertext = environment.PasswordCiphertext,
CreatedAt = environment.CreatedAt,
UpdatedAt = environment.UpdatedAt
})
.ToList()
};
}
}
