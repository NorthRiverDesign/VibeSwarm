
<div class="list-group-item p-3 hover-bg-tertiary">
	<div class="d-flex flex-column flex-lg-row align-items-stretch align-items-lg-start gap-2 gap-lg-3">
		<div class="flex-grow-1 min-width-0">
			<div class="d-flex align-items-start justify-content-between gap-2">
				<div class="min-width-0">
					<div class="d-flex align-items-center gap-2 flex-wrap">
						<a href="/projects/@Project.Id" class="fw-semibold text-decoration-none text-break">@Project.Name</a>
						@if (!Project.IsActive)
						{
							<span class="small text-body-tertiary">Inactive</span>
						}
					</div>
					@if (!string.IsNullOrEmpty(Project.Description))
					{
						<div class="small text-body-secondary mt-1 d-md-none">@TruncateText(Project.Description, 80)</div>
					}
				</div>
				<div class="d-flex d-lg-none align-items-center gap-2 flex-shrink-0">
					<ProjectActionsDropdown DetailsHref="@($"/projects/{Project.Id}")" OnEdit="OnEdit"
											IsActive="@Project.IsActive" OnToggleActive="OnToggleActive"
											ShowStartIdeaQueueAction="@(Stats.TotalIdeas > 0 && !Project.IdeasProcessingActive)"
											StartIdeaQueueEnabled="@StartIdeaQueueEnabled"
											IsStartingIdeaQueue="@IsStartingIdeaQueue"
											StartIdeaQueueTooltip="@StartIdeaQueueTooltip"
											OnStartIdeaQueue="OnStartIdeaQueue"
											ShowSyncAction="@(!string.IsNullOrEmpty(CurrentBranch))"
											SyncLabel="Sync with Origin" OnSync="OnSync"
											ShowMergeBranchAction="@(!string.IsNullOrWhiteSpace(CurrentBranch))"
											IsSyncing="@IsSyncing"
											IsMerging="@IsMerging"
											OnMergeBranch="OnMergeBranch"
											ShowDeleteAction="true" OnDelete="OnDelete" />
				</div>
			</div>
			<div class="d-flex flex-wrap align-items-center gap-2 mt-2 small">
				@if (Project.AutoCommitMode != AutoCommitMode.Off)
				{
					<span class="badge bg-info-subtle text-info-emphasis">Auto-commit</span>
				}
				@if (ShowStats && Project.Environments.Any(environment => environment.IsEnabled))
				{
					<span class="small text-body-secondary d-inline-flex align-items-center gap-1">
						<i class="bi bi-globe2 opacity-75"></i>@Project.Environments.Count(environment => environment.IsEnabled)
					</span>
				}
				@if (ShowStats && Stats.ActiveJobs > 0)
				{
					<span class="small text-body-secondary d-inline-flex align-items-center gap-1">
						<i class="bi bi-activity opacity-75"></i>@Stats.ActiveJobs running
					</span>
				}
				@if (Project.IdeasProcessingActive)
				{
					<span class="small text-info-emphasis d-inline-flex align-items-center gap-1" title="Idea queue is running">
						<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>Queue running
					</span>
				}
			</div>
			@if (ShowStats)
			{
				<div class="d-flex d-md-none flex-wrap align-items-center gap-2 mt-2 small text-body-secondary">
					@if (!string.IsNullOrEmpty(CurrentBranch))
					{
						<span class="d-inline-flex align-items-center gap-1">
							<i class="bi bi-git opacity-75"></i>
							@CurrentBranch
						</span>
					}
					@if (Project.ProviderSelections.Any(pp => pp.IsEnabled))
					{
						<span class="d-inline-flex align-items-center gap-1">
							<i class="bi bi-diagram-3 opacity-75"></i>
							@Project.ProviderSelections.Count(pp => pp.IsEnabled) provider@(Project.ProviderSelections.Count(pp => pp.IsEnabled) == 1 ? string.Empty : "s")
						</span>
					}
					@if (Project.TeamAssignments.Any(assignment => assignment.IsEnabled && assignment.TeamRole != null))
					{
						<span class="d-inline-flex align-items-center gap-1">
							<i class="bi bi-people opacity-75"></i>
							@Project.TeamAssignments.Count(assignment => assignment.IsEnabled && assignment.TeamRole != null) role@(Project.TeamAssignments.Count(assignment => assignment.IsEnabled && assignment.TeamRole != null) == 1 ? string.Empty : "s")
						</span>
					}
				</div>
			}
			@if (!string.IsNullOrEmpty(Project.Description))
			{
				<div class="small text-body-secondary mt-1 d-none d-md-block">@TruncateText(Project.Description, 100)</div>
			}
			@if (ShowStats)
			{
				<div class="d-flex flex-wrap gap-2 gap-md-3 mt-2 small text-body-secondary">
					@if (!string.IsNullOrEmpty(Project.GitHubRepository))
					{
						<span class="d-flex align-items-center gap-1" title="GitHub Repository">
							<i class="bi bi-github opacity-75"></i>
							<a href="https://github.com/@Project.GitHubRepository" target="_blank"
								   class="text-body-secondary text-decoration-none hover-underline">
								@Project.GitHubRepository
							</a>
						</span>
					}
					else
					{
						<span class="font-monospace bg-body-tertiary px-2 py-1 rounded-1 text-truncate"
							  style="max-width: min(280px, 50vw);" title="@Project.WorkingPath">
							@Project.WorkingPath
						</span>
					}
					@if (!string.IsNullOrEmpty(CurrentBranch))
					{
						<span class="d-flex align-items-center gap-1" title="Current branch">
							<i class="bi bi-git opacity-75"></i>
							@CurrentBranch
						</span>
					}
				</div>
				@if (Project.ProviderSelections.Any(pp => pp.IsEnabled))
				{
					<div class="d-none d-md-flex flex-wrap align-items-center gap-2 mt-2 small text-body-secondary">
						<span class="d-flex align-items-center gap-1">
							<i class="bi bi-diagram-3 opacity-75"></i>
							Providers
						</span>
						<span>@string.Join("  •  ", Project.ProviderSelections.Where(pp => pp.IsEnabled).OrderBy(pp => pp.Priority).Select(selection => $"#{selection.Priority + 1} {selection.Provider?.Name ?? "Unknown"}"))</span>
					</div>
				}
			}
			@if (ShowStats && Project.TeamAssignments.Any(assignment => assignment.IsEnabled && assignment.TeamRole != null))
			{
				<div class="d-none d-md-flex flex-wrap align-items-center gap-2 mt-2 small text-body-secondary">
					<span class="d-flex align-items-center gap-1">
						<i class="bi bi-people opacity-75"></i>
						Team
					</span>
					<span>@string.Join("  •  ", Project.TeamAssignments.Where(assignment => assignment.IsEnabled && assignment.TeamRole != null).OrderBy(assignment => assignment.TeamRole!.Name).Select(assignment => $"{assignment.TeamRole!.Name} ({assignment.Provider?.Name ?? "Unassigned"})"))</span>
				</div>
			}
			@if (ShowStats)
			{
				<div class="d-flex flex-wrap gap-2 gap-md-3 mt-2 small">
					<span class="d-flex align-items-center gap-1 text-body-secondary" title="Total ideas">
						<i class="bi bi-lightbulb opacity-75"></i>
						@Stats.TotalIdeas idea@(Stats.TotalIdeas == 1 ? string.Empty : "s")
					</span>
					@if (Stats.UnprocessedIdeas > 0)
					{
						<span class="d-flex align-items-center gap-1 text-body-secondary" title="Ideas waiting to run">
							<i class="bi bi-hourglass-split opacity-75"></i>
							@Stats.UnprocessedIdeas pending
						</span>
					}
					@if (Stats.TotalJobs > 0)
					{
						<span class="d-flex align-items-center gap-1 text-body-secondary" title="Total jobs">
							<i class="bi bi-list-check opacity-75"></i>
							@Stats.TotalJobs jobs
						</span>
						@if (Stats.TotalInputTokens > 0 || Stats.TotalOutputTokens > 0)
						{
							<span class="d-flex align-items-center gap-1 text-body-secondary"
								  title="Total tokens (input / output)">
								<i class="bi bi-braces opacity-75"></i>
								@TokenHelper.FormatTokenCount(Stats.TotalInputTokens) /
								@TokenHelper.FormatTokenCount(Stats.TotalOutputTokens)
							</span>
						}
						@if (Stats.TotalCostUsd > 0)
						{
							<span class="d-flex align-items-center gap-1 text-success fw-medium" title="Total cost">
								<i class="bi bi-currency-dollar opacity-75"></i>
								@TokenHelper.FormatCost(Stats.TotalCostUsd)
							</span>
						}
					}
				</div>
			}
			@if (LatestJob != null)
			{
				<div class="border-top pt-2 mt-2 d-flex flex-column gap-2 min-width-0">
					<div class="d-flex align-items-center gap-2 small min-width-0">
						<a href="/jobs/view/@LatestJob.Id"
							   class="d-flex align-items-center gap-2 text-decoration-none min-width-0 w-100"
							   title="@LatestJob.DisplayTitle">
							@switch (LatestJob.Status)
							{
								case JobStatus.Completed:
									<i class="bi bi-check-circle-fill text-success flex-shrink-0" title="Completed"></i>
									break;
								case JobStatus.Failed:
									<i class="bi bi-x-circle-fill text-danger flex-shrink-0" title="Failed"></i>
									break;
								case JobStatus.Started:
								case JobStatus.Planning:
								case JobStatus.Processing:
									<span class="spinner-border spinner-border-sm text-info flex-shrink-0" role="status"
										  title="Running"></span>
									break;
								case JobStatus.Cancelled:
									<i class="bi bi-slash-circle text-secondary flex-shrink-0" title="Cancelled"></i>
									break;
								case JobStatus.Stalled:
									<i class="bi bi-exclamation-triangle-fill text-warning flex-shrink-0" title="Stalled"></i>
									break;
								default:
									<i class="bi bi-clock text-secondary flex-shrink-0" title="Pending"></i>
									break;
							}
							<span class="text-truncate text-body-secondary flex-grow-1 min-width-0">@TruncateText(LatestJob.DisplayTitle, 60)</span>
						</a>
					</div>
					<div class="min-width-0">
						<JobOutcomeHint Status="@LatestJob.Status"
										ChangedFilesCount="@LatestJob.ChangedFilesCount"
										BuildVerified="@LatestJob.BuildVerified"
										BuildVerificationEnabled="@LatestJob.BuildVerificationEnabled"
										IsPushed="@LatestJob.IsPushed"
										GitCommitHash="@LatestJob.GitCommitHash"
										PullRequestUrl="@LatestJob.PullRequestUrl"
										PullRequestNumber="@LatestJob.PullRequestNumber"
										MergedAt="@LatestJob.MergedAt" />
						<JobOutcomeSummarySnippet SessionSummary="@LatestJob.SessionSummary" />
					</div>
				</div>
			}
			@if (ActiveJobs.Any())
			{
				<div class="@(LatestJob == null ? "border-top pt-2 mt-2" : "mt-1")">
					@foreach (var job in ActiveJobs)
					{
						<div class="bg-body-tertiary rounded-2 p-2 mb-1 small">
							<a href="/jobs/view/@job.Id" class="d-flex align-items-center gap-2 text-decoration-none small min-width-0 w-100">
								<StatusBadge Status="@job.Status.ToString()" />
								<span class="text-truncate flex-grow-1 min-width-0">@TruncateText(job.DisplayTitle, 50)</span>
								@if (!string.IsNullOrEmpty(job.CurrentActivity))
								{
									<span class="text-info fst-italic small d-none d-md-inline">@job.CurrentActivity</span>
								}
							</a>
						</div>
					}
				</div>
			}
		</div>
		<div class="d-none d-lg-flex align-items-center gap-2 flex-shrink-0">
			<ProjectActionsDropdown DetailsHref="@($"/projects/{Project.Id}")" OnEdit="OnEdit"
									IsActive="@Project.IsActive" OnToggleActive="OnToggleActive"
									ShowStartIdeaQueueAction="@(Stats.TotalIdeas > 0 && !Project.IdeasProcessingActive)"
									StartIdeaQueueEnabled="@StartIdeaQueueEnabled"
									IsStartingIdeaQueue="@IsStartingIdeaQueue"
									StartIdeaQueueTooltip="@StartIdeaQueueTooltip"
									OnStartIdeaQueue="OnStartIdeaQueue"
									ShowSyncAction="@(!string.IsNullOrEmpty(CurrentBranch))"
									SyncLabel="Sync with Origin" OnSync="OnSync"
									ShowMergeBranchAction="@(!string.IsNullOrWhiteSpace(CurrentBranch))"
									IsSyncing="@IsSyncing"
									IsMerging="@IsMerging"
									OnMergeBranch="OnMergeBranch"
									ShowDeleteAction="true" OnDelete="OnDelete" />
		</div>
	</div>
</div>

@code {
	[Parameter] public required Project Project { get; set; }
	[Parameter] public required ProjectJobStats Stats { get; set; }
	[Parameter] public JobSummary? LatestJob { get; set; }
	[Parameter] public string? CurrentBranch { get; set; }
	[Parameter] public List<JobSummary> ActiveJobs { get; set; } = [];
	[Parameter] public bool ShowStats { get; set; }
	[Parameter] public bool IsSyncing { get; set; }
	[Parameter] public bool IsMerging { get; set; }
	[Parameter] public bool StartIdeaQueueEnabled { get; set; }
	[Parameter] public bool IsStartingIdeaQueue { get; set; }
	[Parameter] public string? StartIdeaQueueTooltip { get; set; }
	[Parameter] public EventCallback OnEdit { get; set; }
	[Parameter] public EventCallback OnToggleActive { get; set; }
	[Parameter] public EventCallback OnStartIdeaQueue { get; set; }
	[Parameter] public EventCallback OnSync { get; set; }
	[Parameter] public EventCallback OnMergeBranch { get; set; }
	[Parameter] public EventCallback OnDelete { get; set; }

	private static string TruncateText(string text, int maxLength)
		=> string.IsNullOrEmpty(text) || text.Length <= maxLength ? text : text[..maxLength] + "...";
}
