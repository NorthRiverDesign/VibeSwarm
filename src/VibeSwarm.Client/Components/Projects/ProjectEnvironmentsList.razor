
@if (Environments == null || !Environments.Any(environment => environment.IsEnabled))
{
	<EmptyState Icon="globe2" Title="No environments configured"
		Message="Add a web URL, release page, or deployment target so jobs can use real project environments." />
}
else
{
	<div class="d-grid gap-3">
		@foreach (var environment in Environments.Where(environment => environment.IsEnabled).OrderByDescending(environment => environment.IsPrimary).ThenBy(environment => environment.SortOrder))
		{
			<div class="border rounded p-3 bg-body-tertiary">
				<div class="d-flex align-items-start justify-content-between gap-3 flex-wrap">
					<div class="min-width-0">
						<div class="d-flex align-items-center gap-2 flex-wrap">
							<span class="fw-semibold">@environment.Name</span>
							<span class="badge bg-secondary-subtle text-secondary-emphasis">@environment.Type</span>
							<span class="@GetStageBadgeClass(environment.Stage)">@environment.Stage</span>
							@if (environment.IsPrimary)
							{
								<span class="badge bg-success-subtle text-success-emphasis">Primary</span>
							}
							@if (environment.Type == EnvironmentType.Web)
							{
								<span class="badge bg-info-subtle text-info-emphasis">Playwright MCP</span>
							}
						</div>
						<div class="small mt-2">
							<a href="@environment.Url" target="_blank" rel="noopener noreferrer" class="text-decoration-none font-monospace">
								@environment.Url
							</a>
						</div>
						@if (!string.IsNullOrWhiteSpace(environment.Description))
						{
							<div class="small text-body-secondary mt-2">@environment.Description</div>
						}
						<div class="small text-body-secondary mt-2">@GetStageSummary(environment.Stage)</div>
					</div>
					@if (environment.Type == EnvironmentType.Web && !string.IsNullOrWhiteSpace(environment.Username))
					{
						<div class="small text-body-secondary">
							<div class="fw-semibold text-body">Saved login</div>
							<div>@environment.Username</div>
							@if (environment.HasPassword)
							{
								<div class="mt-1">Password stored securely</div>
							}
						</div>
					}
				</div>
			</div>
		}
	</div>
}

@code {
	[Parameter, EditorRequired]
	public ICollection<ProjectEnvironment> Environments { get; set; } = new List<ProjectEnvironment>();

	private static string GetStageBadgeClass(EnvironmentStage stage) => stage switch
	{
		EnvironmentStage.Production => "badge bg-danger-subtle text-danger-emphasis",
		EnvironmentStage.Development => "badge bg-warning-subtle text-warning-emphasis",
		EnvironmentStage.Local => "badge bg-info-subtle text-info-emphasis",
		_ => "badge bg-secondary-subtle text-secondary-emphasis"
	};

	private static string GetStageSummary(EnvironmentStage stage) => stage switch
	{
		EnvironmentStage.Production => "Production: keep changes conservative and expect slower deployment feedback.",
		EnvironmentStage.Development => "Development: iterative changes are fine, but deploy or restart steps may still be needed.",
		EnvironmentStage.Local => "Local: rebuilds, restarts, redeploys, and local database resets are fair game when useful.",
		_ => string.Empty
	};
}
