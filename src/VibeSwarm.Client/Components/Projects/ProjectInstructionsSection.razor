@using VibeSwarm.Shared.Validation

<div class="mb-3">
	<label class="form-label d-flex align-items-center gap-2 mb-2">
		<i class="bi bi-journal-richtext"></i>
		<span>Instructions &amp; Memory</span>
	</label>

	<div class="border rounded p-3 bg-body-tertiary">
		<div class="mb-3">
			<label for="modal-promptContext" class="form-label">
				<i class="bi bi-chat-left-text me-1"></i>Prompt Context
				<span class="text-body-secondary fw-normal">(optional)</span>
			</label>
			<InputTextArea id="modal-promptContext" @bind-Value="Project.PromptContext" class="form-control"
				rows="5"
				maxlength="@ValidationLimits.ProjectPromptContextMaxLength"
				placeholder="Optional instructions injected into every job prompt for this project (e.g., coding conventions, framework preferences)" />
			<ValidationMessage For="@(() => Project.PromptContext)" class="text-danger small" />
			<div class="form-text">
				These instructions are automatically included in every job prompt for this project to guide AI agents.
				<span class="ms-2">@GetCharacterCount(Project.PromptContext, ValidationLimits.ProjectPromptContextMaxLength)</span>
			</div>
		</div>

		<div>
			<div class="d-flex flex-column flex-sm-row align-items-sm-center justify-content-sm-between gap-2 mb-2">
				<label for="modal-projectMemory" class="form-label mb-0">
					<i class="bi bi-journal-text me-1"></i>Project Memory
					<span class="text-body-secondary fw-normal">(optional)</span>
				</label>

				@if (HasProjectMemory)
				{
					<ActionButton Icon="trash" Text="Clear" Title="Clear project memory"
								  Size="ActionButton.ButtonSize.Small" Style="ActionButton.ButtonStyle.Danger"
								  OnClick="ShowClearProjectMemoryConfirmation" />
				}
			</div>

			<InputTextArea id="modal-projectMemory" @bind-Value="Project.Memory" class="form-control"
				rows="6"
				maxlength="@ValidationLimits.ProjectMemoryMaxLength"
				placeholder="Persistent notes that help fresh agent sessions avoid repeating past mistakes, remember workflows, and keep important project-specific context." />
			<ValidationMessage For="@(() => Project.Memory)" class="text-danger small" />
			<div class="form-text">
				VibeSwarm exposes this as persistent memory for every job on this project. Agents are instructed to read it first and update it whenever they learn durable context or correct a mistake.
				<span class="ms-2">@GetCharacterCount(Project.Memory, ValidationLimits.ProjectMemoryMaxLength)</span>
			</div>
		</div>
	</div>
</div>

<ConfirmationModal @bind-IsVisible="_showClearProjectMemoryModal" Title="Clear project memory"
				   Message="Remove this project's stored memory?"
				   SubMessage="Future jobs will stop receiving these durable notes until new memory is saved. Prompt context is not affected."
				   ConfirmText="Clear memory" ButtonClass="btn-danger"
				   OnConfirm="ClearProjectMemory" OnCancel="CancelClearProjectMemory" />

@code {
	[Parameter, EditorRequired]
	public ProjectModalFormModel Project { get; set; } = default!;

	private bool _showClearProjectMemoryModal;

	private bool HasProjectMemory => !string.IsNullOrWhiteSpace(Project.Memory);

	private static string GetCharacterCount(string? value, int maxLength)
	{
		return $"{value?.Length ?? 0}/{maxLength} characters";
	}

	private void ShowClearProjectMemoryConfirmation()
	{
		_showClearProjectMemoryModal = true;
	}

	private Task ClearProjectMemory()
	{
		Project.Memory = null;
		_showClearProjectMemoryModal = false;
		return Task.CompletedTask;
	}

	private Task CancelClearProjectMemory()
	{
		_showClearProjectMemoryModal = false;
		return Task.CompletedTask;
	}
}
