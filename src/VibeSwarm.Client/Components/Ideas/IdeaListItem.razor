@* Individual idea list item component *@

@using VibeSwarm.Shared.Validation

<li class="list-group-item p-3">
	@if (IsEditing)
	{
		@* Edit Mode *@
		<div class="d-flex flex-column flex-sm-row align-items-stretch align-items-sm-end gap-3">
			<div class="flex-grow-1">
				<textarea class="form-control form-control-sm" rows="5" @bind="EditDescription" @bind:event="oninput"
						  maxlength="@ValidationLimits.IdeaDescriptionMaxLength">
				</textarea>
				<div class="d-flex justify-content-between mt-2 small text-body-secondary">
					<span>@GetEditLengthSummary()</span>
				</div>
				@if (!string.IsNullOrWhiteSpace(EditValidationMessage))
				{
					<div class="text-danger small mt-2">
						<i class="bi bi-exclamation-circle me-1"></i>@EditValidationMessage
					</div>
				}
			</div>
			<div class="d-flex justify-content-end gap-2">
				<button type="button" class="btn btn-sm btn-success" @onclick="SaveEdit"
						disabled="@(!CanSaveEdit)">
					<i class="bi bi-check-lg"></i>
				</button>
				<button type="button" class="btn btn-sm btn-secondary" @onclick="CancelEdit">
					<i class="bi bi-x-lg"></i>
				</button>
			</div>
		</div>
	}
	else
	{
		@* View Mode — grid: [status pill][body + meta][actions] *@
		<div class="d-flex flex-column flex-sm-row gap-3 align-items-stretch align-items-sm-start">
			<div class="d-flex gap-3 align-items-start flex-grow-1 min-width-0">
				<StatusIconPill Status="@GetStatusSemantic()" Icon="@GetStatusIcon()" />

				<div class="d-flex flex-column gap-1 flex-grow-1 min-width-0">
					<div class="text-break text-truncate-lines-2 small @(IsRunningIdea() ? "text-body-tertiary" : "")">@Idea.Description</div>
					<div class="d-flex flex-wrap gap-2 align-items-center">
						@if (Idea.ExpansionStatus == IdeaExpansionStatus.Approved)
						{
							<MetaChip Variant="ai" Icon="bi-stars" Text="Expanded" />
						}
						else if (Idea.ExpansionStatus == IdeaExpansionStatus.PendingReview)
						{
							<MetaChip Icon="bi-eye" Text="Review" />
						}
						@if (Idea.Attachments.Any())
						{
							<MetaChip Icon="bi-paperclip" Text="@($"{Idea.Attachments.Count} attachment{(Idea.Attachments.Count == 1 ? "" : "s")}")" />
						}
						@if (IsQueuedIdea() && Idea.JobId.HasValue)
						{
							<NavLink href="@($"/jobs/view/{Idea.JobId}")" class="badge text-bg-info text-decoration-none">
								<i class="bi bi-hourglass-split"></i> Queued Job <i class="bi bi-arrow-right-short"></i>
							</NavLink>
						}
					</div>
					@if (Idea.Attachments.Any())
					{
						<div class="d-flex flex-wrap gap-2 mt-1">
							@foreach (var attachment in Idea.Attachments.OrderBy(attachment => attachment.CreatedAt))
							{
								<a class="d-inline-flex align-items-center gap-2 text-decoration-none border rounded-2 px-2 py-1 bg-body-secondary min-width-0"
								   href="@GetAttachmentUrl(attachment.Id)" target="_blank" rel="noreferrer"
								   title="@attachment.FileName">
									@if (IsImageAttachment(attachment))
									{
										<img src="@GetAttachmentUrl(attachment.Id)" alt="@attachment.FileName" class="rounded border flex-shrink-0 object-fit-cover attachment-thumb" />
									}
									else
									{
										<i class="bi bi-paperclip text-muted flex-shrink-0"></i>
									}
									<span class="d-flex flex-column min-width-0">
										<span class="text-truncate small">@attachment.FileName</span>
										<span class="text-muted small">@FormatAttachmentSize(attachment.SizeBytes)</span>
									</span>
								</a>
							}
						</div>
					}
				</div>
			</div>

			@* Action buttons *@
			<div class="d-flex align-items-center justify-content-end gap-2 flex-shrink-0">
				@if (!IsRunningIdea() && !IsQueuedIdea())
				{
					<button type="button" class="btn btn-sm btn-success" @onclick="HandleStart"
							disabled="@(!HasDefaultProvider || IsStarting || Idea.JobId.HasValue)"
							title="@(HasActiveJobs ? "Queue this idea after the current job" : "Start this idea")">
						@if (IsStarting)
						{
							<span class="spinner-border spinner-border-sm" role="status"></span>
						}
						else
						{
							<i class="bi bi-play-fill"></i>
						}
						<span class="d-inline d-sm-none ms-1">Start</span>
					</button>
				}
				else if (IsQueuedIdea())
				{
					<button type="button" class="btn btn-sm btn-secondary" disabled title="Queued for auto-processing">
						<i class="bi bi-hourglass-split"></i>
						<span class="d-inline d-sm-none ms-1">Queued</span>
					</button>
				}
				else if (Idea.JobId.HasValue)
				{
					<NavLink href="@($"/jobs/view/{Idea.JobId}")" class="btn btn-sm btn-secondary">
						<span class="spinner-border spinner-border-sm" role="status"></span>
						<span class="ms-1">View Job</span>
					</NavLink>
				}
				else
				{
					<button type="button" class="btn btn-sm btn-secondary" disabled>
						<span class="spinner-border spinner-border-sm" role="status"></span>
						<span class="d-inline d-sm-none ms-1">Processing</span>
					</button>
				}

				<RowActionsDropdown MobileLabel="Options">
					@if (IsRunningIdea() && Idea.JobId.HasValue)
					{
						<RowActionsItem Icon="stop-fill" Text="Stop Job" Warning="true" OnClick="HandleStopJob" />
						<RowActionsDivider />
					}
					<RowActionsItem Icon="magic" Text="Expand with AI" OnClick="HandleExpand"
									Disabled="@(Idea.JobId.HasValue || Idea.ExpansionStatus == IdeaExpansionStatus.Expanding)" />
					<RowActionsDivider />
					<RowActionsItem Icon="pencil" Text="Edit" OnClick="StartEdit" />
					<RowActionsItem Icon="copy" Text="Copy to Project" OnClick="HandleCopy" />
					<RowActionsItem Icon="box-arrow-right" Text="Move to Project" OnClick="HandleMove"
									Disabled="@(IsRunningIdea() || IsQueuedIdea() || Idea.JobId.HasValue)" />
					<RowActionsDivider />
					<RowActionsItem Icon="trash" Text="Delete" Danger="true"
									OnClick="HandleDelete" Disabled="@IsRunningIdea()" />
				</RowActionsDropdown>
			</div>
		</div>
	}
</li>

@functions {
	private string GetStatusSemantic()
	{
		if (IsRunningIdea()) return "running";
		if (IsQueuedIdea()) return "primary";
		if (Idea.ExpansionStatus == IdeaExpansionStatus.Expanding) return "info";
		if (Idea.ExpansionStatus == IdeaExpansionStatus.Approved) return "success";
		if (Idea.ExpansionStatus == IdeaExpansionStatus.PendingReview) return "warning";
		return "warning";
	}

	private string GetStatusIcon()
	{
		if (IsRunningIdea()) return "bi-hourglass-split";
		if (IsQueuedIdea()) return "bi-hourglass-split";
		if (Idea.ExpansionStatus == IdeaExpansionStatus.Expanding) return "bi-stars";
		if (Idea.ExpansionStatus == IdeaExpansionStatus.Approved) return "bi-check-lg";
		if (Idea.ExpansionStatus == IdeaExpansionStatus.PendingReview) return "bi-eye";
		return "bi-lightbulb";
	}
}

@code {
	[Parameter, EditorRequired]
	public Idea Idea { get; set; } = null!;

	[Parameter]
	public bool IsProcessing { get; set; }

	[Parameter]
	public bool IsStarting { get; set; }

	[Parameter]
	public bool HasActiveJobs { get; set; }

	/// <summary>
	/// Whether this idea is implicitly queued for processing (auto-processing is active and idea hasn't started yet)
	/// </summary>
	[Parameter]
	public bool IsQueuedForProcessing { get; set; }

	[Parameter]
	public bool HasDefaultProvider { get; set; }

	[Parameter]
	public EventCallback OnExpand { get; set; }

	[Parameter]
	public EventCallback OnStart { get; set; }

	[Parameter]
	public EventCallback OnCopy { get; set; }

	[Parameter]
	public EventCallback OnMove { get; set; }

	[Parameter]
	public EventCallback OnDelete { get; set; }

	[Parameter]
	public EventCallback OnStopJob { get; set; }

	[Parameter]
	public EventCallback<(Guid IdeaId, string Description)> OnSaveEdit { get; set; }

	private bool IsEditing { get; set; }
	private string EditDescription { get; set; } = string.Empty;
	private string? EditValidationMessage => !string.IsNullOrEmpty(EditDescription) &&
		EditDescription.Length > ValidationLimits.IdeaDescriptionMaxLength
			? $"Idea text must be {ValidationLimits.IdeaDescriptionMaxLength:N0} characters or fewer."
			: null;
	private bool CanSaveEdit => !string.IsNullOrWhiteSpace(EditDescription) && string.IsNullOrWhiteSpace(EditValidationMessage);

	private void StartEdit()
	{
		IsEditing = true;
		EditDescription = Idea.Description;
	}

	private void CancelEdit()
	{
		IsEditing = false;
		EditDescription = string.Empty;
	}

	private async Task SaveEdit()
	{
		if (!CanSaveEdit)
		{
			return;
		}

		await OnSaveEdit.InvokeAsync((Idea.Id, EditDescription.Trim()));
		IsEditing = false;
		EditDescription = string.Empty;
	}

	private bool IsQueuedIdea()
	{
		return IsQueuedForProcessing || Idea.Job?.Status == JobStatus.New || Idea.Job?.Status == JobStatus.Pending;
	}

	private bool IsRunningIdea()
	{
		return IsProcessing || Idea.Job?.Status == JobStatus.Started || Idea.Job?.Status == JobStatus.Planning || Idea.Job?.Status == JobStatus.Processing ||
			Idea.Job?.Status == JobStatus.Paused;
	}

	private async Task HandleExpand() => await OnExpand.InvokeAsync();
	private async Task HandleStart() => await OnStart.InvokeAsync();
	private async Task HandleCopy() => await OnCopy.InvokeAsync();
	private async Task HandleMove() => await OnMove.InvokeAsync();
	private async Task HandleDelete() => await OnDelete.InvokeAsync();
	private async Task HandleStopJob() => await OnStopJob.InvokeAsync();

	private string GetExpandButtonTooltip()
	{
		return Idea.ExpansionStatus switch
		{
			IdeaExpansionStatus.Approved => "View approved specification",
			IdeaExpansionStatus.PendingReview => "Review AI-generated specification",
			IdeaExpansionStatus.Expanding => "Expanding...",
			_ => "Expand with AI"
		};
	}

	private string GetEditLengthSummary()
	{
		return $"{EditDescription.Length}/{ValidationLimits.IdeaDescriptionMaxLength} characters";
	}

	private static bool IsImageAttachment(IdeaAttachment attachment)
		=> !string.IsNullOrWhiteSpace(attachment.ContentType)
			&& attachment.ContentType.StartsWith("image/", StringComparison.OrdinalIgnoreCase);

	private static string GetAttachmentUrl(Guid attachmentId)
		=> $"/api/ideas/attachments/{attachmentId}";

	private static string FormatAttachmentSize(long sizeBytes)
	{
		if (sizeBytes < 1024)
		{
			return $"{sizeBytes} B";
		}

		var kilobytes = sizeBytes / 1024d;
		if (kilobytes < 1024)
		{
			return $"{kilobytes:0.#} KB";
		}

		return $"{kilobytes / 1024d:0.#} MB";
	}
}
