@* Ideas panel component for managing project feature ideas *@
@inject IProjectService ProjectService
@inject IIdeaService IdeaService
@inject IJobService JobService
@inject IJSRuntime JSRuntime
@inject NotificationService NotificationService
@using System.Diagnostics.CodeAnalysis
@using System.Globalization
@using VibeSwarm.Shared.Data
@using VibeSwarm.Shared.Inference
@using VibeSwarm.Shared.Models
@using VibeSwarm.Shared.Providers
@using VibeSwarm.Shared.Validation
@implements IAsyncDisposable

<div class="d-grid gap-3">
	<div class="d-flex flex-wrap justify-content-between align-items-center gap-2">
		<div class="d-flex flex-wrap align-items-center gap-2 small text-body-secondary">
			@if (IsPageLoading)
			{
				<span class="d-inline-flex align-items-center gap-2">
					<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
					<span>Refreshing ideas</span>
				</span>
			}
			@if (UnprocessedIdeasCount > 0)
			{
				<span class="badge bg-body-secondary text-body">@UnprocessedIdeasCount pending</span>
			}
			@if (IsProcessingActive)
			{
				<span class="badge text-bg-info d-inline-flex align-items-center gap-1" title="@ActiveProcessingMessage">
					<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
					<span>Auto-running</span>
				</span>
			}
		</div>
	</div>

	@if (_suggestResult != null)
	{
		<div class="d-flex align-items-start gap-2 rounded-3 border px-3 py-2 @GetSuggestResultContainerClass()">
			<i class="bi @(_suggestResult.Success ? "bi-stars" : "bi-exclamation-triangle") mt-1"></i>
			<div class="flex-grow-1 min-width-0">
				<div class="small fw-medium">@_suggestResult.Message</div>
				@if (!string.IsNullOrEmpty(_suggestResult.InferenceError) && !_suggestResult.Success)
				{
					<div class="small text-body-secondary font-monospace mt-1">
						@_suggestResult.InferenceError[..Math.Min(200, _suggestResult.InferenceError.Length)]
					</div>
				}
			</div>
			<button type="button" class="btn-close btn-close-sm" @onclick="() => _suggestResult = null"
					aria-label="Dismiss suggestion status"></button>
		</div>
	}

	<div class="border rounded-3 bg-body-tertiary p-3">
		<label class="form-label fw-medium mb-2" for="@_textareaId">Add idea</label>
		<div class="d-flex gap-2 align-items-end">
			<div class="flex-grow-1">
				<textarea class="form-control" id="@_textareaId" rows="5" placeholder="Describe a feature or improvement..."
						  value="@NewIdeaDescription" @oninput="HandleNewIdeaInput" @onkeypress="HandleKeyPress"
						  @ref="_newIdeaTextarea"
						  maxlength="@ValidationLimits.IdeaDescriptionMaxLength"
						  title="Describe a feature or improvement. Press Ctrl+Enter to submit or paste an image into the box."></textarea>
			</div>
			<button type="button" class="btn btn-primary align-self-stretch px-3" @onclick="AddIdea"
					disabled="@(!CanAddIdea)"
					title="@GetAddIdeaTooltip()">
				@if (IsAddingIdea)
				{
					<span class="spinner-border spinner-border-sm" role="status"></span>
				}
				else
				{
					<i class="bi bi-plus-lg"></i>
				}
				<span class="d-none d-sm-inline ms-1">Add</span>
			</button>
		</div>
		<div class="d-flex flex-wrap align-items-center gap-2 mt-2">
			<label class="btn btn-sm btn-secondary mb-0 @(_attachmentInteropAvailable ? string.Empty : "disabled opacity-50 pe-none")"
				   for="@_fileInputId" title="@GetAttachmentButtonTooltip()">
				<i class="bi bi-paperclip me-1"></i>Attach Files
			</label>
			<input id="@_fileInputId" class="d-none" type="file" multiple @onchange="HandleFileSelection"
				   disabled="@(!_attachmentInteropAvailable)" />
			@if (CanSuggestIdeas)
			{
				<button type="button" class="btn btn-sm btn-secondary" @onclick="OpenSuggestIdeasModal"
						disabled="@(IsSuggestingIdeas || IsProcessingActive)"
						title="@GetSuggestIdeasTooltip()">
					@if (IsSuggestingIdeas)
					{
						<span class="spinner-border spinner-border-sm me-1" role="status"></span>
					}
					else
					{
						<i class="bi bi-stars me-1"></i>
					}
					<span>Suggest Ideas</span>
				</button>
			}
			@if (_pendingAttachments.Any())
			{
				<span class="small text-body-secondary">@GetAttachmentSummary()</span>
			}
		</div>
		@if (_attachmentInteropAvailable)
		{
			<div class="small text-body-secondary mt-2">
				Paste images directly into the idea box to attach them.
			</div>
		}
		@if (_pendingAttachments.Any())
		{
			<div class="d-flex flex-column gap-2 mt-2">
				@foreach (var attachment in _pendingAttachments.Select((item, index) => (item, index)))
				{
					var attachmentIndex = attachment.index;
					<div class="d-flex flex-wrap align-items-center justify-content-between gap-2 border rounded-3 px-2 py-2 bg-body">
						<div class="d-flex align-items-center gap-2 min-width-0">
							@if (TryGetAttachmentPreviewDataUrl(attachment.item, out var previewDataUrl))
							{
								<img src="@previewDataUrl" alt="@attachment.item.FileName" class="rounded border flex-shrink-0"
									 style="width: 3.5rem; height: 3.5rem; object-fit: cover;" />
							}
							else
							{
								<i class="bi bi-paperclip text-body-secondary"></i>
							}
							<div class="d-flex flex-column min-width-0">
								<span class="text-truncate min-width-0">@attachment.item.FileName</span>
								<span class="small text-body-secondary">@FormatAttachmentSize(attachment.item.Content.LongLength)</span>
							</div>
						</div>
						<button type="button" class="btn btn-sm btn-secondary" @onclick="() => RemovePendingAttachment(attachmentIndex)">
							<i class="bi bi-x-lg"></i>
						</button>
					</div>
				}
			</div>
		}
		<div class="d-flex flex-wrap align-items-center gap-2 mt-2 small text-body-secondary">
			<span>@GetIdeaLengthSummary(NewIdeaDescription)</span>
			<span><kbd>Ctrl</kbd>+<kbd>Enter</kbd> to add</span>
			@if (!HasDefaultProvider)
			{
				<a class="btn btn-sm btn-warning ms-auto" href="/providers"
				   title="Set a default provider to enable one-tap idea processing">
					<i class="bi bi-plug me-1"></i>Set default provider
				</a>
			}
		</div>
		@if (!string.IsNullOrWhiteSpace(AddIdeaValidationMessage))
		{
			<div class="text-danger small mt-2">
				<i class="bi bi-exclamation-circle me-1"></i>@AddIdeaValidationMessage
			</div>
		}
	</div>

	@if (!Ideas.Any())
	{
		<EmptyState Icon="lightbulb" Title="No ideas yet"
					Message="Add an idea to build up the project queue." />
	}
	else
	{
		<div class="d-flex flex-wrap justify-content-between align-items-center gap-2">
			<div class="d-flex flex-wrap align-items-center gap-2">
				<h3 class="mb-0 fs-5 fw-semibold">Ideas</h3>
				@if (UnprocessedIdeasCount > 0)
				{
					<span class="badge bg-body-secondary text-body">@UnprocessedIdeasCount pending</span>
				}
			</div>
			@if (IsProcessingActive)
			{
				<button type="button" class="btn btn-sm btn-danger" @onclick="OnStopProcessing"
						disabled="@IsTogglingProcessing" title="Stop automatic idea processing">
					@if (IsTogglingProcessing)
					{
						<span class="spinner-border spinner-border-sm me-1" role="status"></span>
					}
					else
					{
						<i class="bi bi-stop-fill"></i>
					}
					<span class="d-none d-sm-inline ms-1">Stop</span>
				</button>
			}
			else if (TotalIdeasCount >= 1)
			{
				<button type="button" class="btn btn-sm btn-success" @onclick="OpenStartAllModal"
						disabled="@(IsTogglingProcessing || !HasDefaultProvider || UnprocessedIdeasCount == 0)"
						title="@GetStartAllTooltip()">
					@if (IsTogglingProcessing)
					{
						<span class="spinner-border spinner-border-sm me-1" role="status"></span>
					}
					else
					{
						<i class="bi bi-play-fill"></i>
					}
					<span class="d-none d-sm-inline ms-1">Start All</span>
				</button>
			}
		</div>
		<div class="border rounded-3">
			<ul class="list-group list-group-flush rounded-3">
				@foreach (var idea in Ideas)
				{
					<IdeaListItem @key="idea.Id" Idea="idea" IsProcessing="@IsIdeaProcessing(idea.Id)"
							  IsStarting="@(StartingIdeaId == idea.Id)" HasActiveJobs="@HasActiveJobs"
							  HasDefaultProvider="@HasDefaultProvider"
							  IsQueuedForProcessing="@(IsProcessingActive && !idea.IsProcessing && !IsIdeaProcessing(idea.Id) && !idea.JobId.HasValue)"
							  OnExpand="@(() => OpenExpandModal(idea))" OnStart="@(() => StartSingleIdea(idea))"
							  OnCopy="@(() => OpenCopyModal(idea))" OnMove="@(() => OpenMoveModal(idea))"
							  OnDelete="@(() => OnDeleteIdea.InvokeAsync(idea.Id))" OnSaveEdit="HandleIdeaEdit"
							  OnStopJob="@(() => HandleStopJob(idea))" />
				}
			</ul>
		</div>
	}

	<PaginationControls PageNumber="@CurrentPage" PageSize="@PageSize" TotalCount="@TotalIdeasCount"
						IsLoading="@IsPageLoading" OnPreviousPage="OnPreviousPage" OnNextPage="OnNextPage" />
</div>
	@* Copy Idea Modal *@
	<ProjectTransferModal @bind-IsVisible="ShowCopyModal" IdeaDescription="@(SelectedIdea?.Description ?? "")"
						  ExcludeProjectId="@CurrentProjectId" AvailableProjects="@AvailableProjects" IsMove="false"
						  IsProcessing="@IsProcessingAction" OnConfirm="ConfirmCopyIdea" OnCancel="CloseModals" />

	@* Move Idea Modal *@
	<ProjectTransferModal @bind-IsVisible="ShowMoveModal" IdeaDescription="@(SelectedIdea?.Description ?? "")"
						  ExcludeProjectId="@CurrentProjectId" AvailableProjects="@AvailableProjects" IsMove="true"
						  IsProcessing="@IsProcessingAction" OnConfirm="ConfirmMoveIdea" OnCancel="CloseModals" />

	@* Idea Expansion Modal *@
	<IdeaExpansionModal @bind-IsVisible="ShowExpansionModal" Idea="SelectedIdeaForExpansion" IsExpanding="IsExpandingIdea"
						IsProcessing="IsProcessingExpansion" OnExpand="HandleExpandIdea" OnCancel="HandleCancelExpansion"
						OnApprove="HandleApproveExpansion" OnReject="HandleRejectExpansion" AvailableModels="@AvailableLocalModels"
						HasInference="@HasInference" AvailableProviders="@AvailableProviders" />

	@* Start All Confirmation Modal *@
	<ModalDialog @bind-IsVisible="_showStartAllModal" Title="Start All Ideas" Icon="play-fill"
				 Size="ModalDialog.ModalSize.Small">
		<ChildContent>
			<p>
				Start processing <strong>@UnprocessedIdeasCount</strong> idea@(UnprocessedIdeasCount == 1 ? "" : "s")?
				@StartAllDescription
			</p>

				@if (IsGitRepository)
				{
					<div class="mb-2">
						<label for="startAllAutoCommit" class="form-label fw-medium">Auto-Commit Mode</label>
						<select id="startAllAutoCommit" class="form-select" @bind="_startAllAutoCommitMode">
							<option value="@AutoCommitMode.Off">Off - Manual commit required</option>
							<option value="@AutoCommitMode.CommitOnly">Commit Only - Auto-commit after job completion</option>
							<option value="@AutoCommitMode.CommitAndPush">Commit & Push - Auto-commit and push</option>
						</select>
						<div class="form-text">Controls what happens after each job completes.</div>
					</div>
				}

				<div class="mb-2">
					<label for="startAllProvider" class="form-label fw-medium">Provider</label>
					<select id="startAllProvider" class="form-select" @bind="SelectedStartAllProviderIdValue"
							disabled="@(!StartAllProviders.Any())">
						@foreach (var provider in StartAllProviders)
						{
							<option value="@provider.Id">@provider.Name</option>
						}
					</select>
					<div class="form-text">
						Choose which provider queued ideas should use. Defaults to the project's current priority.
					</div>
				</div>

				<div class="mb-0">
					<label for="startAllModel" class="form-label fw-medium">
						Model
						<span class="text-body-secondary fw-normal">(optional)</span>
					</label>
					<select id="startAllModel" class="form-select" @bind="SelectedStartAllModelIdValue"
							disabled="@(!SelectedStartAllProviderId.HasValue || !SelectedStartAllProviderModels.Any())">
						<option value="">Use project/provider default model</option>
						@foreach (var model in SelectedStartAllProviderModels)
						{
							<option value="@model.ModelId">@GetStartAllModelDisplayName(model)</option>
						}
					</select>
					<div class="form-text">
						Leave blank to keep the project's default model for the selected provider.
					</div>
				</div>
			</ChildContent>
			<FooterContent>
				<button type="button" class="btn btn-secondary" @onclick="CloseStartAllModal">Cancel</button>
				<button type="button" class="btn btn-success" @onclick="ConfirmStartAll" disabled="@IsTogglingProcessing">
					@if (IsTogglingProcessing)
					{
						<span class="spinner-border spinner-border-sm me-1" role="status"></span>
					}
					<i class="bi bi-play-fill me-1"></i>Start All
				</button>
			</FooterContent>
		</ModalDialog>

	<SuggestIdeasModal @bind-IsVisible="_showSuggestIdeasModal"
					   UseInference="@_suggestUseInference"
					   UseInferenceChanged="OnSuggestUseInferenceChanged"
					   HasInference="@HasInference"
					   AvailableInferenceProviders="@AvailableInferenceProviders"
					   AvailableProviders="@AvailableProviders"
					   SelectedProviderId="@SelectedSuggestProviderId"
					   SelectedProviderIdChanged="OnSelectedSuggestProviderChanged"
					   SelectedModelId="@SelectedSuggestModelId"
					   SelectedModelIdChanged="OnSelectedSuggestModelChanged"
					   IdeaCount="@_suggestIdeaCount"
					   IdeaCountChanged="OnSuggestIdeaCountChanged"
					   IsProcessing="@IsSuggestingIdeas"
					   OnConfirm="SuggestIdeas"
					   OnCancel="CloseSuggestIdeasModal" />

@code {
	[Parameter]
	public List<Idea> Ideas { get; set; } = new();

	[Parameter]
	public int TotalIdeasCount { get; set; }

	[Parameter]
	public int CurrentPage { get; set; } = 1;

	[Parameter]
	public int PageSize { get; set; } = 10;

	[Parameter]
	public bool IsPageLoading { get; set; }

	[Parameter]
	public Guid CurrentProjectId { get; set; }

	[Parameter]
	public bool IsProcessingActive { get; set; }

	[Parameter]
	public bool IsTogglingProcessing { get; set; }

	[Parameter]
	public bool HasDefaultProvider { get; set; }

	[Parameter]
	public bool HasActiveJobs { get; set; }

	[Parameter]
	public bool IsAddingIdea { get; set; }

	[Parameter]
	public HashSet<Guid> ProcessingIdeaIds { get; set; } = new();

	[Parameter]
	public EventCallback<bool> OnStartProcessing { get; set; }

	[Parameter]
	public EventCallback OnStopProcessing { get; set; }

	[Parameter]
	public EventCallback<CreateIdeaRequest> OnAddIdea { get; set; }

	[Parameter]
	public EventCallback<(Guid IdeaId, string Description)> OnUpdateIdea { get; set; }

	[Parameter]
	public EventCallback<Guid> OnDeleteIdea { get; set; }

	[Parameter]
	public EventCallback<(Guid ideaId, Guid targetProjectId)> OnCopyIdea { get; set; }

	[Parameter]
	public EventCallback<(Guid ideaId, Guid targetProjectId)> OnMoveIdea { get; set; }

	[Parameter]
	public EventCallback<Guid> OnStartSingleIdea { get; set; }

	[Parameter]
	public EventCallback<(Guid ideaId, IdeaExpansionRequest request)> OnExpandIdea { get; set; }

	[Parameter]
	public EventCallback<Guid> OnCancelExpansion { get; set; }

	[Parameter]
	public EventCallback<(Guid ideaId, string? editedDescription)> OnApproveExpansion { get; set; }

	[Parameter]
	public EventCallback<Guid> OnRejectExpansion { get; set; }

	[Parameter]
	public EventCallback OnSuggestIdeas { get; set; }

	[Parameter]
	public EventCallback OnPreviousPage { get; set; }

	[Parameter]
	public EventCallback OnNextPage { get; set; }

	[Parameter]
	public AutoCommitMode CurrentAutoCommitMode { get; set; } = AutoCommitMode.Off;

	[Parameter]
	public bool IsGitRepository { get; set; }

	[Parameter]
	public EventCallback<IdeaProcessingOptions> OnStartProcessingWithOptions { get; set; }

	[Parameter]
	public List<DiscoveredModel> AvailableLocalModels { get; set; } = new();

	[Parameter]
	public bool HasInference { get; set; }

	[Parameter]
	public List<Provider> AvailableProviders { get; set; } = new();

	[Parameter]
	public Guid? DefaultProcessingProviderId { get; set; }

	[Parameter]
	public string? DefaultProcessingModelId { get; set; }

	[Parameter]
	public List<InferenceProvider> AvailableInferenceProviders { get; set; } = new();

	[Parameter]
	public Guid? DefaultInferenceProviderId { get; set; }

	[Parameter]
	public string? DefaultInferenceModelId { get; set; }

	private ElementReference _newIdeaTextarea;
	private const string IdeaDraftStorageKeyPrefix = "vibeswarm.idea-draft";
	private readonly string _fileInputId = $"idea-files-{Guid.NewGuid():N}";
	private readonly string _textareaId = $"idea-textarea-{Guid.NewGuid():N}";
	private string NewIdeaDescription { get; set; } = string.Empty;
	private string? _savedDraftDescription;
	private List<IdeaAttachmentUpload> _pendingAttachments = [];
	private bool _attachmentInteropAvailable = true;
	private bool _pasteTargetRegistered;
	private DotNetObjectReference<IdeasPanel>? _dotNetReference;
	private Guid? StartingIdeaId { get; set; }
	private bool IsSuggestingIdeas { get; set; }
	private SuggestIdeasResult? _suggestResult;
	private bool _showSuggestIdeasModal;
	private bool _suggestUseInference = true;
	private Guid? _selectedInferenceProviderId;
	private string? _selectedInferenceModelId;
	private Guid? _selectedConfiguredProviderId;
	private string? _selectedConfiguredModelId;
	private int _suggestIdeaCount = SuggestIdeasRequest.DefaultIdeaCount;

	// Start All confirmation modal state
	private bool _showStartAllModal { get; set; }
	private AutoCommitMode _startAllAutoCommitMode { get; set; }
	private Guid? _selectedStartAllProviderId;
	private string? _selectedStartAllModelId;

	// Modal state
	private bool ShowCopyModal { get; set; }
	private bool ShowMoveModal { get; set; }
	private bool ShowExpansionModal { get; set; }
	private Idea? SelectedIdea { get; set; }
	private Idea? SelectedIdeaForExpansion { get; set; }
	private List<Project> AvailableProjects { get; set; } = new();
	private bool IsProcessingAction { get; set; }
	private bool IsExpandingIdea { get; set; }
	private bool IsProcessingExpansion { get; set; }

	private async Task HandleKeyPress(KeyboardEventArgs e)
	{
		if (e.Key == "Enter" && e.CtrlKey && !string.IsNullOrWhiteSpace(NewIdeaDescription))
		{
			await AddIdea();
		}
	}

	private async Task HandleNewIdeaInput(ChangeEventArgs e)
	{
		NewIdeaDescription = e.Value?.ToString() ?? string.Empty;
		await PersistDraftAsync();
	}

	private bool _isSubmitting;
	private string? AddIdeaValidationMessage => ValidateAddIdeaInput();
	private bool CanAddIdea => string.IsNullOrWhiteSpace(AddIdeaValidationMessage) &&
		!string.IsNullOrWhiteSpace(NewIdeaDescription) &&
		!IsAddingIdea &&
		!_isSubmitting;

	private async Task AddIdea()
	{
		if (_isSubmitting)
		{
			return;
		}

		if (!CanAddIdea)
		{
			if (!string.IsNullOrWhiteSpace(AddIdeaValidationMessage))
			{
				NotificationService.ShowWarning(AddIdeaValidationMessage, "Idea Validation");
			}
			return;
		}

		_isSubmitting = true;
		try
		{
			await OnAddIdea.InvokeAsync(new CreateIdeaRequest
			{
				ProjectId = CurrentProjectId,
				Description = NewIdeaDescription.Trim(),
				Attachments = _pendingAttachments
					.Select(attachment => new IdeaAttachmentUpload
					{
						FileName = attachment.FileName,
						ContentType = attachment.ContentType,
						Content = attachment.Content
					})
					.ToList()
			});
			NewIdeaDescription = string.Empty;
			_pendingAttachments.Clear();
			await ClearDraftAsync();
		}
		finally { _isSubmitting = false; }
	}

	private async Task HandleStopJob(Idea idea)
	{
		if (!idea.JobId.HasValue) return;
		try
		{
			await JobService.RequestCancellationAsync(idea.JobId.Value);
		}
		catch (Exception ex)
		{
			NotificationService.ShowError($"Error stopping job: {ex.Message}");
		}
	}

	private async Task HandleIdeaEdit((Guid IdeaId, string Description) update)
	{
		await OnUpdateIdea.InvokeAsync(update);
	}

	private async Task OpenCopyModal(Idea idea)
	{
		SelectedIdea = idea;
		await LoadAvailableProjects();
		ShowCopyModal = true;
	}

	private async Task OpenMoveModal(Idea idea)
	{
		SelectedIdea = idea;
		await LoadAvailableProjects();
		ShowMoveModal = true;
	}

	private async Task LoadAvailableProjects()
	{
		try
		{
			AvailableProjects = (await ProjectService.GetAllAsync()).ToList();
		}
		catch
		{
			AvailableProjects = new List<Project>();
		}
	}

	private void CloseModals()
	{
		ShowCopyModal = false;
		ShowMoveModal = false;
		SelectedIdea = null;
	}

	private async Task ConfirmCopyIdea(Guid targetProjectId)
	{
		if (SelectedIdea == null) return;

		IsProcessingAction = true;
		try
		{
			await OnCopyIdea.InvokeAsync((SelectedIdea.Id, targetProjectId));
			CloseModals();
		}
		finally
		{
			IsProcessingAction = false;
		}
	}

	private async Task ConfirmMoveIdea(Guid targetProjectId)
	{
		if (SelectedIdea == null) return;

		IsProcessingAction = true;
		try
		{
			await OnMoveIdea.InvokeAsync((SelectedIdea.Id, targetProjectId));
			CloseModals();
		}
		finally
		{
			IsProcessingAction = false;
		}
	}

	private async Task StartSingleIdea(Idea idea)
	{
		// Set the starting ID to show spinner immediately
		StartingIdeaId = idea.Id;
		StateHasChanged();

		try
		{
			// The parent component handles adding to ProcessingIdeaIds and calling the API
			await OnStartSingleIdea.InvokeAsync(idea.Id);
		}
		finally
		{
			StartingIdeaId = null;
			StateHasChanged();
		}
	}

	private bool IsIdeaProcessing(Guid ideaId) => ProcessingIdeaIds.Contains(ideaId);

	private void OpenExpandModal(Idea idea)
	{
		SelectedIdeaForExpansion = idea;
		ShowExpansionModal = true;
	}

	private async Task HandleExpandIdea(IdeaExpansionRequest request)
	{
		if (SelectedIdeaForExpansion == null) return;

		IsExpandingIdea = true;
		StateHasChanged();

		try
		{
			await OnExpandIdea.InvokeAsync((SelectedIdeaForExpansion.Id, request));
			var updated = Ideas.FirstOrDefault(i => i.Id == SelectedIdeaForExpansion.Id);
			if (updated != null)
			{
				SelectedIdeaForExpansion = updated;
			}
		}
		finally
		{
			IsExpandingIdea = false;
			StateHasChanged();
		}
	}

	private async Task HandleCancelExpansion()
	{
		var ideaId = SelectedIdeaForExpansion?.Id;
		if (ideaId == null) return;

		try
		{
			await OnCancelExpansion.InvokeAsync(ideaId.Value);
			var updated = Ideas.FirstOrDefault(i => i.Id == ideaId.Value);
			if (updated != null)
			{
				SelectedIdeaForExpansion = updated;
			}
		}
		finally
		{
			IsExpandingIdea = false;
			StateHasChanged();
		}
	}

	private async Task HandleApproveExpansion((Guid ideaId, string? editedDescription) args)
	{
		IsProcessingExpansion = true;
		StateHasChanged();

		try
		{
			await OnApproveExpansion.InvokeAsync(args);
		}
		finally
		{
			IsProcessingExpansion = false;
			ShowExpansionModal = false;
			SelectedIdeaForExpansion = null;
			StateHasChanged();
		}
	}

	private async Task HandleRejectExpansion(Guid ideaId)
	{
		IsProcessingExpansion = true;
		StateHasChanged();

		try
		{
			await OnRejectExpansion.InvokeAsync(ideaId);
			var updated = Ideas.FirstOrDefault(i => i.Id == ideaId);
			if (updated != null)
			{
				SelectedIdeaForExpansion = updated;
			}
		}
		finally
		{
			IsProcessingExpansion = false;
			StateHasChanged();
		}
	}

