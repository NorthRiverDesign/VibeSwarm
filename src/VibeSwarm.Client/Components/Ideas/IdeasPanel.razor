	private void OpenSuggestIdeasModal()
	{
		if (!CanSuggestIdeas)
		{
			NotificationService.ShowWarning(
				"No enabled suggestion sources are available. Add one under Settings → Providers or Settings → Inference before suggesting ideas.",
				"Suggestion Source Required");
			return;
		}

		if (_suggestUseInference && !HasInference && AvailableProviders.Any())
		{
			_suggestUseInference = false;
		}
		else if (!_suggestUseInference && !AvailableProviders.Any() && HasInference)
		{
			_suggestUseInference = true;
		}

		EnsureSuggestProviderSelection();
		_suggestIdeaCount = Math.Clamp(_suggestIdeaCount, SuggestIdeasRequest.MinIdeaCount, SuggestIdeasRequest.MaxIdeaCount);
		_showSuggestIdeasModal = true;
	}

	private void CloseSuggestIdeasModal()
	{
		_showSuggestIdeasModal = false;
	}

	private Task OnSuggestUseInferenceChanged(bool useInference)
	{
		_suggestUseInference = useInference;
		EnsureSuggestProviderSelection();
		return Task.CompletedTask;
	}

	private Task OnSelectedSuggestProviderChanged(Guid? providerId)
	{
		if (_suggestUseInference)
		{
			_selectedInferenceProviderId = providerId;
		}
		else
		{
			_selectedConfiguredProviderId = providerId;
		}

		return OnSelectedSuggestModelChanged(null);
	}

	private Task OnSelectedSuggestModelChanged(string? modelId)
	{
		var normalizedModelId = string.IsNullOrWhiteSpace(modelId)
			? null
			: modelId.Trim();

		if (_suggestUseInference)
		{
			_selectedInferenceModelId = normalizedModelId;
		}
		else
		{
			_selectedConfiguredModelId = normalizedModelId;
		}

		return Task.CompletedTask;
	}

	private Task OnSuggestIdeaCountChanged(int ideaCount)
	{
		_suggestIdeaCount = Math.Clamp(ideaCount, SuggestIdeasRequest.MinIdeaCount, SuggestIdeasRequest.MaxIdeaCount);
		return Task.CompletedTask;
	}

	private async Task SuggestIdeas()
	{
		if (!SelectedSuggestProviderId.HasValue)
		{
			NotificationService.ShowWarning(
				_suggestUseInference
					? "Choose an inference provider before generating ideas."
					: "Choose a provider before generating ideas.",
				"Provider Required");
			return;
		}

		IsSuggestingIdeas = true;
		_showSuggestIdeasModal = false;
		_suggestResult = null;
		StateHasChanged();

		try
		{
			var result = await IdeaService.SuggestIdeasFromCodebaseAsync(CurrentProjectId, new SuggestIdeasRequest
			{
				UseInference = _suggestUseInference,
				ProviderId = SelectedSuggestProviderId,
				ModelId = SelectedSuggestModelId,
				IdeaCount = _suggestIdeaCount
			});
			_suggestResult = result;

			if (result.Success)
			{
				// Tell the parent to reload the ideas list so the new suggestions appear
				await OnSuggestIdeas.InvokeAsync();

				var durationHint = result.InferenceDurationMs.HasValue
					? $" ({result.InferenceDurationMs.Value / 1000.0:F1}s)"
					: string.Empty;
				var modelHint = !string.IsNullOrEmpty(result.ModelUsed)
					? $" via {result.ModelUsed}"
					: string.Empty;
				NotificationService.ShowSuccess(
					$"{result.Ideas.Count} idea{(result.Ideas.Count == 1 ? "" : "s")} added{modelHint}{durationHint}.",
					"Suggestions Ready");
			}
			else
			{
				var title = result.Stage switch
				{
					SuggestIdeasStage.NotConfigured => _suggestUseInference ? "Inference Not Configured" : "Provider Not Configured",
					SuggestIdeasStage.ProviderNotFound => "Provider Unavailable",
					SuggestIdeasStage.ModelNotFound => "Model Unavailable",
					SuggestIdeasStage.ProviderUnreachable => "Provider Unreachable",
					SuggestIdeasStage.NoModel => "No Model Assigned",
					SuggestIdeasStage.RepoMapFailed => "Directory Scan Failed",
					SuggestIdeasStage.GenerateFailed => _suggestUseInference ? "Inference Failed" : "Provider Failed",
					SuggestIdeasStage.ParseFailed => "Unexpected Response",
					_ => "Suggestion Failed"
				};
				NotificationService.ShowWarning(result.Message, title);
			}
		}
		catch (OperationCanceledException)
		{
			// User navigated away — don't show any feedback
		}
		catch (Exception ex)
		{
			Console.Error.WriteLine($"[IdeasPanel.SuggestIdeas] Unexpected error: {ex}");
			_suggestResult = new SuggestIdeasResult
			{
				Stage = SuggestIdeasStage.GenerateFailed,
				Message = $"Unexpected error: {ex.Message}"
			};
			NotificationService.ShowError($"Error generating suggestions: {ex.Message}");
		}
		finally
		{
			IsSuggestingIdeas = false;
			StateHasChanged();
		}
	}

	private void OpenStartAllModal()
	{
		_startAllAutoCommitMode = CurrentAutoCommitMode;
		_selectedStartAllProviderId = StartAllProviders.Any(provider => provider.Id == DefaultProcessingProviderId)
			? DefaultProcessingProviderId
			: StartAllProviders.Select(provider => (Guid?)provider.Id).FirstOrDefault();
		_selectedStartAllModelId = _selectedStartAllProviderId == DefaultProcessingProviderId && !string.IsNullOrWhiteSpace(DefaultProcessingModelId)
			? DefaultProcessingModelId
			: null;
		ResetStartAllModelIfUnavailable();
		_showStartAllModal = true;
	}

	private void CloseStartAllModal()
	{
		_showStartAllModal = false;
	}

	private async Task ConfirmStartAll()
	{
		_showStartAllModal = false;
		await OnStartProcessingWithOptions.InvokeAsync(new IdeaProcessingOptions
		{
			AutoCommitMode = _startAllAutoCommitMode,
			ProviderId = _selectedStartAllProviderId,
			ModelId = _selectedStartAllModelId
		});
	}

	private void EnsureSuggestProviderSelection()
	{
		if (_suggestUseInference)
		{
			// Prefer the project's configured inference provider, then fall back to the first available
			_selectedInferenceProviderId ??= (DefaultInferenceProviderId.HasValue
				&& AvailableInferenceProviders.Any(p => p.Id == DefaultInferenceProviderId.Value))
				? DefaultInferenceProviderId
				: AvailableInferenceProviders
					.OrderBy(provider => provider.Name)
					.Select(provider => (Guid?)provider.Id)
					.FirstOrDefault();

			// Apply the project's default model when the project's provider was selected
			if (_selectedInferenceProviderId == DefaultInferenceProviderId
				&& _selectedInferenceModelId == null
				&& !string.IsNullOrWhiteSpace(DefaultInferenceModelId))
			{
				_selectedInferenceModelId = DefaultInferenceModelId;
			}
			return;
		}

		_selectedConfiguredProviderId ??= AvailableProviders
			.OrderBy(provider => provider.Name)
			.Select(provider => (Guid?)provider.Id)
			.FirstOrDefault();
	}

	private void ResetStartAllModelIfUnavailable()
	{
		var validModelIds = SelectedStartAllProviderModels
			.Select(model => model.ModelId)
			.ToHashSet(StringComparer.Ordinal);

		if (!string.IsNullOrWhiteSpace(_selectedStartAllModelId) && !validModelIds.Contains(_selectedStartAllModelId))
		{
			_selectedStartAllModelId = null;
		}
	}

	private static string GetStartAllModelDisplayName(ProviderModel model)
	{
		var label = model.DisplayName ?? model.ModelId;
		return model.IsDefault
			? $"{label} (Default)"
			: label;
	}

	public async ValueTask DisposeAsync()
	{
		if (_pasteTargetRegistered)
		{
			try
			{
				await JSRuntime.InvokeVoidAsync("vibeSwarmIdeas.unregisterPasteTarget", _textareaId);
			}
			catch (JSException)
			{
			}
			catch (InvalidOperationException)
			{
			}
			catch (OperationCanceledException)
			{
			}
		}

		_dotNetReference?.Dispose();
		_dotNetReference = null;
		_pasteTargetRegistered = false;
	}
