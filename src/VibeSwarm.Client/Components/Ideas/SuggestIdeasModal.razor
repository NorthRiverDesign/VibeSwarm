
<ModalDialog IsVisible="IsVisible" IsVisibleChanged="HandleVisibilityChanged" Title="Suggest Ideas" Icon="stars"
			 Size="ModalDialog.ModalSize.Small" OnClose="HandleCancel">
	<ChildContent>
		<p class="text-body-secondary mb-3">
			Choose how to analyze the current codebase, then generate a short list of actionable ideas.
		</p>

		@if (!HasAnySuggestionSource)
		{
			<Alert Type="Alert.AlertType.Warning"
				   Message="No enabled suggestion sources are available. Configure a provider under Settings → Providers or Settings → Inference before suggesting ideas." />
		}
		else
		{
			@if (HasInference && HasConfiguredProviders)
			{
				<div class="form-check form-switch mb-3">
					<input class="form-check-input" type="checkbox" id="useInferenceForSuggestions" checked="@UseInference"
						   @onchange="HandleToggleInference">
					<label class="form-check-label" for="useInferenceForSuggestions">
						<i class="bi @(UseInference ? "bi-pc-display" : "bi-cloud") me-1"></i>
						@(UseInference ? "Use inference" : "Use configured provider")
					</label>
				</div>
			}

			<div class="mb-3">
				<label for="suggestIdeasProvider" class="form-label fw-medium">@GetProviderLabel()</label>
				<select id="suggestIdeasProvider" class="form-select" @bind="SelectedProviderIdValue"
						disabled="@(!CurrentProviders.Any())">
					@foreach (var provider in CurrentProviders.OrderBy(provider => provider.Name))
					{
						<option value="@provider.Id">@provider.Name</option>
					}
				</select>
				@if (!CurrentProviders.Any())
				{
					<div class="form-text">
						@(UseInference
							? "Add an enabled inference provider under Settings → Inference."
							: "Add an enabled provider under Settings → Providers.")
					</div>
				}
			</div>

			<div class="mb-3">
				<label for="suggestIdeasModel" class="form-label fw-medium">
					Model
					<span class="text-body-secondary fw-normal">(optional)</span>
				</label>
				<select id="suggestIdeasModel" class="form-select" @bind="SelectedModelIdValue"
						disabled="@(!SelectedProviderId.HasValue || !SelectedProviderModels.Any())">
					<option value="">Use provider default model</option>
					@foreach (var model in SelectedProviderModels)
					{
						<option value="@model.ModelId">@model.DisplayName</option>
					}
				</select>
				<div class="form-text">@GetModelHelpText()</div>
			</div>

			<div>
				<label for="suggestIdeasCount" class="form-label fw-medium">Ideas to Generate</label>
				<select id="suggestIdeasCount" class="form-select" @bind="IdeaCountValue">
					@for (var count = SuggestIdeasRequest.MinIdeaCount; count <= SuggestIdeasRequest.MaxIdeaCount; count++)
					{
						<option value="@count">@count</option>
					}
				</select>
			</div>
		}
	</ChildContent>

	<FooterContent>
		<button type="button" class="btn btn-secondary" @onclick="HandleCancel">Cancel</button>
		<button type="button" class="btn btn-primary" @onclick="HandleConfirm" disabled="@(IsProcessing || !CanConfirm)">
			@if (IsProcessing)
			{
				<span class="spinner-border spinner-border-sm me-1" role="status"></span>
			}
			<i class="bi bi-stars me-1"></i>Generate Ideas
		</button>
	</FooterContent>
</ModalDialog>

@code {
	[Parameter]
	public bool IsVisible { get; set; }

	[Parameter]
	public EventCallback<bool> IsVisibleChanged { get; set; }

	[Parameter]
	public bool UseInference { get; set; } = true;

	[Parameter]
	public EventCallback<bool> UseInferenceChanged { get; set; }

	[Parameter]
	public bool HasInference { get; set; }

	[Parameter]
	public List<InferenceProvider> AvailableInferenceProviders { get; set; } = new();

	[Parameter]
	public List<Provider> AvailableProviders { get; set; } = new();

	[Parameter]
	public Guid? SelectedProviderId { get; set; }

	[Parameter]
	public EventCallback<Guid?> SelectedProviderIdChanged { get; set; }

	[Parameter]
	public string? SelectedModelId { get; set; }

	[Parameter]
	public EventCallback<string?> SelectedModelIdChanged { get; set; }

	[Parameter]
	public int IdeaCount { get; set; } = SuggestIdeasRequest.DefaultIdeaCount;

	[Parameter]
	public EventCallback<int> IdeaCountChanged { get; set; }

	[Parameter]
	public bool IsProcessing { get; set; }

	[Parameter]
	public EventCallback OnConfirm { get; set; }

	[Parameter]
	public EventCallback OnCancel { get; set; }

	private bool HasConfiguredProviders => AvailableProviders.Any();
	private bool HasAnySuggestionSource => HasInference || HasConfiguredProviders;
	private bool CanConfirm => CurrentProviders.Any() && SelectedProviderId.HasValue;

	private IReadOnlyList<SuggestionProviderOption> CurrentProviders => UseInference
		? AvailableInferenceProviders
			.OrderBy(provider => provider.Name)
			.Select(provider => new SuggestionProviderOption(
				provider.Id,
				provider.Name,
				provider.Models
					.Where(model => model.IsAvailable)
					.Select(model => new SuggestionModelOption(
						model.ModelId,
						GetInferenceModelDisplayName(model),
						model.IsDefault))
					.OrderByDescending(model => model.IsDefault)
					.ThenBy(model => model.DisplayName)
					.ToList()))
			.ToList()
		: AvailableProviders
			.OrderBy(provider => provider.Name)
			.Select(provider => new SuggestionProviderOption(
				provider.Id,
				provider.Name,
				provider.AvailableModels
					.Where(model => model.IsAvailable)
					.Select(model => new SuggestionModelOption(
						model.ModelId,
						GetProviderModelDisplayName(model),
						model.IsDefault))
					.OrderByDescending(model => model.IsDefault)
					.ThenBy(model => model.DisplayName)
					.ToList()))
			.ToList();

	private IReadOnlyList<SuggestionModelOption> SelectedProviderModels => CurrentProviders
		.FirstOrDefault(provider => provider.Id == SelectedProviderId)?
		.Models ?? [];

	private string SelectedProviderIdValue
	{
		get => SelectedProviderId?.ToString() ?? string.Empty;
		set
		{
			Guid? providerId = Guid.TryParse(value, out var parsed) ? parsed : null;
			if (SelectedProviderId != providerId)
			{
				SelectedProviderId = providerId;
				_ = SelectedProviderIdChanged.InvokeAsync(providerId);
			}

			ResetSelectedModelIfUnavailable();
		}
	}

	private string SelectedModelIdValue
	{
		get => SelectedModelId ?? string.Empty;
		set
		{
			var normalizedModelId = string.IsNullOrWhiteSpace(value) ? null : value.Trim();
			if (!string.Equals(SelectedModelId, normalizedModelId, StringComparison.Ordinal))
			{
				SelectedModelId = normalizedModelId;
				_ = SelectedModelIdChanged.InvokeAsync(normalizedModelId);
			}
		}
	}

	private int IdeaCountValue
	{
		get => IdeaCount;
		set
		{
			var normalizedCount = Math.Clamp(value, SuggestIdeasRequest.MinIdeaCount, SuggestIdeasRequest.MaxIdeaCount);
			if (IdeaCount != normalizedCount)
			{
				IdeaCount = normalizedCount;
				_ = IdeaCountChanged.InvokeAsync(normalizedCount);
			}
		}
	}

	protected override async Task OnParametersSetAsync()
	{
		var normalizedCount = Math.Clamp(IdeaCount, SuggestIdeasRequest.MinIdeaCount, SuggestIdeasRequest.MaxIdeaCount);
		if (normalizedCount != IdeaCount)
		{
			IdeaCount = normalizedCount;
			await IdeaCountChanged.InvokeAsync(IdeaCount);
		}

		if (UseInference && !HasInference && HasConfiguredProviders)
		{
			UseInference = false;
			await UseInferenceChanged.InvokeAsync(false);
		}
		else if (!UseInference && !HasConfiguredProviders && HasInference)
		{
			UseInference = true;
			await UseInferenceChanged.InvokeAsync(true);
		}

		await EnsureValidProviderSelectionAsync();
		await ResetSelectedModelIfUnavailableAsync();
	}

	private async Task HandleVisibilityChanged(bool visible)
	{
		IsVisible = visible;
		await IsVisibleChanged.InvokeAsync(visible);
	}

	private async Task HandleConfirm()
	{
		if (!CanConfirm)
		{
			return;
		}

		await OnConfirm.InvokeAsync();
	}

	private async Task HandleCancel()
	{
		await IsVisibleChanged.InvokeAsync(false);
		await OnCancel.InvokeAsync();
	}

	private async Task HandleToggleInference(ChangeEventArgs e)
	{
		var useInference = e.Value is bool value && value;
		if (UseInference == useInference)
		{
			return;
		}

		UseInference = useInference;
		SelectedProviderId = null;
		SelectedModelId = null;

		await UseInferenceChanged.InvokeAsync(useInference);
		await SelectedProviderIdChanged.InvokeAsync(null);
		await SelectedModelIdChanged.InvokeAsync(null);
		await EnsureValidProviderSelectionAsync();
	}

	private async Task EnsureValidProviderSelectionAsync()
	{
		if (CurrentProviders.Any() && (!SelectedProviderId.HasValue || CurrentProviders.All(provider => provider.Id != SelectedProviderId.Value)))
		{
			SelectedProviderId = CurrentProviders
				.Select(provider => (Guid?)provider.Id)
				.FirstOrDefault();
			await SelectedProviderIdChanged.InvokeAsync(SelectedProviderId);
		}
	}

	private void ResetSelectedModelIfUnavailable()
	{
		var validModelIds = SelectedProviderModels
			.Select(model => model.ModelId)
			.ToHashSet(StringComparer.Ordinal);

		if (!string.IsNullOrWhiteSpace(SelectedModelId) && !validModelIds.Contains(SelectedModelId))
		{
			SelectedModelId = null;
			_ = SelectedModelIdChanged.InvokeAsync(null);
		}
	}

	private async Task ResetSelectedModelIfUnavailableAsync()
	{
		var validModelIds = SelectedProviderModels
			.Select(model => model.ModelId)
			.ToHashSet(StringComparer.Ordinal);

		if (!string.IsNullOrWhiteSpace(SelectedModelId) && !validModelIds.Contains(SelectedModelId))
		{
			SelectedModelId = null;
			await SelectedModelIdChanged.InvokeAsync(null);
		}
	}

	private string GetProviderLabel() => UseInference ? "Inference Provider" : "Configured Provider";

	private string GetModelHelpText()
	{
		if (!SelectedProviderId.HasValue)
		{
			return UseInference
				? "Choose an inference provider to browse any cached models."
				: "Choose a configured provider to browse any cached models.";
		}

		if (!SelectedProviderModels.Any())
		{
			return UseInference
				? "No cached models were found for this inference provider yet. Its configured suggest/default model will be used if available."
				: "No cached models were found for this provider yet. Its default CLI model will be used.";
		}

		return UseInference
			? "Leave this blank to use the provider's configured suggest model first, then its default model."
			: "Leave this blank to use the provider's default model selection.";
	}

	private static string GetInferenceModelDisplayName(InferenceModel model)
	{
		var label = model.DisplayName ?? model.ModelId;
		return model.IsDefault
			? $"{label} (Default)"
			: label;
	}

	private static string GetProviderModelDisplayName(ProviderModel model)
	{
		var label = model.DisplayName ?? model.ModelId;
		return model.IsDefault
			? $"{label} (Default)"
			: label;
	}

	private sealed record SuggestionProviderOption(Guid Id, string Name, IReadOnlyList<SuggestionModelOption> Models);

	private sealed record SuggestionModelOption(string ModelId, string DisplayName, bool IsDefault);
}
