@* Job list item component for inbox-style CI/CD pipeline layout *@

<div class="job-list-item p-3 border-bottom cursor-pointer touch-manipulation @(_isSelected ? "job-selected" : "")"
	 role="button"
	 tabindex="0"
	 aria-label="@Prompt"
	 @onclick="HandleClick"
	 @onkeydown="HandleKeyDown">
    <div class="d-flex align-items-start gap-3">
        @* Status Icon Column *@
        <div class="d-flex align-items-center justify-content-center flex-shrink-0" style="width: 24px; min-width: 24px;">
            @switch (Status.ToLowerInvariant())
            {
                case "new":
                case "pending":
                    <i class="bi bi-clock text-secondary fs-5" title="Pending"></i>
                    break;
                case "started":
                case "planning":
                case "processing":
                    <div class="spinner-border spinner-border-sm text-info" role="status" title="Running">
                        <span class="visually-hidden">Running...</span>
                    </div>
                    break;
                case "completed":
                    <i class="bi bi-check-circle-fill text-success fs-5" title="Completed"></i>
                    break;
                case "failed":
                    <i class="bi bi-x-circle-fill text-danger fs-5" title="Failed"></i>
                    break;
                case "cancelled":
                    <i class="bi bi-slash-circle text-secondary fs-5" title="Cancelled"></i>
                    break;
                case "stalled":
                    <i class="bi bi-exclamation-triangle-fill text-warning fs-5" title="Stalled"></i>
                    break;
                case "paused":
                    <i class="bi bi-pause-circle-fill text-warning fs-5" title="Paused"></i>
                    break;
                default:
                    <i class="bi bi-question-circle text-secondary fs-5"></i>
                    break;
            }
        </div>

        @* Main Content *@
        <div class="flex-grow-1 min-width-0">
            @* Goal Prompt *@
            <div class="mb-1 text-break lh-sm">
                <span class="@(IsActiveStatus() ? "fw-semibold" : "")">@TruncateText(Prompt, 150)</span>
            </div>

            @* Meta info row *@
            <div class="d-flex flex-wrap align-items-center gap-2 small text-body-secondary">
                @if (!string.IsNullOrEmpty(ProjectName) && ShowProjectName)
                {
                    <span class="fw-medium">@ProjectName</span>
                }
                @if (!string.IsNullOrEmpty(AgentName))
                {
                    <span class="d-inline-flex align-items-center gap-1 px-2 py-1 bg-primary-subtle text-primary-emphasis rounded-pill"
                          title="Team swarm role">
                        <i class="bi bi-diagram-3 opacity-75"></i>
                        <span>@AgentName</span>
                    </span>
                }
                @if (MaxCycles > 1)
                {
                    <span title="@GetCycleModeTitle()">
                        <i class="bi bi-arrow-repeat me-1 opacity-75"></i>@CurrentCycle/@MaxCycles
                    </span>
                }
                @if (!string.IsNullOrEmpty(Activity) && IsActiveStatus())
                {
                    <span class="text-info fst-italic text-truncate" style="max-width: min(200px, 40vw);">@Activity</span>
                }
            </div>

    			<JobOutcomeBadges Status="@ParsedStatus"
    							  ChangedFilesCount="@ChangedFilesCount"
    							  BuildVerified="@BuildVerified"
    							  BuildVerificationEnabled="@BuildVerificationEnabled"
    							  IsPushed="@IsPushed"
    							  GitCommitHash="@GitCommitHash"
    							  PullRequestUrl="@PullRequestUrl"
  							  PullRequestNumber="@PullRequestNumber"
							  MergedAt="@MergedAt" />
 
			<JobOutcomeHint Status="@ParsedStatus"
							ChangedFilesCount="@ChangedFilesCount"
							BuildVerified="@BuildVerified"
							BuildVerificationEnabled="@BuildVerificationEnabled"
							IsPushed="@IsPushed"
							GitCommitHash="@GitCommitHash"
							PullRequestUrl="@PullRequestUrl"
							PullRequestNumber="@PullRequestNumber"
							MergedAt="@MergedAt" />

			<JobOutcomeSummarySnippet SessionSummary="@SessionSummary" />

             @* Time display *@
             @if (!string.IsNullOrEmpty(TimeDisplay))
             {
                <div class="small text-body-tertiary mt-1">@TimeDisplay</div>
            }
        </div>

        @* Right Column - Tokens, Cost (no time here) *@
        <div class="job-stats d-none d-sm-flex flex-column align-items-end gap-1 flex-shrink-0 text-end">
            @* Token info *@
            @if (InputTokens.HasValue || OutputTokens.HasValue)
            {
                <span class="font-monospace small text-body-secondary" title="Input / Output tokens">
                    @TokenHelper.FormatTokenCount(InputTokens ?? 0) / @TokenHelper.FormatTokenCount(OutputTokens ?? 0)
                </span>
            }
            @* Cost *@
            @if (Cost.HasValue && Cost.Value > 0)
            {
                <span class="font-monospace small fw-medium text-success">@TokenHelper.FormatCost(Cost.Value)</span>
            }
        </div>
    </div>

    @* Footer row - Mobile token stats *@
    <div class="d-sm-none d-flex align-items-center gap-2 small text-body-secondary mt-2 ps-4 ms-2">
        @if (InputTokens.HasValue || OutputTokens.HasValue || Cost.HasValue)
        {
            <span class="font-monospace">
                @TokenHelper.FormatTokenCount((InputTokens ?? 0) + (OutputTokens ?? 0)) tokens
                @if (Cost.HasValue && Cost.Value > 0)
                {
                    <span class="text-success ms-1">@TokenHelper.FormatCost(Cost.Value)</span>
                }
            </span>
        }
    </div>
</div>

@code {
    [Parameter]
    public string Status { get; set; } = string.Empty;

    [Parameter]
    public string Prompt { get; set; } = string.Empty;

    [Parameter]
    public string? ProjectName { get; set; }

    [Parameter]
    public bool ShowProjectName { get; set; } = true;

	[Parameter]
	public string? ModelUsed { get; set; }

	[Parameter]
	public string? PlanningProviderName { get; set; }

	[Parameter]
	public string? PlanningModelUsed { get; set; }

    [Parameter]
    public string? ProviderName { get; set; }

    [Parameter]
    public string? Activity { get; set; }

    [Parameter]
    public string TimeDisplay { get; set; } = string.Empty;

    [Parameter]
    public decimal? Cost { get; set; }

    [Parameter]
    public int? InputTokens { get; set; }

    [Parameter]
    public int? OutputTokens { get; set; }

    [Parameter]
    public bool IsSelected { get; set; }

    [Parameter]
    public EventCallback OnClick { get; set; }

    [Parameter]
    public int CurrentCycle { get; set; } = 1;

    [Parameter]
    public int MaxCycles { get; set; } = 1;

    [Parameter]
    public CycleMode CycleMode { get; set; } = CycleMode.SingleCycle;

    [Parameter]
    public string? AgentName { get; set; }

    [Parameter]
    public bool PlaywrightEnabled { get; set; }

    [Parameter]
    public int EnvironmentCount { get; set; }

	[Parameter]
	public int? ChangedFilesCount { get; set; }

	[Parameter]
	public bool? BuildVerified { get; set; }

	[Parameter]
	public bool BuildVerificationEnabled { get; set; }

	[Parameter]
	public bool IsPushed { get; set; }

	[Parameter]
	public string? GitCommitHash { get; set; }

	[Parameter]
	public string? PullRequestUrl { get; set; }

	[Parameter]
	public int? PullRequestNumber { get; set; }

	[Parameter]
	public DateTime? MergedAt { get; set; }

	[Parameter]
	public string? SessionSummary { get; set; }

    private bool _isSelected => IsSelected;

	private string? ProviderModelDisplay => BuildProviderModelDisplay(PlanningProviderName, PlanningModelUsed, ProviderName, ModelUsed);

	private JobStatus ParsedStatus => Enum.TryParse<JobStatus>(Status, ignoreCase: true, out var status)
		? status
		: JobStatus.New;

    private bool IsActiveStatus()
    {
        var status = Status.ToLowerInvariant();
        return status is "started" or "planning" or "processing" or "new" or "pending";
    }

    private async Task HandleClick()
    {
        await OnClick.InvokeAsync();
    }

	private async Task HandleKeyDown(KeyboardEventArgs args)
	{
		if (string.Equals(args.Key, "Enter", StringComparison.Ordinal) ||
			string.Equals(args.Key, " ", StringComparison.Ordinal) ||
			string.Equals(args.Key, "Spacebar", StringComparison.Ordinal))
		{
			await HandleClick();
		}
	}

    private string GetCycleModeTitle()
    {
        return CycleMode switch
        {
            CycleMode.FixedCount => $"Fixed Count Mode: {CurrentCycle} of {MaxCycles} cycles",
            CycleMode.Autonomous => $"Autonomous Mode: {CurrentCycle} of {MaxCycles} max cycles",
            _ => $"Cycle {CurrentCycle} of {MaxCycles}"
        };
    }

    private static string TruncateText(string text, int maxLength)
    {
        if (string.IsNullOrEmpty(text) || text.Length <= maxLength)
            return text;
        return text[..maxLength] + "...";
    }

    private static string FormatModelName(string model)
    {
        // Shorten long model names like "claude-sonnet-4-20250514" to "sonnet-4"
        if (string.IsNullOrEmpty(model)) return model;

        var parts = model.Split('-');
        if (parts.Length >= 2)
        {
            // Try to extract a meaningful short name
            var relevantParts = parts.Where(p => !p.All(char.IsDigit) || p.Length <= 2).Take(3);
            return string.Join("-", relevantParts);
        }

        return model.Length > 20 ? model[..20] + "..." : model;
    }

	private static string? BuildProviderModelDisplay(string? planningProviderName, string? planningModelName, string? providerName, string? modelName)
	{
		var planningDisplay = BuildStageDisplay(planningProviderName, planningModelName);
		var executionDisplay = BuildStageDisplay(providerName, modelName);

		if (!string.IsNullOrWhiteSpace(planningDisplay) &&
			!string.IsNullOrWhiteSpace(executionDisplay) &&
			!string.Equals(planningDisplay, executionDisplay, StringComparison.Ordinal))
		{
			return $"{planningDisplay} -> {executionDisplay}";
		}

		return executionDisplay ?? planningDisplay;
	}

	private static string? BuildStageDisplay(string? providerName, string? modelName)
	{
		var parts = new List<string>();

		if (!string.IsNullOrWhiteSpace(providerName))
		{
			parts.Add(providerName);
		}

		if (!string.IsNullOrWhiteSpace(modelName))
		{
			parts.Add(FormatModelName(modelName));
		}

		return parts.Count == 0 ? null : string.Join(" / ", parts);
	}
}
