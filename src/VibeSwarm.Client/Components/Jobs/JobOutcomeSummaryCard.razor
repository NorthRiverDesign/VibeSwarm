@using VibeSwarm.Shared.Data

@if (Summary != null)
{
	<div class="card mb-3 mb-lg-4 border-0 shadow-sm">
		<div class="card-body d-flex flex-column gap-3">
			<div class="d-flex flex-column flex-sm-row align-items-start justify-content-between gap-3">
				<div class="d-flex align-items-start gap-3 min-width-0">
					<div class="@Summary.IconContainerClass">
						<i class="bi @Summary.Icon fs-5"></i>
					</div>
					<div class="min-width-0">
						<div class="fw-semibold">@Summary.Title</div>
						<div class="small text-body-secondary">@Summary.Message</div>
					</div>
				</div>
				@if (!string.IsNullOrWhiteSpace(PullRequestUrl))
				{
					<a class="btn btn-sm btn-secondary flex-shrink-0"
					   href="@PullRequestUrl" target="_blank" rel="noreferrer">
						<i class="bi bi-github me-1"></i>
						<span>Open PR@(PullRequestNumber.HasValue ? $" #{PullRequestNumber.Value}" : string.Empty)</span>
					</a>
				}
			</div>

			<JobOutcomeBadges Status="@Status"
							  ChangedFilesCount="@ChangedFilesCount"
							  BuildVerified="@BuildVerified"
							  GitCommitHash="@GitCommitHash"
							  PullRequestUrl="@PullRequestUrl" />

			@if (!string.IsNullOrWhiteSpace(BuildOutput) && BuildVerified == false)
			{
				<details>
					<summary class="small text-body-secondary cursor-pointer">Show verification output</summary>
					<pre class="mt-2 mb-0 p-3 bg-body-tertiary rounded small white-space-pre-wrap overflow-auto"
						 style="max-height: 300px;">@BuildOutput</pre>
				</details>
			}
		</div>
	</div>
}

@code {
	[Parameter]
	public JobStatus Status { get; set; }

	[Parameter]
	public int? ChangedFilesCount { get; set; }

	[Parameter]
	public bool? BuildVerified { get; set; }

	[Parameter]
	public string? GitCommitHash { get; set; }

	[Parameter]
	public string? PullRequestUrl { get; set; }

	[Parameter]
	public int? PullRequestNumber { get; set; }

	[Parameter]
	public string? BuildOutput { get; set; }

	private OutcomeSummary? Summary
	{
		get
		{
			var hasDeliveredChanges = !string.IsNullOrWhiteSpace(PullRequestUrl) || !string.IsNullOrWhiteSpace(GitCommitHash);
			var hasDetectedChanges = ChangedFilesCount.GetValueOrDefault() > 0 || hasDeliveredChanges;

			return Status switch
			{
				JobStatus.Completed when BuildVerified == false => new OutcomeSummary(
					"bi-shield-x",
					"Verification blocked delivery",
					hasDetectedChanges
						? "Build or tests failed after the run, so the changes were left for manual review instead of being auto-delivered."
						: "Build or tests failed after the run completed."),
				JobStatus.Completed when !string.IsNullOrWhiteSpace(PullRequestUrl) => new OutcomeSummary(
					"bi-check2-circle",
					"Changes delivered with a pull request",
					"The run completed successfully, the changes were verified, and a pull request is ready for review."),
				JobStatus.Completed when !string.IsNullOrWhiteSpace(GitCommitHash) => new OutcomeSummary(
					"bi-check2-circle",
					"Changes committed to the branch",
					"The run completed successfully and the resulting changes are already committed."),
				JobStatus.Completed when ChangedFilesCount == 0 => new OutcomeSummary(
					"bi-file-earmark",
					"Completed without code changes",
					"The run finished, but no file changes were detected in the repository."),
				JobStatus.Completed when BuildVerified == true => new OutcomeSummary(
					"bi-check2-circle",
					"Verified changes are ready",
					"The run completed successfully, verification passed, and the changes are ready for final review or delivery."),
				JobStatus.Completed when hasDetectedChanges => new OutcomeSummary(
					"bi-send-check",
					"Changes are ready for review",
					"The run completed and produced changes, but they still need to be reviewed and delivered."),
				JobStatus.Failed or JobStatus.Cancelled or JobStatus.Stalled when hasDetectedChanges => new OutcomeSummary(
					"bi-exclamation-triangle",
					"Run stopped with changes still present",
					"The job did not finish cleanly, but repository changes remain available for review, commit, or discard."),
				JobStatus.Failed => new OutcomeSummary(
					"bi-x-circle",
					"Run failed before a deliverable result",
					"The job stopped with an error before it produced a clean, ready-to-deliver outcome."),
				JobStatus.Cancelled => new OutcomeSummary(
					"bi-slash-circle",
					"Run was cancelled",
					"The job was cancelled before it reached a clean, deliverable outcome."),
				JobStatus.Stalled => new OutcomeSummary(
					"bi-exclamation-triangle",
					"Run stalled before completion",
					"The job stopped making progress and may need to be retried or reviewed."),
				_ => null
			};
		}
	}

	private sealed class OutcomeSummary(string icon, string title, string message)
	{
		public string Icon { get; } = icon;
		public string Title { get; } = title;
		public string Message { get; } = message;
		public string IconContainerClass => "d-inline-flex align-items-center justify-content-center rounded-circle flex-shrink-0 bg-body-tertiary text-body-secondary";
	}
}
