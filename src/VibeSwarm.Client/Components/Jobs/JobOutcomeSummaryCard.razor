@using VibeSwarm.Shared.Data
@using VibeSwarm.Shared.VersionControl

@if (Summary != null)
{
	<div class="card mb-3 mb-lg-4 border-0 shadow-sm">
		<div class="card-body d-flex flex-column gap-3">
			<div class="d-flex flex-column flex-sm-row align-items-start justify-content-between gap-3">
				<div class="d-flex align-items-start gap-3 min-width-0">
					<div class="@Summary.IconContainerClass">
						<i class="bi @Summary.Icon fs-5"></i>
					</div>
					<div class="min-width-0">
						<div class="fw-semibold">@Summary.Title</div>
						<div class="small text-body-secondary">@Summary.Message</div>
					</div>
				</div>
				@if (!string.IsNullOrWhiteSpace(PullRequestUrl))
				{
					<a class="btn btn-sm btn-secondary flex-shrink-0"
					   href="@PullRequestUrl" target="_blank" rel="noreferrer">
						<i class="bi bi-github me-1"></i>
						<span>Open PR@(PullRequestNumber.HasValue ? $" #{PullRequestNumber.Value}" : string.Empty)</span>
					</a>
				}
			</div>

			<JobOutcomeBadges Status="@Status"
							  ChangedFilesCount="@ChangedFilesCount"
							  BuildVerified="@BuildVerified"
							  GitCommitHash="@GitCommitHash"
							  PullRequestUrl="@PullRequestUrl"
							  PullRequestNumber="@PullRequestNumber"
							  MergedAt="@MergedAt" />

			<div class="row g-2">
				<div class="col-12 col-lg-4">
					<div class="border rounded p-3 h-100 d-flex flex-column gap-2 min-width-0">
						<div class="small fw-semibold text-body-secondary text-uppercase">Outcome</div>
						<div class="fw-semibold">@OutcomeBlock.Title</div>
						<div class="small text-body-secondary">@OutcomeBlock.Message</div>
					</div>
				</div>
				<div class="col-12 col-lg-4">
					<div class="border rounded p-3 h-100 d-flex flex-column gap-2 min-width-0">
						<div class="small fw-semibold text-body-secondary text-uppercase">Verification</div>
						<div class="fw-semibold">@VerificationBlock.Title</div>
						<div class="small text-body-secondary">@VerificationBlock.Message</div>
						@if (VerificationCommands.Count > 0)
						{
							<div class="d-flex flex-column gap-2">
								@foreach (var command in VerificationCommands)
								{
									<div class="d-flex flex-column gap-1">
										<div class="small text-body-secondary">@command.Label</div>
										<div class="small font-monospace bg-body-tertiary rounded px-2 py-1 text-break">@command.Value</div>
									</div>
								}
							</div>
						}
					</div>
				</div>
				<div class="col-12 col-lg-4">
					<div class="border rounded p-3 h-100 d-flex flex-column gap-2 min-width-0">
						<div class="small fw-semibold text-body-secondary text-uppercase">Delivery</div>
						<div class="fw-semibold">@DeliveryBlock.Title</div>
						<div class="small text-body-secondary">@DeliveryBlock.Message</div>
						@if (DeliveryBadges.Count > 0)
						{
							<div class="d-flex flex-wrap gap-2">
								@foreach (var badge in DeliveryBadges)
								{
									<span class="badge bg-body-tertiary text-body font-monospace text-break">@badge</span>
								}
							</div>
						}
					</div>
				</div>
			</div>

			<div class="border rounded p-3 d-flex flex-column gap-2 min-width-0">
				<div class="small fw-semibold text-body-secondary text-uppercase">Next step</div>
				<div class="fw-semibold">@NextStepBlock.Title</div>
				<div class="small text-body-secondary">@NextStepBlock.Message</div>
				@if (NextStepActions.Count > 0)
				{
					<div class="d-grid d-sm-flex flex-wrap gap-2">
						@foreach (var action in NextStepActions)
						{
							<a class="btn @(action.IsPrimary ? "btn-primary" : "btn-secondary") btn-sm"
							   href="@action.Href"
							   target="@action.Target"
							   rel="@action.Rel">
								<i class="bi @action.Icon me-1"></i>
								<span>@action.Text</span>
							</a>
						}
					</div>
				}
			</div>

			@if (!string.IsNullOrWhiteSpace(BuildOutput) && BuildVerified == false)
			{
				<details id="job-verification-output">
					<summary class="small text-body-secondary cursor-pointer">Show verification output</summary>
					<pre class="mt-2 mb-0 p-3 bg-body-tertiary rounded small white-space-pre-wrap overflow-auto"
						 style="max-height: 300px;">@BuildOutput</pre>
				</details>
			}
		</div>
	</div>
}

@code {
	[Parameter]
	public JobStatus Status { get; set; }

	[Parameter]
	public int? ChangedFilesCount { get; set; }

	[Parameter]
	public bool? BuildVerified { get; set; }

	[Parameter]
	public string? GitCommitHash { get; set; }

	[Parameter]
	public string? PullRequestUrl { get; set; }

	[Parameter]
	public int? PullRequestNumber { get; set; }

	[Parameter]
	public string? BuildOutput { get; set; }

	[Parameter]
	public bool BuildVerificationEnabled { get; set; }

	[Parameter]
	public string? BuildCommand { get; set; }

	[Parameter]
	public string? TestCommand { get; set; }

	[Parameter]
	public GitChangeDeliveryMode DeliveryMode { get; set; } = GitChangeDeliveryMode.CommitToBranch;

	[Parameter]
	public string? BranchName { get; set; }

	[Parameter]
	public string? TargetBranch { get; set; }

	[Parameter]
	public DateTime? MergedAt { get; set; }

	[Parameter]
	public bool IsPushed { get; set; }

	[Parameter]
	public string? ReviewChangesHref { get; set; }

	[Parameter]
	public string? DeliveryHref { get; set; }

	[Parameter]
	public string? ReviewTranscriptHref { get; set; }

	[Parameter]
	public string? VerificationOutputHref { get; set; }

	private bool HasDeliveredChanges => JobOutcomeDisplayHelper.HasDeliveredChanges(PullRequestUrl, GitCommitHash, MergedAt);

	private bool HasDetectedChanges => JobOutcomeDisplayHelper.HasDetectedChanges(ChangedFilesCount, PullRequestUrl, GitCommitHash, MergedAt);

	private bool HasVerificationConfigured
		=> BuildVerificationEnabled
			|| !string.IsNullOrWhiteSpace(BuildCommand)
			|| !string.IsNullOrWhiteSpace(TestCommand);

	private string? EffectiveVerificationOutputHref
		=> !string.IsNullOrWhiteSpace(VerificationOutputHref)
			? VerificationOutputHref
			: !string.IsNullOrWhiteSpace(BuildOutput) && BuildVerified == false
				? "#job-verification-output"
				: null;

	private OutcomeSummary? Summary
	{
		get
		{
			return Status switch
			{
				JobStatus.Completed when BuildVerified == false => new OutcomeSummary(
					"bi-shield-x",
					"Verification blocked delivery",
					HasDetectedChanges
						? "The run finished with changes, but post-run verification failed so delivery stayed manual."
						: "Post-run verification failed after the run completed."),
				JobStatus.Completed when MergedAt.HasValue => new OutcomeSummary(
					"bi-check2-circle",
					"Changes merged into the target branch",
					"The run completed successfully and the resulting changes are already merged."),
				JobStatus.Completed when !string.IsNullOrWhiteSpace(PullRequestUrl) => new OutcomeSummary(
					"bi-check2-circle",
					$"{JobOutcomeDisplayHelper.FormatPullRequestReference(PullRequestNumber)} ready for review",
					$"The run completed successfully and {JobOutcomeDisplayHelper.FormatPullRequestReference(PullRequestNumber).ToLowerInvariant()} is ready for review."),
				JobStatus.Completed when !string.IsNullOrWhiteSpace(GitCommitHash) => new OutcomeSummary(
					"bi-check2-circle",
					$"{JobOutcomeDisplayHelper.FormatCommitLabel(GitCommitHash)} recorded",
					"The run completed successfully and the resulting changes are already committed."),
				JobStatus.Completed when ChangedFilesCount == 0 => new OutcomeSummary(
					"bi-file-earmark",
					"Completed without code changes",
					"The run finished, but no file changes were detected in the repository."),
				JobStatus.Completed when BuildVerified == true => new OutcomeSummary(
					"bi-check2-circle",
					"Verified changes are ready",
					"The run completed successfully, verification passed, and the changes are ready for final review or delivery."),
				JobStatus.Completed when HasDetectedChanges => new OutcomeSummary(
					"bi-send-check",
					"Changes are ready for review",
					"The run completed and produced changes, but they still need to be reviewed and delivered."),
				JobStatus.Failed or JobStatus.Cancelled or JobStatus.Stalled when HasDetectedChanges => new OutcomeSummary(
					"bi-exclamation-triangle",
					"Run stopped with changes still present",
					"The job did not finish cleanly, but repository changes remain available for review, commit, or discard."),
				JobStatus.Failed => new OutcomeSummary(
					"bi-x-circle",
					"Run failed before a deliverable result",
					"The job stopped with an error before it produced a clean, ready-to-deliver outcome."),
				JobStatus.Cancelled => new OutcomeSummary(
					"bi-slash-circle",
					"Run was cancelled",
					"The job was cancelled before it reached a clean, deliverable outcome."),
				JobStatus.Stalled => new OutcomeSummary(
					"bi-exclamation-triangle",
					"Run stalled before completion",
					"The job stopped making progress and may need to be retried or reviewed."),
				_ => null
			};
		}
	}

	private DetailBlock OutcomeBlock
	{
		get
		{
			if (ChangedFilesCount.GetValueOrDefault() > 0)
			{
				var fileLabel = ChangedFilesCount == 1 ? "file changed" : "files changed";
				return new DetailBlock("Repository changes detected", $"{ChangedFilesCount} {fileLabel} were recorded for this run.");
			}

			if (HasDeliveredChanges)
			{
				return new DetailBlock("Deliverable result recorded", "The repository already has a commit or pull request associated with this run.");
			}

			return Status switch
			{
				JobStatus.Completed => new DetailBlock("No repository changes detected", "The run completed without producing file changes."),
				JobStatus.Failed => new DetailBlock("Execution stopped with an error", "Review the transcript to see where the run failed."),
				JobStatus.Cancelled => new DetailBlock("Execution stopped by request", "The run was cancelled before it could finish cleanly."),
				JobStatus.Stalled => new DetailBlock("Execution stopped making progress", "The run stalled and may need intervention or a retry."),
				_ => new DetailBlock("Outcome available", "Review the job transcript for more context.")
			};
		}
	}

	private DetailBlock VerificationBlock
	{
		get
		{
			if (BuildVerified == true)
			{
				return new DetailBlock("Verification passed", "Configured build and test checks passed after the run.");
			}

			if (BuildVerified == false)
			{
				return new DetailBlock("Verification failed", "Build or test verification failed, so delivery stayed manual.");
			}

			if (HasVerificationConfigured)
			{
				return new DetailBlock("Verification result missing", "This project is configured to verify changes after a run, but this job did not record a verification result.");
			}

			return new DetailBlock("Verification not configured", "This project does not run build or test verification before delivery.");
		}
	}

	private IReadOnlyList<CommandChip> VerificationCommands
	{
		get
		{
			var commands = new List<CommandChip>();

			if (!string.IsNullOrWhiteSpace(BuildCommand))
			{
				commands.Add(new CommandChip("Build command", BuildCommand));
			}

			if (!string.IsNullOrWhiteSpace(TestCommand))
			{
				commands.Add(new CommandChip("Test command", TestCommand));
			}

			return commands;
		}
	}

	private DetailBlock DeliveryBlock
	{
		get
		{
			if (!HasDetectedChanges && Status == JobStatus.Completed)
			{
				return new DetailBlock("No delivery needed", "There are no code changes from this run to push, merge, or review.");
			}

			if (MergedAt.HasValue)
			{
				return new DetailBlock(
					"Merged into target branch",
					$"The resulting changes were merged{FormatTargetBranchClause()}.");
			}

			if (!string.IsNullOrWhiteSpace(PullRequestUrl))
			{
				return new DetailBlock(
					$"{JobOutcomeDisplayHelper.FormatPullRequestReference(PullRequestNumber)} ready",
					$"{JobOutcomeDisplayHelper.FormatPullRequestReference(PullRequestNumber)} is ready{FormatTargetBranchClause()}.");
			}

			if (IsPushed)
			{
				return new DetailBlock(
					"Changes pushed to the remote branch",
					$"The branch is updated and ready for the next delivery step{FormatTargetBranchClause()}.");
			}

			if (!string.IsNullOrWhiteSpace(GitCommitHash))
			{
				return new DetailBlock("Changes committed locally", $"{JobOutcomeDisplayHelper.FormatCommitLabel(GitCommitHash)} exists for this run, but it has not been delivered remotely yet.");
			}

			if (HasDetectedChanges && Status == JobStatus.Completed)
			{
				var readyMessage = DeliveryMode == GitChangeDeliveryMode.PullRequest
					? $"Review the diff, then create or update a pull request{FormatTargetBranchClause()}."
					: "Review the diff, then commit and push the branch when it is ready.";
				return new DetailBlock("Ready for delivery", readyMessage);
			}

			if (HasDetectedChanges)
			{
				return new DetailBlock("Delivery paused", "The run stopped before delivery, but repository changes remain available for review.");
			}

			return new DetailBlock("No delivery result recorded", "This run did not produce a deliverable repository update.");
		}
	}

	private IReadOnlyList<string> DeliveryBadges
	{
		get
		{
			var badges = new List<string>();

			if (MergedAt.HasValue)
			{
				badges.Add("Merged");
			}

			if (!string.IsNullOrWhiteSpace(BranchName))
			{
				badges.Add($"Source {BranchName}");
			}

			if (!string.IsNullOrWhiteSpace(TargetBranch))
			{
				badges.Add($"Target {TargetBranch}");
			}

			badges.Add(DeliveryMode == GitChangeDeliveryMode.PullRequest ? "Pull request flow" : "Branch flow");

			if (PullRequestNumber.HasValue)
			{
				badges.Add($"PR #{PullRequestNumber.Value}");
			}

			if (!string.IsNullOrWhiteSpace(GitCommitHash))
			{
				badges.Add(JobOutcomeDisplayHelper.FormatCommitLabel(GitCommitHash));
			}

			return badges;
		}
	}

	private DetailBlock NextStepBlock
	{
		get
		{
			if (BuildVerified == false)
			{
				return new DetailBlock("Start with the failed checks", "Inspect the verification output and repository changes before trying to deliver them.");
			}

			if (MergedAt.HasValue)
			{
				return new DetailBlock("Delivery is complete", "The code is already merged, so only follow-up review or monitoring remains.");
			}

			if (!string.IsNullOrWhiteSpace(PullRequestUrl))
			{
				return new DetailBlock("Review the pull request", "Open the PR, check the diff, and merge it when the review is complete.");
			}

			if (HasDetectedChanges && !string.IsNullOrWhiteSpace(DeliveryHref) && Status == JobStatus.Completed)
			{
				return new DetailBlock("Finish delivery", "Review the diff and use the delivery actions below to push, create a pull request, or merge.");
			}

			if (HasDetectedChanges && !string.IsNullOrWhiteSpace(ReviewChangesHref))
			{
				return new DetailBlock("Inspect the remaining changes", "Review the repository changes before retrying, committing, or discarding them.");
			}

			if (Status == JobStatus.Completed)
			{
				return new DetailBlock("No follow-up required", "This run does not need a delivery action unless you want the agent to take another pass.");
			}

			return new DetailBlock("Check the transcript before retrying", "Use the session messages to understand what stopped the run before you retry it.");
		}
	}

	private IReadOnlyList<NextStepAction> NextStepActions
	{
		get
		{
			var actions = new List<NextStepAction>();

			if (BuildVerified == false && !string.IsNullOrWhiteSpace(EffectiveVerificationOutputHref))
			{
				actions.Add(new NextStepAction("Review verification output", "bi-shield-x", EffectiveVerificationOutputHref, true, null, null));
			}

			if (!string.IsNullOrWhiteSpace(PullRequestUrl))
			{
				actions.Add(new NextStepAction(
					$"Open {JobOutcomeDisplayHelper.FormatPullRequestReference(PullRequestNumber)}",
					"bi-github",
					PullRequestUrl,
					actions.Count == 0,
					"_blank",
					"noreferrer"));
			}

			if (!string.IsNullOrWhiteSpace(ReviewChangesHref))
			{
				actions.Add(new NextStepAction("Review changes", "bi-files", ReviewChangesHref, actions.Count == 0, null, null));
			}

			if (!string.IsNullOrWhiteSpace(DeliveryHref) && BuildVerified != false && Status == JobStatus.Completed)
			{
				actions.Add(new NextStepAction("Go to delivery", "bi-cloud-upload", DeliveryHref, actions.Count == 0, null, null));
			}

			if (!string.IsNullOrWhiteSpace(ReviewTranscriptHref)
				&& Status is JobStatus.Failed or JobStatus.Cancelled or JobStatus.Stalled
				&& actions.All(action => !string.Equals(action.Href, ReviewTranscriptHref, StringComparison.Ordinal)))
			{
				actions.Add(new NextStepAction("Review transcript", "bi-chat-square-text", ReviewTranscriptHref, actions.Count == 0, null, null));
			}

			return actions;
		}
	}

	private string FormatTargetBranchClause()
		=> string.IsNullOrWhiteSpace(TargetBranch)
			? string.Empty
			: $" targeting {TargetBranch}";

	private sealed class OutcomeSummary(string icon, string title, string message)
	{
		public string Icon { get; } = icon;
		public string Title { get; } = title;
		public string Message { get; } = message;
		public string IconContainerClass => "d-inline-flex align-items-center justify-content-center rounded-circle flex-shrink-0 bg-body-tertiary text-body-secondary";
	}

	private sealed record DetailBlock(string Title, string Message);
	private sealed record CommandChip(string Label, string Value);
	private sealed record NextStepAction(string Text, string Icon, string Href, bool IsPrimary, string? Target, string? Rel);
}
