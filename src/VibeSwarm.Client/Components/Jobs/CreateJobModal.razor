@* Modal component for creating new jobs *@
@using System.ComponentModel.DataAnnotations
@inject IJobTemplateService JobTemplateService
@inject NotificationService NotificationService

<ModalDialog IsVisible="IsVisible" IsVisibleChanged="IsVisibleChanged" Title="Create Job" Icon="plus-circle"
Size="ModalDialog.ModalSize.Large" OnClose="Close">
<ChildContent>
<EditForm id="@_formId" Model="@FormModel" OnValidSubmit="HandleSubmit">
<DataAnnotationsValidator />
<ValidationSummary class="text-danger mb-3" />

<div class="border rounded p-3 mb-3 bg-body-tertiary">
<div class="d-flex flex-column flex-lg-row align-items-lg-end gap-3">
<div class="flex-grow-1">
<label for="jobTemplate" class="form-label">Template Library</label>
<InputSelect TValue="Guid?" id="jobTemplate" @bind-Value="_selectedTemplateId" @bind-Value:after="HandleTemplateSelectionChanged" class="form-select" disabled="@_isApplyingTemplate">
<option value="">Start from scratch...</option>
@foreach (var template in TemplateLibrary)
{
<option value="@template.Id">@template.Name</option>
}
</InputSelect>
<div class="form-text">Apply a reusable prompt and settings, then customize anything before creating the job.</div>
</div>
<div class="d-flex flex-wrap gap-2">
<button type="button" class="btn btn-secondary" @onclick="RefreshTemplatesAsync" disabled="@(_isApplyingTemplate || _isSavingTemplate)">
<i class="bi bi-arrow-clockwise me-1"></i>Refresh
</button>
<button type="button" class="btn btn-primary" @onclick="SaveAsTemplateAsync" disabled="@(_isApplyingTemplate || _isSavingTemplate)">
@if (_isSavingTemplate)
{
<span class="spinner-border spinner-border-sm me-1" role="status"></span>
<span>Saving...</span>
}
else
{
<i class="bi bi-bookmark-plus me-1"></i>
<span>Save as Template</span>
}
</button>
</div>
</div>
@if (!string.IsNullOrWhiteSpace(_templateStatusMessage))
{
<div class="form-text mt-2">@_templateStatusMessage</div>
}
</div>

<div class="mb-3">
<label for="goalPrompt" class="form-label">Goal Prompt</label>
<InputTextArea id="goalPrompt" @bind-Value="FormModel.GoalPrompt" class="form-control" rows="5"
placeholder="Describe what you want the AI agent to accomplish..." />
<ValidationMessage For="@(() => FormModel.GoalPrompt)" class="text-danger small" />
</div>

@if (AvailableAgents.Any())
{
<div class="mb-3">
<label for="agentPreset" class="form-label">Run as Agent</label>
<InputSelect TValue="Guid?" id="agentPreset"
			 Value="FormModel.AgentId"
			 ValueChanged="HandleAgentChanged"
			 ValueExpression="@(() => FormModel.AgentId)"
			 class="form-select">
<option value="">Choose provider manually</option>
@foreach (var agent in AvailableAgents)
{
<option value="@agent.AgentId">@agent.Agent!.Name</option>
}
</InputSelect>
<div class="form-text">Agent presets combine a purpose, provider/model assignment, and optional multi-cycle defaults for this project.</div>
</div>
}

@if (SelectedAgent != null)
{
<div class="border rounded p-3 mb-3 bg-body-tertiary">
<div class="d-flex align-items-start justify-content-between gap-2 flex-wrap">
<div class="min-width-0 flex-grow-1">
<div class="fw-semibold">@SelectedAgent.Agent!.Name</div>
@if (!string.IsNullOrWhiteSpace(SelectedAgent.Agent.Description))
{
<div class="small text-body-secondary mt-1">@SelectedAgent.Agent.Description</div>
}
</div>
<span class="badge bg-primary-subtle text-primary-emphasis">Agent Preset</span>
</div>
@if (!string.IsNullOrWhiteSpace(SelectedAgent.Agent.Responsibilities))
{
<div class="small white-space-pre-wrap mt-2">@SelectedAgent.Agent.Responsibilities</div>
}
<div class="row g-3 mt-1">
<div class="col-12 col-md-6">
<div class="small text-body-secondary text-uppercase fw-semibold mb-1">Provider</div>
<div>@GetSelectedAgentProviderDisplayText()</div>
</div>
<div class="col-12 col-md-6">
<div class="small text-body-secondary text-uppercase fw-semibold mb-1">Model</div>
<div>@GetSelectedAgentModelDisplayText()</div>
</div>
<div class="col-12 col-md-6">
<div class="small text-body-secondary text-uppercase fw-semibold mb-1">Reasoning</div>
<div>@GetSelectedAgentReasoningDisplayText()</div>
</div>
<div class="col-12 col-md-6">
<div class="small text-body-secondary text-uppercase fw-semibold mb-1">Execution</div>
<div>@GetSelectedAgentExecutionDisplayText()</div>
</div>
@if (FormModel.CycleMode != CycleMode.SingleCycle)
{
<div class="col-12 col-md-6">
<div class="small text-body-secondary text-uppercase fw-semibold mb-1">Session</div>
<div>@GetCycleSessionModeDisplayText(FormModel.CycleSessionMode)</div>
</div>
}
</div>
@if (!string.IsNullOrWhiteSpace(FormModel.CycleReviewPrompt))
{
<div class="mt-3">
<div class="small text-body-secondary text-uppercase fw-semibold mb-1">Cycle Review Prompt</div>
<div class="small white-space-pre-wrap">@FormModel.CycleReviewPrompt</div>
</div>
}
<div class="form-text mt-3">Remove the agent selection to choose provider, model, reasoning, or cycle behavior manually for this one job.</div>
</div>
}

@if (SelectedAgent == null)
{
<div class="mb-3">
<label for="provider" class="form-label">Provider</label>
@if (!string.IsNullOrEmpty(ProviderHint))
{
<div class="form-text mb-2">@ProviderHint</div>
}
<InputSelect TValue="Guid?" id="provider" @bind-Value="FormModel.ProviderId"
@bind-Value:after="HandleProviderChanged" class="form-select">
<option value="">Select a provider...</option>
@foreach (var provider in Providers.Where(p => p.IsEnabled))
{
<option value="@provider.Id">@GetProviderDisplayText(provider)</option>
}
</InputSelect>
<ValidationMessage For="@(() => FormModel.ProviderId)" class="text-danger small" />
@if (!Providers.Any(p => p.IsEnabled))
{
<div class="form-text text-warning">
No enabled providers. <a href="/providers">Configure one</a> first.
</div>
}
</div>

<div class="mb-3">
<label for="model" class="form-label">Model</label>
<InputSelect id="model" @bind-Value="SelectedModelId" class="form-select"
disabled="@(!FormModel.ProviderId.HasValue || IsLoadingModels)">
@if (IsLoadingModels)
{
<option value="">Loading models...</option>
}
else if (!AvailableModels.Any())
{
<option value="">@(!FormModel.ProviderId.HasValue ? "Select a provider first..." : "No models available")</option>
}
else
{
<option value="">Use project/provider default</option>
@foreach (var model in AvailableModels.Where(m => m.IsAvailable))
{
<option value="@model.ModelId">@(model.DisplayName ?? model.ModelId)@(model.IsDefault ? " (default)" : "")</option>
}
}
</InputSelect>
<div class="form-text">Leave empty to use the project's default model, or the provider default when no project override is set.</div>
</div>

<div class="mb-3">
<label for="reasoning" class="form-label">Reasoning</label>
<InputSelect id="reasoning" @bind-Value="FormModel.ReasoningEffort" class="form-select"
disabled="@(!FormModel.ProviderId.HasValue || !ReasoningOptions.Any())">
<option value="">Use project/provider default</option>
@foreach (var reasoning in ReasoningOptions)
{
<option value="@reasoning">@reasoning</option>
}
</InputSelect>
<div class="form-text">
@if (FormModel.ProviderId.HasValue && !ReasoningOptions.Any())
{
<span>This provider does not expose configurable reasoning levels.</span>
}
else
{
<span>Leave empty to use the project's default reasoning, or the provider default when no project override is set.</span>
}
</div>
</div>
}

@if (ShowBranchSelector && Branches.Any())
{
<div class="mb-3">
<label for="branch" class="form-label">Branch</label>
<InputSelect id="branch" @bind-Value="FormModel.Branch" class="form-select">
@foreach (var branch in Branches.Where(b => !b.IsRemote).OrderByDescending(b => b.Name == CurrentBranch))
{
<option value="@branch.Name">
@branch.Name @(branch.Name == CurrentBranch ? "(current)" : "")
</option>
}
</InputSelect>
<div class="form-text">The branch where the AI agent will operate.</div>
</div>
}

<div class="mb-3">
<label for="gitChangeDeliveryMode" class="form-label">Result Delivery</label>
<InputSelect id="gitChangeDeliveryMode" @bind-Value="FormModel.GitChangeDeliveryMode" class="form-select">
<option value="@GitChangeDeliveryMode.CommitToBranch">Commit to the selected branch</option>
<option value="@GitChangeDeliveryMode.PullRequest">Create a pull request</option>
</InputSelect>
<div class="form-text">Control where the job's final changes should land after successful execution.</div>
</div>

@if (FormModel.GitChangeDeliveryMode == GitChangeDeliveryMode.PullRequest)
{
<div class="mb-3">
<label for="targetBranch" class="form-label">Target Branch</label>
@if (Branches.Any(b => !b.IsRemote))
{
<InputSelect id="targetBranch" @bind-Value="FormModel.TargetBranch" class="form-select">
@foreach (var branch in Branches.Where(b => !b.IsRemote).OrderByDescending(b => b.Name == CurrentBranch))
{
<option value="@branch.Name">
@branch.Name @(branch.Name == CurrentBranch ? "(current)" : "")
</option>
}
</InputSelect>
}
else
{
<InputText id="targetBranch" @bind-Value="FormModel.TargetBranch" class="form-control" placeholder="develop" />
}
<ValidationMessage For="@(() => FormModel.TargetBranch)" class="text-danger small" />
<div class="form-text">Completed work will be proposed from the source branch into this branch.</div>
</div>
}

@if (SelectedAgent == null)
{
<div class="mb-3">
<button type="button" class="btn btn-link p-0 text-decoration-none" @onclick="ToggleAdvancedOptions">
<i class="bi @(ShowAdvancedOptions ? "bi-chevron-down" : "bi-chevron-right") me-1"></i>
Advanced Options
</button>
</div>

@if (ShowAdvancedOptions)
{
<div class="border rounded p-3 mb-3 bg-body-tertiary">
<div class="mb-3">
<label for="cycleMode" class="form-label">Cycle Mode</label>
<InputSelect id="cycleMode" @bind-Value="FormModel.CycleMode" class="form-select">
<option value="@CycleMode.SingleCycle">Single Cycle (default)</option>
<option value="@CycleMode.FixedCount">Fixed Count</option>
<option value="@CycleMode.Autonomous">Autonomous</option>
</InputSelect>
<div class="form-text">
@switch (FormModel.CycleMode)
{
case CycleMode.SingleCycle:
<span>Agent runs once and completes.</span>
break;
case CycleMode.FixedCount:
<span>Agent runs for a fixed number of cycles.</span>
break;
case CycleMode.Autonomous:
<span>Agent decides when the task is complete (max cycles as safety limit).</span>
break;
}
</div>
</div>

@if (FormModel.CycleMode != CycleMode.SingleCycle)
{
<div class="mb-3">
<label for="maxCycles" class="form-label">Max Cycles</label>
<InputNumber id="maxCycles" @bind-Value="FormModel.MaxCycles" class="form-control" min="1" max="100" />
<ValidationMessage For="@(() => FormModel.MaxCycles)" class="text-danger small" />
<div class="form-text">Maximum number of execution cycles (1-100).</div>
</div>

<div class="mb-3">
<label for="cycleSessionMode" class="form-label">Session Mode</label>
<InputSelect id="cycleSessionMode" @bind-Value="FormModel.CycleSessionMode" class="form-select">
<option value="@CycleSessionMode.ContinueSession">Continue Session</option>
<option value="@CycleSessionMode.FreshSession">Fresh Session</option>
</InputSelect>
<div class="form-text">
@if (FormModel.CycleSessionMode == CycleSessionMode.ContinueSession)
{
<span>Maintain context between cycles (recommended for iterative work).</span>
}
else
{
<span>Start fresh context each cycle (useful for independent tasks).</span>
}
</div>
</div>

<div class="mb-3">
<label for="cycleReviewPrompt" class="form-label">Cycle Review Prompt (Optional)</label>
<InputTextArea id="cycleReviewPrompt" @bind-Value="FormModel.CycleReviewPrompt" class="form-control"
rows="4" placeholder="Instructions for reviewing progress between cycles..." />
<div class="form-text">Additional context provided at the start of each subsequent cycle.</div>
</div>
}
</div>
}
}

@if (!string.IsNullOrEmpty(ErrorMessage))
{
<Alert Type="Alert.AlertType.Danger" Message="@ErrorMessage" Class="mb-0" />
}
</EditForm>
</ChildContent>
<FooterContent>
<ActionButton Text="Cancel" OnClick="Close" Disabled="@IsSaving" />
<ActionButton Type="submit" Form="@_formId" Style="ActionButton.ButtonStyle.Primary"
			  Icon="plus-lg" Text="Create Job" LoadingText="Creating..." IsLoading="@IsSaving" />
</FooterContent>
</ModalDialog>

@code {
[Parameter]
public bool IsVisible { get; set; }

[Parameter]
public EventCallback<bool> IsVisibleChanged { get; set; }

[Parameter, EditorRequired]
public Job JobModel { get; set; } = new();

[Parameter]
public Project? Project { get; set; }

[Parameter]
public List<Provider> Providers { get; set; } = new();

[Parameter]
public List<ProviderModel> AvailableModels { get; set; } = new();

[Parameter]
public List<GitBranchInfo> Branches { get; set; } = new();

[Parameter]
public string? CurrentBranch { get; set; }

[Parameter]
public bool ShowBranchSelector { get; set; }

[Parameter]
public bool IsLoadingModels { get; set; }

[Parameter]
public bool IsSaving { get; set; }

[Parameter]
public string? ErrorMessage { get; set; }

[Parameter]
public string SelectedModelId { get; set; } = string.Empty;

[Parameter]
public EventCallback<string> SelectedModelIdChanged { get; set; }

[Parameter]
public EventCallback<Guid> OnProviderChanged { get; set; }

[Parameter]
public EventCallback OnSubmit { get; set; }

[Parameter]
public string? ProviderHint { get; set; }

[Parameter]
public List<JobTemplate> TemplateLibrary { get; set; } = new();

[Parameter]
public EventCallback OnTemplateLibraryChanged { get; set; }

private readonly string _formId = $"create-job-form-{Guid.NewGuid():N}";
private bool ShowAdvancedOptions { get; set; }
private bool _previousIsVisible;
private CreateJobFormModel FormModel { get; set; } = new();
private Guid? _selectedTemplateId;
private bool _isApplyingTemplate;
private bool _isSavingTemplate;
private string? _templateStatusMessage;
private IReadOnlyList<ProjectAgent> AvailableAgents => AgentPresetHelper.GetEnabledAgents(Project);
private ProjectAgent? SelectedAgent => AgentPresetHelper.ResolveAgent(Project, FormModel.AgentId);
private IReadOnlyList<string> ReasoningOptions => FormModel.ProviderId.HasValue
? Providers.Where(provider => provider.Id == FormModel.ProviderId.Value)
	.SelectMany(ProviderCapabilities.GetSupportedReasoningEfforts)
	.Distinct(StringComparer.Ordinal)
	.ToList()
: [];

protected override void OnParametersSet()
{
if (IsVisible && !_previousIsVisible)
{
FormModel = CreateJobFormModel.FromJob(JobModel);
_selectedTemplateId = JobModel.JobTemplateId;
_templateStatusMessage = null;
if (SelectedAgent != null)
{
ApplySelectedAgent(SelectedAgent);
ShowAdvancedOptions = false;
}
else
{
ShowAdvancedOptions = FormModel.CycleMode != CycleMode.SingleCycle;
}
}

_previousIsVisible = IsVisible;
}

private void ToggleAdvancedOptions()
{
if (SelectedAgent != null)
{
return;
}

ShowAdvancedOptions = !ShowAdvancedOptions;
}

private Task HandleAgentChanged(Guid? agentId)
{
FormModel.AgentId = agentId;

if (SelectedAgent != null)
{
ApplySelectedAgent(SelectedAgent);
ShowAdvancedOptions = false;
}
else
{
ShowAdvancedOptions = FormModel.CycleMode != CycleMode.SingleCycle;
}

return Task.CompletedTask;
}

private async Task HandleProviderChanged()
{
await OnProviderChanged.InvokeAsync(FormModel.ProviderId ?? Guid.Empty);
}

private async Task HandleSubmit()
{
FormModel.ApplyTo(JobModel);
JobModel.JobTemplateId = _selectedTemplateId;
JobModel.ModelUsed = string.IsNullOrEmpty(SelectedModelId) ? null : SelectedModelId;
await SelectedModelIdChanged.InvokeAsync(SelectedModelId);
await OnSubmit.InvokeAsync();
}

private async Task HandleTemplateSelectionChanged()
{
	if (!_selectedTemplateId.HasValue)
	{
		JobModel.JobTemplateId = null;
		_templateStatusMessage = null;
		return;
	}

	var template = TemplateLibrary.FirstOrDefault(item => item.Id == _selectedTemplateId.Value)
		?? await JobTemplateService.GetByIdAsync(_selectedTemplateId.Value);
	if (template == null)
	{
		_templateStatusMessage = "The selected template could not be found.";
		return;
	}

	_isApplyingTemplate = true;
	try
	{
		ApplyTemplateToJob(template);
		FormModel = CreateJobFormModel.FromJob(JobModel);
		ShowAdvancedOptions = FormModel.CycleMode != CycleMode.SingleCycle;
		await SelectedModelIdChanged.InvokeAsync(SelectedModelId);
		await OnProviderChanged.InvokeAsync(FormModel.ProviderId ?? Guid.Empty);
		_templateStatusMessage = $"Applied template '{template.Name}'.";
		await JobTemplateService.IncrementUseCountAsync(template.Id);
		await RefreshTemplatesAsync();
	}
	finally
	{
		_isApplyingTemplate = false;
	}
}

private async Task RefreshTemplatesAsync()
{
	await OnTemplateLibraryChanged.InvokeAsync();
	_templateStatusMessage = "Template library refreshed.";
}

private async Task SaveAsTemplateAsync()
{
	try
	{
		_isSavingTemplate = true;
		FormModel.ApplyTo(JobModel);
		JobModel.ModelUsed = string.IsNullOrEmpty(SelectedModelId) ? null : SelectedModelId;

		var templateName = BuildTemplateName(JobModel.GoalPrompt);
		var template = new JobTemplate
		{
			Name = templateName,
			Description = $"Saved from a create-job draft on {DateTime.UtcNow:yyyy-MM-dd}.",
			GoalPrompt = JobModel.GoalPrompt,
			ProviderId = JobModel.ProviderId == Guid.Empty ? null : JobModel.ProviderId,
			ModelId = JobModel.ModelUsed,
			ReasoningEffort = JobModel.ReasoningEffort,
			Branch = JobModel.Branch,
			GitChangeDeliveryMode = JobModel.GitChangeDeliveryMode,
			TargetBranch = JobModel.TargetBranch,
			CycleMode = JobModel.CycleMode,
			CycleSessionMode = JobModel.CycleSessionMode,
			MaxCycles = JobModel.MaxCycles,
			CycleReviewPrompt = JobModel.CycleReviewPrompt
		};

		var created = await JobTemplateService.CreateAsync(template);
		_selectedTemplateId = created.Id;
		JobModel.JobTemplateId = created.Id;
		await RefreshTemplatesAsync();
		_templateStatusMessage = $"Saved template '{created.Name}'.";
		NotificationService.ShowSuccess($"Saved template '{created.Name}'.");
	}
	catch (ValidationException ex)
	{
		_templateStatusMessage = ex.Message;
		NotificationService.ShowError(ex.Message);
	}
	catch (HttpRequestException ex)
	{
		_templateStatusMessage = ex.Message;
		NotificationService.ShowError(ex.Message);
	}
	finally
	{
		_isSavingTemplate = false;
	}
}

private async Task Close()
{
await IsVisibleChanged.InvokeAsync(false);
}

private string GetProviderDisplayText(Provider provider)
{
var index = Providers.FindIndex(p => p.Id == provider.Id);
return index >= 0
? $"#{index + 1} {provider.Name} ({provider.Type})"
: $"{provider.Name} ({provider.Type})";
}

private void ApplyTemplateToJob(JobTemplate template)
{
	JobModel.JobTemplateId = template.Id;
	JobModel.GoalPrompt = template.GoalPrompt;
	JobModel.AgentId = null;
	JobModel.ProviderId = template.ProviderId ?? Guid.Empty;
	JobModel.ModelUsed = template.ModelId;
	JobModel.ReasoningEffort = template.ReasoningEffort;
	JobModel.Branch = template.Branch;
	JobModel.GitChangeDeliveryMode = template.GitChangeDeliveryMode;
	JobModel.TargetBranch = template.TargetBranch;
	JobModel.CycleMode = template.CycleMode;
	JobModel.CycleSessionMode = template.CycleSessionMode;
	JobModel.MaxCycles = template.MaxCycles;
	JobModel.CycleReviewPrompt = template.CycleReviewPrompt;
	SelectedModelId = template.ModelId ?? string.Empty;
}

private void ApplySelectedAgent(ProjectAgent assignment)
{
	var job = new Job
	{
		GoalPrompt = FormModel.GoalPrompt,
		AgentId = assignment.AgentId
	};

	AgentPresetHelper.ApplyExecutionDefaults(job, assignment);
	FormModel.ProviderId = job.ProviderId == Guid.Empty ? null : job.ProviderId;
	SelectedModelId = job.ModelUsed ?? string.Empty;
	FormModel.ReasoningEffort = job.ReasoningEffort;
	FormModel.CycleMode = job.CycleMode;
	FormModel.CycleSessionMode = job.CycleSessionMode;
	FormModel.MaxCycles = job.MaxCycles;
	FormModel.CycleReviewPrompt = job.CycleReviewPrompt;
}

private string GetSelectedAgentProviderDisplayText()
{
	return SelectedAgent?.Provider?.Name
		?? Providers.FirstOrDefault(provider => provider.Id == FormModel.ProviderId)?.Name
		?? "Unknown provider";
}

private string GetSelectedAgentModelDisplayText()
{
	return string.IsNullOrWhiteSpace(SelectedModelId)
		? "Use provider default"
		: SelectedModelId;
}

private string GetSelectedAgentReasoningDisplayText()
{
	return string.IsNullOrWhiteSpace(FormModel.ReasoningEffort)
		? "Use provider default"
		: FormModel.ReasoningEffort;
}

private string GetSelectedAgentExecutionDisplayText()
{
	return FormModel.CycleMode switch
	{
		CycleMode.FixedCount => $"Fixed count ({FormModel.MaxCycles} cycles)",
		CycleMode.Autonomous => $"Autonomous (max {FormModel.MaxCycles} cycles)",
		_ => "Single cycle"
	};
}

private static string GetCycleSessionModeDisplayText(CycleSessionMode cycleSessionMode)
{
	return cycleSessionMode == CycleSessionMode.ContinueSession
		? "Continue session between cycles"
		: "Start a fresh session each cycle";
}

private static string BuildTemplateName(string prompt)
{
	var trimmed = prompt.Trim();
	if (string.IsNullOrEmpty(trimmed))
	{
		throw new ValidationException("Enter a goal prompt before saving a template.");
	}

	const int maxLength = 100;
	var firstLine = trimmed.Split(['\r', '\n'], StringSplitOptions.RemoveEmptyEntries).FirstOrDefault() ?? trimmed;
	return firstLine.Length <= maxLength ? firstLine : firstLine[..maxLength].TrimEnd();
}
}
