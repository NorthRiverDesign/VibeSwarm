@inject ISettingsService SettingsService
@inject AppTimeZoneService AppTimeZoneService
@inject IFileSystemService FileSystemService
@inject NotificationService NotificationService
@inject ICriticalErrorLogService CriticalErrorLogService

<div class="card">
<div class="card-header bg-body-secondary">
<h5 class="mb-0 fw-semibold">
<i class="bi bi-gear me-2"></i>Application Settings
</h5>
</div>
<div class="card-body">
@if (_isLoading)
{
<LoadingSpinner />
}
else
{
<EditForm Model="@_settings" OnValidSubmit="SaveSettings">
<DataAnnotationsValidator />

<h6 class="text-body-secondary mb-3">
<i class="bi bi-folder me-1"></i>Project Defaults
</h6>

<div class="mb-3">
<label for="defaultProjectsDirectory" class="form-label">Default Projects Directory</label>
<div class="input-group">
<input type="text" id="defaultProjectsDirectory" class="form-control font-monospace"
   @bind="_settings.DefaultProjectsDirectory" placeholder="@_placeholder" />
<button type="button" class="btn btn-secondary" @onclick="OpenDirectoryBrowser"
title="Browse directories">
<i class="bi bi-folder2-open"></i>
</button>
</div>
<div class="form-text">
This path will be used as the default prefix when creating new projects.
For example, if you set this to <code>@_examplePath</code> and create a project named
"MyApp",
the working path will default to
<code>@_examplePath@Path.DirectorySeparatorChar@("MyApp")</code>.
</div>

@if (!string.IsNullOrEmpty(_settings.DefaultProjectsDirectory))
{
<div class="mt-2 d-flex flex-wrap align-items-center gap-2">
@if (_directoryExists)
{
<span class="badge bg-success-subtle text-success-emphasis">
<i class="bi bi-check-circle me-1"></i>Directory exists
</span>
<button type="button" class="btn btn-primary btn-sm" @onclick="OpenScanProjectsModal">
<i class="bi bi-folder-symlink me-1"></i>Scan For Projects
</button>
}
else
{
<span class="badge bg-warning-subtle text-warning-emphasis">
<i class="bi bi-exclamation-triangle me-1"></i>Directory does not exist
</span>
}
</div>
}
</div>

<div class="mb-3">
<label for="timeZoneId" class="form-label">Timezone</label>
<select id="timeZoneId" class="form-select" @bind="_settings.TimeZoneId">
	@foreach (var group in GetGroupedTimeZones())
	{
		<optgroup label="@group.Key">
			@foreach (var timeZone in group)
			{
				<option value="@timeZone.Id">@DateTimeHelper.GetTimeZoneOptionLabel(timeZone)</option>
			}
		</optgroup>
	}
</select>
<div class="form-text">
Recurring schedules and timestamp displays use this timezone. Existing schedules keep the same local
clock time when you change it.
</div>
</div>

<div class="d-flex flex-column flex-sm-row gap-2 mt-4">
<button type="submit" class="btn btn-primary" disabled="@_isSaving">
@if (_isSaving)
{
<span class="spinner-border spinner-border-sm me-1" role="status"></span>
<span>Saving...</span>
}
else
{
<i class="bi bi-check-lg me-1"></i>
<span>Save Settings</span>
}
</button>
<button type="button" class="btn btn-secondary" @onclick="ReloadSettings" disabled="@_isSaving">
<i class="bi bi-arrow-counterclockwise me-1"></i>
Reset
</button>
</div>

<hr class="my-4" />

<h6 class="text-body-secondary mb-3">
<i class="bi bi-robot me-1"></i>Agent Quality
</h6>

<div class="mb-3">
<div class="form-check form-switch">
<input class="form-check-input" type="checkbox" id="enablePromptStructuring"
   @bind="_settings.EnablePromptStructuring" />
<label class="form-check-label" for="enablePromptStructuring">
Structure job prompts with XML tags
</label>
</div>
<div class="form-text">
Wraps job prompts with project context and constraints using XML tags for clearer agent
instructions.
</div>
</div>

<div class="mb-3">
<div class="form-check form-switch">
<input class="form-check-input" type="checkbox" id="injectRepoMap"
   @bind="_settings.InjectRepoMap" />
<label class="form-check-label" for="injectRepoMap">
Inject repo map into system prompt
</label>
</div>
<div class="form-text">
Auto-generates a compact project file tree and injects it into the agent's system prompt for
faster codebase navigation.
</div>
</div>

<div class="mb-3">
<div class="form-check form-switch">
<input class="form-check-input" type="checkbox" id="injectEfficiencyRules"
   @bind="_settings.InjectEfficiencyRules" />
<label class="form-check-label" for="injectEfficiencyRules">
Inject efficiency rules into system prompt
</label>
</div>
<div class="form-text">
Adds rules to prevent agents from modifying unrelated files, adding unnecessary comments, or
refactoring beyond the task.
</div>
</div>

<div class="mb-3">
<div class="form-check form-switch">
<input class="form-check-input" type="checkbox" id="enableCommitAttribution"
   @bind="_settings.EnableCommitAttribution" />
<label class="form-check-label" for="enableCommitAttribution">
Enable provider commit attribution
</label>
</div>
<div class="form-text">
When enabled, provider-run jobs can add provider-specific commit attribution such as Copilot
co-author trailers or provider identity on auto-commits. When disabled, jobs should use the
repository's default git identity without provider attribution.
</div>
</div>

<hr class="my-4" />

<h6 class="text-body-secondary mb-3">
<i class="bi bi-exclamation-octagon me-1"></i>Critical Error Logs
</h6>

<div class="row g-3">
	<div class="col-12 col-md-6">
		<label for="criticalErrorLogRetentionDays" class="form-label">Retention (days)</label>
		<InputNumber id="criticalErrorLogRetentionDays" @bind-Value="_settings.CriticalErrorLogRetentionDays" class="form-control" />
		<div class="form-text">
			Keep critical crash logs for between @AppSettings.MinCriticalErrorLogRetentionDays and @AppSettings.MaxCriticalErrorLogRetentionDays days.
		</div>
		<ValidationMessage For="@(() => _settings.CriticalErrorLogRetentionDays)" class="text-danger small" />
	</div>
	<div class="col-12 col-md-6">
		<label for="criticalErrorLogMaxEntries" class="form-label">Maximum stored entries</label>
		<InputNumber id="criticalErrorLogMaxEntries" @bind-Value="_settings.CriticalErrorLogMaxEntries" class="form-control" />
		<div class="form-text">
			Once this cap is reached, the oldest critical logs are removed automatically.
		</div>
		<ValidationMessage For="@(() => _settings.CriticalErrorLogMaxEntries)" class="text-danger small" />
	</div>
</div>

<div class="mt-3 d-flex flex-wrap gap-2">
	<button type="button" class="btn btn-secondary btn-sm" @onclick="RefreshCriticalErrorLogs" disabled="@_isLoadingCriticalErrorLogs">
		@if (_isLoadingCriticalErrorLogs)
		{
			<span class="spinner-border spinner-border-sm me-1" role="status"></span>
		}
		<i class="bi bi-arrow-clockwise me-1"></i>Refresh Logs
	</button>
	<button type="button" class="btn btn-secondary btn-sm" @onclick="PruneCriticalErrorLogs" disabled="@_isPruningCriticalErrorLogs">
		@if (_isPruningCriticalErrorLogs)
		{
			<span class="spinner-border spinner-border-sm me-1" role="status"></span>
		}
		<i class="bi bi-trash3 me-1"></i>Apply Retention Now
	</button>
</div>

<div class="mt-3 border rounded-3">
	<div class="list-group list-group-flush">
		@if (_criticalErrorLogs.Count == 0)
		{
			<div class="list-group-item text-body-secondary small">
				No critical errors have been recorded yet.
			</div>
		}
		else
		{
			@foreach (var entry in _criticalErrorLogs)
			{
				<div class="list-group-item">
					<div class="d-flex flex-column gap-2">
						<div class="d-flex flex-wrap align-items-center gap-2">
							<span class="badge bg-danger-subtle text-danger-emphasis text-uppercase">@entry.Source</span>
							<span class="badge bg-body-secondary text-body-secondary text-uppercase">@entry.Category</span>
							@if (entry.TriggeredRefresh)
							{
								<span class="badge bg-warning-subtle text-warning-emphasis">
									<i class="bi bi-arrow-clockwise me-1"></i>@(string.IsNullOrWhiteSpace(entry.RefreshAction) ? "Refresh triggered" : entry.RefreshAction)
								</span>
							}
							<span class="small text-body-secondary">@entry.CreatedAt.FormatDateTimeShort()</span>
						</div>
						<div class="fw-semibold text-break">@entry.Message</div>
						@if (!string.IsNullOrWhiteSpace(entry.Url))
						{
							<div class="small text-body-secondary text-break">
								<i class="bi bi-link-45deg me-1"></i>@entry.Url
							</div>
						}
						@if (!string.IsNullOrWhiteSpace(entry.TraceId))
						{
							<div class="small text-body-secondary font-monospace text-break">Trace: @entry.TraceId</div>
						}
						@if (!string.IsNullOrWhiteSpace(entry.Details))
						{
							<details class="small">
								<summary class="cursor-pointer">Show details</summary>
								<pre class="mb-0 mt-2 p-2 bg-body-tertiary rounded small font-monospace white-space-pre-wrap">@entry.Details</pre>
							</details>
						}
					</div>
				</div>
			}
		}
	</div>
</div>
</EditForm>
}
</div>
</div>

@if (_showDirectoryBrowser)
{
<DirectoryBrowser @ref="_directoryBrowser" InitialPath="@_settings.DefaultProjectsDirectory"
  OnDirectorySelected="OnDirectorySelected" OnClosed="CloseDirectoryBrowser" />
}

<ScanProjectsModal @ref="_scanProjectsModal" OnProjectsImported="OnProjectsImported" />

@code {
	[Parameter] public EventCallback OnSettingsSaved { get; set; }

	private AppSettings _settings = new();
	private bool _isLoading = true;
	private bool _isSaving;
	private bool _showDirectoryBrowser;
	private bool _directoryExists;
	private DirectoryBrowser? _directoryBrowser;
	private ScanProjectsModal? _scanProjectsModal;
	private IReadOnlyList<TimeZoneInfo> _timeZones = [];
	private bool _isLoadingCriticalErrorLogs;
	private bool _isPruningCriticalErrorLogs;
	private List<CriticalErrorLogEntry> _criticalErrorLogs = [];

	private string _placeholder => OperatingSystem.IsWindows() ? @"C:\Projects" : "/home/user/projects";
	private string _examplePath => OperatingSystem.IsWindows() ? @"C:\Projects" : "/home/user/projects";

	private IOrderedEnumerable<IGrouping<string, TimeZoneInfo>> GetGroupedTimeZones()
	{
		return _timeZones
			.GroupBy(tz => tz.Id.Contains('/') ? tz.Id.Split('/')[0] : "Other")
			.OrderBy(g => g.Key == "Other" ? 1 : 0)
			.ThenBy(g => g.Key, StringComparer.Ordinal);
	}

	protected override async Task OnInitializedAsync()
	{
		_timeZones = AppTimeZoneService.GetAvailableTimeZones();
		await AppTimeZoneService.EnsureInitializedAsync();
		await LoadSettings();
	}

	private async Task LoadSettings()
	{
		_isLoading = true;

		try
		{
			_settings = await SettingsService.GetSettingsAsync();
			_settings.TimeZoneId = DateTimeHelper.ResolveTimeZone(_settings.TimeZoneId).Id;
			AppTimeZoneService.ApplyTimeZone(_settings.TimeZoneId);
			await CheckDirectoryExists();
			await LoadCriticalErrorLogs();
		}
		catch (Exception ex)
		{
			NotificationService.ShowError($"Failed to load settings: {ex.Message}");
		}
		finally
		{
			_isLoading = false;
		}
	}

	private async Task SaveSettings()
	{
		_isSaving = true;

		try
		{
			if (!string.IsNullOrWhiteSpace(_settings.DefaultProjectsDirectory))
			{
				_settings.DefaultProjectsDirectory = _settings.DefaultProjectsDirectory.Trim();
			}
			else
			{
				_settings.DefaultProjectsDirectory = null;
			}

			_settings.TimeZoneId = DateTimeHelper.ResolveTimeZone(_settings.TimeZoneId).Id;
			_settings = await SettingsService.UpdateSettingsAsync(_settings);
			AppTimeZoneService.ApplyTimeZone(_settings.TimeZoneId);
			await CheckDirectoryExists();
			await LoadCriticalErrorLogs();
			NotificationService.ShowSuccess("Settings saved successfully!");
			await OnSettingsSaved.InvokeAsync();
		}
		catch (Exception ex)
		{
			NotificationService.ShowError($"Failed to save settings: {ex.Message}");
		}
		finally
		{
			_isSaving = false;
		}
	}

	private async Task ReloadSettings() => await LoadSettings();

	private async Task RefreshCriticalErrorLogs() => await LoadCriticalErrorLogs();

	private async Task PruneCriticalErrorLogs()
	{
		_isPruningCriticalErrorLogs = true;

		try
		{
			await CriticalErrorLogService.ApplyRetentionPolicyAsync();
			await LoadCriticalErrorLogs();
			NotificationService.ShowSuccess("Critical error log retention applied.");
		}
		catch (Exception ex)
		{
			NotificationService.ShowError($"Failed to prune critical error logs: {ex.Message}");
		}
		finally
		{
			_isPruningCriticalErrorLogs = false;
		}
	}

	private async Task LoadCriticalErrorLogs()
	{
		_isLoadingCriticalErrorLogs = true;

		try
		{
			_criticalErrorLogs = (await CriticalErrorLogService.GetRecentAsync()).ToList();
		}
		catch (Exception ex)
		{
			NotificationService.ShowError($"Failed to load critical error logs: {ex.Message}");
		}
		finally
		{
			_isLoadingCriticalErrorLogs = false;
		}
	}

	private async Task CheckDirectoryExists()
	{
		if (!string.IsNullOrWhiteSpace(_settings.DefaultProjectsDirectory))
		{
			_directoryExists = await FileSystemService.DirectoryExistsAsync(_settings.DefaultProjectsDirectory);
		}
		else
		{
			_directoryExists = false;
		}
	}

	private async Task OpenDirectoryBrowser()
	{
		_showDirectoryBrowser = true;
		StateHasChanged();

		await Task.Delay(50);

		if (_directoryBrowser != null)
		{
			await _directoryBrowser.ShowAsync(_settings.DefaultProjectsDirectory);
		}
	}

	private async Task OnDirectorySelected(string path)
	{
		_settings.DefaultProjectsDirectory = path;
		_showDirectoryBrowser = false;
		await CheckDirectoryExists();
		StateHasChanged();
	}

	private void CloseDirectoryBrowser()
	{
		_showDirectoryBrowser = false;
	}

	private async Task OpenScanProjectsModal()
	{
		if (_scanProjectsModal != null)
		{
			await _scanProjectsModal.ShowAsync(_settings.DefaultProjectsDirectory);
		}
	}

	private void OnProjectsImported()
	{
		NotificationService.ShowSuccess("Projects imported successfully!");
		StateHasChanged();
	}
}
