@inject IDatabaseService DatabaseService
@inject ICriticalErrorLogService CriticalErrorLogService
@inject NotificationService NotificationService
@using System.Text.Json
@using System.Text.Json.Serialization

<div class="card mb-3">
<div class="card-header bg-body-secondary">
<h5 class="mb-0 fw-semibold">
<i class="bi bi-hdd-stack me-2"></i>Storage
</h5>
</div>
<div class="card-body">
@if (DatabaseSummary == null)
{
<LoadingSpinner />
}
else if (DatabaseSummary != null)
{
<div class="row g-3">
<div class="col-12 col-lg-4">
<div class="border rounded-3 p-3 h-100 bg-body-tertiary">
<div class="small text-body-secondary text-uppercase fw-semibold mb-1">Current Size</div>
<div class="fs-3 fw-semibold">@FormatBytes(DatabaseSummary.TotalSizeBytes)</div>
<div class="small text-body-secondary">@GetDatabaseProviderLabel()</div>
@if (!string.IsNullOrWhiteSpace(DatabaseSummary.Location))
{
<div class="small text-body-secondary font-monospace text-break mt-2">@DatabaseSummary.Location</div>
}
</div>
</div>
<div class="col-12 col-lg-8">
<div class="row g-3">
<div class="col-12 col-sm-6">
<div class="border rounded-3 p-3 h-100">
<div class="small text-body-secondary text-uppercase fw-semibold mb-1">Jobs</div>
<div class="fw-semibold">@DatabaseSummary.JobsCount total</div>
<div class="small text-body-secondary">@DatabaseSummary.CompletedJobsOlderThanRetentionCount completed older than @DatabaseMaintenanceDefaults.HistoryRetentionDays days</div>
</div>
</div>
<div class="col-12 col-sm-6">
<div class="border rounded-3 p-3 h-100">
<div class="small text-body-secondary text-uppercase fw-semibold mb-1">Messages</div>
<div class="fw-semibold">@DatabaseSummary.JobMessagesCount total</div>
<div class="small text-body-secondary">Stored session transcript rows</div>
</div>
</div>
<div class="col-12 col-sm-6">
<div class="border rounded-3 p-3 h-100">
<div class="small text-body-secondary text-uppercase fw-semibold mb-1">Usage Records</div>
<div class="fw-semibold">@DatabaseSummary.ProviderUsageRecordsCount total</div>
<div class="small text-body-secondary">@DatabaseSummary.ProviderUsageRecordsOlderThanRetentionCount older than @DatabaseMaintenanceDefaults.HistoryRetentionDays days</div>
</div>
</div>
<div class="col-12 col-sm-6">
<div class="border rounded-3 p-3 h-100">
<div class="small text-body-secondary text-uppercase fw-semibold mb-1">Critical Error Logs</div>
<div class="fw-semibold">@DatabaseSummary.CriticalErrorLogsCount total</div>
<div class="small text-body-secondary">Managed by the retention settings on this page</div>
</div>
</div>
</div>
</div>
@if (DatabaseSummary.DataFileSizeBytes.HasValue || DatabaseSummary.WalFileSizeBytes.HasValue || DatabaseSummary.SharedMemoryFileSizeBytes.HasValue)
{
<div class="col-12">
<div class="small text-body-secondary d-flex flex-wrap gap-3">
@if (DatabaseSummary.DataFileSizeBytes.HasValue)
{
<span>Data: @FormatBytes(DatabaseSummary.DataFileSizeBytes)</span>
}
@if (DatabaseSummary.WalFileSizeBytes.HasValue)
{
<span>WAL: @FormatBytes(DatabaseSummary.WalFileSizeBytes)</span>
}
@if (DatabaseSummary.SharedMemoryFileSizeBytes.HasValue)
{
<span>SHM: @FormatBytes(DatabaseSummary.SharedMemoryFileSizeBytes)</span>
}
</div>
</div>
}
</div>
}
</div>
</div>

<div class="card mb-3">
<div class="card-header bg-body-secondary">
<h5 class="mb-0 fw-semibold">
<i class="bi bi-arrow-left-right me-2"></i>Migration
</h5>
</div>
<div class="card-body d-flex flex-column gap-3">
@if (_databaseMigrationResult != null)
{
<Alert Type="Alert.AlertType.Info" Class="mb-0">
<div class="d-flex flex-column gap-1">
<span>@_databaseMigrationResult.Message</span>
@if (!string.IsNullOrWhiteSpace(_databaseMigrationResult.ConnectionStringPreview))
{
<span class="small text-body-secondary font-monospace text-break">@_databaseMigrationResult.ConnectionStringPreview</span>
}
</div>
</Alert>
}

@if (_isLoadingDatabaseConfiguration && _databaseConfiguration == null)
{
<LoadingSpinner />
}
else if (_databaseConfiguration != null)
{
@if (_databaseConfiguration.HasEnvironmentOverride)
{
<Alert Type="Alert.AlertType.Warning" Class="mb-0">
Migration is disabled because the current database is controlled by environment variables. Clear
<code>DATABASE_PROVIDER</code> and <code>ConnectionStrings__Default</code> to manage database
switching from the UI.
</Alert>
}

@if (!string.IsNullOrWhiteSpace(_databaseConfiguration.PendingProvider))
{
<Alert Type="Alert.AlertType.Info" Class="mb-0">
<div class="d-flex flex-column gap-1">
<span>Restart pending: VibeSwarm will switch to @GetDatabaseProviderDisplayName(_databaseConfiguration.PendingProvider) after restart.</span>
@if (!string.IsNullOrWhiteSpace(_databaseConfiguration.PendingConnectionStringPreview))
{
<span class="small text-body-secondary font-monospace text-break">@_databaseConfiguration.PendingConnectionStringPreview</span>
}
</div>
</Alert>
}

<div class="row g-3">
<div class="col-12 col-lg-4">
<div class="border rounded-3 p-3 h-100 bg-body-tertiary d-flex flex-column gap-2">
<div class="small text-body-secondary text-uppercase fw-semibold">Current Configuration</div>
<div class="fw-semibold">@GetDatabaseProviderDisplayName(_databaseConfiguration.Provider)</div>
<div class="small text-body-secondary">@_databaseConfiguration.ConfigurationSource</div>
@if (!string.IsNullOrWhiteSpace(_databaseConfiguration.ConnectionStringPreview))
{
<div class="small text-body-secondary font-monospace text-break">@_databaseConfiguration.ConnectionStringPreview</div>
}
<div class="small text-body-secondary">Runtime config path: @_databaseConfiguration.RuntimeConfigurationPath</div>
</div>
</div>
<div class="col-12 col-lg-8">
<div class="border rounded-3 p-3 d-flex flex-column gap-3 h-100">
<div class="row g-3">
<div class="col-12 col-md-4">
<label class="form-label">Target Provider</label>
<select class="form-select" @bind="_databaseMigrationRequest.Provider">
<option value="sqlite">SQLite</option>
<option value="mysql">MySQL</option>
<option value="postgresql">PostgreSQL</option>
<option value="sqlserver">SQL Server</option>
</select>
</div>
<div class="col-12 col-md-8">
<label class="form-label">Target Connection String</label>
<input type="text" class="form-control font-monospace" @bind="_databaseMigrationRequest.ConnectionString"
placeholder="@GetDatabaseMigrationConnectionStringPlaceholder()" />
</div>
</div>

<div class="small text-body-secondary">
Copy the entire VibeSwarm database into an empty target database, then save the new provider and
connection string to the runtime database config file. The current database is left unchanged until
you restart the app.
</div>
<div class="small text-body-secondary">
For SQLite, choose a new file path. For MySQL, PostgreSQL, or SQL Server, point to an empty
database that the app can create tables in.
</div>

@if (!string.IsNullOrWhiteSpace(GetDatabaseMigrationValidationMessage()))
{
<div class="small text-danger">@GetDatabaseMigrationValidationMessage()</div>
}

<div class="d-flex flex-column flex-sm-row gap-2">
<button type="button" class="btn btn-primary btn-sm" @onclick="OpenDatabaseMigrationModal"
disabled="@IsDatabaseMigrationDisabled()">
@if (_isMigratingDatabase)
{
<span class="spinner-border spinner-border-sm me-1" role="status"></span>
}
<i class="bi bi-arrow-left-right me-1"></i>Migrate Database
</button>
<button type="button" class="btn btn-secondary btn-sm" @onclick="RefreshDatabaseConfiguration"
disabled="@_isLoadingDatabaseConfiguration">
<i class="bi bi-arrow-clockwise me-1"></i>Refresh Config
</button>
</div>
</div>
</div>
</div>
}
</div>
</div>

<div class="card mb-3">
<div class="card-header bg-body-secondary">
<h5 class="mb-0 fw-semibold">
<i class="bi bi-trash3 me-2"></i>Cleanup
</h5>
</div>
<div class="card-body d-flex flex-column gap-3">
@if (_databaseMaintenanceResult != null)
{
<Alert Type="Alert.AlertType.Info" Class="mb-0">
<div class="d-flex flex-column gap-1">
<span>@_databaseMaintenanceResult.Message</span>
@if (_databaseMaintenanceResult.SizeBeforeBytes.HasValue || _databaseMaintenanceResult.SizeAfterBytes.HasValue)
{
<span class="small text-body-secondary">
Size: @FormatBytes(_databaseMaintenanceResult.SizeBeforeBytes) -> @FormatBytes(_databaseMaintenanceResult.SizeAfterBytes)
</span>
}
</div>
</Alert>
}

<div class="border rounded-3 p-3 d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3">
<div>
<div class="fw-semibold">Apply critical error log retention</div>
<div class="small text-body-secondary">Prune crash logs now using the retention settings configured on this page.</div>
</div>
<button type="button" class="btn btn-secondary btn-sm" @onclick='() => OpenDatabaseMaintenanceModal(DatabaseMaintenanceOperation.ApplyCriticalErrorLogRetention)' disabled="@_isRunningDatabaseMaintenance">
<i class="bi bi-filter-circle me-1"></i>Run Cleanup
</button>
</div>

<div class="border rounded-3 p-3 d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3">
<div>
<div class="fw-semibold">Delete completed jobs older than @DatabaseMaintenanceDefaults.HistoryRetentionDays days</div>
<div class="small text-body-secondary">Removes old completed jobs and their stored transcript rows. Current candidates: @(DatabaseSummary?.CompletedJobsOlderThanRetentionCount ?? 0).</div>
</div>
<button type="button" class="btn btn-danger btn-sm" @onclick='() => OpenDatabaseMaintenanceModal(DatabaseMaintenanceOperation.DeleteCompletedJobsOlderThanRetention)' disabled="@_isRunningDatabaseMaintenance">
<i class="bi bi-trash3 me-1"></i>Delete Old Jobs
</button>
</div>

<div class="border rounded-3 p-3 d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3">
<div>
<div class="fw-semibold">Delete provider usage records older than @DatabaseMaintenanceDefaults.HistoryRetentionDays days</div>
<div class="small text-body-secondary">Clears historical provider usage snapshots that are no longer recent. Current candidates: @(DatabaseSummary?.ProviderUsageRecordsOlderThanRetentionCount ?? 0).</div>
</div>
<button type="button" class="btn btn-danger btn-sm" @onclick='() => OpenDatabaseMaintenanceModal(DatabaseMaintenanceOperation.DeleteProviderUsageOlderThanRetention)' disabled="@_isRunningDatabaseMaintenance">
<i class="bi bi-trash3 me-1"></i>Delete Old Usage
</button>
</div>

<div class="border rounded-3 p-3 d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3">
<div>
<div class="fw-semibold">Compact database</div>
<div class="small text-body-secondary">Runs SQLite compaction to reclaim unused space after cleanup. This is only available for SQLite databases.</div>
</div>
<button type="button" class="btn btn-primary btn-sm" @onclick='() => OpenDatabaseMaintenanceModal(DatabaseMaintenanceOperation.CompactDatabase)' disabled="@(_isRunningDatabaseMaintenance || DatabaseSummary?.SupportsCompaction != true)">
<i class="bi bi-arrows-collapse me-1"></i>Compact
</button>
</div>
</div>
</div>

<div class="card mb-3">
<div class="card-header bg-body-secondary">
<h5 class="mb-0 fw-semibold">
<i class="bi bi-box-arrow-up me-2"></i>Export
</h5>
</div>
<div class="card-body">
<p class="text-body-secondary small mb-3">
Download a JSON backup of your configuration including projects, ideas, skills, agents,
and schedules. Provider credentials and job history are not included.
</p>
<a href="/api/database/export" class="btn btn-primary">
<i class="bi bi-download me-2"></i>Download Export
</a>
</div>
</div>

<div class="card">
<div class="card-header bg-body-secondary">
<h5 class="mb-0 fw-semibold">
<i class="bi bi-box-arrow-in-down me-2"></i>Import
</h5>
</div>
<div class="card-body">
<p class="text-body-secondary small mb-3">
Import a previously exported JSON file. Existing records with the same name will be skipped
to avoid duplicates. New ideas will be added to existing projects.
</p>

@if (_importResult == null && !_isImporting)
{
<div class="mb-3">
<label class="form-label">Select export file</label>
<InputFile OnChange="OnImportFileSelected" accept=".json" class="form-control" />
</div>

@if (_importParseError != null)
{
<div class="alert alert-danger d-flex align-items-start gap-2 mb-3">
<i class="bi bi-exclamation-triangle-fill flex-shrink-0 mt-1"></i>
<div>@_importParseError</div>
</div>
}

@if (_importPreview != null)
{
<div class="border rounded p-3 mb-3 bg-body-secondary">
<h6 class="fw-semibold mb-2">Preview</h6>
<div class="d-flex flex-wrap gap-3 small">
<div class="d-flex align-items-center gap-1">
<i class="bi bi-folder text-primary"></i>
<span>@_importPreview.Projects.Count project(s)</span>
</div>
<div class="d-flex align-items-center gap-1">
<i class="bi bi-lightbulb text-warning"></i>
<span>@_importPreview.Projects.Sum(p => p.Ideas.Count) idea(s)</span>
</div>
<div class="d-flex align-items-center gap-1">
<i class="bi bi-tools text-success"></i>
<span>@_importPreview.Skills.Count skill(s)</span>
</div>
<div class="d-flex align-items-center gap-1">
<i class="bi bi-people text-info"></i>
<span>@_importPreview.TeamRoles.Count agent(s)</span>
</div>
<div class="d-flex align-items-center gap-1">
<i class="bi bi-clock text-secondary"></i>
<span>@_importPreview.Schedules.Count schedule(s)</span>
</div>
</div>
@if (_importPreview.ExportedAt != default)
{
<div class="text-body-secondary small mt-2">
Exported @_importPreview.ExportedAt.ToString("g") UTC
</div>
}
</div>

<button class="btn btn-primary" @onclick="ConfirmImport">
<i class="bi bi-check-lg me-1"></i>Import
</button>
}
}
else if (_isImporting)
{
<div class="d-flex align-items-center gap-2 text-body-secondary">
<span class="spinner-border spinner-border-sm" role="status"></span>
<span>Importing...</span>
</div>
}
else if (_importResult != null)
{
@if (_importResult.Imported.Count > 0)
{
<div class="mb-3">
<h6 class="text-success fw-semibold mb-2">
<i class="bi bi-check-circle me-1"></i>Imported (@_importResult.Imported.Count)
</h6>
<ul class="list-unstyled small mb-0">
@foreach (var item in _importResult.Imported)
{
<li class="d-flex align-items-start gap-1 mb-1">
<i class="bi bi-check text-success flex-shrink-0 mt-1"></i>
<span>@item</span>
</li>
}
</ul>
</div>
}

@if (_importResult.Skipped.Count > 0)
{
<div class="mb-3">
<h6 class="text-warning fw-semibold mb-2">
<i class="bi bi-skip-forward me-1"></i>Skipped — already exists (@_importResult.Skipped.Count)
</h6>
<ul class="list-unstyled small mb-0">
@foreach (var item in _importResult.Skipped)
{
<li class="d-flex align-items-start gap-1 mb-1">
<i class="bi bi-dash text-warning flex-shrink-0 mt-1"></i>
<span>@item</span>
</li>
}
</ul>
</div>
}

@if (_importResult.Errors.Count > 0)
{
<div class="mb-3">
<h6 class="text-danger fw-semibold mb-2">
<i class="bi bi-exclamation-triangle me-1"></i>Errors (@_importResult.Errors.Count)
</h6>
<ul class="list-unstyled small mb-0">
@foreach (var item in _importResult.Errors)
{
<li class="d-flex align-items-start gap-1 mb-1">
<i class="bi bi-x text-danger flex-shrink-0 mt-1"></i>
<span>@item</span>
</li>
}
</ul>
</div>
}

@if (_importResult.Imported.Count == 0 && _importResult.Skipped.Count == 0 && _importResult.Errors.Count == 0)
{
<p class="text-body-secondary small">Nothing to import.</p>
}

<button class="btn btn-secondary btn-sm" @onclick="ResetImport">
<i class="bi bi-arrow-counterclockwise me-1"></i>Import another file
</button>
}
</div>
</div>

<ConfirmationModal @bind-IsVisible="_showDatabaseMaintenanceModal" Title="@GetDatabaseMaintenanceModalTitle()"
Message="@GetDatabaseMaintenanceModalMessage()" SubMessage="@GetDatabaseMaintenanceModalSubMessage()"
ConfirmText="@GetDatabaseMaintenanceConfirmText()" ButtonClass="@GetDatabaseMaintenanceButtonClass()"
IsProcessing="@_isRunningDatabaseMaintenance" OnConfirm="RunDatabaseMaintenance" />
<ConfirmationModal @bind-IsVisible="_showDatabaseMigrationModal" Title="Migrate Database"
Message="@GetDatabaseMigrationModalMessage()" SubMessage="@GetDatabaseMigrationModalSubMessage()"
ConfirmText="Migrate" ButtonClass="btn-primary" IsProcessing="@_isMigratingDatabase"
OnConfirm="RunDatabaseMigration" />

@code {
	private static readonly JsonSerializerOptions ImportJsonOptions = new()
	{
		PropertyNameCaseInsensitive = true,
		Converters = { new JsonStringEnumConverter() },
	};

	[Parameter] public DatabaseStorageSummary? DatabaseSummary { get; set; }
	[Parameter] public EventCallback OnDatabaseChanged { get; set; }

	private DatabaseExportDto? _importPreview;
	private DatabaseImportResult? _importResult;
	private string? _importParseError;
	private bool _isImporting;
	private bool _isLoadingDatabaseConfiguration;
	private DatabaseConfigurationInfo? _databaseConfiguration;
	private DatabaseMaintenanceResult? _databaseMaintenanceResult;
	private DatabaseMigrationResult? _databaseMigrationResult;
	private DatabaseMigrationRequest _databaseMigrationRequest = new();
	private DatabaseMaintenanceOperation? _pendingDatabaseMaintenanceOperation;
	private bool _isMigratingDatabase;
	private bool _isRunningDatabaseMaintenance;
	private bool _showDatabaseMigrationModal;
	private bool _showDatabaseMaintenanceModal;

	protected override async Task OnInitializedAsync()
	{
		await LoadDatabaseConfiguration();
	}

	private async Task RefreshDatabaseConfiguration() => await LoadDatabaseConfiguration();

	private async Task LoadDatabaseConfiguration()
	{
		_isLoadingDatabaseConfiguration = true;

		try
		{
			_databaseConfiguration = await DatabaseService.GetConfigurationAsync();
			if (string.IsNullOrWhiteSpace(_databaseMigrationRequest.ConnectionString) &&
				(string.IsNullOrWhiteSpace(_databaseMigrationRequest.Provider) || _databaseMigrationRequest.Provider == "sqlite"))
			{
				_databaseMigrationRequest.Provider = _databaseConfiguration.Provider;
			}
		}
		catch (Exception ex)
		{
			NotificationService.ShowError($"Failed to load database configuration: {ex.Message}");
		}
		finally
		{
			_isLoadingDatabaseConfiguration = false;
		}
	}

	private async Task OnImportFileSelected(InputFileChangeEventArgs e)
	{
		_importPreview = null;
		_importParseError = null;

		var file = e.File;
		if (file == null)
			return;

		try
		{
			using var stream = file.OpenReadStream(maxAllowedSize: 50 * 1024 * 1024);
			var export = await JsonSerializer.DeserializeAsync<DatabaseExportDto>(stream, ImportJsonOptions);
			if (export == null)
			{
				_importParseError = "The file could not be parsed as a valid VibeSwarm export.";
				return;
			}
			_importPreview = export;
		}
		catch (JsonException ex)
		{
			_importParseError = $"Invalid JSON: {ex.Message}";
		}
		catch (Exception ex)
		{
			_importParseError = $"Failed to read file: {ex.Message}";
		}
	}

	private async Task ConfirmImport()
	{
		if (_importPreview == null)
			return;

		_isImporting = true;

		try
		{
			_importResult = await DatabaseService.ImportAsync(_importPreview);
			NotificationService.ShowSuccess("Import complete!");
		}
		catch (Exception ex)
		{
			NotificationService.ShowError($"Import failed: {ex.Message}");
			_isImporting = false;
			return;
		}

		_isImporting = false;
		_importPreview = null;
	}

	private void ResetImport()
	{
		_importResult = null;
		_importPreview = null;
		_importParseError = null;
	}

	private void OpenDatabaseMaintenanceModal(DatabaseMaintenanceOperation operation)
	{
		_pendingDatabaseMaintenanceOperation = operation;
		_showDatabaseMaintenanceModal = true;
	}

	private void OpenDatabaseMigrationModal()
	{
		if (!string.IsNullOrWhiteSpace(GetDatabaseMigrationValidationMessage()))
			return;

		_showDatabaseMigrationModal = true;
	}

	private async Task RunDatabaseMaintenance()
	{
		if (!_pendingDatabaseMaintenanceOperation.HasValue)
			return;

		_isRunningDatabaseMaintenance = true;

		try
		{
			_databaseMaintenanceResult = await DatabaseService.RunMaintenanceAsync(new DatabaseMaintenanceRequest
			{
				Operation = _pendingDatabaseMaintenanceOperation.Value
			});

			_showDatabaseMaintenanceModal = false;
			NotificationService.ShowSuccess(_databaseMaintenanceResult.Message);
			await OnDatabaseChanged.InvokeAsync();
		}
		catch (Exception ex)
		{
			NotificationService.ShowError($"Database cleanup failed: {ex.Message}");
		}
		finally
		{
			_isRunningDatabaseMaintenance = false;
		}
	}

	private async Task RunDatabaseMigration()
	{
		var validationMessage = GetDatabaseMigrationValidationMessage();
		if (!string.IsNullOrWhiteSpace(validationMessage))
		{
			NotificationService.ShowError(validationMessage);
			return;
		}

		_isMigratingDatabase = true;

		try
		{
			_databaseMigrationResult = await DatabaseService.MigrateAsync(_databaseMigrationRequest);
			_showDatabaseMigrationModal = false;
			await LoadDatabaseConfiguration();
			NotificationService.ShowSuccess(_databaseMigrationResult.Message);
			await OnDatabaseChanged.InvokeAsync();
		}
		catch (Exception ex)
		{
			NotificationService.ShowError($"Database migration failed: {ex.Message}");
		}
		finally
		{
			_isMigratingDatabase = false;
		}
	}

	private string GetDatabaseMaintenanceModalTitle() => _pendingDatabaseMaintenanceOperation switch
	{
		DatabaseMaintenanceOperation.ApplyCriticalErrorLogRetention => "Apply Log Retention",
		DatabaseMaintenanceOperation.DeleteCompletedJobsOlderThanRetention => "Delete Old Completed Jobs",
		DatabaseMaintenanceOperation.DeleteProviderUsageOlderThanRetention => "Delete Old Provider Usage",
		DatabaseMaintenanceOperation.CompactDatabase => "Compact Database",
		_ => "Confirm Cleanup"
	};

	private string GetDatabaseMaintenanceModalMessage() => _pendingDatabaseMaintenanceOperation switch
	{
		DatabaseMaintenanceOperation.ApplyCriticalErrorLogRetention => "Apply the configured critical error log retention policy now?",
		DatabaseMaintenanceOperation.DeleteCompletedJobsOlderThanRetention => $"Delete completed jobs older than {DatabaseMaintenanceDefaults.HistoryRetentionDays} days?",
		DatabaseMaintenanceOperation.DeleteProviderUsageOlderThanRetention => $"Delete provider usage records older than {DatabaseMaintenanceDefaults.HistoryRetentionDays} days?",
		DatabaseMaintenanceOperation.CompactDatabase => "Compact the SQLite database file now?",
		_ => "Run the selected cleanup operation?"
	};

	private string? GetDatabaseMaintenanceModalSubMessage() => _pendingDatabaseMaintenanceOperation switch
	{
		DatabaseMaintenanceOperation.DeleteCompletedJobsOlderThanRetention => "This also removes stored messages and provider-attempt rows for those completed jobs.",
		DatabaseMaintenanceOperation.CompactDatabase => "Compaction can take a moment on larger databases and is only available for SQLite.",
		_ => null
	};

	private string GetDatabaseMaintenanceConfirmText() => _pendingDatabaseMaintenanceOperation switch
	{
		DatabaseMaintenanceOperation.ApplyCriticalErrorLogRetention => "Apply Retention",
		DatabaseMaintenanceOperation.DeleteCompletedJobsOlderThanRetention => "Delete Jobs",
		DatabaseMaintenanceOperation.DeleteProviderUsageOlderThanRetention => "Delete Usage",
		DatabaseMaintenanceOperation.CompactDatabase => "Compact",
		_ => "Confirm"
	};

	private string GetDatabaseMaintenanceButtonClass() => _pendingDatabaseMaintenanceOperation switch
	{
		DatabaseMaintenanceOperation.DeleteCompletedJobsOlderThanRetention => "btn-danger",
		DatabaseMaintenanceOperation.DeleteProviderUsageOlderThanRetention => "btn-danger",
		DatabaseMaintenanceOperation.CompactDatabase => "btn-primary",
		_ => "btn-secondary"
	};

	private string GetDatabaseProviderLabel() => DatabaseSummary?.Provider switch
	{
		"sqlite" => "SQLite database",
		"mysql" => "MySQL database",
		"postgresql" => "PostgreSQL database",
		"sqlserver" => "SQL Server database",
		{ Length: > 0 } provider => provider,
		_ => "Database size unavailable"
	};

	private static string GetDatabaseProviderDisplayName(string? provider) => provider switch
	{
		"sqlite" => "SQLite",
		"mysql" => "MySQL",
		"postgresql" => "PostgreSQL",
		"sqlserver" => "SQL Server",
		{ Length: > 0 } value => value,
		_ => "Unknown"
	};

	private string GetDatabaseMigrationConnectionStringPlaceholder() => _databaseMigrationRequest.Provider switch
	{
		"sqlite" => OperatingSystem.IsWindows()
			? @"Data Source=C:\VibeSwarm\vibeswarm.db"
			: "Data Source=/var/lib/vibeswarm/vibeswarm.db",
		"mysql" => "Server=localhost;Database=vibeswarm;User=vibeswarm;Password=secret",
		"postgresql" => "Host=localhost;Database=vibeswarm;Username=vibeswarm;Password=secret",
		"sqlserver" => "Server=localhost;Database=vibeswarm;Trusted_Connection=true;TrustServerCertificate=true",
		_ => string.Empty
	};

	private bool IsDatabaseMigrationDisabled() =>
		_isMigratingDatabase ||
		_databaseConfiguration == null ||
		_databaseConfiguration.HasEnvironmentOverride ||
		!string.IsNullOrWhiteSpace(GetDatabaseMigrationValidationMessage());

	private string? GetDatabaseMigrationValidationMessage()
	{
		if (_databaseConfiguration?.HasEnvironmentOverride == true)
			return "Environment variable overrides must be cleared before migrating from the UI.";

		if (string.IsNullOrWhiteSpace(_databaseMigrationRequest.Provider))
			return "Choose a target provider.";

		if (string.IsNullOrWhiteSpace(_databaseMigrationRequest.ConnectionString))
			return "Enter a target connection string.";

		return null;
	}

	private string GetDatabaseMigrationModalMessage()
		=> $"Copy all VibeSwarm data to the {GetDatabaseProviderDisplayName(_databaseMigrationRequest.Provider)} database now?";

	private string GetDatabaseMigrationModalSubMessage()
		=> "The target database must be empty. The current database remains untouched, and VibeSwarm will switch to the new database after restart.";

	internal static string FormatBytes(long? bytes)
	{
		if (!bytes.HasValue)
			return "Unavailable";

		const long kilobyte = 1024;
		const long megabyte = kilobyte * 1024;
		const long gigabyte = megabyte * 1024;

		if (bytes.Value >= gigabyte)
			return $"{bytes.Value / (double)gigabyte:0.#} GB";

		if (bytes.Value >= megabyte)
			return $"{bytes.Value / (double)megabyte:0.#} MB";

		if (bytes.Value >= kilobyte)
			return $"{bytes.Value / (double)kilobyte:0.#} KB";

		return $"{bytes.Value} B";
	}
}
