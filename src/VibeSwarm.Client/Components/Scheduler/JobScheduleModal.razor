@using VibeSwarm.Shared.Data
@using VibeSwarm.Shared.Services
@using VibeSwarm.Shared.Utilities
@using VibeSwarm.Shared.Validation
@inject IJobScheduleService JobScheduleService
@inject IProjectService ProjectService
@inject IProviderService ProviderService
@inject IInferenceProviderService InferenceProviderService
@inject AppTimeZoneService AppTimeZoneService
@inject NotificationService NotificationService

<ModalDialog IsVisible="IsVisible" IsVisibleChanged="HandleModalVisibilityChanged"
			 Title="@(IsEdit ? "Edit Schedule" : "Add Schedule")" Icon="calendar-event"
			 Size="ModalDialog.ModalSize.Large" OnClose="HandleClose">
	<ChildContent>
		<EditForm Model="@Schedule" OnValidSubmit="HandleValidSubmit">
			<DataAnnotationsValidator />
			<ValidationSummary class="text-danger mb-3" />

			<div class="mb-3">
				<label for="schedule-project" class="form-label">Project</label>
				<select id="schedule-project" class="form-select" value="@GetProjectValue()" @onchange="OnProjectChanged">
					<option value="">Select project...</option>
					@foreach (var project in _projects)
					{
						<option value="@project.Id">@project.Name</option>
					}
				</select>
			</div>

			<div class="row g-3 mb-3">
				<div class="col-12 col-lg-4">
					<label for="schedule-type" class="form-label">Schedule Type</label>
					<InputSelect id="schedule-type" @bind-Value="Schedule.ScheduleType" @bind-Value:after="OnScheduleTypeChanged" class="form-select">
						<option value="@JobScheduleType.RunJob">Run Job</option>
						<option value="@JobScheduleType.GenerateIdeas">Generate Ideas</option>
					</InputSelect>
				</div>
			</div>

			@if (Schedule.ScheduleType == JobScheduleType.RunJob)
			{
				<div class="mb-3">
					<label for="schedule-prompt" class="form-label">Prompt</label>
					<InputTextArea id="schedule-prompt" @bind-Value="Schedule.Prompt" class="form-control" rows="5"
								   placeholder="update dependencies, check for security issues" />
					<ValidationMessage For="@(() => Schedule.Prompt)" class="text-danger small" />
					<div class="form-text">Each time this schedule runs, VibeSwarm will create a new job with this prompt.</div>
				</div>
			}
			else
			{
				<div class="mb-3">
					<label for="schedule-idea-count" class="form-label">Ideas to Generate</label>
					<InputSelect id="schedule-idea-count" @bind-Value="Schedule.IdeaCount" class="form-select">
						@for (var count = ValidationLimits.JobScheduleIdeaCountMin; count <= ValidationLimits.JobScheduleIdeaCountMax; count++)
						{
							<option value="@count">@count</option>
						}
					</InputSelect>
					<div class="form-text">Each run will analyze the project and add fresh ideas while avoiding existing backlog duplicates.</div>
				</div>
			}

			<div class="row g-3">
				@if (Schedule.ScheduleType == JobScheduleType.RunJob)
				{
					<div class="col-12 col-lg-4">
						<label for="schedule-target" class="form-label">Executor Type</label>
						<InputSelect id="schedule-target" @bind-Value="Schedule.ExecutionTarget" @bind-Value:after="OnExecutionTargetChanged" class="form-select">
							<option value="@JobScheduleExecutionTarget.Provider">Provider</option>
							<option value="@JobScheduleExecutionTarget.TeamRole">Team Member</option>
						</InputSelect>
						<div class="form-text">Choose a direct provider or a project team member role that should run this task.</div>
					</div>

					@if (Schedule.ExecutionTarget == JobScheduleExecutionTarget.Provider)
					{
						<div class="col-12 col-lg-4">
							<label for="schedule-provider" class="form-label">Provider</label>
							<select id="schedule-provider" class="form-select" value="@GetProviderValue()" @onchange="OnProviderChanged"
									disabled="@(!_allowedProviders.Any())">
								<option value="">@(_allowedProviders.Any() ? "Select provider..." : "No enabled providers")</option>
								@foreach (var provider in _allowedProviders)
								{
									<option value="@provider.Id">@provider.Name</option>
								}
							</select>
						</div>
					}
					else
					{
						<div class="col-12 col-lg-4">
							<label for="schedule-team-role" class="form-label">Team Member</label>
							<select id="schedule-team-role" class="form-select" value="@GetTeamRoleValue()" @onchange="OnTeamRoleChanged"
									disabled="@(!_availableTeamAssignments.Any())">
								<option value="">@(_availableTeamAssignments.Any() ? "Select team member..." : "No enabled team members")</option>
								@foreach (var assignment in _availableTeamAssignments)
								{
									<option value="@assignment.TeamRoleId">@GetTeamAssignmentDisplayText(assignment)</option>
								}
							</select>
							@if (!_availableTeamAssignments.Any())
							{
								<div class="form-text text-warning">Assign an enabled team role with an enabled provider in the project settings first.</div>
							}
						</div>
					}
				}
				else
				{
					<div class="col-12 col-lg-4">
						<label for="schedule-inference-provider" class="form-label">Inference Provider</label>
						<select id="schedule-inference-provider" class="form-select" value="@GetInferenceProviderValue()" @onchange="OnInferenceProviderChanged"
								disabled="@(!_inferenceProviders.Any())">
							<option value="">@(_inferenceProviders.Any() ? "Select inference provider..." : "No enabled inference providers")</option>
							@foreach (var provider in _inferenceProviders)
							{
								<option value="@provider.Id">@provider.Name</option>
							}
						</select>
						@if (!_inferenceProviders.Any())
						{
							<div class="form-text text-warning">Configure an enabled inference provider first.</div>
						}
					</div>
				}

				<div class="col-12 col-lg-4">
					<label for="schedule-model" class="form-label">Model</label>
					<select id="schedule-model" class="form-select" @bind="_selectedModelId" @bind:after="OnModelChanged"
							disabled="@(_isLoadingModels || !_models.Any())">
						<option value="">@(_isLoadingModels ? "Loading..." : "Use assigned default")</option>
						@foreach (var model in _models)
						{
							<option value="@model.ModelId">@(model.DisplayName ?? model.ModelId)</option>
						}
					</select>
					<div class="form-text">@GetModelHelpText()</div>
				</div>
			</div>

			@if (Schedule.ScheduleType == JobScheduleType.RunJob && Schedule.ExecutionTarget == JobScheduleExecutionTarget.TeamRole)
			{
				var assignment = GetSelectedTeamAssignment();
				@if (assignment != null)
				{
					<div class="small text-body-secondary mt-2 d-flex flex-wrap gap-3">
						<span class="d-inline-flex align-items-center gap-1">
							<i class="bi bi-cpu opacity-75"></i>
							@(assignment.Provider?.Name ?? "Unknown provider")
						</span>
						@if (!string.IsNullOrWhiteSpace(assignment.PreferredReasoningEffort))
						{
							<span class="d-inline-flex align-items-center gap-1">
								<i class="bi bi-lightning-charge opacity-75"></i>
								@assignment.PreferredReasoningEffort
							</span>
						}
					</div>
				}
			}

			<div class="row g-3 mt-1">
				<div class="col-12 col-lg-4">
					<label for="schedule-frequency" class="form-label">Schedule</label>
					<InputSelect id="schedule-frequency" @bind-Value="Schedule.Frequency" class="form-select">
						@foreach (var frequency in Enum.GetValues<JobScheduleFrequency>())
						{
							<option value="@frequency">@frequency</option>
						}
					</InputSelect>
				</div>

				@if (Schedule.Frequency == JobScheduleFrequency.Hourly)
				{
					<div class="col-12 col-lg-4">
						<label for="schedule-minute" class="form-label">Minute past the hour (@AppTimeZoneService.CurrentTimeZoneId)</label>
						<InputNumber id="schedule-minute" @bind-Value="Schedule.MinuteUtc" class="form-control" min="0" max="59" />
					</div>
				}
				else
				{
					<div class="col-12 col-lg-4">
						<label for="schedule-time" class="form-label">Run time (@AppTimeZoneService.CurrentTimeZoneId)</label>
						<input id="schedule-time" type="time" class="form-control" value="@_timeValue" @onchange="OnTimeChanged" />
					</div>
				}

				@if (Schedule.Frequency == JobScheduleFrequency.Weekly)
				{
					<div class="col-12 col-lg-4">
						<label for="schedule-weekday" class="form-label">Day of week</label>
						<InputSelect id="schedule-weekday" @bind-Value="Schedule.WeeklyDay" class="form-select">
							@foreach (var day in Enum.GetValues<DayOfWeek>())
							{
								<option value="@day">@day</option>
							}
						</InputSelect>
					</div>
				}
				else if (Schedule.Frequency == JobScheduleFrequency.Monthly)
				{
					<div class="col-12 col-lg-4">
						<label for="schedule-day-of-month" class="form-label">Day of month</label>
						<InputNumber id="schedule-day-of-month" @bind-Value="Schedule.DayOfMonth" class="form-control" min="1" max="31" />
						<div class="form-text">Shorter months run on their final day.</div>
					</div>
				}
			</div>

			<div class="form-check form-switch mt-3">
				<InputCheckbox id="schedule-enabled" @bind-Value="Schedule.IsEnabled" class="form-check-input" />
				<label class="form-check-label" for="schedule-enabled">Active</label>
			</div>
			<div class="form-text">Times use the configured timezone and are converted to UTC when the scheduler runs.</div>

			@if (!string.IsNullOrEmpty(ErrorMessage))
			{
				<div class="text-danger small mt-3">
					<i class="bi bi-exclamation-circle me-1"></i>@ErrorMessage
				</div>
			}

			<div class="d-flex gap-2 justify-content-end mt-4">
				<button type="button" class="btn btn-secondary" @onclick="HandleCancel">Cancel</button>
				<button type="submit" class="btn btn-primary" disabled="@IsSaving">
					@if (IsSaving)
					{
						<span class="spinner-border spinner-border-sm me-1" role="status"></span>
					}
					@(IsSaving ? "Saving..." : (IsEdit ? "Update Schedule" : "Add Schedule"))
				</button>
			</div>
		</EditForm>
	</ChildContent>
</ModalDialog>

@code {
	[Parameter]
	public bool IsVisible { get; set; }

	[Parameter]
	public EventCallback<bool> IsVisibleChanged { get; set; }

	[Parameter]
	public JobSchedule? EditSchedule { get; set; }

	[Parameter]
	public EventCallback<Guid?> OnSaved { get; set; }

	[Parameter]
	public EventCallback OnCancelled { get; set; }

	[Parameter]
	public EventCallback OnClosed { get; set; }

	private JobSchedule Schedule { get; set; } = new();
	private bool IsEdit => EditSchedule != null;
	private bool IsSaving { get; set; }
	private string? ErrorMessage { get; set; }
	private bool _previousIsVisible;
	private List<Project> _projects = [];
	private List<Provider> _providers = [];
	private List<InferenceProvider> _inferenceProviders = [];
	private List<Provider> _allowedProviders = [];
	private List<ProjectTeamRole> _availableTeamAssignments = [];
	private List<ProviderModel> _models = [];
	private bool _isLoadingModels;
	private string _selectedModelId = string.Empty;
	private string _timeValue = "09:00";

	protected override async Task OnInitializedAsync()
	{
		await AppTimeZoneService.EnsureInitializedAsync();
		await LoadLookupDataAsync();
	}

	protected override async Task OnParametersSetAsync()
	{
		if (!_projects.Any() || !_providers.Any())
		{
			await LoadLookupDataAsync();
		}

		if (IsVisible && !_previousIsVisible)
		{
			await ResetStateAsync();
		}

		_previousIsVisible = IsVisible;
	}

	private async Task LoadLookupDataAsync()
	{
		var projectsTask = ProjectService.GetAllAsync();
		var providersTask = ProviderService.GetAllAsync();
		var inferenceProvidersTask = InferenceProviderService.GetEnabledAsync();
		await Task.WhenAll(projectsTask, providersTask, inferenceProvidersTask);

		_projects = projectsTask.Result
			.OrderBy(project => project.Name)
			.ToList();
		_providers = providersTask.Result
			.Where(provider => provider.IsEnabled)
			.OrderByDescending(provider => provider.IsDefault)
			.ThenBy(provider => provider.Name)
			.ToList();
		_inferenceProviders = inferenceProvidersTask.Result
			.OrderBy(provider => provider.Name)
			.ToList();
	}

	private async Task ResetStateAsync()
	{
		ErrorMessage = null;
		IsSaving = false;
		_models = [];

		if (EditSchedule != null)
		{
			Schedule = new JobSchedule
			{
				Id = EditSchedule.Id,
				ProjectId = EditSchedule.ProjectId,
				ScheduleType = EditSchedule.ScheduleType,
				ExecutionTarget = EditSchedule.ExecutionTarget,
				ProviderId = EditSchedule.ProviderId,
				TeamRoleId = EditSchedule.TeamRoleId,
				InferenceProviderId = EditSchedule.InferenceProviderId,
				Prompt = EditSchedule.Prompt,
				ModelId = EditSchedule.ModelId,
				IdeaCount = EditSchedule.IdeaCount,
				Frequency = EditSchedule.Frequency,
				HourUtc = EditSchedule.HourUtc,
				MinuteUtc = EditSchedule.MinuteUtc,
				WeeklyDay = EditSchedule.WeeklyDay,
				DayOfMonth = EditSchedule.DayOfMonth,
				IsEnabled = EditSchedule.IsEnabled,
				CreatedAt = EditSchedule.CreatedAt,
				UpdatedAt = EditSchedule.UpdatedAt,
				NextRunAtUtc = EditSchedule.NextRunAtUtc,
				LastRunAtUtc = EditSchedule.LastRunAtUtc,
				LastError = EditSchedule.LastError
			};
		}
		else
		{
			var project = _projects.FirstOrDefault();
			Schedule = new JobSchedule
			{
				ProjectId = project?.Id ?? Guid.Empty,
				ScheduleType = JobScheduleType.RunJob,
				ExecutionTarget = JobScheduleExecutionTarget.Provider,
				InferenceProviderId = _inferenceProviders.FirstOrDefault()?.Id,
				IdeaCount = SuggestIdeasRequest.DefaultIdeaCount,
				Frequency = JobScheduleFrequency.Daily,
				HourUtc = 9,
				MinuteUtc = 0,
				WeeklyDay = DayOfWeek.Monday,
				DayOfMonth = 1,
				IsEnabled = true
			};
		}

		_timeValue = $"{Schedule.HourUtc:D2}:{Schedule.MinuteUtc:D2}";
		await SyncExecutionTargetsAsync(preserveCurrentSelection: IsEdit);
	}

	private Project? GetSelectedProject()
		=> _projects.FirstOrDefault(project => project.Id == Schedule.ProjectId);

	private async Task SyncExecutionTargetsAsync(bool preserveCurrentSelection)
	{
		var project = GetSelectedProject();
		_allowedProviders = ProjectExecutionDefaults.GetAllowedProviders(project, _providers);
		_availableTeamAssignments = project?.TeamAssignments?
			.Where(assignment =>
				assignment.IsEnabled &&
				assignment.TeamRole != null &&
				assignment.TeamRole.IsEnabled &&
				assignment.Provider != null &&
				assignment.Provider.IsEnabled)
			.OrderBy(assignment => assignment.TeamRole!.Name, StringComparer.OrdinalIgnoreCase)
			.ToList() ?? [];

		if (Schedule.ScheduleType == JobScheduleType.GenerateIdeas)
		{
			if (!preserveCurrentSelection || !Schedule.InferenceProviderId.HasValue || !_inferenceProviders.Any(provider => provider.Id == Schedule.InferenceProviderId.Value))
			{
				Schedule.InferenceProviderId = _inferenceProviders.FirstOrDefault()?.Id;
			}

			Schedule.ProviderId = null;
			Schedule.TeamRoleId = null;
		}
		else if (Schedule.ExecutionTarget == JobScheduleExecutionTarget.Provider)
		{
			if (!preserveCurrentSelection || !Schedule.ProviderId.HasValue || !_allowedProviders.Any(provider => provider.Id == Schedule.ProviderId.Value))
			{
				Schedule.ProviderId = ProjectExecutionDefaults.GetPreferredProvider(project, _providers)?.Id
					?? _allowedProviders.FirstOrDefault()?.Id;
			}

			Schedule.TeamRoleId = null;
		}
		else
		{
			if (!preserveCurrentSelection || !Schedule.TeamRoleId.HasValue || !_availableTeamAssignments.Any(assignment => assignment.TeamRoleId == Schedule.TeamRoleId.Value))
			{
				Schedule.TeamRoleId = _availableTeamAssignments.FirstOrDefault()?.TeamRoleId;
			}

			Schedule.ProviderId = null;
		}

		await LoadModelsAsync();
	}

	private async Task LoadModelsAsync()
	{
		_models = [];
		_selectedModelId = string.Empty;

		var resolvedProviderId = ResolveSelectedProviderId();
		if (!resolvedProviderId.HasValue)
		{
			Schedule.ModelId = null;
			return;
		}

		_isLoadingModels = true;
		StateHasChanged();

		try
		{
			if (Schedule.ScheduleType == JobScheduleType.GenerateIdeas)
			{
				_models = (await InferenceProviderService.GetModelsAsync(resolvedProviderId.Value))
					.Where(model => model.IsAvailable)
					.Select(model => new ProviderModel
					{
						Id = model.Id,
						ModelId = model.ModelId,
						DisplayName = model.DisplayName ?? model.ModelId,
						IsAvailable = model.IsAvailable,
						IsDefault = model.IsDefault
					})
					.OrderByDescending(model => model.IsDefault)
					.ThenBy(model => model.DisplayName ?? model.ModelId)
					.ToList();
			}
			else
			{
				_models = (await ProviderService.GetModelsAsync(resolvedProviderId.Value))
					.Where(model => model.IsAvailable)
					.OrderByDescending(model => model.IsDefault)
					.ThenBy(model => model.DisplayName ?? model.ModelId)
					.ToList();
			}

			if (!string.IsNullOrWhiteSpace(Schedule.ModelId) && _models.Any(model => model.ModelId == Schedule.ModelId))
			{
				_selectedModelId = Schedule.ModelId;
			}
			else
			{
				_selectedModelId = ResolveDefaultModel(resolvedProviderId.Value);
				Schedule.ModelId = string.IsNullOrWhiteSpace(_selectedModelId) ? null : _selectedModelId;
			}
		}
		catch
		{
			_models = [];
			_selectedModelId = string.Empty;
			Schedule.ModelId = null;
		}
		finally
		{
			_isLoadingModels = false;
		}
	}

	private async Task OnProjectChanged(ChangeEventArgs args)
	{
		Schedule.ProjectId = TryParseGuid(args.Value);
		ErrorMessage = null;
		await SyncExecutionTargetsAsync(preserveCurrentSelection: false);
	}

	private async Task OnExecutionTargetChanged()
	{
		ErrorMessage = null;
		await SyncExecutionTargetsAsync(preserveCurrentSelection: false);
	}

	private async Task OnScheduleTypeChanged()
	{
		ErrorMessage = null;
		await SyncExecutionTargetsAsync(preserveCurrentSelection: false);
	}

	private async Task OnProviderChanged(ChangeEventArgs args)
	{
		Schedule.ProviderId = TryParseNullableGuid(args.Value);
		ErrorMessage = null;
		await LoadModelsAsync();
	}

	private async Task OnInferenceProviderChanged(ChangeEventArgs args)
	{
		Schedule.InferenceProviderId = TryParseNullableGuid(args.Value);
		ErrorMessage = null;
		await LoadModelsAsync();
	}

	private async Task OnTeamRoleChanged(ChangeEventArgs args)
	{
		Schedule.TeamRoleId = TryParseNullableGuid(args.Value);
		ErrorMessage = null;
		await LoadModelsAsync();
	}

	private Task OnModelChanged()
	{
		Schedule.ModelId = string.IsNullOrWhiteSpace(_selectedModelId) ? null : _selectedModelId;
		return Task.CompletedTask;
	}

	private Task OnTimeChanged(ChangeEventArgs args)
	{
		_timeValue = args.Value?.ToString() ?? string.Empty;
		return Task.CompletedTask;
	}

	private async Task HandleValidSubmit()
	{
		ErrorMessage = null;

		if (Schedule.ProjectId == Guid.Empty)
		{
			ErrorMessage = "Please select a project.";
			return;
		}

		if (Schedule.ScheduleType == JobScheduleType.RunJob && Schedule.ExecutionTarget == JobScheduleExecutionTarget.Provider && !Schedule.ProviderId.HasValue)
		{
			ErrorMessage = "Please select a provider.";
			return;
		}

		if (Schedule.ScheduleType == JobScheduleType.RunJob && Schedule.ExecutionTarget == JobScheduleExecutionTarget.TeamRole && !Schedule.TeamRoleId.HasValue)
		{
			ErrorMessage = "Please select a team member.";
			return;
		}

		if (Schedule.ScheduleType == JobScheduleType.GenerateIdeas && !Schedule.InferenceProviderId.HasValue)
		{
			ErrorMessage = "Please select an inference provider.";
			return;
		}

		if (Schedule.Frequency != JobScheduleFrequency.Hourly)
		{
			if (!TimeOnly.TryParse(_timeValue, out var time))
			{
				ErrorMessage = "Please provide a valid run time.";
				return;
			}

			Schedule.HourUtc = time.Hour;
			Schedule.MinuteUtc = time.Minute;
		}
		else
		{
			Schedule.HourUtc = 0;
		}

		if (Schedule.ScheduleType == JobScheduleType.GenerateIdeas)
		{
			Schedule.ProviderId = null;
			Schedule.TeamRoleId = null;
			Schedule.Prompt = string.Empty;
		}
		else if (Schedule.ExecutionTarget == JobScheduleExecutionTarget.Provider)
		{
			Schedule.TeamRoleId = null;
			Schedule.InferenceProviderId = null;
		}
		else
		{
			Schedule.ProviderId = null;
			Schedule.InferenceProviderId = null;
		}

		Schedule.ModelId = string.IsNullOrWhiteSpace(_selectedModelId) ? null : _selectedModelId;

		IsSaving = true;
		try
		{
			var saved = IsEdit
				? await JobScheduleService.UpdateAsync(Schedule)
				: await JobScheduleService.CreateAsync(Schedule);

			NotificationService.ShowSuccess(IsEdit ? "Schedule updated successfully." : "Schedule created successfully.");
			await IsVisibleChanged.InvokeAsync(false);
			await OnSaved.InvokeAsync(saved.Id);
		}
		catch (Exception ex)
		{
			ErrorMessage = ex.Message;
		}
		finally
		{
			IsSaving = false;
		}
	}

	private async Task HandleCancel()
	{
		await IsVisibleChanged.InvokeAsync(false);
		await OnCancelled.InvokeAsync();
	}

	private async Task HandleClose()
	{
		await IsVisibleChanged.InvokeAsync(false);
		await OnClosed.InvokeAsync();
	}

	private async Task HandleModalVisibilityChanged(bool isVisible)
	{
		IsVisible = isVisible;
		await IsVisibleChanged.InvokeAsync(isVisible);
	}

	private ProjectTeamRole? GetSelectedTeamAssignment()
		=> Schedule.TeamRoleId.HasValue
			? _availableTeamAssignments.FirstOrDefault(assignment => assignment.TeamRoleId == Schedule.TeamRoleId.Value)
			: null;

	private Guid? ResolveSelectedProviderId()
	{
		if (Schedule.ScheduleType == JobScheduleType.GenerateIdeas)
		{
			return Schedule.InferenceProviderId;
		}

		if (Schedule.ExecutionTarget == JobScheduleExecutionTarget.Provider)
		{
			return Schedule.ProviderId;
		}

		return GetSelectedTeamAssignment()?.ProviderId;
	}

	private string ResolveDefaultModel(Guid providerId)
	{
		if (Schedule.ScheduleType == JobScheduleType.GenerateIdeas)
		{
			return _models.FirstOrDefault(model => model.IsDefault)?.ModelId ?? string.Empty;
		}

		if (Schedule.ExecutionTarget == JobScheduleExecutionTarget.Provider)
		{
			return ProjectExecutionDefaults.ResolveModelId(GetSelectedProject(), providerId, _models);
		}

		var teamAssignment = GetSelectedTeamAssignment();
		if (!string.IsNullOrWhiteSpace(teamAssignment?.PreferredModelId) && _models.Any(model => model.ModelId == teamAssignment.PreferredModelId))
		{
			return teamAssignment.PreferredModelId!;
		}

		return _models.FirstOrDefault(model => model.IsDefault)?.ModelId ?? string.Empty;
	}

	private string GetModelHelpText()
	{
		if (Schedule.ScheduleType == JobScheduleType.GenerateIdeas)
		{
			return "Leave empty to use the inference provider's default suggest/default model.";
		}

		if (Schedule.ExecutionTarget == JobScheduleExecutionTarget.Provider)
		{
			return "Leave empty to use the project's preferred provider model or the provider default.";
		}

		var assignment = GetSelectedTeamAssignment();
		if (assignment == null)
		{
			return "Leave empty to use the selected team member's assigned default model.";
		}

		if (!string.IsNullOrWhiteSpace(assignment.PreferredModelId))
		{
			return $"Leave empty to use {assignment.TeamRole?.Name}'s assigned model ({assignment.PreferredModelId}).";
		}

		return "Leave empty to use the selected team member's provider default model.";
	}

	private static string GetTeamAssignmentDisplayText(ProjectTeamRole assignment)
	{
		var roleName = assignment.TeamRole?.Name ?? "Unknown team member";
		var providerName = assignment.Provider?.Name ?? "Unknown provider";
		return $"{roleName} ({providerName})";
	}

	private string GetProjectValue() => Schedule.ProjectId == Guid.Empty ? string.Empty : Schedule.ProjectId.ToString();
	private string GetProviderValue() => Schedule.ProviderId?.ToString() ?? string.Empty;
	private string GetTeamRoleValue() => Schedule.TeamRoleId?.ToString() ?? string.Empty;
	private string GetInferenceProviderValue() => Schedule.InferenceProviderId?.ToString() ?? string.Empty;

	private static Guid TryParseGuid(object? value)
		=> Guid.TryParse(value?.ToString(), out var id) ? id : Guid.Empty;

	private static Guid? TryParseNullableGuid(object? value)
		=> Guid.TryParse(value?.ToString(), out var id) ? id : null;
