@* Single chat message component *@

<div class="@GetContainerClasses()">
	<div class="chat-bubble py-2 px-3 text-break @GetBubbleClasses()">
		@if (Role == MessageRole.ToolUse)
		{
			<details>
				<summary class="fw-semibold small opacity-75">
					<i class="bi bi-tools me-1"></i>@ToolName
				</summary>
				@if (!string.IsNullOrEmpty(ToolInput))
				{
					<pre class="chat-tool-code white-space-pre-wrap m-0 mt-2 p-2 rounded small text-break overflow-auto"
						style="max-height: 150px;">@ToolInput</pre>
				}
			</details>
		}
		else if (Role == MessageRole.ToolResult)
		{
			<details>
				<summary class="fw-semibold small opacity-75">
					<i class="bi bi-arrow-return-right me-1"></i>@ToolName
				</summary>
				<pre class="chat-tool-code white-space-pre-wrap m-0 mt-2 p-2 rounded small text-break overflow-auto"
					style="max-height: 150px;">@TruncateOutput(ToolOutput ?? Content ?? "", 500)</pre>
			</details>
		}
		else
		{
			<div class="@GetContentClasses()">@Content</div>
		}
	</div>
	<div class="d-flex gap-2 mt-1 px-2 small text-secondary">
		<span class="fw-medium"><i class="@GetLabelIcon() me-1"></i>@GetLabel()</span>
		<span class="opacity-75">@Timestamp.FormatTime()</span>
	</div>
</div>

@code {
	[Parameter, EditorRequired]
	public MessageRole Role { get; set; }

	[Parameter]
	public string? Content { get; set; }

	[Parameter]
	public string? ToolName { get; set; }

	[Parameter]
	public string? ToolInput { get; set; }

	[Parameter]
	public string? ToolOutput { get; set; }

	[Parameter]
	public DateTime Timestamp { get; set; }

	[Parameter]
	public MessageSource Source { get; set; } = MessageSource.System;

	[Parameter]
	public MessageLevel Level { get; set; } = MessageLevel.Normal;

	[Parameter]
	public MessageDisplayVariant DisplayVariant { get; set; } = MessageDisplayVariant.Standard;

	[Parameter]
	public string? LabelOverride { get; set; }

	[Parameter]
	public string? BubbleClassOverride { get; set; }

	[Parameter]
	public string? IconOverride { get; set; }

	private static string TruncateOutput(string text, int maxLength)
	{
		if (string.IsNullOrEmpty(text) || text.Length <= maxLength)
			return text;
		return text[..maxLength] + "\n... (truncated)";
	}

	private string GetLabel()
	{
		if (!string.IsNullOrWhiteSpace(LabelOverride))
			return LabelOverride;

		if (DisplayVariant == MessageDisplayVariant.Thinking)
			return "Thinking";

		return Role switch
		{
			MessageRole.User => "User",
			MessageRole.Assistant => "Provider",
			MessageRole.ToolUse => "Tool Call",
			MessageRole.ToolResult => "Tool Result",
			MessageRole.System => Source switch
			{
				MessageSource.Provider => "Provider",
				MessageSource.User => "User",
				_ => "System"
			},
			_ => Role.ToString()
		};
	}

	private string GetBubbleClasses()
	{
		if (!string.IsNullOrWhiteSpace(BubbleClassOverride))
			return BubbleClassOverride;

		if (DisplayVariant == MessageDisplayVariant.Thinking)
			return "bg-secondary-subtle text-secondary-emphasis border border-secondary-subtle";

		if (Role == MessageRole.System)
		{
			return Level switch
			{
				MessageLevel.Success => "bg-success-subtle text-success-emphasis border border-success-subtle",
				MessageLevel.Warning => "bg-warning-subtle text-warning-emphasis border border-warning-subtle",
				MessageLevel.Error => "bg-danger-subtle text-danger-emphasis border border-danger-subtle",
				_ => "bg-primary-subtle text-primary-emphasis border border-primary-subtle"
			};
		}

		return Role switch
		{
			MessageRole.User => "bg-primary text-white",
			MessageRole.Assistant => "bg-body-tertiary border",
			MessageRole.ToolUse => "bg-info-subtle text-info-emphasis border",
			MessageRole.ToolResult => "bg-success-subtle text-success-emphasis border",
			_ => ""
		};
	}

	private string GetLabelIcon()
	{
		if (!string.IsNullOrWhiteSpace(IconOverride))
			return IconOverride;

		if (DisplayVariant == MessageDisplayVariant.Thinking)
			return "bi bi-lightbulb";

		if (Role == MessageRole.System)
		{
			return Level switch
			{
				MessageLevel.Success => "bi bi-check-circle",
				MessageLevel.Warning => "bi bi-exclamation-triangle",
				MessageLevel.Error => "bi bi-x-circle",
				_ => "bi bi-info-circle"
			};
		}

		return Role switch
		{
			MessageRole.User => "bi bi-person-circle",
			MessageRole.Assistant => "bi bi-stars",
			MessageRole.ToolUse => "bi bi-tools",
			MessageRole.ToolResult => "bi bi-arrow-return-right",
			_ => "bi bi-chat-left-text"
		};
	}

	private string GetContainerClasses()
	{
		var roleClass = DisplayVariant == MessageDisplayVariant.Thinking
			? "chat-message-thinking"
			: $"chat-message-{Role.ToString().ToLower()}";
		var indentClass = Role is MessageRole.ToolUse or MessageRole.ToolResult ? " ms-3" : string.Empty;
		return $"chat-message d-flex flex-column {roleClass}{indentClass}";
	}

	private string GetContentClasses()
		=> DisplayVariant == MessageDisplayVariant.Thinking
			? "white-space-pre-wrap m-0 lh-base fst-italic"
			: "white-space-pre-wrap m-0 lh-base";
}
