@* Usage meter component showing provider usage as one or more progress bars *@

@{
	var displayWindows = GetDisplayWindows();
}

@if (displayWindows.Count > 0)
{
	<div class="usage-meter @Class">
		@foreach (var window in displayWindows)
		{
			var percentUsed = GetPercentUsed(window);
			<div class="@(window != displayWindows[0] ? "mt-2 pt-2 border-top border-secondary-subtle" : string.Empty)">
				@if (window.MaxUsage.HasValue && window.MaxUsage > 0)
				{
					<div class="d-flex justify-content-between align-items-center small mb-1">
						<span class="text-body-secondary">@GetUsageLabel(window)</span>
						<span class="fw-medium @GetTextColorClass(percentUsed)">
							@percentUsed%
						</span>
					</div>
					<div class="progress" style="height: 6px;" role="progressbar" aria-valuenow="@percentUsed"
						 aria-valuemin="0" aria-valuemax="100">
						<div class="progress-bar @GetProgressBarClass(percentUsed)" style="width: @percentUsed%"></div>
					</div>
				}
				else
				{
					<div class="small text-body-secondary">
						<i class="bi bi-graph-up me-1"></i>@GetFallbackUsageLabel(window)
					</div>
				}

				@if (ShowResetTime && window.ResetTime.HasValue)
				{
					<div class="small text-body-tertiary mt-1">
						<i class="bi bi-clock me-1"></i>Resets @FormatResetTime(window.ResetTime.Value)
					</div>
				}

				@if (window.IsLimitReached)
				{
					<div class="small text-danger mt-1">
						<i class="bi bi-exclamation-triangle-fill me-1"></i>Limit reached
					</div>
				}

				@if (!string.IsNullOrWhiteSpace(window.Message) && ShouldShowMessage(window, displayWindows.Count))
				{
					<div class="small text-body-tertiary mt-1">@window.Message</div>
				}
			</div>
		}
	</div>
}
else if (UsageSummary != null && ShowEmptyState)
{
	<div class="usage-meter @Class">
		@if (GetFallbackUsageLabel() is { } fallbackLabel)
		{
			<div class="small text-body-secondary">
				<i class="bi bi-graph-up me-1"></i>@fallbackLabel
			</div>
			@if (!string.IsNullOrWhiteSpace(UsageSummary.LimitMessage))
			{
				<div class="small text-body-tertiary mt-1">@UsageSummary.LimitMessage</div>
			}
			@if (ShowResetTime && UsageSummary.LimitResetTime.HasValue)
			{
				<div class="small text-body-tertiary mt-1">
					<i class="bi bi-clock me-1"></i>Resets @FormatResetTime(UsageSummary.LimitResetTime.Value)
				</div>
			}
		}
		else
		{
			<div class="small text-body-tertiary">
				<i class="bi bi-graph-up me-1"></i>No usage data
			</div>
		}
	</div>
}

@code {
	[Parameter]
	public ProviderUsageSummary? UsageSummary { get; set; }

	[Parameter]
	public string Class { get; set; } = "";

	[Parameter]
	public bool ShowResetTime { get; set; } = true;

	[Parameter]
	public bool ShowEmptyState { get; set; } = false;

	[Parameter]
	public bool Compact { get; set; } = false;

	private List<UsageLimitWindow> GetDisplayWindows()
	{
		if (UsageSummary == null)
		{
			return [];
		}

		if (UsageSummary.LimitWindows.Count > 0)
		{
			return UsageSummary.LimitWindows
				.OrderBy(window => GetDisplayOrder(window.Scope))
				.ToList();
		}

		if (UsageSummary.CurrentUsage.HasValue || UsageSummary.EffectiveMaxUsage.HasValue || UsageSummary.LimitResetTime.HasValue)
		{
			return
			[
				new UsageLimitWindow
				{
					Scope = InferScope(UsageSummary.LimitType),
					LimitType = UsageSummary.LimitType,
					CurrentUsage = UsageSummary.CurrentUsage,
					MaxUsage = UsageSummary.EffectiveMaxUsage,
					ResetTime = UsageSummary.LimitResetTime,
					IsLimitReached = UsageSummary.IsLimitReached,
					Message = UsageSummary.LimitMessage
				}
			];
		}

		return [];
	}

	private string GetUsageLabel(UsageLimitWindow window)
	{
		long current = window.CurrentUsage ?? 0;
		long max = window.MaxUsage ?? 0;
		var label = GetScopeLabel(window.Scope);

		return window.LimitType switch
		{
			UsageLimitType.PremiumRequests => Compact
				? $"{label}: {current}/{max}"
				: $"{label}: {current:N0} / {max:N0} Premium Requests",
			UsageLimitType.TokenLimit => Compact
				? $"{label}: {FormatTokens(current)}/{FormatTokens(max)}"
				: $"{label}: {FormatTokens(current)} / {FormatTokens(max)} Tokens",
			_ => Compact
				? $"{label}: {current}/{max}"
				: $"{label}: {current:N0} / {max:N0}"
		};
	}

	private string? GetFallbackUsageLabel()
	{
		if (UsageSummary == null)
		{
			return null;
		}

		if (UsageSummary.LimitType == UsageLimitType.PremiumRequests && UsageSummary.TotalPremiumRequestsConsumed > 0)
		{
			return Compact
				? $"{UsageSummary.TotalPremiumRequestsConsumed:N0} premium used"
				: $"{UsageSummary.TotalPremiumRequestsConsumed:N0} Premium Requests Used";
		}

		if (UsageSummary.CurrentUsage.HasValue)
		{
			return UsageSummary.LimitType switch
			{
				UsageLimitType.SessionLimit => $"Session usage: {UsageSummary.CurrentUsage:N0}",
				UsageLimitType.RateLimit => $"Latest limit usage: {UsageSummary.CurrentUsage:N0}",
				UsageLimitType.TokenLimit => $"Latest token usage: {FormatTokens(UsageSummary.CurrentUsage.Value)}",
				_ => $"Latest usage: {UsageSummary.CurrentUsage:N0}"
			};
		}

		return !string.IsNullOrWhiteSpace(UsageSummary.LimitMessage)
			? "Latest limit update"
			: null;
	}

	private string GetFallbackUsageLabel(UsageLimitWindow window)
	{
		if (window.CurrentUsage.HasValue)
		{
			return window.LimitType switch
			{
				UsageLimitType.SessionLimit => $"Session usage: {window.CurrentUsage:N0}",
				UsageLimitType.RateLimit => $"Latest limit usage: {window.CurrentUsage:N0}",
				UsageLimitType.TokenLimit => $"Latest token usage: {FormatTokens(window.CurrentUsage.Value)}",
				UsageLimitType.PremiumRequests => Compact
					? $"{window.CurrentUsage:N0} premium used"
					: $"{window.CurrentUsage:N0} Premium Requests Used",
				_ => $"{GetScopeLabel(window.Scope)}: {window.CurrentUsage:N0}"
			};
		}

		return window.Message ?? "Usage update available";
	}

	private static bool ShouldShowMessage(UsageLimitWindow window, int totalWindows)
	{
		if (string.IsNullOrWhiteSpace(window.Message))
		{
			return false;
		}

		return totalWindows == 1 || !window.MaxUsage.HasValue;
	}

	private static int GetPercentUsed(UsageLimitWindow window) => window.PercentUsed ?? 0;

	private string FormatTokens(long tokens)
	{
		if (tokens >= 1_000_000) return $"{tokens / 1_000_000.0:F1}M";
		if (tokens >= 1_000) return $"{tokens / 1_000.0:F1}K";
		return tokens.ToString("N0");
	}

	private static string GetProgressBarClass(int percent) => percent switch
	{
		>= 95 => "bg-danger",
		>= 80 => "bg-warning",
		>= 60 => "bg-info",
		_ => "bg-success"
	};

	private static string GetTextColorClass(int percent) => percent switch
	{
		>= 95 => "text-danger",
		>= 80 => "text-warning",
		_ => ""
	};

	private string FormatResetTime(DateTime resetTime)
	{
		var now = DateTime.UtcNow;
		var diff = resetTime - now;

		if (diff.TotalDays > 1)
			return $"in {(int)diff.TotalDays} days";
		if (diff.TotalHours > 1)
			return $"in {(int)diff.TotalHours} hours";
		if (diff.TotalMinutes > 1)
			return $"in {(int)diff.TotalMinutes} minutes";
		if (diff.TotalSeconds > 0)
			return "soon";

		return resetTime.ToString("M/d");
	}

	private static UsageLimitWindowScope InferScope(UsageLimitType limitType) => limitType switch
	{
		UsageLimitType.SessionLimit => UsageLimitWindowScope.Session,
		UsageLimitType.PremiumRequests => UsageLimitWindowScope.Monthly,
		_ => UsageLimitWindowScope.Unknown
	};

	private static int GetDisplayOrder(UsageLimitWindowScope scope) => scope switch
	{
		UsageLimitWindowScope.Session => 0,
		UsageLimitWindowScope.Daily => 1,
		UsageLimitWindowScope.Weekly => 2,
		UsageLimitWindowScope.Monthly => 3,
		_ => 4
	};

	private static string GetScopeLabel(UsageLimitWindowScope scope) => scope switch
	{
		UsageLimitWindowScope.Session => "Session",
		UsageLimitWindowScope.Daily => "Daily",
		UsageLimitWindowScope.Weekly => "Weekly",
		UsageLimitWindowScope.Monthly => "Monthly",
		_ => "Usage"
	};
}
