@inject IInferenceProviderService InferenceProviderService
@inject IInferenceService InferenceService
@inject NotificationService NotificationService
@inject IJSRuntime JSRuntime

<div class="border-top pt-3 mt-3">
	<div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-3">
		<h6 class="fw-semibold mb-0">
			<i class="bi bi-chat-square-dots me-2"></i>Test Inference
		</h6>
		@if (!Provider.IsEnabled)
		{
			<span class="badge bg-warning-subtle text-warning-emphasis">Enable to test</span>
		}
	</div>

	<div class="row g-3 mb-3">
		<div class="col-12 col-lg-4">
			<label for="@GetModelInputId()" class="form-label">Model</label>
			<select id="@GetModelInputId()"
					class="form-select"
					value="@_selectedModelId"
					@onchange="HandleModelChanged"
					disabled="@(!Provider.IsEnabled || _isLoadingModels || _testModels.Count == 0)">
				<option value="">@(_isLoadingModels ? "Loading..." : "Use provider default model")</option>
				@foreach (var model in _testModels)
				{
					<option value="@model.ModelId">
						@(model.DisplayName ?? model.ModelId)
						@if (model.IsDefault)
						{
							@(" (Default)")
						}
					</option>
				}
			</select>
			<div class="form-text">@GetTestModelHelpText()</div>
		</div>
		<div class="col-12 col-lg-8">
			<label for="@GetPromptInputId()" class="form-label">Prompt</label>
			<textarea id="@GetPromptInputId()"
					  class="form-control font-monospace"
					  rows="3"
					  @bind="_testPrompt"
					  placeholder="Enter a test prompt..."
					  disabled="@(!Provider.IsEnabled || _isTesting)"></textarea>
		</div>
	</div>

	<button id="@GetSubmitButtonId()"
			type="button"
			class="btn btn-primary"
			@onclick="HandleSubmit"
			disabled="@(!CanSubmit)">
		@if (_isTesting)
		{
			<span class="spinner-border spinner-border-sm me-1" role="status"></span>
			<span>Sending...</span>
		}
		else
		{
			<i class="bi bi-send me-1"></i>
			<span>Send</span>
		}
	</button>

	@if (_testResponse != null)
	{
		<hr />
		@if (_testResponse.Success)
		{
			<div class="d-flex flex-wrap gap-3 small text-body-secondary mb-2">
				@if (!string.IsNullOrEmpty(_testResponse.ModelUsed))
				{
					<span><i class="bi bi-cpu me-1"></i>@_testResponse.ModelUsed</span>
				}
				@if (_testResponse.DurationMs.HasValue)
				{
					<span><i class="bi bi-clock me-1"></i>@((_testResponse.DurationMs.Value / 1000.0).ToString("F2"))s</span>
				}
				@if (_testResponse.CompletionTokens.HasValue)
				{
					<span><i class="bi bi-hash me-1"></i>@_testResponse.CompletionTokens tokens</span>
				}
			</div>
			<pre class="p-3 rounded bg-body-secondary small mb-0 white-space-pre-wrap" style="word-break:break-word;">@_testResponse.Response</pre>
		}
		else
		{
			<Alert Type="Alert.AlertType.Danger" Message="@(_testResponse.Error ?? "An unknown error occurred.")" />
		}
	}
</div>

@code {
	private const string DefaultPromptText = "Say hello in one sentence.";

	private readonly List<InferenceModel> _testModels = [];
	private string _selectedModelId = string.Empty;
	private string _testPrompt = DefaultPromptText;
	private bool _isLoadingModels;
	private bool _isTesting;
	private InferenceResponse? _testResponse;
	private Guid _loadedProviderId;
	private string? _loadedEndpoint;
	private InferenceProviderType? _loadedProviderType;
	private bool _loadedIsEnabled;

	[Parameter, EditorRequired]
	public InferenceProvider Provider { get; set; } = default!;

	private bool CanSubmit => Provider.IsEnabled && !_isTesting && !string.IsNullOrWhiteSpace(_testPrompt);

	protected override async Task OnParametersSetAsync()
	{
		if (_loadedProviderId == Provider.Id
			&& string.Equals(_loadedEndpoint, Provider.Endpoint, StringComparison.Ordinal)
			&& _loadedProviderType == Provider.ProviderType
			&& _loadedIsEnabled == Provider.IsEnabled)
		{
			return;
		}

		_loadedProviderId = Provider.Id;
		_loadedEndpoint = Provider.Endpoint;
		_loadedProviderType = Provider.ProviderType;
		_loadedIsEnabled = Provider.IsEnabled;
		_selectedModelId = string.Empty;
		_testResponse = null;

		await LoadModelsAsync();
	}

	private async Task LoadModelsAsync()
	{
		_testModels.Clear();
		if (!Provider.IsEnabled)
		{
			return;
		}

		_isLoadingModels = true;
		try
		{
			_testModels.AddRange((await InferenceProviderService.GetModelsAsync(Provider.Id))
				.Where(model => model.IsAvailable)
				.OrderByDescending(model => model.IsDefault)
				.ThenBy(model => model.DisplayName ?? model.ModelId));
		}
		catch (Exception ex)
		{
			NotificationService.ShowError($"Failed to load inference models for {Provider.Name}: {ex.Message}");
		}
		finally
		{
			_isLoadingModels = false;
		}
	}

	private Task HandleModelChanged(ChangeEventArgs args)
	{
		_selectedModelId = args.Value?.ToString() ?? string.Empty;
		return Task.CompletedTask;
	}

	private async Task HandleSubmit()
	{
		if (!CanSubmit)
		{
			return;
		}

		_isTesting = true;
		_testResponse = null;

		try
		{
			await PersistLastTestProviderIdAsync(Provider.Id);
			_testResponse = await InferenceService.GenerateAsync(new InferenceRequest
			{
				Prompt = _testPrompt.Trim(),
				Model = string.IsNullOrWhiteSpace(_selectedModelId) ? null : _selectedModelId,
				ProviderId = Provider.Id,
				Endpoint = Provider.Endpoint,
				ProviderType = Provider.ProviderType
			});
		}
		catch (Exception ex)
		{
			_testResponse = new InferenceResponse
			{
				Success = false,
				Error = ex.Message
			};
		}
		finally
		{
			_isTesting = false;
		}
	}

	private async Task PersistLastTestProviderIdAsync(Guid providerId)
	{
		try
		{
			await JSRuntime.InvokeVoidAsync("sessionStorage.setItem", VibeSwarm.Client.Pages.LocalInference.LastTestProviderStorageKey, providerId.ToString("D"));
		}
		catch (JSException ex)
		{
			LogTestProviderStorageFailure("save the last test provider", ex);
		}
		catch (InvalidOperationException ex)
		{
			LogTestProviderStorageFailure("save the last test provider", ex);
		}
		catch (OperationCanceledException ex)
		{
			LogTestProviderStorageFailure("save the last test provider", ex);
		}
	}

	private string GetTestModelHelpText()
	{
		if (!Provider.IsEnabled)
		{
			return "Enable this provider to run an inference test.";
		}

		if (_isLoadingModels)
		{
			return "Loading models for this provider...";
		}

		if (_testModels.Count == 0)
		{
			return "No discovered models are available for this provider yet.";
		}

		var defaultModel = _testModels.FirstOrDefault(model => model.IsDefault);
		return defaultModel == null
			? "Choose a model to test with this provider."
			: $"Leave unselected to use {defaultModel.DisplayName ?? defaultModel.ModelId}.";
	}

	private string GetModelInputId() => $"testModel-{Provider.Id:D}";

	private string GetPromptInputId() => $"testPrompt-{Provider.Id:D}";

	private string GetSubmitButtonId() => $"testSubmit-{Provider.Id:D}";

	private static void LogTestProviderStorageFailure(string action, Exception exception)
	{
		Console.Error.WriteLine($"[LocalInference] Unable to {action}: {exception.Message}");
	}
}
