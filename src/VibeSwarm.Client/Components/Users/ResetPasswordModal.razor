<ModalDialog IsVisible="IsVisible" IsVisibleChanged="HandleVisibleChanged" Title="Reset Password" Icon="key"
			 Size="ModalDialog.ModalSize.Default" OnClose="HandleClose">
	<ChildContent>
		@if (!string.IsNullOrEmpty(UserName))
		{
			<p class="text-body-secondary">
				Reset password for <strong>@UserName</strong>
			</p>

			@if (!string.IsNullOrEmpty(ErrorMessage))
			{
				<div class="text-danger small mb-3">
					<i class="bi bi-exclamation-circle me-1"></i>@ErrorMessage
				</div>
			}

			<div class="mb-3">
				<label for="newPassword" class="form-label">New Password</label>
				<input type="password" id="newPassword" value="@NewPassword" @oninput="HandleNewPasswordChanged" class="form-control" />
				<div class="form-text">
					Password must be at least 8 characters with uppercase, lowercase, and a digit.
				</div>
			</div>

			<div class="mb-3">
				<label for="confirmNewPassword" class="form-label">Confirm Password</label>
				<input type="password" id="confirmNewPassword" value="@ConfirmPassword" @oninput="HandleConfirmPasswordChanged" class="form-control" />
			</div>

			<div class="d-flex justify-content-end gap-2">
				<button type="button" class="btn btn-secondary" @onclick="CloseAsync">Cancel</button>
				<button type="button" class="btn btn-primary" @onclick="OnSubmit" disabled="@IsSubmitting">
					@if (IsSubmitting)
					{
						<span class="spinner-border spinner-border-sm me-1" role="status"></span>
					}
					Reset Password
				</button>
			</div>
		}
	</ChildContent>
</ModalDialog>

@code {
	[Parameter]
	public bool IsVisible { get; set; }

	[Parameter]
	public EventCallback<bool> IsVisibleChanged { get; set; }

	[Parameter]
	public string? UserName { get; set; }

	[Parameter]
	public string NewPassword { get; set; } = string.Empty;

	[Parameter]
	public EventCallback<string> NewPasswordChanged { get; set; }

	[Parameter]
	public string ConfirmPassword { get; set; } = string.Empty;

	[Parameter]
	public EventCallback<string> ConfirmPasswordChanged { get; set; }

	[Parameter]
	public string? ErrorMessage { get; set; }

	[Parameter]
	public bool IsSubmitting { get; set; }

	[Parameter]
	public EventCallback OnSubmit { get; set; }

	[Parameter]
	public EventCallback OnCancel { get; set; }

	private Task HandleVisibleChanged(bool isVisible) => IsVisibleChanged.InvokeAsync(isVisible);

	private Task HandleClose() => OnCancel.InvokeAsync();

	private Task HandleNewPasswordChanged(ChangeEventArgs args)
		=> NewPasswordChanged.InvokeAsync(args.Value?.ToString() ?? string.Empty);

	private Task HandleConfirmPasswordChanged(ChangeEventArgs args)
		=> ConfirmPasswordChanged.InvokeAsync(args.Value?.ToString() ?? string.Empty);

	private async Task CloseAsync()
	{
		await IsVisibleChanged.InvokeAsync(false);
		await OnCancel.InvokeAsync();
	}
}
