<ul class="nav nav-tabs flex-nowrap flex-sm-wrap overflow-x-auto overflow-y-hidden overscroll-contain mb-0" role="tablist">
	<li class="nav-item" role="presentation">
		<button type="button"
				role="tab"
				aria-selected="@(ActiveFilter == ActiveFilterValue)"
				class="nav-link @(ActiveFilter == ActiveFilterValue ? "active" : "")"
				@onclick="@(() => OnFilterChanged.InvokeAsync(ActiveFilterValue))">
			<i class="bi bi-check-circle me-1"></i>Active
			<span class="badge bg-primary-subtle text-primary-emphasis ms-1">@ActiveCount</span>
		</button>
	</li>
	<li class="nav-item" role="presentation">
		<button type="button"
				role="tab"
				aria-selected="@(ActiveFilter == InactiveFilterValue)"
				class="nav-link @(ActiveFilter == InactiveFilterValue ? "active" : "")"
				@onclick="@(() => OnFilterChanged.InvokeAsync(InactiveFilterValue))">
			<i class="bi bi-pause-circle me-1"></i>Inactive
			<span class="badge bg-secondary-subtle text-secondary-emphasis ms-1">@InactiveCount</span>
		</button>
	</li>
</ul>

@code {
	private const string ActiveFilterValue = "active";
	private const string InactiveFilterValue = "inactive";

	[Parameter]
	public string ActiveFilter { get; set; } = ActiveFilterValue;

	[Parameter]
	public int ActiveCount { get; set; }

	[Parameter]
	public int InactiveCount { get; set; }

	[Parameter]
	public EventCallback<string> OnFilterChanged { get; set; }
}
