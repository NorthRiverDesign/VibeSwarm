
<li class="list-group-item py-3">
	<div class="d-flex align-items-center justify-content-between gap-3">
		<div class="d-flex align-items-center gap-3 flex-grow-1 min-width-0">
			<i class="bi bi-person-circle fs-4 text-secondary flex-shrink-0"></i>
			<div class="min-width-0">
				<div class="d-flex align-items-center gap-2 flex-wrap">
					<span class="fw-semibold">@User.UserName</span>
					@if (User.Roles.Contains(UserRoles.Admin))
					{
						<span class="badge bg-primary">Admin</span>
					}
					else
					{
						<span class="badge bg-secondary">User</span>
					}
				</div>
				<div class="d-flex flex-wrap gap-2 text-body-secondary small mt-1">
					<span class="d-none d-md-inline">
						<i class="bi bi-calendar me-1"></i>Created @User.CreatedAt.FormatDateTimeShort()
					</span>
					<span class="d-none d-lg-inline">
						<i class="bi bi-clock me-1"></i>Last login: @(User.LastLoginAt.HasValue ? User.LastLoginAt.Value.FormatDateTimeShort() : "Never")
					</span>
				</div>
			</div>
		</div>

		<RowActionsDropdown AriaLabel="User actions">
			<RowActionsItem Icon="key" Text="Reset Password"
							OnClick="@(() => OnResetPassword.InvokeAsync(User))" />
			<RowActionsItem Icon="pencil" Text="Edit Role"
							OnClick="@(() => OnEditRole.InvokeAsync(User))" />
			<RowActionsItem Icon="@(User.IsActive ? "x-circle" : "check-circle")"
							OnClick="@(() => OnToggleActive.InvokeAsync(User))"
							Disabled="@(User.Id == CurrentUserId && User.IsActive)">
				@if (User.Id == CurrentUserId && User.IsActive)
				{
					<span class="text-body-secondary">Cannot deactivate yourself</span>
				}
				else
				{
					@(User.IsActive ? "Deactivate" : "Activate")
				}
			</RowActionsItem>
			<RowActionsDivider />
			<RowActionsItem Icon="trash" Text="Delete" Danger="true"
							OnClick="@(() => OnDelete.InvokeAsync(User))" />
		</RowActionsDropdown>
	</div>
</li>

@code {
	[Parameter, EditorRequired]
	public UserDto User { get; set; } = new();

	[Parameter]
	public Guid CurrentUserId { get; set; }

	[Parameter]
	public EventCallback<UserDto> OnResetPassword { get; set; }

	[Parameter]
	public EventCallback<UserDto> OnEditRole { get; set; }

	[Parameter]
	public EventCallback<UserDto> OnToggleActive { get; set; }

	[Parameter]
	public EventCallback<UserDto> OnDelete { get; set; }
}
