@inject IProjectService ProjectService

<section>
	<div class="d-flex flex-column flex-sm-row justify-content-between align-items-sm-center gap-2 mb-3">
		<h5 class="mb-0 fw-semibold text-truncate">
			<i class="bi bi-graph-up-arrow me-2 opacity-75"></i>Job Analytics
		</h5>

		<div class="d-flex flex-wrap gap-1 gap-sm-2">
			@foreach (var rangeDays in RangeOptions)
			{
				<button type="button" class="btn btn-sm @(SelectedRangeDays == rangeDays ? "btn-primary" : "btn-secondary")"
						disabled="@IsRefreshing" aria-pressed="@(SelectedRangeDays == rangeDays)"
						@onclick="() => ChangeRangeAsync(rangeDays)">
					@if (SelectedRangeDays == rangeDays && IsRefreshing)
					{
						<span class="spinner-border spinner-border-sm me-1" aria-hidden="true"></span>
					}
					@FormatRangeOption(rangeDays)
				</button>
			}
		</div>
	</div>

	@if (IsLoading)
	{
		<LoadingSpinner />
	}
	else if (!string.IsNullOrWhiteSpace(LoadError))
	{
		<EmptyState Icon="exclamation-triangle" Title="Unable to load analytics" Message="@LoadError">
			<button type="button" class="btn btn-sm btn-primary" @onclick="RetryAsync">
				<i class="bi bi-arrow-clockwise me-1"></i>Try Again
			</button>
		</EmptyState>
	}
	else
	{
		<div class="row g-3">
			<div class="col-12 col-lg-6">
				<DashboardMetricChart Title="Completed Jobs" Subtitle="@GetChartSubtitle()" Icon="check2-circle"
									  Summary="@GetCompletedSummary()" EmptyIcon="check2-circle" EmptyTitle="No completed jobs yet"
									  EmptyMessage="Completed jobs from the selected time range will show up here."
									  Points="@GetCompletedChartPoints()" BarColor="var(--bs-success)"  UseIntegerYAxisTicks="true"
									  YAxisLabelFormatter="FormatCompletedAxisLabel" />
			</div>

			<div class="col-12 col-lg-6">
				<DashboardMetricChart Title="Average Job Duration" Subtitle="@GetChartSubtitle()" Icon="stopwatch"
									  Summary="@GetDurationSummary()" EmptyIcon="stopwatch" EmptyTitle="No duration data yet"
									  EmptyMessage="Average duration appears after jobs complete with timing information."
									  Points="@GetDurationChartPoints()" BarColor="var(--bs-info)"
									  YAxisLabelFormatter="FormatDurationAxisLabel" />
			</div>

			<div class="col-12 col-lg-6">
				<DashboardMetricChart Title="Input Tokens" Subtitle="@GetChartSubtitle()" Icon="arrow-down-circle"
									  Summary="@GetInputTokensSummary()" EmptyIcon="arrow-down-circle" EmptyTitle="No token data yet"
									  EmptyMessage="Input token usage will appear once jobs with token tracking complete."
									  Points="@GetInputTokensChartPoints()" BarColor="var(--bs-warning)"
									  YAxisLabelFormatter="FormatTokenAxisLabel" />
			</div>

			<div class="col-12 col-lg-6">
				<DashboardMetricChart Title="Output Tokens" Subtitle="@GetChartSubtitle()" Icon="arrow-up-circle"
									  Summary="@GetOutputTokensSummary()" EmptyIcon="arrow-up-circle" EmptyTitle="No token data yet"
									  EmptyMessage="Output token usage will appear once jobs with token tracking complete."
									  Points="@GetOutputTokensChartPoints()" BarColor="var(--bs-purple)"
									  YAxisLabelFormatter="FormatTokenAxisLabel" />
			</div>
		</div>
	}
</section>

@code {
	private static readonly int[] RangeOptions = [1, 7, 30, 90];

	private DashboardJobMetrics Metrics { get; set; } = new();
	private int SelectedRangeDays { get; set; } = 7;
	private bool IsLoading { get; set; } = true;
	private bool IsRefreshing { get; set; }
	private string? LoadError { get; set; }

	protected override async Task OnInitializedAsync()
	{
		await LoadMetricsAsync(initialLoad: true);
	}

	private async Task ChangeRangeAsync(int rangeDays)
	{
		if (SelectedRangeDays == rangeDays)
		{
			return;
		}

		SelectedRangeDays = rangeDays;
		await LoadMetricsAsync(initialLoad: false);
	}

	private async Task RetryAsync()
	{
		await LoadMetricsAsync(initialLoad: false);
	}

	private async Task LoadMetricsAsync(bool initialLoad)
	{
		LoadError = null;
		IsLoading = initialLoad;
		IsRefreshing = !initialLoad;

		try
		{
			Metrics = await ProjectService.GetDashboardJobMetricsAsync(SelectedRangeDays);
		}
		catch (Exception ex)
		{
			LoadError = ex.Message;
			Metrics = new DashboardJobMetrics
			{
				RangeDays = SelectedRangeDays
			};
		}
		finally
		{
			IsLoading = false;
			IsRefreshing = false;
		}
	}

	private string GetChartSubtitle() => Metrics.RangeDays switch
	{
		1 => "Last 24 hours",
		7 => "Last 7 days",
		30 => "Last 30 days",
		90 => "Last 90 days",
		_ => $"Last {Metrics.RangeDays} days"
	};

	private string GetCompletedSummary() => Metrics.TotalCompletedJobs == 1
		? "1 job completed"
		: $"{Metrics.TotalCompletedJobs} jobs completed";

	private string GetDurationSummary() => Metrics.AverageDurationSeconds.HasValue
		? $"Avg {TokenHelper.FormatDuration(Metrics.AverageDurationSeconds)}"
		: "No completed jobs";

	private IReadOnlyList<DashboardChartPoint> GetCompletedChartPoints()
	{
		return Metrics.Buckets
			.Select(bucket => new DashboardChartPoint
			{
				Label = FormatBucketLabel(bucket.BucketStartUtc),
				Value = bucket.CompletedJobs,
				ValueLabel = bucket.CompletedJobs == 1 ? "1 completed job" : $"{bucket.CompletedJobs} completed jobs"
			})
			.ToList();
	}

	private IReadOnlyList<DashboardChartPoint> GetDurationChartPoints()
	{
		return Metrics.Buckets
			.Select(bucket => new DashboardChartPoint
			{
				Label = FormatBucketLabel(bucket.BucketStartUtc),
				Value = bucket.AverageDurationSeconds ?? 0,
				ValueLabel = bucket.AverageDurationSeconds.HasValue
					? TokenHelper.FormatDuration(bucket.AverageDurationSeconds)
					: "No completed jobs"
			})
			.ToList();
	}

	private string FormatBucketLabel(DateTime bucketStartUtc)
	{
		var localTime = DateTime.SpecifyKind(bucketStartUtc, DateTimeKind.Utc).ToConfiguredTime();

		return Metrics.RangeDays switch
		{
			1 => localTime.ToString("ha").ToLowerInvariant(),
			90 => localTime.ToString("M/d"),
			_ => localTime.ToString("M/d")
		};
	}

	private static string FormatRangeOption(int rangeDays) => rangeDays switch
	{
		1 => "1 Day",
		_ => $"{rangeDays} Days"
	};

	private IReadOnlyList<DashboardChartPoint> GetInputTokensChartPoints()
	{
		return Metrics.Buckets
			.Select(bucket => new DashboardChartPoint
			{
				Label = FormatBucketLabel(bucket.BucketStartUtc),
				Value = bucket.TotalInputTokens,
				ValueLabel = TokenHelper.FormatTokenCount((int)Math.Min(bucket.TotalInputTokens, int.MaxValue)) + " input tokens"
			})
			.ToList();
	}

	private IReadOnlyList<DashboardChartPoint> GetOutputTokensChartPoints()
	{
		return Metrics.Buckets
			.Select(bucket => new DashboardChartPoint
			{
				Label = FormatBucketLabel(bucket.BucketStartUtc),
				Value = bucket.TotalOutputTokens,
				ValueLabel = TokenHelper.FormatTokenCount((int)Math.Min(bucket.TotalOutputTokens, int.MaxValue)) + " output tokens"
			})
			.ToList();
	}

	private string GetInputTokensSummary() => Metrics.TotalInputTokens > 0
		? TokenHelper.FormatTokenCount((int)Math.Min(Metrics.TotalInputTokens, int.MaxValue)) + " total"
		: "No token data";

	private string GetOutputTokensSummary() => Metrics.TotalOutputTokens > 0
		? TokenHelper.FormatTokenCount((int)Math.Min(Metrics.TotalOutputTokens, int.MaxValue)) + " total"
		: "No token data";

	private static string FormatTokenAxisLabel(double value) => value <= 0
		? "0"
		: TokenHelper.FormatTokenCount((int)Math.Min(value, int.MaxValue));

	private static string FormatCompletedAxisLabel(double value) => Math.Round(value).ToString("0");

	private static string FormatDurationAxisLabel(double value) => value <= 0
		? "0s"
		: TokenHelper.FormatDuration(value);
}