@using VibeSwarm.Client.Models

<div class="card h-100">
	<div class="card-body d-flex flex-column">
		<div class="d-flex justify-content-between align-items-start gap-3 mb-3">
			<div>
				<h6 class="card-title fw-semibold mb-1">
					<i class="bi bi-@Icon me-2 opacity-75"></i>@Title
				</h6>
				<p class="small text-body-secondary mb-0">@Subtitle</p>
			</div>
			@if (!string.IsNullOrWhiteSpace(Summary))
			{
				<span class="badge bg-body-tertiary text-body text-wrap text-end">@Summary</span>
			}
		</div>

		@if (!HasData)
		{
			<div class="flex-grow-1 d-flex align-items-center">
				<EmptyState Icon="@EmptyIcon" Title="@EmptyTitle" Message="@EmptyMessage" />
			</div>
		}
		else
		{
			<div class="w-100 pb-2">
				<div class="w-100">
					<svg class="d-block w-100" height="@ChartHeight" viewBox="0 0 @ChartWidth @ChartHeight"
						 preserveAspectRatio="none" role="img" aria-label="@Title">
						<title>@Title</title>

						@foreach (var axisTick in YAxisTicks)
						{
							@RenderYAxisLabel(axisTick)

							<line x1="@ChartPaddingLeft"  y1="@axisTick.Y"  x2="@(ChartWidth - ChartPaddingRight)"  y2="@axisTick.Y"
								  stroke="var(--bs-border-color)"  stroke-width="1"  opacity="0.5" />
						}

						<line x1="@ChartPaddingLeft"  y1="@ChartPaddingTop"  x2="@ChartPaddingLeft"  y2="@BaselineY"
							  stroke="var(--bs-border-color)"  stroke-width="1.25" />

						<line x1="@ChartPaddingLeft"  y1="@BaselineY"  x2="@(ChartWidth - ChartPaddingRight)"  y2="@BaselineY"
							  stroke="var(--bs-border-color)"  stroke-width="1.25" />

						@for (var index = 0; index < Points.Count; index++)
						{
							var point = Points[index];
							var barHeight = GetBarHeight(point.Value);
							var x = GetBarX(index);
							var y = BaselineY - barHeight;
							var slotStartX = GetSlotStartX(index);
							var tooltip = GetPointTooltip(point);

							<rect x="@slotStartX" y="@ChartPaddingTop" width="@SlotWidth" height="@PlotHeight" fill="transparent">
								<title>@tooltip</title>
							</rect>

							<rect x="@x" y="@y" width="@BarWidth" height="@Math.Max(barHeight, 2)" rx="6" fill="@BarColor"
								  fill-opacity="0.85" aria-label="@tooltip">
								<title>@tooltip</title>
							</rect>
						}
					</svg>

					<div class="d-grid align-items-start pt-2"
						 style="padding-left:@(ChartPaddingLeft)px; padding-right:@(ChartPaddingRight)px; grid-template-columns: repeat(@Points.Count, minmax(0, 1fr));">
						@for (var index = 0; index < Points.Count; index++)
						{
							var point = Points[index];
							<div class="text-body-secondary text-center" style="min-width:0; font-size:0.72rem; line-height:1.2;">
								@if (ShouldRenderLabel(index))
								{
									<span class="d-block text-truncate" title="@point.Label">@point.Label</span>
								}
							</div>
						}
					</div>
				</div>
			</div>
		}
	</div>
</div>

@code {
	private const int ChartHeight = 220;
	private const int ChartWidth = 1000;
	private const int ChartPaddingLeft = 56;
	private const int ChartPaddingRight = 16;
	private const int ChartPaddingTop = 16;
	private const int ChartPaddingBottom = 40;
	private const int AxisTickCount = 4;

	[Parameter]
	public string Title { get; set; } = string.Empty;

	[Parameter]
	public string Subtitle { get; set; } = string.Empty;

	[Parameter]
	public string Icon { get; set; } = "bar-chart";

	[Parameter]
	public string Summary { get; set; } = string.Empty;

	[Parameter]
	public string EmptyTitle { get; set; } = "No data yet";

	[Parameter]
	public string EmptyMessage { get; set; } = "Completed jobs will appear here once work starts finishing.";

	[Parameter]
	public string EmptyIcon { get; set; } = "bar-chart";

	[Parameter]
	public string BarColor { get; set; } = "var(--bs-primary)";

	[Parameter]
	public IReadOnlyList<DashboardChartPoint> Points { get; set; } = [];

	[Parameter]
	public Func<double, string>? YAxisLabelFormatter { get; set; }

	[Parameter]
	public bool UseIntegerYAxisTicks { get; set; }

	private bool HasData => Points.Any(point => point.Value > 0);
	private double BaselineY => ChartHeight - ChartPaddingBottom;
	private double PlotHeight => ChartHeight - ChartPaddingTop - ChartPaddingBottom;
	private double PlotWidth => ChartWidth - ChartPaddingLeft - ChartPaddingRight;
	private double SlotWidth => Points.Count == 0 ? PlotWidth : PlotWidth / Points.Count;
	private double BarWidth => Math.Clamp(SlotWidth * 0.6, 8, 28);
	private double MaxValue => Points.Count == 0 ? 0 : Points.Max(point => point.Value);
	private double ChartMaxValue => ResolveChartMaxValue(MaxValue);
	private double AxisStepValue => ChartMaxValue / (AxisTickCount - 1);
	private IReadOnlyList<AxisTick> YAxisTicks => Enumerable.Range(0, AxisTickCount)
		.Select(index =>
		{
			var tickValue = ChartMaxValue - (AxisStepValue * index);
			var tickY = ChartPaddingTop + ((PlotHeight / (AxisTickCount - 1)) * index);

			return new AxisTick(tickValue, tickY, FormatAxisLabel(tickValue));
		})
		.ToList();

	private double GetBarHeight(double value)
	{
		return value <= 0 ? 0 : Math.Max((value / ChartMaxValue) * PlotHeight, 2);
	}

	private double GetSlotStartX(int index)
	{
		return ChartPaddingLeft + (index * SlotWidth);
	}

	private double GetBarX(int index)
	{
		var slotStartX = GetSlotStartX(index);
		return slotStartX + ((SlotWidth - BarWidth) / 2);
	}

	private string GetPointTooltip(DashboardChartPoint point)
	{
		var pointValueLabel = string.IsNullOrWhiteSpace(point.ValueLabel)
			? point.Value.ToString("0.##")
			: point.ValueLabel;

		return $"{point.Label}: {pointValueLabel}";
	}

	private bool ShouldRenderLabel(int index)
	{
		var labelStep = Points.Count switch
		{
			<= 12 => 1,
			<= 24 => 2,
			<= 45 => 4,
			_ => 6
		};

		return index % labelStep == 0 || index == Points.Count - 1;
	}

	private string FormatAxisLabel(double value)
	{
		if (YAxisLabelFormatter is not null)
		{
			return YAxisLabelFormatter(value);
		}

		return value.ToString("0.##");
	}

	private double ResolveChartMaxValue(double maxValue)
	{
		if (maxValue <= 0)
		{
			return 1;
		}

		if (UseIntegerYAxisTicks)
		{
			var integerStep = Math.Max(1, (int)Math.Ceiling(maxValue / (AxisTickCount - 1)));
			return integerStep * (AxisTickCount - 1);
		}

		var rawStep = maxValue / (AxisTickCount - 1);
		var niceStep = ResolveNiceStep(rawStep);

		return Math.Max(niceStep * (AxisTickCount - 1), 1);
	}

	private static double ResolveNiceStep(double rawStep)
	{
		if (rawStep <= 0)
		{
			return 1;
		}

		var exponent = Math.Floor(Math.Log10(rawStep));
		var magnitude = Math.Pow(10, exponent);
		var normalizedStep = rawStep / magnitude;

		var roundedStep = normalizedStep switch
		{
			<= 1 => 1,
			<= 2 => 2,
			<= 5 => 5,
			_ => 10
		};

		return roundedStep * magnitude;
	}

	private MarkupString RenderYAxisLabel(AxisTick axisTick)
	{
		var encodedLabel = System.Text.Encodings.Web.HtmlEncoder.Default.Encode(axisTick.Label);
		var x = (ChartPaddingLeft - 8).ToString(System.Globalization.CultureInfo.InvariantCulture);
		var y = axisTick.Y.ToString(System.Globalization.CultureInfo.InvariantCulture);

		return new MarkupString($"<text x=\"{x}\" y=\"{y}\" fill=\"var(--bs-secondary-color)\" font-size=\"11\" text-anchor=\"end\" dominant-baseline=\"middle\">{encodedLabel}</text>");
	}

	private readonly record struct AxisTick(double Value, double Y, string Label);
}
