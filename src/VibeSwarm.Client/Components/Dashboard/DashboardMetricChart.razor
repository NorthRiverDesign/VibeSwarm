@inject IJSRuntime JS

<div class="card h-100">
	<div class="card-body d-flex flex-column p-3">
		<div class="d-flex justify-content-between align-items-start gap-3 mb-2 mb-sm-3">
			<div>
				<h6 class="card-title fw-semibold mb-1">
					<i class="bi bi-@Icon me-2 opacity-75"></i>@Title
				</h6>
				<p class="small text-body-secondary mb-0">@Subtitle</p>
			</div>
			@if (!string.IsNullOrWhiteSpace(Summary))
			{
				<span class="badge bg-body-tertiary text-body text-wrap text-end">@Summary</span>
			}
		</div>

		@if (!HasData)
		{
			<div class="flex-grow-1 d-flex align-items-center">
				<div class="w-100">
					<EmptyState Icon="@EmptyIcon" Title="@EmptyTitle" Message="@EmptyMessage" />
				</div>
			</div>
		}
		else
		{
			<div class="w-100">
				@if (HighlightedPoint is not null)
				{
					<div
						class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-2 mb-sm-3 px-2 py-2 rounded bg-body-tertiary small">
						<div class="d-flex flex-wrap align-items-center gap-2 min-width-0">
							<span class="badge bg-body text-body">@HighlightedPoint.Label</span>
							<span class="fw-semibold text-break">@GetPointValueLabel(HighlightedPoint)</span>
						</div>
						@if (SelectedPoint is not null)
						{
							<span class="text-body-secondary">Selected</span>
						}
						else
						{
							<span class="text-body-secondary">Latest</span>
						}
					</div>
				}

				<div class="d-flex align-items-start gap-1 gap-sm-2">
					<div class="position-relative flex-shrink-0 pe-1"
						 style="width:@FormatPixels(YAxisLabelWidth); min-width:@FormatPixels(YAxisLabelWidth); height:@FormatPixels(ChartHeight);">
						@foreach (var axisTick in YAxisTicks)
						{
							<div class="position-absolute end-0 translate-middle-y text-body-secondary text-end"
								 style="top:@FormatPixels(axisTick.Y); font-size:0.72rem; line-height:1;">
								@axisTick.Label
							</div>
						}
					</div>

					<div @ref="_scrollContainer"
						 class="flex-grow-1 overflow-auto overscroll-contain pb-1 touch-manipulation">
						<div class="d-flex flex-column" style="width:@ScrollContentWidth;">
							<div class="position-relative w-100" style="height:@FormatPixels(ChartHeight);">
								<svg class="d-block w-100" height="@ChartHeight" viewBox="0 0 @ChartWidth @ChartHeight"
									 preserveAspectRatio="none" role="img" aria-label="@Title">
									<title>@Title</title>

									@foreach (var axisTick in YAxisTicks)
									{
										<line x1="0" y1="@axisTick.Y" x2="@ChartWidth" y2="@axisTick.Y"
											  stroke="var(--bs-border-color)" stroke-width="1" opacity="0.5" />
									}

									<line x1="0" y1="@ChartPaddingTop" x2="0" y2="@BaselineY"
										  stroke="var(--bs-border-color)" stroke-width="1.25" />

									<line x1="0" y1="@BaselineY" x2="@ChartWidth" y2="@BaselineY"
										  stroke="var(--bs-border-color)" stroke-width="1.25" />

									@for (var index = 0; index < Points.Count; index++)
									{
										var point = Points[index];
										var isSelected = SelectedPointIndex == index;
										var barHeight = GetBarHeight(point.Value);
										var x = GetBarX(index);
										var y = BaselineY - barHeight;
										var tooltip = GetPointTooltip(point);

										<rect x="@x" y="@y" width="@BarWidth" height="@Math.Max(barHeight, 2)" rx="6"
											  fill="@BarColor" fill-opacity="@(isSelected ? "1" : "0.85")"
											  stroke="@(isSelected ? "var(--bs-emphasis-color)" : "none")" stroke-width="2"
											  aria-label="@tooltip">
											<title>@tooltip</title>
										</rect>
									}
								</svg>

								@for (var index = 0; index < Points.Count; index++)
								{
									var pointIndex = index;
									var point = Points[index];
									var isSelected = SelectedPointIndex == pointIndex;
									var slotStartX = GetSlotStartX(pointIndex);
									var tooltip = GetPointTooltip(point);

									<button type="button"
											class="position-absolute p-0 border-0 bg-transparent cursor-pointer touch-manipulation"
											style="left:@FormatPercent(slotStartX / ChartWidth); top:@FormatPixels(ChartPaddingTop); width:@FormatPercent(SlotWidth / ChartWidth); height:@FormatPixels(PlotHeight);"
											title="@tooltip" aria-label="@tooltip" aria-pressed="@(isSelected ? "true" : "false")"
											@onclick="() => TogglePointSelection(pointIndex)"></button>
								}
							</div>

							<div class="d-grid align-items-start pt-1" style="grid-template-columns:@XAxisGridColumns;">
								@for (var index = 0; index < Points.Count; index++)
								{
									var point = Points[index];
									<div class="text-body-secondary text-center px-1"
										 style="min-width:0; font-size:0.72rem; line-height:1.15;">
										@foreach (var segment in GetLabelSegments(point.Label))
										{
											<span class="d-block text-truncate" title="@point.Label">@segment</span>
										}
									</div>
								}
							</div>
						</div>
					</div>
				</div>
			</div>
		}
	</div>
</div>

@code {
	private const int ChartHeight = 196;
	private const int MinimumChartWidth = 320;
	private const int MinimumSlotWidth = 48;
	private const int MinimumYAxisLabelWidth = 24;
	private const int MaximumYAxisLabelWidth = 48;
	private const int ChartPaddingTop = 12;
	private const int ChartPaddingBottom = 12;
	private const int AxisTickCount = 4;

	[Parameter]
	public string Title { get; set; } = string.Empty;

	[Parameter]
	public string Subtitle { get; set; } = string.Empty;

	[Parameter]
	public string Icon { get; set; } = "bar-chart";

	[Parameter]
	public string Summary { get; set; } = string.Empty;

	[Parameter]
	public string EmptyTitle { get; set; } = "No data yet";

	[Parameter]
	public string EmptyMessage { get; set; } = "Completed jobs will appear here once work starts finishing.";

	[Parameter]
	public string EmptyIcon { get; set; } = "bar-chart";

	[Parameter]
	public string BarColor { get; set; } = "var(--bs-primary)";

	[Parameter]
	public IReadOnlyList<DashboardChartPoint> Points { get; set; } = [];

	[Parameter]
	public Func<double, string>? YAxisLabelFormatter { get; set; }

	[Parameter]
	public bool UseIntegerYAxisTicks { get; set; }

	private bool HasData => Points.Any(point => point.Value > 0);
	private DashboardChartPoint? SelectedPoint => SelectedPointIndex.HasValue && SelectedPointIndex.Value < Points.Count
		? Points[SelectedPointIndex.Value]
		: null;
	private DashboardChartPoint? HighlightedPoint => ResolveHighlightedPoint();
	private double BaselineY => ChartHeight - ChartPaddingBottom;
	private double PlotHeight => ChartHeight - ChartPaddingTop - ChartPaddingBottom;
	private double ChartWidth => Math.Max(Points.Count * MinimumSlotWidth, MinimumChartWidth);
	private string ScrollContentWidth => $"max(100%, {FormatPixels(ChartWidth)})";
	private string XAxisGridColumns => $"repeat({Points.Count}, minmax({MinimumSlotWidth}px, 1fr))";
	private double SlotWidth => Points.Count == 0 ? ChartWidth : ChartWidth / Points.Count;
	private double BarWidth => Math.Clamp(SlotWidth * 0.58, 12, 32);
	private double MaxValue => Points.Count == 0 ? 0 : Points.Max(point => point.Value);
	private double ChartMaxValue => ResolveChartMaxValue(MaxValue);
	private double AxisStepValue => ChartMaxValue / (AxisTickCount - 1);
	private double YAxisLabelWidth => ResolveYAxisLabelWidth();
	private int? SelectedPointIndex { get; set; }
	private ElementReference _scrollContainer;
	private int _lastScrolledPointCount = -1;
	private IReadOnlyList<AxisTick> YAxisTicks => Enumerable.Range(0, AxisTickCount)
		.Select(index =>
		{
			var tickValue = ChartMaxValue - (AxisStepValue * index);
			var tickY = ChartPaddingTop + ((PlotHeight / (AxisTickCount - 1)) * index);

			return new AxisTick(tickValue, tickY, FormatAxisLabel(tickValue));
		})
		.ToList();

	private double GetBarHeight(double value)
	{
		return value <= 0 ? 0 : Math.Max((value / ChartMaxValue) * PlotHeight, 2);
	}

	private double GetSlotStartX(int index)
	{
		return index * SlotWidth;
	}

	private double GetBarX(int index)
	{
		var slotStartX = GetSlotStartX(index);
		return slotStartX + ((SlotWidth - BarWidth) / 2);
	}

	private string GetPointTooltip(DashboardChartPoint point)
	{
		return $"{point.Label}: {GetPointValueLabel(point)}";
	}

	private string GetPointValueLabel(DashboardChartPoint point)
	{
		return string.IsNullOrWhiteSpace(point.ValueLabel)
			? point.Value.ToString("0.##")
			: point.ValueLabel;
	}

	private DashboardChartPoint? ResolveHighlightedPoint()
	{
		if (SelectedPoint is not null)
		{
			return SelectedPoint;
		}

		var latestPoint = Points.LastOrDefault(point => point.Value > 0) ?? Points.LastOrDefault();
		return latestPoint;
	}

	private static IReadOnlyList<string> GetLabelSegments(string label)
	{
		if (string.IsNullOrWhiteSpace(label))
		{
			return [string.Empty];
		}

		var lastSpaceIndex = label.LastIndexOf(' ');
		if (lastSpaceIndex <= 0 || lastSpaceIndex >= label.Length - 1)
		{
			return [label];
		}

		return
		[
			label[..lastSpaceIndex],
			label[(lastSpaceIndex + 1)..]
		];
	}

	private string FormatAxisLabel(double value)
	{
		if (YAxisLabelFormatter is not null)
		{
			return YAxisLabelFormatter(value);
		}

		return value.ToString("0.##");
	}

	private double ResolveYAxisLabelWidth()
	{
		if (YAxisTicks.Count == 0)
		{
			return MinimumYAxisLabelWidth;
		}

		var widestLabel = YAxisTicks.Max(axisTick => EstimateAxisLabelWidth(axisTick.Label));
		return Math.Clamp(widestLabel, MinimumYAxisLabelWidth, MaximumYAxisLabelWidth);
	}

	private static double EstimateAxisLabelWidth(string label)
	{
		if (string.IsNullOrWhiteSpace(label))
		{
			return MinimumYAxisLabelWidth;
		}

		return (label.Length * 6.2) + 10;
	}

	private double ResolveChartMaxValue(double maxValue)
	{
		if (maxValue <= 0)
		{
			return 1;
		}

		if (UseIntegerYAxisTicks)
		{
			var integerStep = Math.Max(1, (int)Math.Ceiling(maxValue / (AxisTickCount - 1)));
			return integerStep * (AxisTickCount - 1);
		}

		var rawStep = maxValue / (AxisTickCount - 1);
		var niceStep = ResolveNiceStep(rawStep);

		return Math.Max(niceStep * (AxisTickCount - 1), 1);
	}

	private static double ResolveNiceStep(double rawStep)
	{
		if (rawStep <= 0)
		{
			return 1;
		}

		var exponent = Math.Floor(Math.Log10(rawStep));
		var magnitude = Math.Pow(10, exponent);
		var normalizedStep = rawStep / magnitude;

		double[] stepCandidates = [1, 1.5, 2, 2.5, 3, 4, 5, 6, 7.5, 8, 10];
		var roundedStep = stepCandidates.FirstOrDefault(step => normalizedStep <= step);

		return (roundedStep == 0 ? 10 : roundedStep) * magnitude;
	}

	private void TogglePointSelection(int index)
	{
		SelectedPointIndex = SelectedPointIndex == index ? null : index;
	}

	protected override async Task OnAfterRenderAsync(bool firstRender)
	{
		if (HasData && Points.Count != _lastScrolledPointCount)
		{
			_lastScrolledPointCount = Points.Count;
			try
			{
				await JS.InvokeVoidAsync("scrollToEnd", _scrollContainer);
			}
			catch
			{
				// Ignore interop errors during prerendering
			}
		}
	}

	private static string FormatPixels(double value) =>
		$"{value.ToString(System.Globalization.CultureInfo.InvariantCulture)}px";

	private static string FormatPercent(double value) =>
		$"{(value * 100.0).ToString("F4", System.Globalization.CultureInfo.InvariantCulture)}%";

	private readonly record struct AxisTick(double Value, double Y, string Label);
}