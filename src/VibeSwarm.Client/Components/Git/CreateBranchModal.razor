@* Create branch modal component *@

<ModalDialog IsVisible="IsVisible" IsVisibleChanged="HandleModalVisibilityChanged" Title="Create New Branch" Icon="git"
    Size="ModalDialog.ModalSize.Default">
    <ChildContent>
        <div class="mb-3">
            <label for="newBranchName" class="form-label">Branch Name</label>
            <input type="text" class="form-control" id="newBranchName" @bind="_branchName" @bind:event="oninput"
                placeholder="e.g., feature/new-feature" disabled="@IsCreating" />
            <div class="form-text">
                <i class="bi bi-info-circle me-1"></i>
                Branch will be created from current branch: <strong>@CurrentBranch</strong>
            </div>
        </div>
        @if (!string.IsNullOrEmpty(ErrorMessage))
        {
            <Alert Type="Alert.AlertType.Danger" Class="py-2 mb-0">@ErrorMessage</Alert>
        }
        <div class="alert alert-info py-2 mb-0 mt-3">
            <i class="bi bi-lightbulb me-1"></i>
            <small>This branch will only be created locally. Use this to isolate Job changes before pushing.</small>
        </div>
    </ChildContent>
    <FooterContent>
        <ActionButton Text="Cancel" OnClick="HandleClose" Disabled="@IsCreating" />
        <ActionButton Style="ActionButton.ButtonStyle.Primary" Icon="plus-lg" Text="Create & Switch"
            LoadingText="Creating..." OnClick="HandleCreate"
            Disabled="@(IsCreating || string.IsNullOrWhiteSpace(_branchName))" IsLoading="@IsCreating" />
    </FooterContent>
</ModalDialog>

@code {
    [Parameter]
    public bool IsVisible { get; set; }

    [Parameter]
    public EventCallback<bool> IsVisibleChanged { get; set; }

    [Parameter]
    public string? CurrentBranch { get; set; }

    [Parameter]
    public bool IsCreating { get; set; }

    [Parameter]
    public string? ErrorMessage { get; set; }

    [Parameter]
    public EventCallback<string> OnCreate { get; set; }

    private string _branchName = string.Empty;

    private async Task HandleModalVisibilityChanged(bool visible)
    {
        if (!visible)
        {
            _branchName = string.Empty;
            await IsVisibleChanged.InvokeAsync(false);
        }
    }

    private async Task HandleClose()
    {
        _branchName = string.Empty;
        await IsVisibleChanged.InvokeAsync(false);
    }

    private async Task HandleCreate()
    {
        if (string.IsNullOrWhiteSpace(_branchName)) return;
        await OnCreate.InvokeAsync(_branchName.Trim());
    }
}
