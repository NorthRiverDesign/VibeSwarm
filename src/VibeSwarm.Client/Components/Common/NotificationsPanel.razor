@inject NotificationService NotificationService
@implements IDisposable

<div class="position-relative">
    <button class="btn btn-link text-secondary p-0 fs-5 d-flex align-items-center position-relative touch-manipulation"
            type="button" @onclick="NotificationService.TogglePanel" title="Notifications" aria-label="Notifications">
        <i class="bi bi-bell@(_unreadCount > 0 ? "-fill" : "")"></i>
        @if (_unreadCount > 0)
        {
            <span class="notification-bell-badge position-absolute badge rounded-pill bg-danger"
                  aria-label="@_unreadCount unread notifications">
                @(_unreadCount > 9 ? "9+" : _unreadCount.ToString())
            </span>
        }
    </button>
</div>

@code {
    private int _unreadCount;

    protected override void OnInitialized()
    {
        NotificationService.OnChange += OnNotificationChange;
        _unreadCount = NotificationService.UnreadCount;
    }

    private void OnNotificationChange()
    {
        _unreadCount = NotificationService.UnreadCount;
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        NotificationService.OnChange -= OnNotificationChange;
    }
}
