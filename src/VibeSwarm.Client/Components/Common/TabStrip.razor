@* Reusable tab strip wrapping Bootstrap nav-tabs *@

<ul class="nav @VariantClass @Class" role="tablist">
	@ChildContent
</ul>

@code {
	[Parameter]
	public RenderFragment? ChildContent { get; set; }

	[Parameter]
	public string? Class { get; set; }

	[Parameter]
	public StyleVariant Variant { get; set; } = StyleVariant.Tabs;

	private string VariantClass => Variant switch
	{
		StyleVariant.Pills => "nav-pills",
		_ => "nav-tabs"
	};

	public enum StyleVariant
	{
		Tabs,
		Pills
	}
}
