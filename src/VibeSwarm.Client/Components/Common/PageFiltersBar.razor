@* Reusable index-page filter shell for search, tabs, and secondary actions *@

<div class="d-flex flex-column gap-2 mb-3 @Class">
	@if (SearchContent != null)
	{
		<div class="min-width-0">
			@SearchContent
		</div>
	}

	@if (Tabs != null || Actions != null)
	{
		<div class="d-flex flex-column flex-sm-row align-items-stretch align-items-sm-center justify-content-between gap-2">
			@if (Tabs != null)
			{
				<div class="flex-grow-1 min-width-0">
					@Tabs
				</div>
			}

			@if (Actions != null)
			{
				<div class="d-flex flex-wrap align-items-stretch justify-content-end gap-2 flex-shrink-0 ms-sm-auto">
					@Actions
				</div>
			}
		</div>
	}
</div>

@code {
	[Parameter]
	public RenderFragment? SearchContent { get; set; }

	[Parameter]
	public RenderFragment? Tabs { get; set; }

	[Parameter]
	public RenderFragment? Actions { get; set; }

	[Parameter]
	public string Class { get; set; } = string.Empty;
}
