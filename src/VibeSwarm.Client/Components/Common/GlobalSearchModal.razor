@inject HttpSearchService SearchService
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime

@if (IsVisible)
{
    <div class="modal-backdrop fade show vs-modal-backdrop position-fixed inset-0" @onclick="Close"></div>
    <div class="position-fixed inset-0 d-flex justify-content-center pe-none" style="z-index: 1055; padding-top: 80px; align-items: flex-start;">
        <div class="bg-body border rounded shadow-lg pe-auto overflow-hidden d-flex flex-column" style="width: min(680px, calc(100vw - 32px)); max-height: calc(100vh - 120px);">
            @* Search Input *@
            <div class="d-flex align-items-center gap-2 px-3 border-bottom" style="min-height: 52px;">
                @if (_isLoading)
                {
                    <span class="spinner-border spinner-border-sm text-secondary flex-shrink-0" role="status"></span>
                }
                else
                {
                    <i class="bi bi-search text-secondary flex-shrink-0"></i>
                }
                <input @ref="_inputRef"
                       type="text"
                       class="form-control border-0 shadow-none ps-0 bg-transparent"
                       placeholder="Search projects, jobs, ideas..."
                       value="@_query"
                       @oninput="OnQueryChanged"
                       @onkeydown="OnKeyDown"
                       autocomplete="off"
                       spellcheck="false" />
                @if (!string.IsNullOrEmpty(_query))
                {
                    <button class="btn btn-link p-0 text-secondary flex-shrink-0" @onclick="ClearQuery" tabindex="-1" aria-label="Clear">
                        <i class="bi bi-x-lg"></i>
                    </button>
                }
                <kbd class="border rounded px-1 small text-secondary flex-shrink-0 d-none d-sm-inline" style="font-size: 0.7rem;">Esc</kbd>
            </div>

            @* Results *@
            <div class="overflow-y-auto flex-grow-1 overscroll-contain" @onkeydown="OnKeyDown">
                @if (!string.IsNullOrWhiteSpace(_query) && _query.Trim().Length >= 2)
                {
                    @if (_result != null && _result.Items.Count > 0)
                    {
                        var allItems = _result.Items;
                        var projectItems = allItems.Where(i => i.Type == SearchResultType.Project).ToList();
                        var jobItems = allItems.Where(i => i.Type == SearchResultType.Job).ToList();
                        var ideaItems = allItems.Where(i => i.Type == SearchResultType.Idea).ToList();

                        @if (projectItems.Count > 0)
                        {
                            <div class="px-3 pt-2 pb-1">
                                <small class="text-secondary fw-semibold text-uppercase" style="font-size: 0.7rem; letter-spacing: 0.05em;">Projects</small>
                            </div>
                            @foreach (var item in projectItems)
                            {
                                var flatIndex = allItems.IndexOf(item);
                                <button class="w-100 text-start border-0 bg-transparent d-flex align-items-center gap-3 px-3 py-2 search-result-item @(_selectedIndex == flatIndex ? "bg-body-secondary" : "")"
                                        @onclick="() => NavigateTo(item)"
                                        @onmouseover="() => _selectedIndex = flatIndex">
                                    <i class="bi bi-folder text-primary flex-shrink-0"></i>
                                    <div class="min-width-0 flex-grow-1">
                                        <div class="fw-medium text-truncate">@item.Title</div>
                                        @if (!string.IsNullOrEmpty(item.Subtitle))
                                        {
                                            <div class="small text-secondary text-truncate">@item.Subtitle</div>
                                        }
                                    </div>
                                </button>
                            }
                        }

                        @if (jobItems.Count > 0)
                        {
                            <div class="px-3 pt-2 pb-1 @(projectItems.Count > 0 ? "border-top mt-1" : "")">
                                <small class="text-secondary fw-semibold text-uppercase" style="font-size: 0.7rem; letter-spacing: 0.05em;">Jobs</small>
                            </div>
                            @foreach (var item in jobItems)
                            {
                                var flatIndex = allItems.IndexOf(item);
                                <button class="w-100 text-start border-0 bg-transparent d-flex align-items-center gap-3 px-3 py-2 search-result-item @(_selectedIndex == flatIndex ? "bg-body-secondary" : "")"
                                        @onclick="() => NavigateTo(item)"
                                        @onmouseover="() => _selectedIndex = flatIndex">
                                    <i class="bi bi-list-check text-info flex-shrink-0"></i>
                                    <div class="min-width-0 flex-grow-1">
                                        <div class="fw-medium text-truncate">@TruncateTitle(item.Title)</div>
                                        <div class="d-flex align-items-center gap-2">
                                            @if (!string.IsNullOrEmpty(item.Subtitle))
                                            {
                                                <span class="small text-secondary text-truncate">@item.Subtitle</span>
                                            }
                                            @if (!string.IsNullOrEmpty(item.StatusLabel))
                                            {
                                                <StatusBadge Status="@item.StatusLabel" ShowSpinner="false" />
                                            }
                                        </div>
                                    </div>
                                </button>
                            }
                        }

                        @if (ideaItems.Count > 0)
                        {
                            <div class="px-3 pt-2 pb-1 @((projectItems.Count > 0 || jobItems.Count > 0) ? "border-top mt-1" : "")">
                                <small class="text-secondary fw-semibold text-uppercase" style="font-size: 0.7rem; letter-spacing: 0.05em;">Ideas</small>
                            </div>
                            @foreach (var item in ideaItems)
                            {
                                var flatIndex = allItems.IndexOf(item);
                                <button class="w-100 text-start border-0 bg-transparent d-flex align-items-center gap-3 px-3 py-2 search-result-item @(_selectedIndex == flatIndex ? "bg-body-secondary" : "")"
                                        @onclick="() => NavigateTo(item)"
                                        @onmouseover="() => _selectedIndex = flatIndex">
                                    <i class="bi bi-lightbulb text-warning flex-shrink-0"></i>
                                    <div class="min-width-0 flex-grow-1">
                                        <div class="fw-medium text-truncate">@TruncateTitle(item.Title)</div>
                                        @if (!string.IsNullOrEmpty(item.Subtitle))
                                        {
                                            <div class="small text-secondary text-truncate">@item.Subtitle</div>
                                        }
                                    </div>
                                </button>
                            }
                        }

                        <div class="px-3 py-2 border-top">
                            <small class="text-secondary">@_result.TotalCount result@(_result.TotalCount == 1 ? "" : "s")</small>
                        </div>
                    }
                    else if (!_isLoading && _result != null)
                    {
                        <div class="d-flex flex-column align-items-center justify-content-center p-5 text-secondary">
                            <i class="bi bi-search mb-2" style="font-size: 1.5rem;"></i>
                            <div>No results for "<strong>@_query</strong>"</div>
                        </div>
                    }
                }
                else if (string.IsNullOrWhiteSpace(_query))
                {
                    <div class="d-flex flex-column align-items-center justify-content-center p-5 text-secondary">
                        <i class="bi bi-search mb-2" style="font-size: 1.5rem;"></i>
                        <div class="small">Search projects, jobs, and ideas</div>
                    </div>
                }
            </div>

            @* Footer hints *@
            <div class="px-3 py-2 border-top d-flex align-items-center gap-3 bg-body-secondary">
                <span class="small text-secondary d-flex align-items-center gap-1">
                    <kbd class="border rounded px-1" style="font-size: 0.7rem;">↑↓</kbd> navigate
                </span>
                <span class="small text-secondary d-flex align-items-center gap-1">
                    <kbd class="border rounded px-1" style="font-size: 0.7rem;">↵</kbd> open
                </span>
                <span class="small text-secondary d-flex align-items-center gap-1">
                    <kbd class="border rounded px-1" style="font-size: 0.7rem;">Esc</kbd> close
                </span>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public bool IsVisible { get; set; }

    [Parameter]
    public EventCallback<bool> IsVisibleChanged { get; set; }

    private string _query = string.Empty;
    private GlobalSearchResult? _result;
    private bool _isLoading;
    private int _selectedIndex = -1;
    private ElementReference _inputRef;
    private CancellationTokenSource? _debounceCts;

    protected override async Task OnParametersSetAsync()
    {
        if (IsVisible)
        {
            _query = string.Empty;
            _result = null;
            _selectedIndex = -1;
            await Task.Yield();
            try { await JSRuntime.InvokeVoidAsync("eval", "setTimeout(() => { var el = document.querySelector('.vs-global-search-input'); if (el) el.focus(); }, 50)"); } catch { }
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (IsVisible && string.IsNullOrEmpty(_query))
        {
            try { await _inputRef.FocusAsync(); } catch { }
        }
    }

    private async Task OnQueryChanged(ChangeEventArgs e)
    {
        _query = e.Value?.ToString() ?? string.Empty;
        _selectedIndex = -1;

        _debounceCts?.Cancel();
        _debounceCts = new CancellationTokenSource();
        var cts = _debounceCts;

        try
        {
            await Task.Delay(300, cts.Token);
        }
        catch (OperationCanceledException)
        {
            return;
        }

        if (string.IsNullOrWhiteSpace(_query) || _query.Trim().Length < 2)
        {
            _result = null;
            _isLoading = false;
            StateHasChanged();
            return;
        }

        _isLoading = true;
        StateHasChanged();

        try
        {
            _result = await SearchService.SearchAsync(_query, cts.Token);
        }
        catch (OperationCanceledException)
        {
            return;
        }
        catch
        {
            _result = new GlobalSearchResult();
        }
        finally
        {
            _isLoading = false;
        }

        StateHasChanged();
    }

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Escape")
        {
            await Close();
            return;
        }

        if (_result == null || _result.Items.Count == 0) return;

        if (e.Key == "ArrowDown")
        {
            _selectedIndex = Math.Min(_selectedIndex + 1, _result.Items.Count - 1);
            StateHasChanged();
        }
        else if (e.Key == "ArrowUp")
        {
            _selectedIndex = Math.Max(_selectedIndex - 1, 0);
            StateHasChanged();
        }
        else if (e.Key == "Enter" && _selectedIndex >= 0 && _selectedIndex < _result.Items.Count)
        {
            NavigateTo(_result.Items[_selectedIndex]);
        }
    }

    private void NavigateTo(SearchResultItem item)
    {
        _ = Close();
        NavigationManager.NavigateTo(item.Url);
    }

    private void ClearQuery()
    {
        _query = string.Empty;
        _result = null;
        _selectedIndex = -1;
        StateHasChanged();
    }

    public async Task Close()
    {
        IsVisible = false;
        await IsVisibleChanged.InvokeAsync(false);
    }

    private static string TruncateTitle(string title, int maxLength = 80)
    {
        if (string.IsNullOrEmpty(title)) return title;
        return title.Length <= maxLength ? title : title[..(maxLength - 3)] + "...";
    }
}
