@* Dropdown trigger that shows the current provider/model pair with a colored provider mark. *@

<button type="button" class="provider-pill dropdown-toggle @CssClass"
		data-bs-toggle="dropdown" aria-expanded="false">
	<span class="prov-mark @MarkClass">@MarkLetter</span>
	<span>
		@if (ShowPrefix)
		{
			<span class="label-txt text-fg-3">Run with </span>
		}
		<span class="model">@Model</span>
	</span>
</button>

@code {
	[Parameter] public string Provider { get; set; } = "anthropic"; // anthropic | openai | other
	[Parameter] public string Model { get; set; } = "claude-sonnet-4.6";
	[Parameter] public bool ShowPrefix { get; set; } = true;
	[Parameter] public string? CssClass { get; set; }

	private string MarkClass => Provider?.ToLowerInvariant() switch
	{
		"openai" => "openai",
		"anthropic" => "anthropic",
		_ => "anthropic"
	};

	private string MarkLetter => Provider?.ToLowerInvariant() switch
	{
		"openai" => "O",
		"anthropic" => "C",
		_ => (Provider?.Length > 0 ? char.ToUpperInvariant(Provider[0]).ToString() : "·")
	};
}
