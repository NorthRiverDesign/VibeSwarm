@* Bootstrap badge with a status-tinted background + icon. Uses only text-bg-* + rounded-pill utilities. *@

<span class="badge @TextBgClass d-inline-flex align-items-center justify-content-center @SizeClass @CssClass">
	<i class="bi @ResolvedIcon"></i>
</span>

@code {
	/// <summary>Semantic status: completed, running, failed, queued, pending, info, primary, success, warning, danger.</summary>
	[Parameter] public string Status { get; set; } = "primary";

	/// <summary>Override icon name (without bi- prefix).</summary>
	[Parameter] public string? Icon { get; set; }

	[Parameter] public string Size { get; set; } = "md"; // sm | md | lg

	[Parameter] public string? CssClass { get; set; }

	private string TextBgClass => Normalized switch
	{
		"success" => "text-bg-success",
		"warning" => "text-bg-warning",
		"danger" => "text-bg-danger",
		"info" => "text-bg-info",
		_ => "text-bg-primary"
	};

	private string SizeClass => Size switch
	{
		"sm" => "p-1 fs-6",
		"lg" => "p-2 fs-5",
		_ => "p-1 fs-6"
	};

	private string ResolvedIcon => Icon ?? DefaultIconFor(Normalized);

	private string Normalized => Status?.Trim().ToLowerInvariant() switch
	{
		"completed" or "done" or "success" or "delivered" => "success",
		"running" or "active" or "in_progress" or "inprogress" or "primary" => "primary",
		"queued" or "pending" or "waiting" or "warning" or "scheduled" => "warning",
		"failed" or "error" or "danger" or "cancelled" or "canceled" => "danger",
		"info" => "info",
		_ => "primary"
	};

	private static string DefaultIconFor(string status) => status switch
	{
		"success" => "bi-check-lg",
		"primary" => "bi-hourglass-split",
		"warning" => "bi-lightbulb",
		"danger" => "bi-exclamation-lg",
		"info" => "bi-info-circle",
		_ => "bi-circle"
	};
}
