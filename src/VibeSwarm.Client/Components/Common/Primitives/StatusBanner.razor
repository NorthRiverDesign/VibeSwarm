@* Status-tinted message block used under job cards / job detail headers.
   Replaces the old three-card Outcome/Verification/Delivery trio. *@

<div class="vs-banner @VariantClass @CssClass">
	<i class="bi @ResolvedIcon"></i>
	<div class="d-flex flex-column flex-grow-1 min-width-0 gap-1">
		@if (!string.IsNullOrEmpty(Headline))
		{
			<div class="fw-semibold text-fg-0">@Headline</div>
		}
		@if (ChildContent is not null)
		{
			<div>@ChildContent</div>
		}
		@if (MetaContent is not null)
		{
			<div class="d-flex flex-wrap gap-2 align-items-center pt-1">@MetaContent</div>
		}
	</div>
	@if (ActionContent is not null)
	{
		<div class="d-flex gap-2 align-items-center ms-auto flex-shrink-0">@ActionContent</div>
	}
</div>

@code {
	[Parameter] public string Variant { get; set; } = "success"; // success | primary | warning | danger
	[Parameter] public string? Icon { get; set; }
	[Parameter] public string? Headline { get; set; }
	[Parameter] public RenderFragment? ChildContent { get; set; }
	[Parameter] public RenderFragment? MetaContent { get; set; }
	[Parameter] public RenderFragment? ActionContent { get; set; }
	[Parameter] public string? CssClass { get; set; }

	private string VariantClass => Variant?.ToLowerInvariant() switch
	{
		"primary" or "running" => "primary",
		"warning" or "queued" => "warning",
		"danger" or "failed" => "danger",
		_ => "success"
	};

	private string ResolvedIcon => Icon ?? VariantClass switch
	{
		"success" => "bi-cloud-check-fill",
		"primary" => "bi-hourglass-split",
		"warning" => "bi-clock",
		"danger" => "bi-x-octagon",
		_ => "bi-info-circle"
	};
}
