@* Reusable page header component with title, subtitle, and actions *@

<div class="d-flex @AlignItemsClass justify-content-between gap-2 gap-sm-3 mb-3 mb-lg-4">
	<div class="min-width-0">
		<h3 class="mb-0 fs-4 fw-semibold">@Title</h3>
	</div>
	@if (Actions != null)
	{
		<div class="d-flex flex-wrap align-items-stretch justify-content-end gap-2 flex-shrink-0 ms-auto">
			@Actions
		</div>
	}
</div>

@code {
	[Parameter]
	public string Title { get; set; } = string.Empty;

	[Parameter]
	public RenderFragment? Actions { get; set; }

	[Parameter]
	public string AlignItemsClass { get; set; } = "align-items-start";
}
