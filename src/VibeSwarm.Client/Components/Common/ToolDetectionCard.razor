@* Tool Detection Card - Shows status of detected CLI tools with install support *@
@inject HttpClient Http

<div class="card mt-3">
	<div class="card-header bg-body-secondary d-flex align-items-center justify-content-between flex-wrap gap-2">
		<h5 class="mb-0 fw-semibold">
			<i class="bi bi-tools me-2"></i>Detected Tools
		</h5>
		<button type="button" class="btn btn-sm btn-secondary" @onclick="DetectTools" disabled="@(_isLoading || _isInstalling != null)"
				title="Re-detect tools">
			<i class="bi bi-arrow-clockwise @(_isLoading ? "spin" : "")"></i>
		</button>
	</div>
	<div class="card-body">
		@if (_isLoading)
		{
			<div class="d-flex align-items-center gap-2 text-body-secondary">
				<span class="spinner-border spinner-border-sm" role="status"></span>
				<span>Detecting tools...</span>
			</div>
		}
		else
		{
			<ul class="list-unstyled mb-0">
				@* Git *@
				<li class="d-flex align-items-center gap-2 mb-2">
					<i class="bi bi-git text-danger"></i>
					<span class="flex-grow-1">Git</span>
					@if (_gitAvailable)
					{
						<span class="badge bg-success-subtle text-success-emphasis">
							<i class="bi bi-check-circle me-1"></i>Available
						</span>
					}
					else
					{
						<span class="badge bg-danger-subtle text-danger-emphasis me-1">
							<i class="bi bi-x-circle me-1"></i>Not Found
						</span>
						<button type="button" class="btn btn-sm btn-outline-primary"
								@onclick='() => InstallTool("git")'
								disabled="@(_isInstalling != null)">
							@if (_isInstalling == "git")
							{
								<span class="spinner-border spinner-border-sm me-1" role="status"></span>
								<span>Installing...</span>
							}
							else
							{
								<i class="bi bi-download me-1"></i>
								<span>Install</span>
							}
						</button>
					}
				</li>

				@* GitHub CLI *@
				<li class="d-flex align-items-center gap-2 mb-2">
					<i class="bi bi-github"></i>
					<span class="flex-grow-1">GitHub CLI</span>
					@if (_ghAvailable)
					{
						<span class="badge bg-success-subtle text-success-emphasis">
							<i class="bi bi-check-circle me-1"></i>Available
						</span>
					}
					else
					{
						<span class="badge bg-danger-subtle text-danger-emphasis me-1">
							<i class="bi bi-x-circle me-1"></i>Not Found
						</span>
						<button type="button" class="btn btn-sm btn-outline-primary"
								@onclick='() => InstallTool("gh")'
								disabled="@(_isInstalling != null)">
							@if (_isInstalling == "gh")
							{
								<span class="spinner-border spinner-border-sm me-1" role="status"></span>
								<span>Installing...</span>
							}
							else
							{
								<i class="bi bi-download me-1"></i>
								<span>Install</span>
							}
						</button>
					}
				</li>

				@* GitHub CLI Auth Status (sub-status) *@
				@if (_ghAvailable)
				{
					<li class="d-flex align-items-center gap-2 ps-4">
						<i class="bi bi-shield-lock opacity-50"></i>
						<span class="flex-grow-1 text-body-secondary small">Authentication</span>
						@if (_ghAuthenticated)
						{
							<span class="badge bg-success-subtle text-success-emphasis">
								<i class="bi bi-check-circle me-1"></i>Authenticated
							</span>
						}
						else
						{
							<span class="badge bg-warning-subtle text-warning-emphasis">
								<i class="bi bi-exclamation-triangle me-1"></i>Not Authenticated
							</span>
						}
					</li>
				}

				@* Separator *@
				<li><hr class="my-2"></li>

				@* Section header for optional browser tools *@
				<li class="mb-2">
					<span class="small fw-semibold text-body-secondary text-uppercase">Browser Tools</span>
					<span class="small text-body-secondary ms-1">(optional)</span>
				</li>

				@* Node.js *@
				<li class="d-flex align-items-center gap-2 mb-2">
					<i class="bi bi-node-plus text-success"></i>
					<span class="flex-grow-1">Node.js</span>
					@if (_nodeAvailable)
					{
						<span class="badge bg-success-subtle text-success-emphasis">
							<i class="bi bi-check-circle me-1"></i>@(_nodeVersion ?? "Available")
						</span>
					}
					else
					{
						<span class="badge bg-secondary-subtle text-secondary-emphasis me-1">
							<i class="bi bi-dash-circle me-1"></i>Not Found
						</span>
						<button type="button" class="btn btn-sm btn-outline-secondary"
								@onclick='() => InstallTool("nodejs")'
								disabled="@(_isInstalling != null)">
							@if (_isInstalling == "nodejs")
							{
								<span class="spinner-border spinner-border-sm me-1" role="status"></span>
								<span>Installing...</span>
							}
							else
							{
								<i class="bi bi-download me-1"></i>
								<span>Install</span>
							}
						</button>
					}
				</li>

				@* Playwright Chromium *@
				<li class="d-flex align-items-center gap-2 mb-2">
					<i class="bi bi-browser-chrome text-primary"></i>
					<span class="flex-grow-1">Playwright Chromium</span>
					@if (_playwrightInstalled)
					{
						<span class="badge bg-success-subtle text-success-emphasis">
							<i class="bi bi-check-circle me-1"></i>Installed
						</span>
					}
					else if (!_nodeAvailable)
					{
						<span class="badge bg-secondary-subtle text-secondary-emphasis">
							<i class="bi bi-dash-circle me-1"></i>Requires Node.js
						</span>
					}
					else
					{
						<span class="badge bg-secondary-subtle text-secondary-emphasis me-1">
							<i class="bi bi-dash-circle me-1"></i>Not Installed
						</span>
						<button type="button" class="btn btn-sm btn-outline-secondary"
								@onclick='() => InstallTool("playwright")'
								disabled="@(_isInstalling != null)">
							@if (_isInstalling == "playwright")
							{
								<span class="spinner-border spinner-border-sm me-1" role="status"></span>
								<span>Installing...</span>
							}
							else
							{
								<i class="bi bi-download me-1"></i>
								<span>Install</span>
							}
						</button>
					}
				</li>

				@* Playwright status detail *@
				@if (_playwrightStatus != null && !_playwrightInstalled)
				{
					<li class="d-flex align-items-center gap-2 ps-4">
						<i class="bi bi-info-circle opacity-50"></i>
						<span class="small text-body-secondary">@_playwrightStatus</span>
					</li>
				}
			</ul>

			@if (_installResult != null)
			{
				<div class="mt-3 border rounded p-2 @(_installResult.Success ? "border-success-subtle bg-success-subtle" : "border-danger-subtle bg-danger-subtle")">
					<div class="d-flex align-items-center gap-2 mb-1">
						@if (_installResult.Success)
						{
							<i class="bi bi-check-circle text-success"></i>
							<span class="small fw-semibold text-success-emphasis">Installation complete</span>
						}
						else
						{
							<i class="bi bi-x-circle text-danger"></i>
							<span class="small fw-semibold text-danger-emphasis">Installation failed</span>
						}
						<button type="button" class="btn-close btn-close-sm ms-auto" @onclick="() => _installResult = null" style="font-size: 0.65rem;"></button>
					</div>
					@if (!string.IsNullOrWhiteSpace(_installResult.Output))
					{
						<pre class="small mb-0 text-body @(_installResult.Success ? "text-success-emphasis" : "text-danger-emphasis")" style="white-space: pre-wrap; max-height: 200px; overflow-y: auto; font-size: 0.75rem;">@_installResult.Output</pre>
					}
					@if (!_installResult.Success && !string.IsNullOrWhiteSpace(_installResult.Error))
					{
						<pre class="small mb-0 text-danger-emphasis" style="white-space: pre-wrap; max-height: 200px; overflow-y: auto; font-size: 0.75rem;">@_installResult.Error</pre>
					}
				</div>
			}

			@if (_error != null)
			{
				<div class="text-danger small mt-2">
					<i class="bi bi-exclamation-triangle me-1"></i>@_error
				</div>
			}
		}
	</div>
</div>

@code {
	private bool _isLoading = true;
	private bool _gitAvailable;
	private bool _ghAvailable;
	private bool _ghAuthenticated;
	private bool _nodeAvailable;
	private string? _nodeVersion;
	private bool _playwrightInstalled;
	private string? _playwrightStatus;
	private string? _error;
	private string? _isInstalling;
	private InstallResult? _installResult;

	protected override async Task OnInitializedAsync()
	{
		await DetectTools();
	}

	private async Task DetectTools()
	{
		_isLoading = true;
		_error = null;
		StateHasChanged();

		try
		{
			var gitTask = Http.GetAsync("/api/git/detected-tools");
			var systemTask = Http.GetAsync("/api/system-tools/detected");
			await Task.WhenAll(gitTask, systemTask);

			var gitResponse = gitTask.Result;
			if (gitResponse.IsSuccessStatusCode)
			{
				var result = await gitResponse.Content.ReadFromJsonAsync<DetectedToolsResult>();
				if (result != null)
				{
					_gitAvailable = result.GitAvailable;
					_ghAvailable = result.GitHubCliAvailable;
					_ghAuthenticated = result.GitHubCliAuthenticated;
				}
			}
			else
			{
				_error = "Failed to detect git tools";
			}

			var systemResponse = systemTask.Result;
			if (systemResponse.IsSuccessStatusCode)
			{
				var result = await systemResponse.Content.ReadFromJsonAsync<SystemToolsResult>();
				if (result != null)
				{
					_nodeAvailable = result.NodeAvailable;
					_nodeVersion = result.NodeVersion;
					_playwrightInstalled = result.PlaywrightBrowsersInstalled;
					_playwrightStatus = result.PlaywrightStatus;
				}
			}
		}
		catch (Exception ex)
		{
			_error = $"Error detecting tools: {ex.Message}";
		}
		finally
		{
			_isLoading = false;
			StateHasChanged();
		}
	}

	private async Task InstallTool(string tool)
	{
		_isInstalling = tool;
		_installResult = null;
		StateHasChanged();

		try
		{
			var response = await Http.PostAsync($"/api/system-tools/install/{tool}", null);
			var result = await response.Content.ReadFromJsonAsync<InstallResponse>();
			if (result != null)
			{
				_installResult = new InstallResult(result.Success, result.Output, result.Error);
				if (result.Success)
				{
					await DetectTools();
				}
			}
			else
			{
				_installResult = new InstallResult(false, null, "Unexpected response from server.");
			}
		}
		catch (Exception ex)
		{
			_installResult = new InstallResult(false, null, $"Error: {ex.Message}");
		}
		finally
		{
			_isInstalling = null;
			StateHasChanged();
		}
	}

	private sealed class DetectedToolsResult
	{
		public bool GitAvailable { get; set; }
		public bool GitHubCliAvailable { get; set; }
		public bool GitHubCliAuthenticated { get; set; }
	}

	private sealed class SystemToolsResult
	{
		public bool NodeAvailable { get; set; }
		public string? NodeVersion { get; set; }
		public bool NpxAvailable { get; set; }
		public bool PlaywrightBrowsersInstalled { get; set; }
		public string? PlaywrightStatus { get; set; }
	}

	private sealed class InstallResponse
	{
		public bool Success { get; set; }
		public string? Output { get; set; }
		public string? Error { get; set; }
	}

	private sealed record InstallResult(bool Success, string? Output, string? Error);
}
