@* A single action inside a <RowActionsDropdown>. Use <RowActionsDivider/> for separators. *@

<li>
	<button type="button" class="dropdown-item @(Danger ? "text-danger" : "") @(Warning ? "text-warning" : "")"
			@onclick="OnClick" @onclick:stopPropagation="true" disabled="@Disabled">
		@if (!string.IsNullOrEmpty(Icon))
		{
			<i class="bi bi-@Icon me-2 @(IconSpin ? "spin" : "")"></i>
		}
		@Text
		@if (ChildContent != null)
		{
			@ChildContent
		}
	</button>
</li>

@code {
	[Parameter] public string? Icon { get; set; }
	[Parameter] public string? Text { get; set; }
	[Parameter] public EventCallback OnClick { get; set; }
	[Parameter] public bool Disabled { get; set; }
	[Parameter] public bool Danger { get; set; }
	[Parameter] public bool Warning { get; set; }
	[Parameter] public bool IconSpin { get; set; }
	[Parameter] public RenderFragment? ChildContent { get; set; }
}
