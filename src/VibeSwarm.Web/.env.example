# VibeSwarm Configuration
# Copy this file to .env and customize as needed.
# All settings have sensible defaults - most users need no changes.

# ── NETWORK ──────────────────────────────────────────
# Use localhost for local-only access.
# Use 0.0.0.0 to allow connections from other devices.
ASPNETCORE_URLS=https://0.0.0.0:5001;http://0.0.0.0:5000

# ── ADMIN ACCOUNT (OPTIONAL) ────────────────────────
# Leave blank to use the setup wizard on first launch.
# DEFAULT_ADMIN_PASS=YourSecurePassword123!
# DEFAULT_ADMIN_USER=admin
# If only DEFAULT_ADMIN_PASS is set, VibeSwarm uses "admin" as the username.

# ── DATABASE (OPTIONAL) ─────────────────────────────
# Default: SQLite (zero configuration, stored next to the app).
# Supported: sqlite, mysql, postgresql, sqlserver
# DATABASE_PROVIDER=sqlite
# ConnectionStrings__Default=Data Source=vibeswarm.db
#
# MySQL example:
# DATABASE_PROVIDER=mysql
# ConnectionStrings__Default=Server=localhost;Database=vibeswarm;User=vibeswarm;Password=secret
#
# PostgreSQL example:
# DATABASE_PROVIDER=postgresql
# ConnectionStrings__Default=Host=localhost;Database=vibeswarm;Username=vibeswarm;Password=secret
#
# SQL Server example:
# DATABASE_PROVIDER=sqlserver
# ConnectionStrings__Default=Server=localhost;Database=vibeswarm;Trusted_Connection=true;TrustServerCertificate=true

# ── DEVELOPER MODE (OPTIONAL) ─────────────────────────
# Enables rebuild + restart controls inside the app for self-hosted development.
# Restart requires the service user to have permission to run the configured command.
# DeveloperMode__Enabled=true
# DeveloperMode__ServiceName=vibeswarm.service
# DeveloperMode__WorkingDirectory=/home/user/GitHub/VibeSwarm
# DeveloperMode__BuildCommand=dotnet build VibeSwarm.sln --nologo
# DeveloperMode__RestartCommand=systemctl restart vibeswarm.service
